---
import Layout from '../layouts/Layout.astro';
import { marked } from 'marked';

const title = '10x Benchmark - LLM Performance in Astro, React, Tailwind and Cloudflare';
const description = 'Task prompt and evaluation criteria for the Przeprogramowani vibe coding benchmark';

const BASE_URL = 'https://raw.githubusercontent.com/przeprogramowani/10x-bench-eval/refs/heads/master/benchmark';

let promptContent = '';
let criteriaContent = '';

try {
  const promptMd = await fetch(`${BASE_URL}/prompt.md`).then(r => r.text());
  promptContent = await marked(promptMd);
} catch (e: any) {
  console.error('Error fetching prompt.md:', e.message);
  promptContent = '<p class="text-red-600">Error loading prompt.md</p>';
}

try {
  const criteriaMd = await fetch(`${BASE_URL}/criteria.md`).then(r => r.text());
  criteriaContent = await marked(criteriaMd);
} catch (e: any) {
  console.error('Error fetching criteria.md:', e.message);
  criteriaContent = '<p class="text-red-600">Error loading criteria.md</p>';
}

// English translation for prompt only
const promptContentEN = await marked(
  'Create a modern and responsive website for the Przeprogramowani.pl project. Download necessary information about our activities online. It should contain pages About Us, Podcast (with latest episodes), YouTube (with latest videos), section for courses Opanuj Frontend, Opanuj TypeScript and 10xDevs (in hero). Stack is Astro, React and Tailwind. Ready for deployment on Cloudflare.'
);
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold text-slate-100 mb-8">Benchmark Details</h1>

    <!-- Prompt Section -->
    <div class="mb-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-3xl font-bold text-slate-100" id="prompt-title">Task Prompt</h2>
        <div id="language-switcher-container"></div>
      </div>
      <div class="prose prose-sm max-w-none bg-slate-800 p-6 rounded-lg border border-slate-700" id="prompt-content">
        <Fragment set:html={promptContent} />
      </div>
    </div>

    <!-- Judge Section -->
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-slate-100 mb-6">Judge</h2>
      <div class="bg-slate-800 p-6 rounded-lg border border-slate-700">
        <p class="text-slate-300 text-base">Claude Opus 4.6 via Claude Code (following <code class="bg-slate-700 rounded px-1.5 py-0.5 text-sm text-red-400 font-mono">criteria.md</code> and human evaluation)</p>
      </div>
    </div>

    <!-- Criteria Section -->
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-slate-100 mb-6" id="criteria-title">Evaluation Criteria</h2>
      <div class="prose prose-sm max-w-none bg-slate-800 p-6 rounded-lg border border-slate-700" id="criteria-content">
        <Fragment set:html={criteriaContent} />
      </div>
    </div>

    <!-- Penalties Section -->
    <div class="mb-12">
      <h2 class="text-3xl font-bold text-slate-100 mb-6">Penalties</h2>
      <div class="bg-slate-800 p-6 rounded-lg border border-slate-700">
        <p class="text-slate-300 text-base mb-4">
          Penalty is an optional deduction subtracted from the total score. It is <strong class="text-slate-100">not included in the max score calculation</strong> and is only applied when issues are identified that are not covered by the standard criteria.
        </p>
        <div class="mb-4">
          <h3 class="text-lg font-semibold text-slate-100 mb-2">Severity Levels</h3>
          <ul class="space-y-2 text-slate-300 text-sm">
            <li class="flex items-start gap-2">
              <span class="inline-block bg-green-900/50 text-green-400 text-xs font-mono px-2 py-0.5 rounded mt-0.5">0 pts</span>
              <span>Fully autonomous, error-free run of the AI agent — website delivered in a direct approach</span>
            </li>
<li class="flex items-start gap-2">
              <span class="inline-block bg-red-900/50 text-red-400 text-xs font-mono px-2 py-0.5 rounded mt-0.5">1 pt</span>
              <span>Significant issues not covered by other criteria (e.g. major functionality broken, serious UX problems)</span>
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-slate-100 mb-3">Examples</h3>
          <div class="bg-slate-900/50 rounded-lg p-4 border border-slate-700">
            <div class="flex items-start gap-3">
              <span class="inline-block bg-red-900/50 text-red-400 text-xs font-mono px-2 py-0.5 rounded mt-0.5 shrink-0">1 pt</span>
              <div>
                <p class="text-slate-200 font-medium text-sm">Manual intervention required to correct paths of agent work</p>
                <p class="text-slate-400 text-sm mt-1">The agent generated incorrect file paths or directory structures that required human correction before the project could build or run. This falls outside standard criteria as it reflects a fundamental workflow failure rather than a specific feature deficiency.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ promptContent, promptContentEN }}>
  // Language switcher component
  const container = document.getElementById('language-switcher-container');

  const switcherHTML = `
    <div class="flex gap-2">
      <button id="btn-pl" class="px-3 py-1 rounded text-sm font-semibold transition-all bg-blue-600 text-white">
        PL
      </button>
      <button id="btn-en" class="px-3 py-1 rounded text-sm font-semibold transition-all bg-slate-700 text-slate-300 hover:bg-slate-600">
        EN
      </button>
    </div>
  `;

  container.innerHTML = switcherHTML;

  let currentLang = 'PL';

  const updateLanguage = (lang) => {
    currentLang = lang;
    const btnPL = document.getElementById('btn-pl');
    const btnEN = document.getElementById('btn-en');
    const promptContentEl = document.getElementById('prompt-content');

    // Update button styles
    if (lang === 'PL') {
      btnPL.className = 'px-3 py-1 rounded text-sm font-semibold transition-all bg-blue-600 text-white';
      btnEN.className = 'px-3 py-1 rounded text-sm font-semibold transition-all bg-slate-700 text-slate-300 hover:bg-slate-600';
      promptContentEl.innerHTML = promptContent;
    } else {
      btnPL.className = 'px-3 py-1 rounded text-sm font-semibold transition-all bg-slate-700 text-slate-300 hover:bg-slate-600';
      btnEN.className = 'px-3 py-1 rounded text-sm font-semibold transition-all bg-blue-600 text-white';
      promptContentEl.innerHTML = promptContentEN;
    }
  };

  document.getElementById('btn-pl').addEventListener('click', () => updateLanguage('PL'));
  document.getElementById('btn-en').addEventListener('click', () => updateLanguage('EN'));
</script>

<style is:global>
  html {
    background-color: #0f172a !important;
    color: #e2e8f0 !important;
  }

  body {
    background-color: #0f172a !important;
    color: #e2e8f0 !important;
  }

  .prose {
    color: #cbd5e1;
    background-color: transparent;
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4,
  .prose h5,
  .prose h6 {
    color: #f1f5f9;
    font-weight: 600;
    margin-top: 1.5em;
    margin-bottom: 0.5em;
  }

  .prose h1 {
    font-size: 2em;
  }

  .prose h2 {
    font-size: 1.5em;
  }

  .prose h3 {
    font-size: 1.25em;
  }

  .prose p {
    margin-bottom: 1em;
    line-height: 1.6;
    color: #cbd5e1;
  }

  .prose ul,
  .prose ol {
    margin-bottom: 1em;
    padding-left: 2em;
  }

  .prose li {
    margin-bottom: 0.5em;
    color: #cbd5e1;
  }

  .prose code {
    background-color: #334155;
    border-radius: 0.375rem;
    padding: 0.2em 0.4em;
    font-family: monospace;
    font-size: 0.9em;
    color: #fca5a5;
  }

  .prose pre {
    background-color: #1e293b;
    color: #e2e8f0;
    padding: 1em;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1em;
  }

  .prose pre code {
    color: inherit;
    background-color: transparent;
    padding: 0;
  }

  .prose blockquote {
    border-left: 4px solid #3b82f6;
    padding-left: 1em;
    margin-left: 0;
    color: #cbd5e1;
    font-style: italic;
    background-color: #1e293b;
    padding: 0.5em 0 0.5em 1em;
  }

  .prose strong {
    font-weight: 600;
    color: #f1f5f9;
  }

  .prose em {
    font-style: italic;
    color: #cbd5e1;
  }

  .prose a {
    color: #60a5fa;
    text-decoration: none;
  }

  .prose a:hover {
    text-decoration: underline;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1em;
  }

  .prose th,
  .prose td {
    border: 1px solid #475569;
    padding: 0.75em;
    text-align: left;
    color: #cbd5e1;
  }

  .prose th {
    background-color: #1e293b;
    font-weight: 600;
  }
</style>
