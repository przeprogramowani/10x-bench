---
import type { PodcastEpisode } from '~/data/podcast';
type Props = { episode: PodcastEpisode };
const { episode } = Astro.props;
const date = new Date(episode.date).toLocaleDateString('pl-PL', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});
---

<article class="card group flex flex-col">
  <div class="flex items-center gap-2">
    <span
      class:list={[
        'chip',
        episode.show === 'Opanuj.AI'
          ? 'border-accent-500/30 bg-accent-500/10 text-accent-400'
          : 'border-brand-400/30 bg-brand-500/10 text-brand-200',
      ]}
    >
      <span
        class:list={[
          'h-1.5 w-1.5 rounded-full',
          episode.show === 'Opanuj.AI' ? 'bg-accent-400' : 'bg-brand-400',
        ]}
      ></span>
      {episode.show}
    </span>
    <span class="text-xs text-slate-400">{date}</span>
    <span class="text-xs text-slate-500">•</span>
    <span class="text-xs text-slate-400">{episode.duration}</span>
  </div>

  <h3 class="mt-4 font-display text-xl font-bold text-white transition-colors group-hover:text-brand-200">
    {episode.title}
  </h3>

  {episode.guest && (
    <p class="mt-1 text-sm text-slate-400">Gość: <span class="text-slate-200">{episode.guest}</span></p>
  )}

  <p class="mt-3 text-sm leading-relaxed text-slate-300">{episode.description}</p>

  <div class="mt-auto pt-5 flex items-center gap-3">
    <a
      href={episode.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 rounded-lg bg-white/5 px-3 py-2 text-xs font-semibold text-white hover:bg-white/10"
    >
      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      Posłuchaj
    </a>
    <a
      href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1471770526"
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-medium text-slate-400 hover:text-white"
    >
      Apple Podcasts
    </a>
  </div>
</article>
