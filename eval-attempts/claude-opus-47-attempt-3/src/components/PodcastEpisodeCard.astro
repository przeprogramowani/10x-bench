---
import { Icon } from './Icon';
import type { PodcastEpisode } from '../data/podcast';

interface Props {
  episode: PodcastEpisode;
  featured?: boolean;
}

const { episode, featured = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(episode.date));
---

<article
  class={`group relative rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-all duration-300 hover:border-white/20 hover:bg-white/[0.06] hover:-translate-y-1 ${
    featured ? 'md:p-8' : ''
  }`}
>
  <div class="flex items-start gap-4">
    <div
      class={`flex-shrink-0 flex items-center justify-center rounded-xl bg-gradient-to-br from-brand-500/20 to-accent-500/10 border border-white/5 ${
        featured ? 'h-16 w-16 md:h-20 md:w-20' : 'h-14 w-14'
      }`}
    >
      <Icon name="mic" width={featured ? 28 : 22} height={featured ? 28 : 22} className="text-brand-300" />
    </div>
    <div class="flex-grow min-w-0">
      <div class="flex items-center gap-2 text-xs text-slate-500">
        <span class="font-mono font-semibold text-brand-300">#{episode.number}</span>
        <span>·</span>
        <time datetime={episode.date}>{formattedDate}</time>
        <span>·</span>
        <span>{episode.duration}</span>
      </div>
      <h3
        class={`mt-2 font-semibold tracking-tight text-white leading-snug group-hover:text-brand-200 transition ${
          featured ? 'text-xl md:text-2xl' : 'text-lg'
        }`}
      >
        {episode.title}
      </h3>
      {
        episode.guest && (
          <p class="mt-1 text-sm text-slate-400">
            Gość: <span class="text-slate-200 font-medium">{episode.guest}</span>
          </p>
        )
      }
    </div>
  </div>

  <p class="mt-4 text-sm text-slate-400 leading-relaxed line-clamp-3">
    {episode.description}
  </p>

  <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-3 pt-4 border-t border-white/5">
    <div class="flex flex-wrap gap-2">
      {
        episode.tags.map((t) => (
          <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-[11px] text-slate-400">#{t}</span>
        ))
      }
    </div>
    <a
      href={episode.spotifyUrl}
      target="_blank"
      rel="noreferrer"
      class="ml-auto inline-flex items-center gap-2 text-sm font-semibold text-brand-300 hover:text-brand-200 transition"
    >
      <Icon name="play" width={14} height={14} />
      Posłuchaj
    </a>
  </div>
</article>
