---
import { Icon } from './Icon';
import { getCourse } from '../data/courses';

const tenX = getCourse('10xdevs')!;
---

<section class="relative overflow-hidden pt-10 md:pt-16 pb-20 md:pb-28">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-hero-radial pointer-events-none" aria-hidden="true"></div>
  <div
    class="absolute inset-0 opacity-[0.08] pointer-events-none"
    style="background-image: linear-gradient(to right, rgba(255,255,255,0.08) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 48px 48px; mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);"
    aria-hidden="true"
  ></div>
  <div class="absolute -top-20 -left-20 w-96 h-96 bg-brand-500/20 rounded-full blur-3xl animate-pulse-slow pointer-events-none" aria-hidden="true"></div>
  <div class="absolute top-40 -right-20 w-96 h-96 bg-accent-500/15 rounded-full blur-3xl animate-pulse-slow pointer-events-none" aria-hidden="true"></div>

  <div class="container-base relative">
    <div class="grid gap-14 lg:grid-cols-[1.1fr_1fr] lg:items-center">
      <!-- Left -->
      <div class="animate-fade-in">
        <div class="section-eyebrow">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
          </span>
          Nowa edycja 10xDevs już otwarta
        </div>

        <h1 class="mt-6 text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold leading-[1.05] tracking-tight">
          <span class="gradient-text">Szersze spojrzenie</span>
          <br />
          na programowanie
        </h1>

        <p class="mt-6 max-w-xl text-base md:text-lg text-slate-300 leading-relaxed">
          Tworzymy kursy, podcast i materiały, które pomagają świadomie wykorzystywać
          <span class="text-white font-semibold">AI w całym cyklu wytwarzania oprogramowania</span> — od researchu,
          przez implementację, po utrzymanie w produkcji.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-3 sm:items-center">
          <a href={tenX.href} target="_blank" rel="noreferrer" class="btn-primary">
            Dołącz do 10xDevs 3.0
            <Icon name="arrow-up-right" width={16} height={16} />
          </a>
          <a href="/kursy" class="btn-ghost">
            Zobacz wszystkie kursy
          </a>
        </div>

        <dl class="mt-12 grid grid-cols-3 gap-6 max-w-lg">
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Lat w edukacji</dt>
            <dd class="mt-1 text-2xl md:text-3xl font-bold text-white">7+</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Absolwentów</dt>
            <dd class="mt-1 text-2xl md:text-3xl font-bold text-white">1000+</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wider text-slate-500">Odcinków podcastu</dt>
            <dd class="mt-1 text-2xl md:text-3xl font-bold text-white">97+</dd>
          </div>
        </dl>
      </div>

      <!-- Right: 10xDevs card -->
      <div class="relative animate-slide-up">
        <div class="absolute -inset-4 bg-gradient-to-br from-brand-500/20 via-purple-500/20 to-accent-500/20 rounded-3xl blur-2xl" aria-hidden="true"></div>
        <div class="relative rounded-3xl border border-white/10 bg-gradient-to-br from-[#0c1222] to-[#0a0f1e] p-7 md:p-9 shadow-2xl">
          <div class="flex items-center justify-between">
            <span class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-brand-500/20 to-accent-500/20 border border-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand-200">
              <Icon name="bolt" width={12} height={12} />
              {tenX.badge}
            </span>
            <span class="text-xs text-slate-500 font-mono">v3.0</span>
          </div>

          <h2 class="mt-5 text-3xl md:text-4xl font-bold tracking-tight">
            <span class="gradient-text-accent">10xDevs</span>
          </h2>
          <p class="mt-2 text-base text-slate-300">{tenX.tagline}</p>

          <div class="mt-6 divider-glow"></div>

          <ul class="mt-6 space-y-3">
            {
              tenX.highlights.slice(0, 4).map((h) => (
                <li class="flex gap-3">
                  <span class="flex-shrink-0 mt-0.5 flex h-5 w-5 items-center justify-center rounded-full bg-brand-500/20 text-brand-300">
                    <Icon name="check" width={12} height={12} />
                  </span>
                  <span class="text-sm text-slate-200">{h}</span>
                </li>
              ))
            }
          </ul>

          <div class="mt-7 grid grid-cols-3 gap-2 text-center">
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-3">
              <p class="text-[10px] uppercase tracking-wider text-slate-500">Czas</p>
              <p class="mt-1 text-sm font-semibold text-white">5 tygodni</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-3">
              <p class="text-[10px] uppercase tracking-wider text-slate-500">Format</p>
              <p class="mt-1 text-sm font-semibold text-white">Kohortowy</p>
            </div>
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-3">
              <p class="text-[10px] uppercase tracking-wider text-slate-500">Poziom</p>
              <p class="mt-1 text-sm font-semibold text-white">Mid+</p>
            </div>
          </div>

          <a href={tenX.href} target="_blank" rel="noreferrer" class="mt-7 btn-accent w-full">
            Poznaj 10xDevs 3.0
            <Icon name="arrow-up-right" width={16} height={16} />
          </a>
        </div>

        <!-- Floating badges -->
        <div class="absolute -top-4 -right-4 hidden md:flex items-center gap-2 rounded-full border border-white/10 bg-[#0c1222]/90 px-3 py-2 shadow-xl backdrop-blur">
          <span class="inline-flex h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-xs font-medium text-slate-200">Rekrutacja otwarta</span>
        </div>
      </div>
    </div>

    <!-- Partners strip -->
    <div class="mt-16 md:mt-24 rounded-2xl border border-white/5 bg-white/[0.02] px-6 py-6">
      <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-10">
        <p class="text-xs uppercase tracking-wider text-slate-500 flex-shrink-0">
          Zaufali nam m.in.
        </p>
        <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
          {
            ['SmartRecruiters', 'Autodesk', 'Callstack', 'Huuuge Games', 'DAZN', 'XTB'].map((p) => (
              <span class="text-sm font-semibold text-slate-400 hover:text-slate-200 transition">{p}</span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
