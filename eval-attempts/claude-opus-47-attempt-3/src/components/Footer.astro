---
import { Icon } from './Icon';
import { site } from '../data/site';
---

<footer class="relative mt-24 border-t border-white/10 bg-[#070c17]">
  <div class="container-base py-14 md:py-16">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="inline-flex items-center gap-2">
          <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-accent-500 text-white font-bold text-sm">
            P!
          </span>
          <span class="font-semibold tracking-tight text-white">{site.name}</span>
        </a>
        <p class="mt-4 max-w-md text-sm text-slate-400 leading-relaxed">
          {site.description}
        </p>
        <a
          href={`mailto:${site.email}`}
          class="mt-6 inline-flex items-center gap-2 text-sm text-slate-300 hover:text-white transition"
        >
          <Icon name="mail" width={16} height={16} />
          {site.email}
        </a>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">Nawigacja</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-400">
          <li><a href="/o-nas" class="hover:text-white transition">O nas</a></li>
          <li><a href="/kursy" class="hover:text-white transition">Kursy</a></li>
          <li><a href="/podcast" class="hover:text-white transition">Podcast</a></li>
          <li><a href="/youtube" class="hover:text-white transition">YouTube</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">Znajdź nas</h3>
        <ul class="mt-4 space-y-2.5 text-sm text-slate-400">
          <li>
            <a href={site.social.youtube} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-white transition">
              <Icon name="youtube" width={16} height={16} /> YouTube
            </a>
          </li>
          <li>
            <a href={site.social.spotify} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-white transition">
              <Icon name="spotify" width={16} height={16} /> Spotify
            </a>
          </li>
          <li>
            <a href={site.social.applePodcasts} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-white transition">
              <Icon name="apple" width={16} height={16} /> Apple Podcasts
            </a>
          </li>
          <li>
            <a href={site.social.linkedin} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-white transition">
              <Icon name="linkedin" width={16} height={16} /> LinkedIn
            </a>
          </li>
          <li>
            <a href={site.social.instagram} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-white transition">
              <Icon name="instagram" width={16} height={16} /> Instagram
            </a>
          </li>
          <li>
            <a href={site.social.substack} target="_blank" rel="noreferrer" class="inline-flex items-center gap-2 hover:text-white transition">
              <Icon name="substack" width={16} height={16} /> Newsletter
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-slate-500">
      <p>© {new Date().getFullYear()} Przeprogramowani. Wszelkie prawa zastrzeżone.</p>
      <p>Zbudowane z Astro, React i Tailwind. Hostowane na Cloudflare.</p>
    </div>
  </div>
</footer>
