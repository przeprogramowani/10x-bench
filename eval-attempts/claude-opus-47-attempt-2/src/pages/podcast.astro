---
import Layout from '~/layouts/Layout.astro';
import SectionHeading from '~/components/SectionHeading.astro';
import PodcastCard from '~/components/PodcastCard.astro';
import { podcastEpisodes } from '~/data/podcast';
import { site } from '~/data/site';
---

<Layout
  title="Podcast"
  description="Najnowsze odcinki podcastu Przeprogramowani i Opanuj.AI — o świadomym AI, inżynierii oprogramowania i karierze."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div aria-hidden class="pointer-events-none absolute inset-0 grid-bg"></div>
    <div
      aria-hidden
      class="pointer-events-none absolute top-0 -left-20 h-[500px] w-[600px] rounded-full bg-brand-500/25 blur-[140px]"
    >
    </div>
    <div
      aria-hidden
      class="pointer-events-none absolute top-10 right-0 h-[400px] w-[600px] rounded-full bg-accent-500/20 blur-[140px]"
    >
    </div>

    <div class="container-p relative pt-20 pb-10 sm:pt-28">
      <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_1fr]">
        <div>
          <span class="heading-eyebrow">Podcast</span>
          <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
            Dwa podcasty. <span class="gradient-text">Jedno szersze spojrzenie.</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-slate-300">
            <strong class="text-white">Przeprogramowani</strong> — rozmowy o programowaniu, karierze i
            architekturze z ludźmi, którzy robią dobrą robotę. <strong class="text-white">Opanuj.AI</strong> —
            tygodniowe zanurzenie w świat modeli, narzędzi i praktyk AI-native.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href={site.social.spotify} target="_blank" rel="noopener noreferrer" class="btn-primary">
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><circle cx="12" cy="12" r="10"/><path fill="#0b0b14" d="M16 15.5a.7.7 0 01-1 .2c-2.7-1.6-6-2-9.9-1.1a.7.7 0 11-.3-1.3c4.2-1 7.8-.6 10.8 1.2.3.2.4.6.2 1zm1.1-2.6a.8.8 0 01-1.1.3c-3.1-1.9-7.9-2.4-11.6-1.3a.9.9 0 11-.5-1.7c4.2-1.3 9.5-.7 13.1 1.5.4.3.5.8.3 1.2zm.1-2.8C13.4 7.9 7.4 7.7 4 8.8a1 1 0 11-.6-2c4-1.2 10.5-1 14.6 1.5a1 1 0 01-1 1.8z"/></svg>
              Spotify
            </a>
            <a href={site.social.applePodcasts} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              Apple Podcasts
            </a>
            <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="btn-secondary">
              YouTube
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-1 rounded-3xl bg-gradient-to-br from-brand-500/40 to-accent-500/40 opacity-60 blur-2xl"></div>
          <div class="relative rounded-3xl border border-white/10 bg-ink-800/80 p-6 backdrop-blur-xl">
            <div class="flex items-center gap-4">
              <div class="grid h-14 w-14 place-items-center rounded-2xl bg-gradient-to-br from-brand-500 to-accent-500 text-white">
                <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 11a7 7 0 01-14 0M12 18v4m-4 0h8M12 2a3 3 0 00-3 3v6a3 3 0 106 0V5a3 3 0 00-3-3z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">Najnowszy odcinek</p>
                <p class="mt-1 font-display text-lg font-bold text-white line-clamp-2">{podcastEpisodes[0].title}</p>
              </div>
            </div>
            <p class="mt-4 text-sm text-slate-300 line-clamp-3">{podcastEpisodes[0].description}</p>

            <div class="mt-5 flex items-center justify-between text-xs text-slate-400">
              <span>{new Date(podcastEpisodes[0].date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
              <span>{podcastEpisodes[0].duration}</span>
            </div>

            <a
              href={podcastEpisodes[0].url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 btn-primary w-full justify-center"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              Odtwórz teraz
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Episodes -->
  <section class="section">
    <div class="container-p">
      <SectionHeading
        eyebrow={`${podcastEpisodes.length} ostatnich odcinków`}
        title="Wszystkie odcinki"
        description="Najnowsze pierwsze. Posłuchaj w Spotify, Apple Podcasts lub na YouTube."
      />

      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {podcastEpisodes.map((ep) => <PodcastCard episode={ep} />)}
      </div>
    </div>
  </section>

  <!-- Subscribe CTA -->
  <section class="section pt-0">
    <div class="container-p">
      <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-brand-600/20 to-accent-500/10 p-10 text-center">
        <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">
          Żaden odcinek więcej Ci nie ucieknie
        </h2>
        <p class="mt-3 text-slate-300">Subskrybuj w dogodnej dla Ciebie platformie.</p>
        <div class="mt-6 flex flex-wrap justify-center gap-3">
          <a href={site.social.spotify} target="_blank" rel="noopener noreferrer" class="btn-primary">Spotify</a>
          <a href={site.social.applePodcasts} target="_blank" rel="noopener noreferrer" class="btn-secondary">Apple Podcasts</a>
          <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="btn-secondary">YouTube</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
