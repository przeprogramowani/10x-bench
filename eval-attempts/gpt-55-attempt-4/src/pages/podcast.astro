---
import BaseLayout from "../layouts/BaseLayout.astro";
import { externalLinks, podcastEpisodes } from "../data/site";
---

<BaseLayout title="Podcast - Przeprogramowani" description="Ostatnie odcinki podcastu Przeprogramowani o programowaniu, karierze i architekturze.">
  <section class="bg-ink py-20 text-paper">
    <div class="container-page grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="eyebrow text-citron">Podcast</p>
        <h1 class="mt-4 font-display text-5xl font-extrabold tracking-normal sm:text-6xl">Szersze spojrzenie na programowanie w rozmowach.</h1>
      </div>
      <div class="self-end">
        <p class="text-xl leading-8 text-paper/78">
          Przeprogramowani to podcast technologiczny Marcina Czarkowskiego i Przemka Smyrdka. Według Apple Podcasts audycja ma 98 odcinków i działa od 2019 roku.
        </p>
        <a href={externalLinks.podcast} class="focus-ring mt-7 inline-flex rounded-md bg-citron px-5 py-3 font-bold text-ink">Otwórz w Apple Podcasts</a>
      </div>
    </div>
  </section>

  <section class="bg-paper py-20">
    <div class="container-page">
      <div class="max-w-3xl">
        <p class="eyebrow">Ostatnie odcinki</p>
        <h2 class="mt-4 font-display text-4xl font-extrabold tracking-normal">Najnowsze rozmowy z feedu podcastu.</h2>
      </div>
      <div class="mt-10 grid gap-5">
        {podcastEpisodes.map((episode, index) => (
          <article class="grid gap-6 rounded-lg border border-ink/10 bg-white p-6 shadow-soft md:grid-cols-[160px_1fr_auto] md:items-center">
            <div>
              <p class="font-mono text-sm font-bold text-ember">{episode.date}</p>
              <p class="mt-2 text-sm font-semibold text-graphite/56">{episode.duration}</p>
            </div>
            <div>
              <p class="text-sm font-bold uppercase tracking-[0.14em] text-graphite/54">#{index + 1} / {episode.guest}</p>
              <h3 class="mt-2 font-display text-2xl font-bold">{episode.title}</h3>
              <p class="mt-3 leading-7 text-graphite/74">{episode.summary}</p>
            </div>
            <a href={externalLinks.podcast} class="focus-ring inline-flex justify-center rounded-md bg-ink px-4 py-3 text-sm font-bold text-paper">Posłuchaj</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
