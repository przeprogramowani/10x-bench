---
import Layout from '../layouts/Layout.astro';

const videos = [
  {
    title: '5 Agent Skills do jakościowego programowania z AI - Claude Code LIVE DEMO',
    thumbnail: 'https://i3.ytimg.com/vi/S-iNbyLSisE/maxresdefault.jpg',
    link: 'https://www.youtube.com/watch?v=S-iNbyLSisE',
    duration: 'LIVE'
  },
  {
    title: 'Product Builders Day | LIVE AI Product Heroes i 10xDevs',
    thumbnail: 'https://i3.ytimg.com/vi/aRkECt7derY/maxresdefault.jpg',
    link: 'https://www.youtube.com/watch?v=aRkECt7derY',
    duration: 'LIVE'
  },
  {
    title: 'Wybierasz model AI do kodowania? Nie ufaj benchmarkom',
    thumbnail: 'https://i3.ytimg.com/vi/vH1T5qB4dBQ/maxresdefault.jpg',
    link: 'https://www.youtube.com/watch?v=vH1T5qB4dBQ',
    duration: '15:32'
  },
  {
    title: 'Claude Code w rękach Product Buildera | LIVE AI Product Heroes x 10xDevs',
    thumbnail: 'https://i3.ytimg.com/vi/bcs8WS4A5Zg/maxresdefault.jpg',
    link: 'https://www.youtube.com/watch?v=bcs8WS4A5Zg',
    duration: 'LIVE'
  },
  {
    title: 'MVP w Claude Code - Context Engineering, kontrola Agenta i refaktoryzacja',
    thumbnail: 'https://i3.ytimg.com/vi/Vce4cD_5XW0/maxresdefault.jpg',
    link: 'https://www.youtube.com/watch?v=Vce4cD_5XW0',
    duration: '42:18'
  },
  {
    title: 'Od chaosu do AI-Native Infrastructure - budujemy platformę dla zespołu, który programuje z Agentami',
    thumbnail: 'https://i3.ytimg.com/vi/hbuCLvwbMVg/maxresdefault.jpg',
    link: 'https://www.youtube.com/watch?v=hbuCLvwbMVg',
    duration: '1:08:45'
  }
];

const stats = [
  { value: '50+', label: 'filmów' },
  { value: '10K+', label: 'subskrybentów' },
  { value: 'LIVE', label: 'regularne streamy' }
];
---

<Layout title="YouTube - Przeprogramowani.pl" description="Kanał YouTube Przeprogramowanych - filmy o programowaniu, AI i rozwoju kariery.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/20 text-red-300 text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
          Przeprogramowani <span class="text-red-400">YouTube</span>
        </h1>
        <p class="text-lg sm:text-xl text-gray-300 leading-relaxed mb-8">
          Filmy o programowaniu z wykorzystaniem AI, live coding, recenzje narzędzi i rozwój kariery. Subskrybuj, żeby być na bieżąco z najnowszymi trendami w świecie technologii.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="https://youtube.com/c/przeprogramowani" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            Subskrybuj kanał
          </a>
        </div>
        <div class="mt-10 flex gap-8">
          {stats.map((stat) => (
            <div>
              <div class="text-2xl sm:text-3xl font-bold text-white">{stat.value}</div>
              <div class="text-sm text-gray-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Videos Grid -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Ostatnie filmy</h2>
        <a href="https://youtube.com/c/przeprogramowani/videos" target="_blank" rel="noopener noreferrer" class="hidden sm:inline-flex items-center gap-1 text-red-600 font-medium hover:text-red-700 transition-colors">
          Wszystkie filmy
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map((video) => (
          <a href={video.link} target="_blank" rel="noopener noreferrer" class="group block rounded-xl overflow-hidden bg-white shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-200 hover:border-gray-300">
            <div class="aspect-video relative overflow-hidden bg-gray-900">
              <img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/30 transition-colors">
                <div class="w-16 h-16 rounded-full bg-white/90 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
                  <svg class="w-7 h-7 text-red-600 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              {video.duration !== 'LIVE' && (
                <span class="absolute bottom-2 right-2 px-2 py-1 bg-black/80 text-white text-xs font-medium rounded">{video.duration}</span>
              )}
              {video.duration === 'LIVE' && (
                <span class="absolute bottom-2 right-2 px-2 py-1 bg-red-600 text-white text-xs font-bold rounded flex items-center gap-1">
                  <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
                  LIVE
                </span>
              )}
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-gray-900 line-clamp-2 group-hover:text-red-600 transition-colors">{video.title}</h3>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center sm:hidden">
        <a href="https://youtube.com/c/przeprogramowani/videos" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-red-600 font-medium">
          Wszystkie filmy
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-50 border-t border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">Nie przegap nowości</h2>
      <p class="text-gray-600 mb-8">Subskrybuj nasz kanał i włącz powiadomienia, żeby być na bieżąco z najnowszymi filmami i live'ami.</p>
      <a href="https://youtube.com/c/przeprogramowani" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-lg transition-colors shadow-lg">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        Subskrybuj na YouTube
      </a>
    </div>
  </section>
</Layout>
