---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Przeprogramowani.pl - Szersze spojrzenie na programowanie' } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <title>{title}</title>
</head>
<body class="min-h-screen flex flex-col">
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900 hover:text-brand-600 transition-colors">
          <span class="text-brand-600">&lt;/&gt;</span>
          <span>Przeprogramowani</span>
        </a>
        
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="text-sm font-medium text-gray-700 hover:text-brand-600 transition-colors">Strona główna</a>
          <a href="/o-nas" class="text-sm font-medium text-gray-700 hover:text-brand-600 transition-colors">O nas</a>
          <a href="/podcast" class="text-sm font-medium text-gray-700 hover:text-brand-600 transition-colors">Podcast</a>
          <a href="/youtube" class="text-sm font-medium text-gray-700 hover:text-brand-600 transition-colors">YouTube</a>
          <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-4 py-2 text-sm font-semibold text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition-colors">
            10xDevs
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </nav>

        <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-700 hover:text-brand-600" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
      <div class="px-4 py-3 space-y-2">
        <a href="/" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-gray-50 rounded-md">Strona główna</a>
        <a href="/o-nas" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-gray-50 rounded-md">O nas</a>
        <a href="/podcast" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-gray-50 rounded-md">Podcast</a>
        <a href="/youtube" class="block px-3 py-2 text-sm font-medium text-gray-700 hover:text-brand-600 hover:bg-gray-50 rounded-md">YouTube</a>
        <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="block px-3 py-2 text-sm font-semibold text-brand-600 hover:bg-brand-50 rounded-md">10xDevs →</a>
      </div>
    </div>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-gray-900 text-gray-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        <div class="md:col-span-2">
          <a href="/" class="flex items-center gap-2 text-xl font-bold text-white mb-4">
            <span class="text-brand-400">&lt;/&gt;</span>
            <span>Przeprogramowani</span>
          </a>
          <p class="text-gray-400 text-sm max-w-sm">Szersze spojrzenie na programowanie. Edukacja, podcasty i społeczność dla ambitnych programistów.</p>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Nawigacja</h3>
          <ul class="space-y-2">
            <li><a href="/" class="text-sm hover:text-white transition-colors">Strona główna</a></li>
            <li><a href="/o-nas" class="text-sm hover:text-white transition-colors">O nas</a></li>
            <li><a href="/podcast" class="text-sm hover:text-white transition-colors">Podcast</a></li>
            <li><a href="/youtube" class="text-sm hover:text-white transition-colors">YouTube</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Projekty</h3>
          <ul class="space-y-2">
            <li><a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors">10xDevs</a></li>
            <li><a href="https://opanujfrontend.pl" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors">Opanuj Frontend</a></li>
            <li><a href="https://opanujtypescript.pl" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors">Opanuj TypeScript</a></li>
            <li><a href="https://opanuj.ai" target="_blank" rel="noopener noreferrer" class="text-sm hover:text-white transition-colors">Opanuj AI</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-8 pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-500">© 2026 Przeprogramowani.pl. Wszelkie prawa zastrzeżone.</p>
        <div class="flex items-center gap-4">
          <a href="https://www.facebook.com/przeprogramowani" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/przeprogramowani" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://youtube.com/c/przeprogramowani" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
