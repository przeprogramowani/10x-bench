---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Przeprogramowani - Szersze spojrzenie na programowanie">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-600 to-purple-700 text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Szersze spojrzenie na programowanie
      </h1>
      <p class="text-xl md:text-2xl mb-12 max-w-3xl mx-auto">
        Nowe oblicze programowania z wykorzystaniem Generatywnego AI.
        Techniki i narzędzia pozwalające świadomie stosować AI w całym cyklu wytwarzania oprogramowania.
      </p>

      <!-- Courses in Hero -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="bg-white bg-opacity-10 rounded-lg p-6 backdrop-blur-sm">
          <h3 class="text-2xl font-semibold mb-4">10xDevs 3.0</h3>
          <p class="mb-6">Programuj z AI nowym sposobem. Warsztaty, podcasty i praktyczne narzędzia.</p>
          <a href="https://10xdevs.pl" class="bg-white text-blue-600 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
            Szczegóły →
          </a>
        </div>
        <div class="bg-white bg-opacity-10 rounded-lg p-6 backdrop-blur-sm">
          <h3 class="text-2xl font-semibold mb-4">Opanuj Frontend</h3>
          <p class="mb-6">AI Edition. Zostań nowoczesnym frontend developerem — 5 obszernych modułów.</p>
          <a href="https://opanujfrontend.pl" class="bg-white text-blue-600 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
            Szczegóły →
          </a>
        </div>
        <div class="bg-white bg-opacity-10 rounded-lg p-6 backdrop-blur-sm">
          <h3 class="text-2xl font-semibold mb-4">Opanuj TypeScript</h3>
          <p class="mb-6">Popraw jakość projektów działających na produkcji i ułatw ich rozwój.</p>
          <a href="https://opanujtypescript.pl" class="bg-white text-blue-600 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition-colors">
            Szczegóły →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Content Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Edukacja technologiczna w epoce AI</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Opanuj AI -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-4 text-blue-600">Opanuj AI</h3>
            <p class="text-gray-600 mb-6">
              Warsztaty, podcast, blog i darmowe ebooki o sztucznej inteligencji. Zdobądź praktyczną wiedzę o AI i wdróż ją w codziennej pracy.
            </p>
            <a href="https://opanuj.ai" class="text-blue-600 hover:text-blue-800 font-semibold">
              Szczegóły →
            </a>
          </div>
        </div>

        <!-- Opanuj Frontend -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-4 text-blue-600">Opanuj Frontend: AI Edition</h3>
            <p class="text-gray-600 mb-6">
              Zostań nowoczesnym frontend developerem — 5 obszernych modułów o frontendzie, testowaniu, CI/CD, open source i architekturze aplikacji webowych.
            </p>
            <a href="https://www.opanujfrontend.pl" class="text-blue-600 hover:text-blue-800 font-semibold">
              Szczegóły →
            </a>
          </div>
        </div>

        <!-- Opanuj TypeScript -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-4 text-blue-600">Opanuj TypeScript</h3>
            <p class="text-gray-600 mb-6">
              Opanuj TypeScript to szkolenie, które podniesie jakość twoich projektów działających na produkcji i ułatwi ich rozwój. Pracujemy z najnowszymi wersjami TypeScript 5 i React 19!
            </p>
            <a href="https://www.opanujtypescript.pl" class="text-blue-600 hover:text-blue-800 font-semibold">
              Szczegóły →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="bg-gray-100 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Filmy i podcasty</h2>
        <p class="text-xl text-gray-600">Rozwój nowoczesnego programisty</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <a href="https://www.youtube.com/watch?v=_kQHwE6zAbM">
            <img src="https://i3.ytimg.com/vi/_kQHwE6zAbM/maxresdefault.jpg" alt="Skills vs AgentsMD: 53% vs 100%. Co poszło nie tak?" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm">Skills vs AgentsMD: 53% vs 100%. Co poszło nie tak?</h3>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <a href="https://www.youtube.com/watch?v=KAJTsQbqBow">
            <img src="https://i3.ytimg.com/vi/KAJTsQbqBow/maxresdefault.jpg" alt="Claude Code + GLM-4.7 - Programowanie z darmowym AI wreszcie możliwe?" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm">Claude Code + GLM-4.7 - Programowanie z darmowym AI wreszcie możliwe?</h3>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <a href="https://www.youtube.com/watch?v=uwi39C2O8NI">
            <img src="https://i3.ytimg.com/vi/uwi39C2O8NI/maxresdefault.jpg" alt="5 TECHNIK, KTÓRE NAPRAWIŁY MÓJ WORKFLOW PROGRAMOWANIA Z AI" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm">5 TECHNIK, KTÓRE NAPRAWIŁY MÓJ WORKFLOW PROGRAMOWANIA Z AI</h3>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <a href="https://www.youtube.com/watch?v=b-gOI128G2s">
            <img src="https://i3.ytimg.com/vi/b-gOI128G2s/maxresdefault.jpg" alt="Demo Day 10xDevs – zobacz najlepsze projekty uczestników 2 edycji! 🎉" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm">Demo Day 10xDevs – zobacz najlepsze projekty uczestników 2 edycji! 🎉</h3>
            </div>
          </a>
        </div>
      </div>

      <div class="text-center">
        <a href="/zobacz-wiecej" class="bg-blue-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-blue-700 transition-colors">
          Zobacz więcej filmow
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-blue-50 rounded-2xl p-8 md:p-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-4">Przeprogramowany Newsletter</h2>
            <p class="text-lg text-gray-600 mb-6">
              Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1: 3 rekomendacje techniczne, 2 rekomendacje rozwojowe, 1 bonus niespodzianka.
            </p>
            <a href="https://przeprogramowani.substack.com" class="bg-blue-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-blue-700 transition-colors">
              Zapisz się za darmo →
            </a>
          </div>
          <div class="text-center">
            <img src="/img/newsletter-qr.png" alt="QR kod newsletter" class="mx-auto w-64 h-64" />
            <p class="text-sm text-gray-500 mt-4">Zeskanuj i dołącz</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
