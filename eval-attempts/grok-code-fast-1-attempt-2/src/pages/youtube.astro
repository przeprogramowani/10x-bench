---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="YouTube - Przeprogramowani" description="Oglądaj nasze filmy o technologii, AI i programowaniu">
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">YouTube</h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Oglądaj nasze filmy o technologii, AI i programowaniu. Analizujemy trendy, dzielimy się wiedzą i pokazujemy praktyczne zastosowania nowoczesnych narzędzi.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <a href="https://www.youtube.com/watch?v=_kQHwE6zAbM">
            <img src="https://i3.ytimg.com/vi/_kQHwE6zAbM/maxresdefault.jpg" alt="Skills vs AgentsMD: 53% vs 100%. Co poszło nie tak?" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm mb-2">Skills vs AgentsMD: 53% vs 100%. Co poszło nie tak?</h3>
              <p class="text-gray-600 text-xs">Porównanie efektywności różnych podejść w pracy z AI.</p>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <a href="https://www.youtube.com/watch?v=KAJTsQbqBow">
            <img src="https://i3.ytimg.com/vi/KAJTsQbqBow/maxresdefault.jpg" alt="Claude Code + GLM-4.7 - Programowanie z darmowym AI wreszcie możliwe?" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm mb-2">Claude Code + GLM-4.7 - Programowanie z darmowym AI wreszcie możliwe?</h3>
              <p class="text-gray-600 text-xs">Alternatywy dla drogiego AI w codziennej pracy programisty.</p>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <a href="https://www.youtube.com/watch?v=uwi39C2O8NI">
            <img src="https://i3.ytimg.com/vi/uwi39C2O8NI/maxresdefault.jpg" alt="5 TECHNIK, KTÓRE NAPRAWIŁY MÓJ WORKFLOW PROGRAMOWANIA Z AI" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm mb-2">5 TECHNIK, KTÓRE NAPRAWIŁY MÓJ WORKFLOW PROGRAMOWANIA Z AI</h3>
              <p class="text-gray-600 text-xs">Praktyczne wskazówki do efektywniejszej pracy z narzędziami AI.</p>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <a href="https://www.youtube.com/watch?v=b-gOI128G2s">
            <img src="https://i3.ytimg.com/vi/b-gOI128G2s/maxresdefault.jpg" alt="Demo Day 10xDevs – zobacz najlepsze projekty uczestników 2 edycji! 🎉" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm mb-2">Demo Day 10xDevs – zobacz najlepsze projekty uczestników 2 edycji! 🎉</h3>
              <p class="text-gray-600 text-xs">Prezentacja projektów stworzonych przez uczestników kursu 10xDevs.</p>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <a href="https://www.youtube.com/watch?v=WJLGzf7qq-c">
            <img src="https://i3.ytimg.com/vi/WJLGzf7qq-c/maxresdefault.jpg" alt="Opanuj Agenta AI (Cursor, Codex, MCP) – praktyczne scenariusze dla programistów" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm mb-2">Opanuj Agenta AI (Cursor, Codex, MCP) – praktyczne scenariusze dla programistów</h3>
              <p class="text-gray-600 text-xs">Demonstracja praktycznych zastosowań agentów AI w kodowaniu.</p>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
          <a href="https://www.youtube.com/watch?v=jjOYxKAk_j8">
            <img src="https://i3.ytimg.com/vi/jjOYxKAk_j8/maxresdefault.jpg" alt="Programowanie z AI bez tajemnic – odpowiedzi na pytania, które zadaje każdy developer" class="w-full h-48 object-cover">
            <div class="p-4">
              <h3 class="font-semibold text-sm mb-2">Programowanie z AI bez tajemnic – odpowiedzi na pytania, które zadaje każdy developer</h3>
              <p class="text-gray-600 text-xs">Rozwiewamy mitów i wyjaśniamy realia pracy z AI w IT.</p>
            </div>
          </a>
        </div>
      </div>

      <div class="text-center">
        <a href="https://youtube.com/c/przeprogramowani/videos" class="bg-red-600 text-white px-8 py-3 rounded-full font-semibold hover:bg-red-700 transition-colors inline-flex items-center">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.016 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <path d="m9.545 15.568-6.559-3.73a.4.4 0 0 1 0-.678l6.559-3.73a.4.4 0 0 1 .6.339V14.9a.4.4 0 0 1-.6.339z" fill="#fff"/>
          </svg>
          zobacz więcej na YouTube
        </a>
      </div>
    </div>
  </section>
</BaseLayout>