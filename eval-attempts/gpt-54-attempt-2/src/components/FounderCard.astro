---
import type { Founder } from '../data/site';

interface Props {
  founder: Founder;
}

const { founder } = Astro.props;
---

<article class="flex h-full flex-col rounded-[2rem] border border-black/6 bg-white/85 p-6 shadow-[0_18px_45px_rgba(16,21,33,0.08)]">
  <div class="flex items-start gap-5">
    <img
      src={founder.image}
      alt={founder.name}
      class="h-24 w-24 rounded-[1.6rem] object-cover object-top shadow-[0_14px_30px_rgba(16,21,33,0.12)]"
      loading="lazy"
    />
    <div>
      <h3 class="font-display text-2xl text-[var(--ink)]">{founder.name}</h3>
      <p class="mt-2 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--accent)]">{founder.role}</p>
    </div>
  </div>
  <p class="mt-6 flex-1 text-sm leading-7 text-[var(--muted)]">{founder.bio}</p>
  <a
    href={founder.linkedin}
    target="_blank"
    rel="noreferrer"
    class="mt-6 inline-flex w-fit items-center gap-2 rounded-full border border-black/8 px-4 py-2 text-sm font-semibold text-[var(--ink)] transition hover:-translate-y-0.5 hover:bg-[var(--panel)]"
  >
    LinkedIn
    <span>↗</span>
  </a>
</article>
