---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  badge?: string;
}

const { eyebrow, title, lead, badge } = Astro.props;
---

<section class="px-4 pt-12 sm:px-6 sm:pt-16 lg:px-8">
  <div class="mx-auto max-w-7xl rounded-[2.4rem] border border-black/6 bg-white/75 px-6 py-12 shadow-[0_25px_60px_rgba(16,21,33,0.08)] sm:px-10 lg:px-14 lg:py-16">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--accent)]">{eyebrow}</p>
        {badge ? <span class="rounded-full bg-[var(--panel)] px-3 py-1 text-xs font-semibold text-[var(--ink)]/72">{badge}</span> : null}
      </div>
      <h1 class="mt-4 font-display text-4xl leading-tight text-[var(--ink)] sm:text-5xl lg:text-6xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--muted)]">{lead}</p>
    </div>
  </div>
</section>
