---
import FounderCard from '../components/FounderCard.astro';
import PageHero from '../components/PageHero.astro';
import SectionIntro from '../components/SectionIntro.astro';
import Layout from '../layouts/Layout.astro';
import { aboutBlocks, founders, partnerNames } from '../data/site';
---

<Layout
  title="Przeprogramowani.pl | O nas"
  description="Podstrona O nas prezentująca founderów, kierunek projektu oraz firmy współpracujące z Przeprogramowanymi."
  activePath="/o-nas"
>
  <PageHero
    eyebrow="O nas"
    title="Programowanie, biznes i rozwój w jednym ekosystemie"
    lead="Przeprogramowani opisują swoją działalność jako miejsce, w którym ambitni developerzy zyskują szersze spojrzenie na programowanie. Projekt łączy treści edukacyjne, kursy, podcasty, wydarzenia i praktyczne podejście do AI."
    badge="Oficjalne bio projektu"
  />

  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionIntro
        eyebrow="Founderzy"
        title="Dwie perspektywy, jeden wspólny standard jakości"
        body="Obaj founderzy łączą doświadczenie z dużych produktów, edukacji technologicznej i komunikacji wiedzy. To widać zarówno w ofertach kursowych, jak i w jakości treści publikowanych w sieci."
      />
      <div class="mt-8 grid gap-5 lg:grid-cols-2">
        {founders.map((founder) => (
          <FounderCard founder={founder} />
        ))}
      </div>
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-5 lg:grid-cols-3">
      {aboutBlocks.map((block) => (
        <article class="rounded-[2rem] border border-black/6 bg-white/85 p-6 shadow-[0_18px_45px_rgba(16,21,33,0.08)]">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--accent)]">Manifest</p>
          <h2 class="mt-4 font-display text-2xl text-[var(--ink)]">{block.title}</h2>
          <p class="mt-4 text-sm leading-7 text-[var(--muted)]">{block.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="px-4 py-10 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl rounded-[2.5rem] border border-black/6 bg-white/80 p-8 shadow-[0_25px_60px_rgba(16,21,33,0.08)] sm:p-10">
      <SectionIntro
        eyebrow="Współpraca"
        title="Firmy obecne w oficjalnej sekcji współpracy"
        body="Na stronie O nas Przeprogramowani pokazują marki, z którymi współpracowali lub które korzystały z ich wiedzy i programów. To dobra ilustracja skali i jakości pozycji projektu na rynku."
      />
      <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        {partnerNames.map((partner) => (
          <div class="rounded-[1.5rem] border border-black/6 bg-[var(--panel)] px-4 py-5 text-center text-sm font-semibold text-[var(--ink)]">
            {partner}
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
