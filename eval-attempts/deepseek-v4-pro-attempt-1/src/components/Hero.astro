---
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-950/50 via-dark-950 to-dark-950" />
  <div class="absolute right-0 top-0 h-[600px] w-[600px] rounded-full bg-brand-500/5 blur-3xl" />
  <div class="absolute bottom-0 left-0 h-[400px] w-[400px] rounded-full bg-purple-500/5 blur-3xl" />

  <div class="relative mx-auto max-w-7xl px-4 pb-20 pt-32 sm:px-6 sm:pb-28 sm:pt-40 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-brand-500/20 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-400">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75" />
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400" />
          </span>
          Nowość &mdash; 10xDevs 4.0
        </div>
        <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Czas na{" "}
          <span class="gradient-text">AI-Native Software Engineering</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-dark-300">
          5-tygodniowy, intensywny program, który uczy developerów pracować z AI w całym cyklu tworzenia oprogramowania: od researchu i planowania, przez implementację, aż po utrzymanie produkcji.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
            Dołącz do 10xDevs
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="#programy" class="btn-secondary text-base">
            Poznaj nasze programy
          </a>
        </div>
        <div class="mt-8 flex items-center gap-4">
          <div class="flex -space-x-2">
            {[1,2,3,4,5].map(() => (
              <div class="h-10 w-10 rounded-full border-2 border-dark-950 bg-gradient-to-br from-brand-400 to-brand-600" />
            ))}
          </div>
          <div>
            <div class="flex items-center gap-1">
              {[1,2,3,4,5].map(() => (
                <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="mt-1 text-sm font-medium text-dark-400"><strong class="text-white">6700+</strong> absolwentów</p>
          </div>
        </div>
      </div>

      <div class="relative hidden lg:block">
        <div class="relative rounded-2xl border border-dark-800 bg-dark-900/80 p-6 backdrop-blur-sm">
          <div class="flex items-center gap-2 border-b border-dark-800 pb-3">
            <div class="h-3 w-3 rounded-full bg-red-500" />
            <div class="h-3 w-3 rounded-full bg-yellow-500" />
            <div class="h-3 w-3 rounded-full bg-green-500" />
            <span class="ml-2 text-xs text-dark-500">terminal</span>
          </div>
          <div class="mt-4 font-mono text-sm">
            <p class="text-dark-400">$ <span class="text-brand-400">10xdevs</span> init --project my-app</p>
            <p class="mt-2 text-green-400">&#10003; AI-powered research initialized</p>
            <p class="mt-1 text-green-400">&#10003; Architecture plan generated</p>
            <p class="mt-1 text-green-400">&#10003; CI/CD pipeline configured</p>
            <p class="mt-1 text-green-400">&#10003; Agent workspace ready</p>
            <p class="mt-3 flex items-center gap-2 text-dark-400">
              <span class="inline-block h-4 w-4 animate-pulse rounded-sm bg-brand-500" />
              Ready. AI-Native environment active.
            </p>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 -z-10 h-48 w-48 rounded-full bg-brand-500/10 blur-2xl" />
        <div class="absolute -left-4 -top-4 -z-10 h-32 w-32 rounded-full bg-purple-500/10 blur-2xl" />
      </div>
    </div>
  </div>
</section>