---
import Layout from "../layouts/Layout.astro";

const team = [
  {
    name: "Przemek Smyrdek",
    role: "Co-founder, Przeprogramowani",
    description: "Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).",
    linkedin: "https://www.linkedin.com/in/psmyrdek/",
    gradient: "from-brand-500 to-purple-500",
  },
  {
    name: "Marcin Czarkowski",
    role: "Co-founder, Przeprogramowani",
    description: "Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca 'Opanuj AI Podcast' — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.",
    linkedin: "https://www.linkedin.com/in/mkczarkowski/",
    gradient: "from-emerald-500 to-teal-500",
  },
];

const values = [
  {
    title: "Szersze spojrzenie",
    description: "Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.",
    icon: "M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122",
  },
  {
    title: "Praktyczna edukacja",
    description: "Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach — od deep-dive'ów technicznych po rozmowy o karierze.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  },
  {
    title: "Społeczność",
    description: "Łączymy świat programowania, biznesu i rozwoju. Od 2019 roku budujemy społeczność ambitnych programistów dzielących się wiedzą.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
  },
];

const partners = [
  "Huuuge Games", "Nutridome", "SmartRecruiters", "Future Processing",
  "Callstack", "edrone", "Xfive", "Euvic", "Strabag", "Autodesk",
];
---

<Layout
  title="O nas"
  description="Poznaj zespół Przeprogramowani.pl - łączymy świat programowania, biznesu i rozwoju."
>
  <section class="relative overflow-hidden border-b border-dark-800/50">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-950/30 to-dark-950" />
    <div class="relative mx-auto max-w-7xl px-4 pb-20 pt-32 sm:px-6 sm:pb-24 sm:pt-40 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Łączymy świat <span class="gradient-text">programowania, biznesu i rozwoju</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-dark-300">
          Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym.
          Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">Poznaj <span class="gradient-text">zespół</span></h2>
        <p class="section-subtitle">Dwóch pasjonatów z ponad 10-letnim doświadczeniem</p>
      </div>

      <div class="mt-14 grid gap-8 lg:grid-cols-2">
        {team.map((member) => (
          <div class="card flex flex-col items-center text-center sm:flex-row sm:text-left">
            <div class={`flex h-24 w-24 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br ${member.gradient} text-3xl font-bold text-white`}>
              {member.name.split(" ").map(n => n[0]).join("")}
            </div>
            <div class="mt-4 sm:ml-6 sm:mt-0">
              <h3 class="text-xl font-bold text-white">{member.name}</h3>
              <p class="text-sm font-medium text-brand-400">{member.role}</p>
              <p class="mt-3 text-sm leading-relaxed text-dark-400">{member.description}</p>
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-dark-400 transition-colors hover:text-brand-400"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-dark-800/50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">Nasze <span class="gradient-text">wartości</span></h2>
      </div>
      <div class="mt-14 grid gap-8 md:grid-cols-3">
        {values.map((value) => (
          <div class="card text-center">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl bg-brand-500/10">
              <svg class="h-7 w-7 text-brand-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold text-white">{value.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-dark-400">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-dark-800/50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="section-title">7 lat na rynku <span class="gradient-text">edukacji technologicznej</span></h2>
        <p class="section-subtitle">Współpracujemy z najlepszymi</p>
      </div>
      <div class="mt-12 grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-5">
        {partners.map((partner) => (
          <div class="flex items-center justify-center rounded-xl border border-dark-800/50 bg-dark-900/50 px-4 py-6 backdrop-blur-sm transition-colors hover:border-dark-700">
            <span class="text-sm font-semibold text-dark-400">{partner}</span>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-dark-500">
        Chcesz nawiązać współpracę?{" "}
        <a href="mailto:kontakt@przeprogramowani.pl" class="text-brand-400 hover:text-brand-300 transition-colors">
          kontakt@przeprogramowani.pl
        </a>
      </p>
    </div>
  </section>
</Layout>