---

<Layout
  title="YouTube"
  description="Oglądaj nasze filmy o programowaniu, AI i nowych technologiach na YouTube."
>
  <section class="relative overflow-hidden border-b border-dark-800/50">
    <div class="absolute inset-0 bg-gradient-to-b from-red-950/20 to-dark-950" />
    <div class="relative mx-auto max-w-7xl px-4 pb-20 pt-32 sm:px-6 sm:pb-24 sm:pt-40 lg:px-8">
      <div class="text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-red-500 to-red-700 mb-6">
          <svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </div>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Obejrzyj nas na <span class="bg-gradient-to-r from-red-400 to-red-600 bg-clip-text text-transparent">YouTube</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-dark-300">
          Filmy o programowaniu, AI, nowych technologiach i rozwoju kariery. 
          Subskrybuj nasz kanał, aby być na bieżąco.
        </p>
        <a
          href="https://youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary mt-8"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          Subskrybuj kanał
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <h2 class="section-title">Ostatnie <span class="bg-gradient-to-r from-red-400 to-red-600 bg-clip-text text-transparent">filmy</span></h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {videos.map((video) => (
          <a href={video.link} target="_blank" rel="noopener noreferrer" class="card group flex flex-col p-0 overflow-hidden hover:border-red-500/30">
            <div class="relative aspect-video overflow-hidden">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-transparent to-transparent" />
              <span class="absolute bottom-3 right-3 rounded-lg bg-dark-950/90 px-2 py-1 text-xs font-semibold text-white backdrop-blur-sm">
                {video.duration}
              </span>
              {video.featured && (
                <span class="absolute left-3 top-3 rounded-lg bg-red-500 px-2 py-1 text-xs font-semibold text-white">
                  Featured
                </span>
              )}
            </div>
            <div class="flex-1 p-4">
              <h3 class="font-semibold text-white group-hover:text-red-400 transition-colors line-clamp-2">
                {video.title}
              </h3>
              <div class="mt-2 flex items-center gap-3 text-xs text-dark-500">
                <span>{video.views} wyświetleń</span>
                <span>&middot;</span>
                <span>{video.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="https://youtube.com/c/przeprogramowani/videos"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Zobacz wszystkie filmy na YouTube
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>