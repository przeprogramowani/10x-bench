---
import PodcastCard from '../components/PodcastCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteData } from '../lib/site-data';

const site = await getSiteData();
---

<BaseLayout
  title="Podcast | Przeprogramowani.pl"
  description="Strona podcastu z ostatnimi odcinkami Przeprogramowani: Opanuj.AI Podcast oraz Przeprogramowani ft. Gość."
  currentPath="/podcast"
>
  <section class="section-wrap pt-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="surface-dark rounded-[2.3rem] px-6 py-8 md:px-10 md:py-12">
          <p class="eyebrow text-white/70">Podcast</p>
          <h1 class="mt-5 max-w-3xl font-display text-4xl leading-[0.98] text-white md:text-6xl">
            {site.podcast.title}
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-white/78">{site.podcast.description}</p>

          <div class="mt-8 flex flex-wrap gap-3">
            {site.podcast.platforms.map((platform) => (
              <a
                href={platform.href}
                target="_blank"
                rel="noreferrer"
                class="rounded-full border border-white/12 bg-[rgba(255,255,255,0.08)] px-4 py-3 text-sm font-semibold text-white transition-colors hover:bg-[rgba(255,255,255,0.14)]"
              >
                {platform.label}
              </a>
            ))}
          </div>
        </div>

        <div class="surface rounded-[2.3rem] p-6 md:p-8">
          <p class="eyebrow">Formaty</p>
          <div class="mt-6 space-y-5">
            {site.podcast.series.map((series) => (
              <div class="rounded-[1.7rem] bg-[rgba(16,19,26,0.05)] p-5">
                <p class="font-display text-2xl text-[var(--color-ink)]">{series.title}</p>
                <p class="mt-2 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-muted)]">
                  {series.listeners}
                </p>
                <p class="mt-3 text-sm leading-6 text-[var(--color-muted)]">{series.subtitle}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  {site.podcast.series.map((series) => (
    <section class="section-wrap">
      <div class="mx-auto max-w-7xl">
        <SectionHeading eyebrow={series.title} title={series.listeners} description={series.subtitle} />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {series.episodes.map((episode) => (
            <PodcastCard
              title={episode.title}
              description={episode.description}
              duration={episode.duration}
              url={episode.url}
              series={series.title}
            />
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>
