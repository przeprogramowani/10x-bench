---
import CourseCard from '../components/CourseCard.astro';
import FounderCard from '../components/FounderCard.astro';
import PodcastCard from '../components/PodcastCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import VideoCard from '../components/VideoCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteData } from '../lib/site-data';

const site = await getSiteData();
const heroCourse = site.courses[0];
const featureCourses = site.courses.slice(1);
const homepagePodcastEpisodes = site.podcast.series.flatMap((series) =>
  series.episodes.slice(0, 2).map((episode) => ({ ...episode, series: series.title })),
);
const homepageVideos = site.youtube.videos.slice(0, 3);
const sourcedLabel = new Intl.DateTimeFormat('pl-PL', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
}).format(new Date(site.sourcedAt));
---

<BaseLayout
  title="Przeprogramowani.pl | Nowoczesna strona projektu"
  description="Nowoczesna, responsywna strona Przeprogramowani.pl z sekcjami O nas, Podcast, YouTube i kursami 10xDevs, Opanuj Frontend oraz Opanuj TypeScript."
  currentPath="/"
>
  <section class="section-wrap pt-6 md:pt-8">
    <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="surface-dark overflow-hidden rounded-[2.3rem] px-6 py-8 md:px-10 md:py-12">
        <div class="hero-noise absolute inset-0 opacity-80" aria-hidden="true" />
        <div class="relative">
          <p class="eyebrow text-white/75">Edukacja technologiczna w epoce AI</p>
          <h1 class="mt-5 max-w-4xl font-display text-4xl leading-[0.96] text-white md:text-6xl">
            Przeprogramowani.pl
            <span class="block text-[var(--color-accent)]">dla developerów, którzy chcą patrzeć szerzej.</span>
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-white/78">
            {site.about.description[0]} {site.about.description[1]}
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/o-nas" class="btn-primary">Poznaj zespół</a>
            <a href="/podcast" class="btn-secondary border-white/20 text-white hover:bg-white/10">Podcast</a>
            <a href="/youtube" class="btn-secondary border-white/20 text-white hover:bg-white/10">YouTube</a>
          </div>

          <div class="mt-10 grid gap-3 sm:grid-cols-3">
            <div class="rounded-[1.5rem] border border-white/10 bg-[rgba(255,255,255,0.06)] p-4">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/55">Historia</p>
              <p class="mt-3 font-display text-3xl text-white">7 lat</p>
              <p class="mt-2 text-sm text-white/70">na rynku edukacji technologicznej</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-[rgba(255,255,255,0.06)] p-4">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/55">Produkty</p>
              <p class="mt-3 font-display text-3xl text-white">3 filary</p>
              <p class="mt-2 text-sm text-white/70">kursy premium, media i community</p>
            </div>
            <div class="rounded-[1.5rem] border border-white/10 bg-[rgba(255,255,255,0.06)] p-4">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/55">Stack 10xDevs</p>
              <p class="mt-3 font-display text-3xl text-white">Astro</p>
              <p class="mt-2 text-sm text-white/70">+ React + TypeScript w oficjalnym workflow</p>
            </div>
          </div>
        </div>
      </div>

      <aside class="surface relative overflow-hidden rounded-[2.3rem] px-6 py-8 md:px-8 md:py-10">
        <div class="mesh-orb -right-12 top-6 h-32 w-32 bg-[var(--color-accent)]/25" aria-hidden="true" />
        <p class="eyebrow">{heroCourse.tag}</p>
        <h2 class="mt-5 font-display text-3xl text-[var(--color-ink)] md:text-4xl">{heroCourse.name}</h2>
        <p class="mt-4 text-base leading-7 text-[var(--color-muted)]">{heroCourse.description}</p>

        <div class="mt-6 flex flex-wrap gap-2">
          {heroCourse.stats.map((stat) => (
            <span class="rounded-full bg-[rgba(16,19,26,0.06)] px-3 py-2 text-sm font-semibold text-[var(--color-ink)]">
              {stat}
            </span>
          ))}
        </div>

        <ul class="mt-8 space-y-3 text-sm leading-6 text-[var(--color-muted)]">
          {heroCourse.highlights.map((item) => (
            <li class="flex gap-3">
              <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[var(--color-accent)]" />
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 rounded-[1.7rem] bg-[var(--color-panel)] px-5 py-5 text-white">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-white/55">Oficjalny przekaz</p>
          <p class="mt-3 text-sm leading-6 text-white/78">
            W materiałach 10xDevs nacisk położony jest na cały cykl pracy z AI: research, planowanie,
            implementację, utrzymanie produkcji oraz kontrolę jakości.
          </p>
        </div>

        <a href={heroCourse.href} target="_blank" rel="noreferrer" class="btn-primary mt-8">
          Przejdź do 10xDevs
        </a>
      </aside>
    </div>
  </section>

  <section class="section-wrap">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="O nas"
        title={site.about.title}
        description="Przeprogramowani budują treści i programy dla programistów, którzy chcą łączyć technikę, biznes, komunikację i rozwój osobisty."
      />

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {site.about.founders.map((founder) => <FounderCard founder={founder} />)}
      </div>
    </div>
  </section>

  <section id="kursy" class="section-wrap">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="Kursy"
        title="Programy skrojone pod realia współczesnego developera."
        description="Od frontendu przez TypeScript po AI-native software engineering. Każdy program ma wyraźny profil, konkretny outcome i mocne osadzenie w praktyce."
      />

      <div class="mt-10 grid gap-6 lg:grid-cols-[1.1fr_0.9fr_0.9fr]">
        <CourseCard course={heroCourse} featured={true} />
        {featureCourses.map((course) => <CourseCard course={course} />)}
      </div>
    </div>
  </section>

  <section class="section-wrap">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="Podcast"
        title="Ostatnie odcinki z oficjalnej strony podcastu."
        description={site.podcast.description}
      />

      <div class="mt-8 flex flex-wrap gap-3">
        {site.podcast.platforms.map((platform) => (
          <a
            href={platform.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-black/10 bg-white/70 px-4 py-2 text-sm font-semibold text-[var(--color-ink)] transition-colors hover:bg-black/5"
          >
            {platform.label}
          </a>
        ))}
      </div>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {homepagePodcastEpisodes.map((episode) => (
          <PodcastCard
            title={episode.title}
            description={episode.description}
            duration={episode.duration}
            url={episode.url}
            series={episode.series}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section-wrap">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="YouTube"
        title="Najnowsze filmy z oficjalnego kanału Przeprogramowani."
        description="Strona korzysta z oficjalnego feedu YouTube kanału Przeprogramowani, dzięki czemu lista filmów odświeża się automatycznie."
      />

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {homepageVideos.map((video) => (
          <VideoCard
            title={video.title}
            description={video.description}
            url={video.url}
            thumbnail={video.thumbnail}
            publishedAt={video.publishedAt}
            views={video.views}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section-wrap pb-20">
    <div class="mx-auto max-w-7xl">
      <div class="surface rounded-[2.3rem] p-6 md:p-8">
        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
          <div>
            <p class="eyebrow">Zaufali im</p>
            <h2 class="mt-4 font-display text-3xl text-[var(--color-ink)] md:text-4xl">
              Firmy i zespoły, które stawiają na jakość edukacji.
            </h2>
            <p class="mt-4 text-base leading-7 text-[var(--color-muted)]">
              Na oficjalnej stronie Przeprogramowanych widoczni są partnerzy z obszaru product development,
              software consultingu i platform engineeringu.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            {site.about.partners.map((partner) => (
              <span class="rounded-full border border-black/10 bg-[rgba(16,19,26,0.05)] px-4 py-3 text-sm font-semibold text-[var(--color-ink)]">
                {partner}
              </span>
            ))}
          </div>
        </div>

        <p class="mt-8 text-sm text-[var(--color-muted)]">Dane źródłowe odświeżono: {sourcedLabel}.</p>
      </div>
    </div>
  </section>
</BaseLayout>
