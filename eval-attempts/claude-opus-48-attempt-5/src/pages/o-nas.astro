---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Newsletter from '../components/Newsletter.tsx';
import { team } from '../data/team';
import { clients, stats, site } from '../data/site';

const values = [
  {
    title: 'Praktyka ponad teorię',
    body: 'Uczymy tego, co realnie działa w produkcyjnych projektach. Wiedza z 10+ lat komercyjnego doświadczenia, nie z podręczników.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    title: 'Szersze spojrzenie',
    body: 'Najlepsi programiści myślą o architekturze, biznesie i ludziach. Rozwijamy Cię na wielu płaszczyznach naraz.',
    icon: 'M12 4.5C7 4.5 2.7 7.6 1 12c1.7 4.4 6 7.5 11 7.5s9.3-3.1 11-7.5c-1.7-4.4-6-7.5-11-7.5Zm0 12.5a5 5 0 1 1 0-10 5 5 0 0 1 0 10Zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z',
  },
  {
    title: 'Na czasie z AI',
    body: 'Sztuczna inteligencja zmienia zawód programisty. Pokazujemy, jak świadomie wykorzystać jej potencjał w codziennej pracy.',
    icon: 'M12 2a2 2 0 0 1 2 2v1h2a2 2 0 0 1 2 2v2h1a2 2 0 0 1 0 4h-1v2a2 2 0 0 1-2 2h-2v1a2 2 0 0 1-4 0v-1H8a2 2 0 0 1-2-2v-2H5a2 2 0 0 1 0-4h1V7a2 2 0 0 1 2-2h2V4a2 2 0 0 1 2-2Z',
  },
];
---

<Layout
  title="O nas"
  description="Poznaj Przeprogramowani — od 7 lat tworzymy kursy, podcasty i narzędzia dla ambitnych programistów. Za projektem stoją Przemek Smyrdek i Marcin Czarkowski."
  path="/o-nas"
>
  <PageHeader
    eyebrow="O nas"
    title="Miejsce, w którym programowanie spotyka rozwój"
    subtitle="Wierzymy, że najlepsi programiści myślą szerzej niż tylko kod — biorą pod uwagę architekturę, biznes i ludzi. Tworzymy treści, kursy i narzędzia, które pomagają rosnąć na każdej z tych płaszczyzn."
  />

  <!-- Stats -->
  <section class="py-16">
    <div class="container-x">
      <div class="grid grid-cols-2 gap-4 lg:grid-cols-4" data-reveal>
        {stats.map((s) => (
          <div class="card p-6 text-center">
            <div class="text-3xl font-bold text-white sm:text-4xl">{s.value}</div>
            <div class="mt-2 text-sm text-slate-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="py-12">
    <div class="container-x">
      <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:items-center">
        <div data-reveal>
          <span class="eyebrow">Nasza historia</span>
          <h2 class="mt-5 text-3xl font-bold sm:text-4xl">Od weekendowego projektu do platformy edukacyjnej</h2>
          <div class="mt-6 space-y-4 leading-relaxed text-slate-400">
            <p>
              Zaczęło się od pasji i newslettera pełnego darmowych treści o programowaniu. Dziś, po {site.years}
              latach, Przeprogramowani to kursy, dwa podcasty, kanał na YouTube i narzędzia, z których korzystają
              tysiące programistów w Polsce i za granicą.
            </p>
            <p>
              Nie uczymy programowania „na sucho”. Pokazujemy, jak wygląda praca nowoczesnego inżyniera — od jakości
              kodu i testów, przez CI/CD i architekturę, po świadome wykorzystanie generatywnej AI w całym cyklu
              wytwarzania oprogramowania.
            </p>
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-2" data-reveal>
          {values.map((v) => (
            <div class="card card-hover p-6">
              <span class="grid h-11 w-11 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-accent-500 text-white">
                <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={v.icon} /></svg>
              </span>
              <h3 class="mt-4 font-semibold text-white">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Founders -->
  <section class="py-16">
    <div class="container-x">
      <h2 class="text-center text-3xl font-bold sm:text-4xl" data-reveal>Poznaj założycieli</h2>
      <div class="mx-auto mt-12 grid max-w-4xl gap-6 md:grid-cols-2">
        {team.map((m, i) => (
          <article class="card card-hover p-8" data-reveal data-reveal-delay={i * 100}>
            <div class="flex items-center gap-4">
              <span class="grid h-16 w-16 flex-shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-brand-500 to-accent-500 font-display text-xl font-bold text-white shadow-lg">
                {m.initials}
              </span>
              <div>
                <h3 class="text-xl font-bold text-white">{m.name}</h3>
                <p class="text-sm font-medium text-brand-300">{m.role}</p>
              </div>
            </div>
            <p class="mt-5 text-sm leading-relaxed text-slate-400">{m.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Clients -->
  <section class="py-16">
    <div class="container-x">
      <p class="text-center text-sm font-semibold uppercase tracking-[0.2em] text-slate-500" data-reveal>
        Zaufali nam inżynierowie z firm
      </p>
      <div class="mx-auto mt-8 flex max-w-4xl flex-wrap items-center justify-center gap-x-8 gap-y-4" data-reveal>
        {clients.map((c) => (
          <span class="font-display text-lg font-semibold text-slate-400">{c}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-x" data-reveal>
      <Newsletter client:visible />
    </div>
  </section>
</Layout>
