---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nie znaleziono strony" path="/404">
  <section class="relative flex min-h-[70vh] items-center overflow-hidden pt-24">
    <div class="pointer-events-none absolute inset-0 grid-lines opacity-30" aria-hidden="true"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/3 h-72 w-72 -translate-x-1/2 rounded-full bg-brand-600/20 blur-[110px]" aria-hidden="true"></div>
    <div class="container-x relative text-center">
      <p class="font-display text-8xl font-bold gradient-text sm:text-9xl">404</p>
      <h1 class="mt-6 text-3xl font-bold sm:text-4xl">Ta strona się przeprogramowała</h1>
      <p class="mx-auto mt-4 max-w-md text-slate-400">
        Nie znaleźliśmy strony, której szukasz. Wróć na stronę główną albo sprawdź nasze kursy.
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/" class="btn-accent">Strona główna</a>
        <a href="/kursy" class="btn-ghost">Zobacz kursy</a>
      </div>
    </div>
  </section>
</Layout>
