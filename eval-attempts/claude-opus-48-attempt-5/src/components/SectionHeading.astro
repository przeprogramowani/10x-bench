---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, subtitle, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'text-center mx-auto items-center' : 'text-left items-start';
---

<div class={`flex flex-col gap-4 ${alignment} ${align === 'center' ? 'max-w-2xl' : 'max-w-3xl'}`} data-reveal>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="text-3xl font-bold leading-tight sm:text-4xl">{title}</h2>
  {subtitle && <p class="text-lg leading-relaxed text-slate-400">{subtitle}</p>}
</div>
