---
import type { Course } from '../data/courses';
interface Props {
  course: Course;
  index?: number;
}
const { course, index = 0 } = Astro.props;
---

<article
  class="card card-hover group flex h-full flex-col overflow-hidden p-6 sm:p-7"
  data-reveal
  data-reveal-delay={index * 90}
>
  <div class="flex items-start justify-between gap-4">
    <div class={`grid h-12 w-12 place-items-center rounded-xl bg-gradient-to-br ${course.accent} text-2xl shadow-lg`}>
      <span aria-hidden="true">{course.emoji}</span>
    </div>
    {course.featured && (
      <span class="rounded-full border border-accent-400/40 bg-accent-500/10 px-3 py-1 text-xs font-semibold text-accent-400">
        Nowość
      </span>
    )}
  </div>

  <h3 class="mt-5 text-xl font-bold text-white">{course.name}</h3>
  <p class="mt-1 text-sm font-medium text-brand-300">{course.tagline}</p>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">{course.description}</p>

  <ul class="mt-5 grid grid-cols-3 gap-2 border-y border-white/10 py-4">
    {course.meta.map((m) => (
      <li class="text-center">
        <div class="text-sm font-bold text-white">{m.value}</div>
        <div class="mt-0.5 text-[11px] uppercase tracking-wide text-slate-500">{m.label}</div>
      </li>
    ))}
  </ul>

  <div class="mt-5 flex items-center justify-between gap-3">
    <a href={course.url} target="_blank" rel="noopener noreferrer" class="btn-ghost px-5 py-2.5 text-sm">
      Zobacz kurs
      <svg viewBox="0 0 24 24" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6" />
      </svg>
    </a>
    <a href="/kursy" class="text-sm font-medium text-slate-400 transition-colors hover:text-white">Szczegóły</a>
  </div>
</article>
