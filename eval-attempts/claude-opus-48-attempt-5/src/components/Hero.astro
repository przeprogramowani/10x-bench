---
import { featuredCourse } from '../data/courses';
import { stats } from '../data/site';
---

<section class="relative overflow-hidden pt-28 pb-20 sm:pt-36 sm:pb-28">
  <!-- Backdrop -->
  <div class="pointer-events-none absolute inset-0 grid-lines opacity-40" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-[520px] bg-gradient-to-b from-brand-900/40 via-brand-950/10 to-transparent" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -left-32 top-10 h-96 w-96 rounded-full bg-brand-600/20 blur-[120px] animate-float-slow" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -right-24 top-40 h-80 w-80 rounded-full bg-accent-500/15 blur-[120px]" aria-hidden="true"></div>

  <div class="container-x relative">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <!-- Left: copy -->
      <div class="max-w-2xl">
        <a href="https://10xdevs.pl" class="eyebrow group animate-fade-up">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-400"></span>
          </span>
          Nowa edycja 10xDevs 4.0 — start 14 września
        </a>

        <h1 class="mt-6 text-4xl font-bold leading-[1.08] sm:text-5xl lg:text-6xl animate-fade-up" style="animation-delay: 60ms">
          Szersze spojrzenie na
          <span class="gradient-text"> programowanie</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-300 animate-fade-up" style="animation-delay: 120ms">
          Miejsce, w którym programowanie spotyka rozwój. Kursy, podcasty i narzędzia dla ambitnych
          programistów — od frontendu i TypeScriptu po <strong class="font-semibold text-white">AI-Native Software Engineering</strong>.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center animate-fade-up" style="animation-delay: 180ms">
          <a href="https://10xdevs.pl" class="btn-accent px-7 py-3.5 text-base">
            Dołącz do 10xDevs 4.0
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14m-6-6 6 6-6 6" /></svg>
          </a>
          <a href="/kursy" class="btn-ghost px-7 py-3.5 text-base">Poznaj wszystkie kursy</a>
        </div>

        <dl class="mt-12 grid max-w-lg grid-cols-2 gap-x-8 gap-y-6 sm:grid-cols-4 animate-fade-up" style="animation-delay: 240ms">
          {stats.map((s) => (
            <div>
              <dt class="text-2xl font-bold text-white sm:text-3xl">{s.value}</dt>
              <dd class="mt-1 text-xs leading-tight text-slate-400">{s.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Right: featured 10xDevs card -->
      <div class="relative animate-fade-up" style="animation-delay: 200ms">
        <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-brand-500/30 to-accent-500/20 blur-2xl" aria-hidden="true"></div>
        <div class="relative overflow-hidden rounded-[1.75rem] border border-white/10 bg-ink-900/80 p-8 shadow-2xl backdrop-blur-xl">
          <div class="flex items-center justify-between">
            <span class="rounded-full border border-accent-400/40 bg-accent-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent-400">
              Program flagowy
            </span>
            <span class="text-4xl" aria-hidden="true">{featuredCourse.emoji}</span>
          </div>

          <h2 class="mt-6 font-display text-3xl font-bold text-white">{featuredCourse.name}</h2>
          <p class="mt-2 text-sm font-medium text-brand-300">{featuredCourse.tagline}</p>
          <p class="mt-4 text-sm leading-relaxed text-slate-400">
            AI-Native Software Engineering w praktyce. Wpleć narzędzia AI w cały cykl wytwarzania oprogramowania —
            od pomysłu, przez agentów, po produkcję.
          </p>

          <ul class="mt-6 space-y-3">
            {featuredCourse.highlights.slice(0, 4).map((h) => (
              <li class="flex items-start gap-3 text-sm text-slate-300">
                <svg viewBox="0 0 24 24" class="mt-0.5 h-5 w-5 flex-shrink-0 text-accent-400" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{h}</span>
              </li>
            ))}
          </ul>

          <div class="mt-7 flex flex-wrap gap-2">
            {featuredCourse.stack.map((t) => (
              <span class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-xs font-medium text-slate-300">{t}</span>
            ))}
          </div>

          <a href={featuredCourse.url} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8 w-full">
            Zapisz się na 10xDevs
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
