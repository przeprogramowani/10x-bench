---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const founders = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder, Przeprogramowani',
    image: 'https://przeprogramowani.pl/img/profiles/przemek.webp',
    bio: 'Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).',
    linkedin: 'https://www.linkedin.com/in/psmyrdek/',
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder, Przeprogramowani',
    image: 'https://przeprogramowani.pl/img/profiles/marcin.webp',
    bio: 'Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca "Opanuj AI Podcast" — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.',
    linkedin: 'https://www.linkedin.com/in/mkczarkowski/',
  },
];

const partners = [
  'Huuuge Games',
  'SmartRecruiters',
  'Callstack',
  'Xfive',
  'Strabag',
  'Nutridome',
  'Future Processing',
  'edrone',
  'Euvic',
  'Autodesk',
];

const values = [
  {
    icon: 'code',
    title: 'Jakość techniczna',
    description: 'Dążymy do doskonałości w każdym aspekcie developmentu — od architektury po testy.',
  },
  {
    icon: 'brain',
    title: 'Rozwój osobisty',
    description: 'Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na siebie i innych.',
  },
  {
    icon: 'users',
    title: 'Społeczność',
    description: 'Budujemy przestrzeń dla osób, które chcą się rozwijać i dzielić wiedzą.',
  },
  {
    icon: 'lightbulb',
    title: 'Innowacja',
    description: 'Eksplorujemy nowe technologie i metody pracy, w tym Generatywne AI.',
  },
];
---

<Layout title="O nas">
  <Header />
  
  <main class="pt-16">
    <section class="py-20 lg:py-32 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
            O nas
          </h1>
          <p class="text-xl text-slate-400 max-w-3xl mx-auto">
            Łączymy świat programowania, biznesu i rozwoju
          </p>
        </div>

        <div class="max-w-4xl mx-auto">
          <div class="prose prose-invert prose-lg max-w-none">
            <div class="bg-slate-800/50 rounded-2xl p-8 lg:p-12 border border-slate-700/50 mb-12">
              <h2 class="text-2xl font-bold text-white mb-6">Witaj na Przeprogramowanych!</h2>
              <p class="text-slate-300 text-lg leading-relaxed mb-6">
                Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. 
                Wierzymy, że <strong class="text-white">najlepsi programiści to ci, którzy patrzą szerzej</strong> — 
                na architekturę, na biznes, na ludzi i na siebie.
              </p>
              <p class="text-slate-300 text-lg leading-relaxed">
                Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. 
                Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32 bg-slate-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-16">
          Założyciele
        </h2>
        
        <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
          {founders.map((founder) => (
            <div class="bg-slate-800/50 rounded-2xl overflow-hidden border border-slate-700/50">
              <div class="p-8">
                <div class="flex items-start gap-6 mb-6">
                  <img
                    src={founder.image}
                    alt={founder.name}
                    class="w-24 h-24 rounded-xl object-cover"
                    loading="lazy"
                  />
                  <div>
                    <h3 class="text-xl font-bold text-white">{founder.name}</h3>
                    <p class="text-primary-400">{founder.role}</p>
                  </div>
                </div>
                <p class="text-slate-300 mb-6">{founder.bio}</p>
                <a
                  href={founder.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-primary-400 hover:text-primary-300 font-medium"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-16">
          Nasze wartości
        </h2>
        
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          {values.map((value) => (
            <div class="text-center">
              <div class="w-16 h-16 mx-auto mb-6 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center">
                {value.icon === 'code' && (
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                  </svg>
                )}
                {value.icon === 'brain' && (
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                )}
                {value.icon === 'users' && (
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                )}
                {value.icon === 'lightbulb' && (
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                )}
              </div>
              <h3 class="text-xl font-semibold text-white mb-2">{value.title}</h3>
              <p class="text-slate-400">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32 bg-slate-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
            7 lat na rynku edukacji technologicznej
          </h2>
          <p class="text-slate-400">Współpracujemy z najlepszymi</p>
        </div>
        
        <div class="flex flex-wrap justify-center items-center gap-8 lg:gap-12">
          {partners.map((partner) => (
            <div class="px-6 py-3 text-slate-500 hover:text-slate-300 transition-colors font-medium">
              {partner}
            </div>
          ))}
        </div>

        <div class="mt-12 text-center">
          <p class="text-slate-400 mb-4">Chcesz nawiązać współpracę?</p>
          <a
            href="mailto:kontakt@przeprogramowani.pl"
            class="inline-flex items-center gap-2 text-primary-400 hover:text-primary-300 font-medium"
          >
            kontakt@przeprogramowani.pl
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>