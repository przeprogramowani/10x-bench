---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CourseCard from '../components/CourseCard.astro';
import VideoCard from '../components/VideoCard.astro';
import TestimonialSlider from '../components/TestimonialSlider';
import Reveal from '../components/Reveal';
import { courses } from '../data/courses';
import { videos } from '../data/videos';
import { shows } from '../data/podcasts';
import { testimonials } from '../data/testimonials';

const brands = [
  'Huuuge Games',
  'SmartRecruiters',
  'Callstack',
  'Autodesk',
  'Future Processing',
  'Xfive',
  'edrone',
  'Euvic',
  'Nutridome',
  'Strabag',
];

const latestEpisodes = shows[0].episodes.slice(0, 3);
---

<BaseLayout
  title="Przeprogramowani.pl — Szersze spojrzenie na programowanie"
  description="Kursy, podcasty i filmy dla ambitnych programistów. 10xDevs — programowanie z Generatywnym AI, Opanuj Frontend: AI Edition, Opanuj TypeScript."
>
  <Hero />

  {/* Zaufali nam */}
  <section class="border-y border-white/5 bg-ink-soft py-10">
    <div class="container-x">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">
        Zaufali nam — 7 lat na rynku edukacji technologicznej
      </p>
      <ul class="mt-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {brands.map((brand) => <li class="font-display text-sm font-semibold text-slate-500">{brand}</li>)}
      </ul>
    </div>
  </section>

  {/* Kursy */}
  <section id="kursy" class="section-pad scroll-mt-20">
    <div class="container-x">
      <Reveal client:load>
        <SectionHeading
          eyebrow="Edukacja technologiczna w epoce AI"
          title="Nasze programy edukacyjne"
          description="Topowe programy dla ambitnych programistów — od nowoczesnego frontendu, przez TypeScript, po świadome korzystanie z potencjału Generatywnego AI."
        />
      </Reveal>
      <div class="grid gap-6 md:grid-cols-3">
        {courses.map((course, i) => (
          <Reveal client:load delay={i * 100}>
            <CourseCard course={course} />
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* YouTube */}
  <section class="section-pad border-t border-white/5 bg-ink-soft">
    <div class="container-x">
      <Reveal client:load>
        <SectionHeading
          eyebrow="Filmy"
          title="Ostatnio na YouTube"
          description="Rozwój nowoczesnego programisty — AI, narzędzia, relacje z konferencji i praktyczne demo."
          linkHref="/youtube"
          linkLabel="Wszystkie filmy"
        />
      </Reveal>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {videos.slice(0, 3).map((video, i) => (
          <Reveal client:load delay={i * 100}>
            <VideoCard id={video.id} title={video.title} />
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  {/* Podcast */}
  <section class="section-pad">
    <div class="container-x">
      <Reveal client:load>
        <SectionHeading
          eyebrow="Podcast"
          title="Ostatnie odcinki"
          description="Opanuj.AI Podcast — comiesięczne podsumowanie najważniejszych wydarzeń ze świata AI. Ponad 4000 słuchaczy."
          linkHref="/podcast"
          linkLabel="Wszystkie odcinki"
        />
      </Reveal>
      <ol class="grid gap-5 lg:grid-cols-3">
        {
          latestEpisodes.map((episode, i) => (
            <Reveal client:load delay={i * 100}>
              <li class="h-full">
                <a href={episode.url} target="_blank" rel="noopener" class="card card-hover group flex h-full flex-col p-6">
                  <div class="flex items-center gap-3 text-xs text-slate-500">
                    <span class="rounded-full bg-brand-400/10 px-2.5 py-1 font-semibold text-brand-300">
                      {episode.duration}
                    </span>
                    <span>Opanuj.AI Podcast</span>
                  </div>
                  <h3 class="mt-4 flex-1 font-display text-lg font-bold leading-snug text-white transition-colors group-hover:text-brand-300">
                    {episode.title}
                  </h3>
                  <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-300">
                    Słuchaj
                    <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
                  </span>
                </a>
              </li>
            </Reveal>
          ))
        }
      </ol>
    </div>
  </section>

  {/* O nas — teaser */}
  <section class="section-pad border-t border-white/5 bg-ink-soft">
    <div class="container-x grid items-center gap-12 lg:grid-cols-2">
      <Reveal client:load>
        <div>
          <p class="eyebrow">O nas</p>
          <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Łączymy świat programowania, biznesu i rozwoju</h2>
          <p class="mt-5 leading-relaxed text-slate-400">
            Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy,
            że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
          </p>
          <a href="/o-nas" class="btn-ghost mt-7">
            Poznaj nas bliżej
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </Reveal>
      <Reveal client:load delay={120}>
        <div class="grid gap-5 sm:grid-cols-2">
          <div class="card p-6">
            <img
              src="https://przeprogramowani.pl/img/profiles/przemek.webp"
              alt="Przemek Smyrdek"
              loading="lazy"
              class="h-16 w-16 rounded-full object-cover"
            />
            <h3 class="mt-4 font-display text-lg font-bold text-white">Przemek Smyrdek</h3>
            <p class="mt-1 text-sm text-slate-400">Co-founder. Lead Engineer i Manager w DAZN i Cabify.</p>
          </div>
          <div class="card p-6">
            <img
              src="https://przeprogramowani.pl/img/profiles/marcin.webp"
              alt="Marcin Czarkowski"
              loading="lazy"
              class="h-16 w-16 rounded-full object-cover"
            />
            <h3 class="mt-4 font-display text-lg font-bold text-white">Marcin Czarkowski</h3>
            <p class="mt-1 text-sm text-slate-400">Co-founder. Lead techniczny w SmartRecruiters.</p>
          </div>
        </div>
      </Reveal>
    </div>
  </section>

  {/* Opinie */}
  <section class="section-pad">
    <div class="container-x">
      <Reveal client:load>
        <SectionHeading
          eyebrow="Opinie"
          title="Co mówią uczestnicy"
          description="Absolwenci naszych programów o tym, jak zmieniła się ich codzienna praca z AI."
        />
      </Reveal>
      <TestimonialSlider client:load testimonials={testimonials} />
    </div>
  </section>

  {/* Newsletter */}
  <section class="section-pad border-t border-white/5 bg-gradient-to-b from-ink-soft to-ink">
    <div class="container-x">
      <Reveal client:load>
        <div class="card relative mx-auto max-w-3xl overflow-hidden p-10 text-center sm:p-14">
          <div class="absolute -top-24 left-1/2 h-48 w-96 -translate-x-1/2 rounded-full bg-brand-500/20 blur-[100px]" aria-hidden="true"></div>
          <p class="eyebrow relative">Newsletter</p>
          <h2 class="relative mt-3 text-3xl font-bold sm:text-4xl">Przeprogramowany Newsletter</h2>
          <p class="relative mx-auto mt-4 max-w-xl text-slate-400">
            Co tydzień w piątek porcja wartościowych treści w formacie 3-2-1: 3 rekomendacje techniczne,
            2 rekomendacje rozwojowe i 1 bonus niespodzianka.
          </p>
          <a href="https://przeprogramowani.substack.com" target="_blank" rel="noopener" class="btn-primary relative mt-8">
            Zapisz się za darmo
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </Reveal>
    </div>
  </section>
</BaseLayout>
