---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Reveal from '../components/Reveal';

const founders = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder, Przeprogramowani',
    photo: 'https://przeprogramowani.pl/img/profiles/przemek.webp',
    bio: 'Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).',
    linkedin: 'https://www.linkedin.com/in/psmyrdek/',
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder, Przeprogramowani',
    photo: 'https://przeprogramowani.pl/img/profiles/marcin.webp',
    bio: 'Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca „Opanuj AI Podcast" — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.',
    linkedin: 'https://www.linkedin.com/in/mkczarkowski/',
  },
];

const stats = [
  { value: '7 lat', label: 'na rynku edukacji technologicznej' },
  { value: '6700+', label: 'absolwentów 10xDevs' },
  { value: '~400', label: 'absolwentów Opanuj Frontend' },
  { value: '7800+', label: 'słuchaczy podcastów' },
];

const activities = [
  {
    title: 'Kursy i programy edukacyjne',
    description: '10xDevs, Opanuj Frontend: AI Edition i Opanuj TypeScript — praktyczne programy dla ambitnych programistów.',
  },
  {
    title: 'Podcasty',
    description: 'Opanuj.AI Podcast i Przeprogramowani ft. Gość — comiesięczne podsumowania świata AI i rozmowy dla głodnych wiedzy.',
  },
  {
    title: 'YouTube',
    description: 'Filmy o nowoczesnym programowaniu, narzędziach AI, relacje z konferencji i praktyczne demo.',
  },
  {
    title: 'Newsletter',
    description: 'Przeprogramowany Newsletter — co piątek format 3-2-1: rekomendacje techniczne, rozwojowe i bonus.',
  },
  {
    title: '10xRules.ai',
    description: 'Nasz produkt — reguły AI dla Twojego zespołu. Buduj osobiste reguły i zarządzaj promptami zespołowymi.',
  },
  {
    title: 'Społeczność',
    description: 'Setki ambitnych programistów dzielących się wiedzą i doświadczeniem w pracy z nowymi technologiami.',
  },
];

const brands = [
  'Huuuge Games',
  'Nutridome',
  'SmartRecruiters',
  'Future Processing',
  'Callstack',
  'edrone',
  'Xfive',
  'Euvic',
  'Strabag',
  'Autodesk',
];
---

<BaseLayout
  title="O nas — Przeprogramowani.pl"
  description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Poznaj Przemka i Marcina oraz naszą misję."
>
  {/* Hero */}
  <section class="relative overflow-hidden">
    <div class="bg-grid absolute inset-0" aria-hidden="true"></div>
    <div class="absolute -top-32 left-1/2 h-96 w-[700px] -translate-x-1/2 rounded-full bg-brand-500/10 blur-[130px]" aria-hidden="true"></div>
    <div class="container-x relative py-20 sm:py-24">
      <p class="eyebrow">O nas</p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold leading-tight sm:text-5xl">
        Łączymy świat <span class="gradient-text">programowania, biznesu i rozwoju</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-400">
        Witaj na Przeprogramowanych! To miejsce, w którym programowanie spotyka się z rozwojem osobistym.
        Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes,
        na ludzi i na siebie.
      </p>
    </div>
  </section>

  {/* Statystyki */}
  <section class="border-y border-white/5 bg-ink-soft py-12">
    <div class="container-x grid grid-cols-2 gap-8 lg:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="text-center">
            <p class="font-display text-3xl font-bold text-white sm:text-4xl">{stat.value}</p>
            <p class="mt-2 text-sm text-slate-400">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* Założyciele */}
  <section class="section-pad">
    <div class="container-x">
      <Reveal client:load>
        <SectionHeading
          eyebrow="Zespół"
          title="Poznaj założycieli"
          description="Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach — od technicznych deep-dive'ów po rozmowy o karierze."
        />
      </Reveal>
      <div class="grid gap-6 lg:grid-cols-2">
        {
          founders.map((founder, i) => (
            <Reveal client:load delay={i * 120}>
              <article class="card card-hover flex h-full flex-col gap-6 p-8 sm:flex-row">
                <img
                  src={founder.photo}
                  alt={founder.name}
                  loading="lazy"
                  class="h-28 w-28 shrink-0 rounded-2xl object-cover"
                />
                <div>
                  <h3 class="font-display text-2xl font-bold text-white">{founder.name}</h3>
                  <p class="mt-1 text-sm font-semibold text-brand-300">{founder.role}</p>
                  <p class="mt-4 text-sm leading-relaxed text-slate-400">{founder.bio}</p>
                  <a
                    href={founder.linkedin}
                    target="_blank"
                    rel="noopener"
                    class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-300 transition-colors hover:text-brand-400"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45z" />
                    </svg>
                    LinkedIn
                  </a>
                </div>
              </article>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  {/* Czym się zajmujemy */}
  <section class="section-pad border-t border-white/5 bg-ink-soft">
    <div class="container-x">
      <Reveal client:load>
        <SectionHeading
          eyebrow="Nasza działalność"
          title="Czym się zajmujemy"
          description="Od kursów, przez podcasty, po własne produkty — wszystko z myślą o szerszym spojrzeniu na programowanie."
        />
      </Reveal>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          activities.map((activity, i) => (
            <Reveal client:load delay={(i % 3) * 100}>
              <div class="card card-hover h-full p-6">
                <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-400/10 font-display text-lg font-bold text-brand-400">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="mt-4 font-display text-lg font-bold text-white">{activity.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-400">{activity.description}</p>
              </div>
            </Reveal>
          ))
        }
      </div>
    </div>
  </section>

  {/* Zaufali nam */}
  <section class="section-pad">
    <div class="container-x text-center">
      <Reveal client:load>
        <p class="eyebrow">Zaufali nam</p>
        <h2 class="mt-3 text-3xl font-bold sm:text-4xl">Współpracowaliśmy z</h2>
        <ul class="mx-auto mt-10 flex max-w-4xl flex-wrap items-center justify-center gap-x-8 gap-y-4">
          {brands.map((brand) => <li class="font-display text-base font-semibold text-slate-500">{brand}</li>)}
        </ul>
      </Reveal>
    </div>
  </section>

  {/* Kontakt */}
  <section class="section-pad border-t border-white/5 bg-gradient-to-b from-ink-soft to-ink">
    <div class="container-x text-center">
      <Reveal client:load>
        <h2 class="text-3xl font-bold sm:text-4xl">Chcesz nawiązać współpracę?</h2>
        <p class="mx-auto mt-4 max-w-xl text-slate-400">
          Zyskaj szersze spojrzenie na programowanie razem z nami. Napisz — odezwiemy się.
        </p>
        <a href="mailto:kontakt@przeprogramowani.pl" class="btn-primary mt-8">
          kontakt@przeprogramowani.pl
        </a>
      </Reveal>
    </div>
  </section>
</BaseLayout>
