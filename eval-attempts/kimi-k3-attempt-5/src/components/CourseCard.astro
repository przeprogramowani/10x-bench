---
import type { Course } from '../data/courses';

interface Props {
  course: Course;
}

const { course } = Astro.props;
---

<a
  href={course.url}
  target="_blank"
  rel="noopener"
  class:list={[
    'card group relative flex flex-col overflow-hidden p-7',
    course.featured
      ? 'border-brand-400/40 bg-gradient-to-b from-brand-400/[0.08] to-transparent shadow-glow'
      : 'card-hover',
  ]}
>
  {
    course.badge && (
      <span class="absolute right-5 top-5 rounded-full bg-brand-400 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-ink">
        {course.badge}
      </span>
    )
  }

  <span class="eyebrow">{course.tag}</span>
  <h3 class="mt-3 pr-24 text-2xl font-bold transition-colors group-hover:text-brand-300">
    {course.name}
  </h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">{course.description}</p>

  <ul class="mt-5 space-y-2">
    {
      course.features.map((feature) => (
        <li class="flex items-start gap-2 text-sm text-slate-300">
          <svg class="mt-0.5 shrink-0 text-brand-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          {feature}
        </li>
      ))
    }
  </ul>

  <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-300">
    Szczegóły
    <span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
  </span>
</a>
