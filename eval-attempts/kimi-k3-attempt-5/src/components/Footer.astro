---
const pageLinks = [
  { href: '/o-nas', label: 'O nas' },
  { href: '/podcast', label: 'Podcast' },
  { href: '/youtube', label: 'YouTube' },
  { href: 'https://przeprogramowani.substack.com', label: 'Newsletter' },
];

const courseLinks = [
  { href: 'https://10xdevs.pl', label: '10xDevs' },
  { href: 'https://www.opanujfrontend.pl', label: 'Opanuj Frontend' },
  { href: 'https://www.opanujtypescript.pl', label: 'Opanuj TypeScript' },
  { href: 'https://opanuj.ai', label: 'Opanuj AI' },
];

const socials = [
  { href: 'https://facebook.com/przeprogramowani', label: 'Facebook' },
  { href: 'https://instagram.com/przeprogramowani', label: 'Instagram' },
  { href: 'https://youtube.com/c/przeprogramowani', label: 'YouTube' },
  { href: 'mailto:kontakt@przeprogramowani.pl', label: 'E-mail' },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-ink-soft">
  <div class="container-x grid gap-10 py-14 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div>
      <a href="/" class="flex items-center gap-2 font-display text-lg font-bold text-white">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-400 to-brand-600 font-mono text-sm font-bold text-ink">
          &lt;/&gt;
        </span>
        Przeprogramowani
      </a>
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
        Szersze spojrzenie na programowanie. Kursy, podcasty i filmy dla ambitnych programistów.
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        {
          socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-medium text-slate-400 transition-colors hover:border-brand-400/50 hover:text-white"
            >
              {s.label}
            </a>
          ))
        }
      </div>
    </div>

    <nav aria-label="Strony">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Strony</h3>
      <ul class="mt-4 space-y-2.5">
        {
          pageLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-slate-400 transition-colors hover:text-brand-300">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label="Kursy">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Kursy</h3>
      <ul class="mt-4 space-y-2.5">
        {
          courseLinks.map((l) => (
            <li>
              <a href={l.href} target="_blank" rel="noopener" class="text-sm text-slate-400 transition-colors hover:text-brand-300">
                {l.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Kontakt</h3>
      <a href="mailto:kontakt@przeprogramowani.pl" class="mt-4 block text-sm text-slate-400 transition-colors hover:text-brand-300">
        kontakt@przeprogramowani.pl
      </a>
      <p class="mt-3 text-sm text-slate-500">Chcesz nawiązać współpracę? Napisz do nas.</p>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div class="container-x flex flex-col items-center justify-between gap-2 py-5 text-xs text-slate-500 sm:flex-row">
      <span>© {year} Przeprogramowani.pl</span>
      <span>Szersze spojrzenie na programowanie</span>
    </div>
  </div>
</footer>
