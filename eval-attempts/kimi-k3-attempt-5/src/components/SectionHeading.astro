---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  linkHref?: string;
  linkLabel?: string;
}

const { eyebrow, title, description, linkHref, linkLabel } = Astro.props;
---

<div class="mb-10 flex flex-wrap items-end justify-between gap-6 sm:mb-14">
  <div class="max-w-2xl">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="mt-3 text-3xl font-bold sm:text-4xl">{title}</h2>
    {description && <p class="mt-4 leading-relaxed text-slate-400">{description}</p>}
  </div>
  {
    linkHref && (
      <a href={linkHref} class="btn-ghost shrink-0">
        {linkLabel ?? 'Zobacz wszystkie'}
        <span aria-hidden="true">→</span>
      </a>
    )
  }
</div>
