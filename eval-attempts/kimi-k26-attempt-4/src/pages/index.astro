---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const courses = [
  {
    title: 'Opanuj AI',
    description: 'Warsztaty, podcast, blog i darmowe ebooki o sztucznej inteligencji. Zdobądź praktyczną wiedzę o AI i wdróż ją w codziennej pracy.',
    href: 'https://opanuj.ai/',
    colorClass: 'cyan',
    bgClass: 'bg-cyan-500',
    hoverClass: 'hover:bg-cyan-400',
    textClass: 'text-cyan-400',
    image: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&q=80',
  },
  {
    title: 'Opanuj Frontend: AI Edition',
    description: 'Zostań nowoczesnym frontend developerem — 5 obszernych modułów o frontendzie, testowaniu, CI/CD, open source i architekturze aplikacji webowych. Cztery edycje i prawie 400 absolwentów!',
    href: 'https://www.opanujfrontend.pl',
    colorClass: 'pink',
    bgClass: 'bg-pink-500',
    hoverClass: 'hover:bg-pink-400',
    textClass: 'text-pink-400',
    image: 'https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=800&q=80',
  },
  {
    title: 'Opanuj TypeScript',
    description: 'Opanuj TypeScript to szkolenie, które podniesie jakość twoich projektów działających na produkcji i ułatwi ich rozwój. Pracujemy z najnowszymi wersjami TypeScript 5 i React 19!',
    href: 'https://www.opanujtypescript.pl',
    colorClass: 'sky',
    bgClass: 'bg-sky-500',
    hoverClass: 'hover:bg-sky-400',
    textClass: 'text-sky-400',
    image: 'https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=800&q=80',
  },
];

const videos = [
  {
    title: '5 Agent Skills do jakościowego programowania z AI - Claude Code LIVE DEMO',
    href: 'https://www.youtube.com/watch?v=S-iNbyLSisE',
    thumbnail: 'https://i3.ytimg.com/vi/S-iNbyLSisE/maxresdefault.jpg',
  },
  {
    title: 'Product Builders Day | LIVE AI Product Heroes i 10xDevs',
    href: 'https://www.youtube.com/watch?v=aRkECt7derY',
    thumbnail: 'https://i3.ytimg.com/vi/aRkECt7derY/maxresdefault.jpg',
  },
  {
    title: 'Wybierasz model AI do kodowania? Nie ufaj benchmarkom',
    href: 'https://www.youtube.com/watch?v=vH1T5qB4dBQ',
    thumbnail: 'https://i3.ytimg.com/vi/vH1T5qB4dBQ/maxresdefault.jpg',
  },
  {
    title: 'Claude Code w rękach Product Buildera | LIVE AI Product Heroes x 10xDevs',
    href: 'https://www.youtube.com/watch?v=bcs8WS4A5Zg',
    thumbnail: 'https://i3.ytimg.com/vi/bcs8WS4A5Zg/maxresdefault.jpg',
  },
  {
    title: 'MVP w Claude Code - Context Engineering, kontrola Agenta i refaktoryzacja',
    href: 'https://www.youtube.com/watch?v=Vce4cD_5XW0',
    thumbnail: 'https://i3.ytimg.com/vi/Vce4cD_5XW0/maxresdefault.jpg',
  },
  {
    title: 'Od chaosu do AI-Native Infrastructure - budujemy platformę dla zespołu, który programuje z Agentami',
    href: 'https://www.youtube.com/watch?v=hbuCLvwbMVg',
    thumbnail: 'https://i3.ytimg.com/vi/hbuCLvwbMVg/maxresdefault.jpg',
  },
];

const partners = [
  'Huuuge Games', 'Nutridome', 'SmartRecruiters', 'Future Processing',
  'Callstack', 'edrone', 'Xfive', 'Euvic', 'Strabag', 'Autodesk'
];
---

<Layout title="Przeprogramowani - Szersze spojrzenie na programowanie">
  <Header />
  <main id="main-content">
    <!-- Hero: 10xDevs -->
    <section class="relative bg-gray-950 overflow-hidden">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-orange-900/20 via-gray-950 to-gray-950"></div>
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-orange-500/10 to-transparent"></div>
      </div>
      <div class="relative max-w-screen-xl mx-auto lg:grid lg:grid-cols-2 lg:gap-12 px-4 sm:px-8 py-16 sm:py-24 items-center">
        <div class="py-4">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-1 bg-orange-500 rounded-full"></div>
            <span class="text-orange-500 text-sm font-bold uppercase tracking-wider">Nowość - Maj 2026</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-tight font-heading">
            10xDevs 3.0
          </h1>
          <p class="mt-5 text-lg text-gray-300 max-w-lg">
            Nowe oblicze programowania z wykorzystaniem Generatywnego AI. Techniki i narzędzia pozwalające świadomie stosować AI w całym cyklu wytwarzania oprogramowania.
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 font-semibold rounded-lg transition-colors duration-150 px-8 py-3 text-base bg-orange-500 text-white shadow-lg hover:bg-orange-400">
              Szczegóły &rarr;
            </a>
          </div>
        </div>
        <div class="hidden lg:flex items-center justify-center">
          <div class="relative w-full max-w-lg">
            <div class="absolute -inset-4 bg-orange-500/20 rounded-2xl blur-2xl"></div>
            <div class="relative bg-gray-900 border border-gray-800 rounded-xl p-6 shadow-2xl">
              <div class="flex items-center gap-2 mb-4">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
                <span class="ml-2 text-xs text-gray-500 font-mono">agent.ts</span>
              </div>
              <pre class="text-sm font-mono text-gray-300 overflow-x-auto"><code><span class="text-purple-400">import</span> &#123; Agent &#125; <span class="text-purple-400">from</span> <span class="text-green-400">'@10xdevs/core'</span>;

<span class="text-purple-400">const</span> agent = <span class="text-purple-400">new</span> Agent(&#123;
  model: <span class="text-green-400">'claude-4'</span>,
  skills: [<span class="text-green-400">'code'</span>, <span class="text-green-400">'test'</span>, <span class="text-green-400">'deploy'</span>],
  context: <span class="text-green-400">'full-stack'</span>
&#125;);

<span class="text-gray-500">// Programuj 10x szybciej z AI</span>
<span class="text-purple-400">await</span> agent.build(product);</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="py-16 sm:py-20">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="relative overflow-hidden shadow-xl sm:rounded-lg bg-gradient-to-br from-gray-900 to-rose-950/30 border border-gray-800">
          <div class="lg:grid lg:grid-cols-5 lg:gap-8 p-6 sm:p-10">
            <div class="lg:col-span-3">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-1 bg-[#e30f55] rounded"></div>
                <span class="text-[#e30f55] text-sm font-bold uppercase tracking-wider">Newsletter</span>
              </div>
              <h2 class="text-white text-3xl font-extrabold tracking-tight sm:text-4xl font-heading">
                Przeprogramowany<br>Newsletter
              </h2>
              <p class="mt-4 text-lg text-gray-300">
                Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1:
              </p>
              <ul class="mt-6 space-y-3">
                <li class="flex items-start gap-3">
                  <span class="text-[#1ff1af] font-bold">3</span>
                  <span class="text-gray-200">rekomendacje techniczne</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[#1ff1af] font-bold">2</span>
                  <span class="text-gray-200">rekomendacje rozwojowe</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[#1ff1af] font-bold">1</span>
                  <span class="text-gray-200">bonus niespodzianka</span>
                </li>
              </ul>
              <div class="mt-8">
                <a href="https://przeprogramowani.substack.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-3 text-base font-semibold bg-[#e30f55] text-white rounded-md shadow transition duration-150 ease-in-out hover:bg-red-500 hover:shadow-lg">
                  Zapisz się za darmo
                  <span>&rarr;</span>
                </a>
              </div>
            </div>
            <div class="lg:col-span-2 flex flex-col items-center justify-center mt-10 lg:mt-0">
              <div class="p-4 bg-gray-800/50 rounded-2xl shadow-lg border border-rose-950">
                <div class="w-48 h-48 bg-gray-700 rounded-xl flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/></svg>
                </div>
              </div>
              <p class="mt-4 text-sm text-gray-500 text-center tracking-wider uppercase">Zapisz się i dołącz</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Courses -->
    <section class="py-16 sm:py-20">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="mb-10 text-center">
          <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading">Edukacja technologiczna w epoce AI</h2>
          <p class="mt-2 text-lg text-gray-400">Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {courses.map(course => (
            <a href={course.href} target="_blank" rel="noopener noreferrer" class="group block overflow-hidden shadow-xl sm:rounded-lg bg-gradient-to-br border transition-all duration-200 hover:shadow-2xl hover:-translate-y-1 from-gray-900 to-gray-950 border-gray-800">
              <div class="h-48 overflow-hidden">
                <img src={course.image} alt={course.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <div class={`w-8 h-1 rounded ${course.bgClass}`}></div>
                  <span class={`text-xs font-bold uppercase tracking-wider ${course.textClass}`}>Kurs</span>
                </div>
                <h3 class="text-xl font-extrabold text-white sm:text-2xl font-heading">{course.title}</h3>
                <p class="mt-3 text-base text-gray-300">{course.description}</p>
                <div class="mt-6">
                  <span class={`inline-flex items-center gap-2 px-6 py-3 font-semibold text-white rounded-md shadow transition duration-150 ease-in-out hover:shadow-lg ${course.bgClass} ${course.hoverClass}`}>
                    Szczegóły
                    <span>&rarr;</span>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Videos -->
    <section class="py-16 sm:py-20">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="mb-10">
          <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading">Filmy i podcasty</h2>
          <p class="mt-2 text-lg text-gray-400">Rozwój nowoczesnego programisty</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {videos.map(video => (
            <a href={video.href} target="_blank" rel="noopener noreferrer" class="group block rounded-xl overflow-hidden border border-gray-800 hover:border-gray-700 transition-all">
              <div class="relative aspect-video">
                <img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/30">
                  <div class="w-12 h-12 rounded-full bg-red-600/90 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-white ml-0.5"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"/></svg>
                  </div>
                </div>
              </div>
              <div class="p-3">
                <h3 class="text-sm font-medium text-gray-200 line-clamp-2 group-hover:text-white transition-colors">{video.title}</h3>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/youtube" class="inline-flex items-center gap-2 px-6 py-3 font-semibold text-white rounded-lg border border-gray-700 hover:bg-gray-800 transition-colors">
            Zobacz więcej filmów
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Partners -->
    <section class="py-16 sm:py-20">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="mb-10 text-center">
          <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading">7 lat na rynku edukacji technologicznej</h2>
          <p class="mt-2 text-lg text-gray-400">Współpracujemy z najlepszymi</p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 max-w-[1100px] mx-auto">
          {partners.map(partner => (
            <div class="w-[160px] h-[80px] flex items-center justify-center rounded-lg border border-gray-800 bg-gray-900/50 px-4">
              <span class="text-sm font-semibold text-gray-400 text-center">{partner}</span>
            </div>
          ))}
        </div>
        <p class="mt-12 text-center text-sm text-gray-500">
          Chcesz nawiązać współpracę?
          <a href="mailto:kontakt@przeprogramowani.pl" class="text-main hover:text-orange-400 transition-colors ml-1">kontakt@przeprogramowani.pl</a>
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
