---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const founders = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder, Przeprogramowani',
    bio: 'Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).',
    linkedin: 'https://www.linkedin.com/in/psmyrdek/',
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder, Przeprogramowani',
    bio: 'Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca "Opanuj AI Podcast" — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.',
    linkedin: 'https://www.linkedin.com/in/mkczarkowski/',
  },
];

const stats = [
  { value: '7+', label: 'lat na rynku' },
  { value: '400+', label: 'absolwentów kursów' },
  { value: '7800+', label: 'słuchaczy podcastów' },
  { value: '50K+', label: 'subskrybentów YouTube' },
];
---

<Layout title="O nas — Przeprogramowani">
  <Header />
  <main id="main-content">
    <!-- Hero -->
    <section class="relative bg-gray-950 py-16 sm:py-24">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-900/10 to-transparent"></div>
      <div class="relative max-w-screen-xl mx-auto px-4 text-center">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight font-heading">
          O nas
        </h1>
        <p class="mt-4 text-xl text-gray-400 max-w-2xl mx-auto">
          Łączymy świat programowania, biznesu i rozwoju
        </p>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-16 sm:py-20">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading mb-6">Witaj na Przeprogramowanych!</h2>
          <p class="text-lg text-gray-300 leading-relaxed mb-6">
            Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
          </p>
          <p class="text-lg text-gray-300 leading-relaxed">
            Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
          </p>
          <div class="mt-8">
            <span class="inline-block text-main font-semibold text-lg">Zyskaj szersze spojrzenie na programowanie.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-16 sm:py-20 bg-gray-900/50">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {stats.map(stat => (
            <div class="text-center">
              <div class="text-4xl sm:text-5xl font-extrabold text-main font-heading">{stat.value}</div>
              <div class="mt-2 text-gray-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Founders -->
    <section class="py-16 sm:py-20">
      <div class="max-w-screen-xl mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="text-2xl sm:text-3xl font-bold text-white font-heading">Zespół</h2>
          <p class="mt-2 text-lg text-gray-400">Ludzie stojący za Przeprogramowanymi</p>
        </div>
        <div class="grid gap-8 lg:grid-cols-2 max-w-4xl mx-auto">
          {founders.map(founder => (
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 sm:p-8">
              <div class="w-20 h-20 rounded-full bg-gray-800 flex items-center justify-center mb-6">
                <span class="text-2xl font-bold text-main">{founder.name.charAt(0)}</span>
              </div>
              <h3 class="text-xl font-bold text-white font-heading">{founder.name}</h3>
              <p class="text-main text-sm font-medium mt-1">{founder.role}</p>
              <p class="mt-4 text-gray-300 leading-relaxed">{founder.bio}</p>
              <a href={founder.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-6 text-gray-400 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
