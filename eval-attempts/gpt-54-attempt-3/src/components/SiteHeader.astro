---
import { navigation, externalLinks } from '../data/site';

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
---

<header class="shell">
  <div class="panel-strong grid-overlay sticky top-4 z-50 mt-2 overflow-hidden px-4 py-4 sm:px-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="flex items-center justify-between gap-4">
        <a href="/" class="font-display text-lg font-bold tracking-tight text-white sm:text-xl">
          Przeprogramowani<span class="text-cyan-300">.pl</span>
        </a>
        <a
          href={externalLinks.tenXDevs}
          target="_blank"
          rel="noreferrer"
          class="hidden rounded-full border border-cyan-300/20 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-200 sm:inline-flex"
        >
          10xDevs 3.0
        </a>
      </div>
      <nav class="flex flex-wrap items-center gap-2 text-sm text-[var(--muted)]">
        {
          navigation.map((item) => {
            const isActive =
              item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);

            return (
              <a
                href={item.href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'rounded-full px-4 py-2 font-medium',
                  isActive
                    ? 'bg-white text-slate-950'
                    : 'border border-transparent hover:border-white/12 hover:bg-white/5 hover:text-white'
                ]}
              >
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </div>
  </div>
</header>
