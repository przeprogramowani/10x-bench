---
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder & Lead Engineer',
    bio: 'Full-stack developer z doświadczeniem w .NET/C#, Java, Node.js, Angular i TypeScript. Były Lead Engineer/Manager w DAZN i Cabify. W 2024 roku odszedł z pracy, by w pełni poświęcić się Przeprogramowani.',
    specialties: ['TypeScript', 'Node.js', 'Angular', 'Architecture', 'AI'],
    social: {
      linkedin: 'https://www.linkedin.com/in/psmyrdek',
      github: 'https://github.com/psmyrdek',
    },
    gradientFrom: 'from-violet-600',
    gradientTo: 'to-indigo-600',
    initials: 'PS',
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder & Lead Specialist',
    bio: 'Lead technical specialist w SmartRecruiters z ponad 10-letnim doświadczeniem w branży. Entuzjasta neurobiologii i host "Opanuj.AI Podcast". W 2024 porzucił etat dla Przeprogramowani.',
    specialties: ['Frontend', 'React', 'AI Tools', 'Neurobiology', 'Podcasting'],
    social: {
      linkedin: 'https://www.linkedin.com/in/mczarkowski',
    },
    gradientFrom: 'from-cyan-600',
    gradientTo: 'to-blue-600',
    initials: 'MC',
  },
];

const stats = [
  { value: '3 700+', label: 'Absolwentów kursów', icon: '🎓' },
  { value: '98', label: 'Odcinków podcastu', icon: '🎙️' },
  { value: '2017', label: 'Rok założenia', icon: '📅' },
  { value: '4', label: 'Autorskie kursy', icon: '📚' },
  { value: '2 500+', label: 'Subskrybentów newslettera', icon: '✉️' },
  { value: '$400K+', label: 'Przychód z 10xDevs', icon: '💰' },
];

const values = [
  {
    title: 'Szersze spojrzenie',
    description:
      'Nie tylko "jak" ale i "dlaczego". Uczymy myślenia o programowaniu jako zawodzie, nie tylko technicznej umiejętności.',
    icon: '🔭',
  },
  {
    title: 'Praktyczna wiedza',
    description:
      'Każdy kurs, odcinek podcastu i artykuł jest zakorzeniony w realnych projektach i doświadczeniach z produkcji.',
    icon: '⚙️',
  },
  {
    title: 'Społeczność',
    description:
      'Budujemy społeczność programistów, którzy chcą się rozwijać i dzielić wiedzą. 3 700+ absolwentów w jednym miejscu.',
    icon: '🤝',
  },
  {
    title: 'Ciągłość i aktualność',
    description:
      'Świat technologii zmienia się szybko. Nasze treści są regularnie aktualizowane i uwzględniają najnowsze trendy, w tym AI.',
    icon: '🔄',
  },
];

const partners = [
  'Huuuge Games',
  'SmartRecruiters',
  'Future Processing',
  'Autodesk',
];

const milestones = [
  { year: '2017', event: 'Założenie Przeprogramowani.pl' },
  { year: '2019', event: 'Start podcastu "Przeprogramowani"' },
  { year: '2021', event: 'Premiera kursu Opanuj TypeScript' },
  { year: '2022', event: 'Start kursu Opanuj Frontend' },
  { year: '2023', event: 'Premiera 10xDevs — AI-first development' },
  { year: '2024', event: 'Pełny etat dla Przeprogramowani, 3 700+ absolwentów' },
  { year: '2026', event: '10xDevs 3.0 — nowy nabór i rozszerzony program' },
];
---

<BaseLayout
  title="O nas"
  description="Poznaj Przeprogramowani.pl — projekt Przemka Smyrdka i Marcina Czarkowskiego. Szersze spojrzenie na programowanie od 2017 roku."
>
  <!-- Hero -->
  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <div class="absolute inset-0 grid-bg"></div>
    <div
      class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-violet-900/10 rounded-full blur-[100px] pointer-events-none"
    ></div>

    <div class="relative max-w-4xl mx-auto text-center">
      <div class="badge mb-6 mx-auto w-fit">O nas</div>
      <h1 class="text-5xl sm:text-6xl font-black leading-tight mb-6">
        <span class="text-white">Przeprogramowani</span><br />
        <span class="gradient-text">od 2017 roku</span>
      </h1>
      <p class="text-slate-400 text-lg leading-relaxed max-w-2xl mx-auto">
        Jesteśmy polską platformą edukacyjną dla programistów, którzy chcą więcej niż tylko pisać
        kod. Prowadzimy kursy, podcast i dostarczamy materiały pomagające w szerokim spojrzeniu na
        karierę w technologii.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {
          stats.map((s) => (
            <div class="card-glass rounded-2xl p-5 text-center">
              <div class="text-2xl mb-2">{s.icon}</div>
              <div class="text-2xl font-black text-white mb-1">{s.value}</div>
              <div class="text-xs text-slate-500 leading-tight">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="badge mb-5">Nasza misja</div>
          <h2 class="section-title mb-6">
            Szersze spojrzenie<br />
            <span class="gradient-text">na programowanie</span>
          </h2>
          <div class="space-y-4 text-slate-400 leading-relaxed">
            <p>
              "Przeprogramowani" to po angielsku "Reprogrammed" — i to jest właśnie nasza misja. Nie
              tylko uczymy programowania, ale pomagamy przeprogramować podejście do zawodu, kariery i
              ciągłego rozwoju.
            </p>
            <p>
              W 2024 roku Przemek i Marcin odeszli z pełnoetatowych stanowisk, by w pełni poświęcić
              się rozwijaniu platformy. Napędza nas przekonanie, że era AI wymaga od programistów
              zupełnie nowych umiejętności.
            </p>
            <p>
              Dzisiaj Przeprogramowani to <strong class="text-white">3 700+ absolwentów</strong>,{' '}
              <strong class="text-white">98 odcinków podcastu</strong> i społeczność najbardziej
              ambitnych polskich programistów.
            </p>
          </div>
        </div>

        <!-- Values grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            values.map((v) => (
              <div class="card-glass rounded-2xl p-6">
                <div class="text-2xl mb-3">{v.icon}</div>
                <h3 class="text-white font-bold mb-2">{v.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed">{v.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-transparent via-violet-950/5 to-transparent">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-14">
        <div class="badge mb-5">Zespół</div>
        <h2 class="section-title mb-4">
          Ludzie za <span class="gradient-text">Przeprogramowani</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {
          team.map((member) => (
            <div class="rounded-3xl border border-white/[0.08] bg-[#0d0d1a] p-8 flex flex-col">
              <!-- Avatar -->
              <div
                class={`w-16 h-16 rounded-2xl bg-gradient-to-br ${member.gradientFrom} ${member.gradientTo} flex items-center justify-center text-white font-black text-xl mb-6 shadow-lg`}
              >
                {member.initials}
              </div>

              <h3 class="text-xl font-bold text-white mb-1">{member.name}</h3>
              <p class="text-violet-400 text-sm font-semibold mb-4">{member.role}</p>
              <p class="text-slate-400 text-sm leading-relaxed mb-6">{member.bio}</p>

              <!-- Specialties -->
              <div class="flex flex-wrap gap-2 mb-6">
                {member.specialties.map((s) => (
                  <span class="px-2.5 py-1 rounded-lg bg-white/[0.05] border border-white/[0.07] text-xs text-slate-300 font-medium">
                    {s}
                  </span>
                ))}
              </div>

              <!-- Social links -->
              <div class="flex items-center gap-3 mt-auto">
                {member.social.linkedin && (
                  <a
                    href={member.social.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-[#0A66C2]/10 border border-[#0A66C2]/25 text-[#0A66C2] text-xs font-medium hover:bg-[#0A66C2]/20 transition-colors"
                  >
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    LinkedIn
                  </a>
                )}
                {member.social.github && (
                  <a
                    href={member.social.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-white/[0.05] border border-white/[0.10] text-slate-300 text-xs font-medium hover:bg-white/[0.10] transition-colors"
                  >
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                    GitHub
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14">
        <div class="badge mb-5">Historia</div>
        <h2 class="section-title mb-4">
          Nasza <span class="gradient-text">droga</span>
        </h2>
      </div>

      <div class="relative">
        <!-- Vertical line -->
        <div
          class="absolute left-16 sm:left-24 top-0 bottom-0 w-px bg-gradient-to-b from-violet-600 via-violet-600/50 to-transparent"
        ></div>

        <div class="space-y-6">
          {
            milestones.map((m, i) => (
              <div class="flex items-start gap-6 sm:gap-10">
                <!-- Year -->
                <div class="flex-shrink-0 w-14 sm:w-20 text-right">
                  <span class="text-sm font-bold text-violet-400">{m.year}</span>
                </div>

                <!-- Dot -->
                <div class="flex-shrink-0 relative z-10 mt-1">
                  <div class={`w-3 h-3 rounded-full border-2 ${i === milestones.length - 1 ? 'border-violet-400 bg-violet-400' : 'border-violet-500/50 bg-violet-900'}`} />
                </div>

                <!-- Content -->
                <div class="flex-1 pb-2">
                  <p class={`text-sm leading-relaxed ${i === milestones.length - 1 ? 'text-white font-semibold' : 'text-slate-400'}`}>
                    {m.event}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <p class="text-center text-slate-500 text-sm mb-8 uppercase tracking-widest font-medium">
        Zaufali nam między innymi
      </p>
      <div class="flex flex-wrap justify-center items-center gap-8">
        {
          partners.map((p) => (
            <span class="text-slate-400 font-semibold text-sm hover:text-slate-200 transition-colors cursor-default">
              {p}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-title mb-4">
        Gotowy by dołączyć?<br />
        <span class="gradient-text">Zacznij z 10xDevs</span>
      </h2>
      <p class="text-slate-400 text-base mb-8 leading-relaxed">
        Następny nabór startuje <strong class="text-white">18 maja 2026</strong>. Dołącz do 3 700+
        programistów, którzy już zmienili sposób pracy.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://10xdevs.pl"
          target="_blank"
          rel="noopener noreferrer"
          class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-violet-600 to-indigo-600 rounded-2xl font-bold text-white text-base hover:opacity-90 transition-all shadow-xl shadow-violet-900/30"
        >
          Sprawdź 10xDevs 3.0 →
        </a>
        <a
          href="/podcast"
          class="w-full sm:w-auto px-8 py-4 bg-white/[0.06] border border-white/[0.10] rounded-2xl font-bold text-white text-base hover:bg-white/[0.10] transition-all"
        >
          Posłuchaj podcastu
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
