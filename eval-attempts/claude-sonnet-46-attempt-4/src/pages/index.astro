---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseCard from '../components/CourseCard.tsx';
import PodcastCard from '../components/PodcastCard.tsx';
import VideoCard from '../components/VideoCard.tsx';

const courses = [
  {
    title: '10xDevs 3.0',
    tagline: '5-tygodniowy kurs AI-first development',
    description:
      'Naucz się integrować AI w profesjonalny workflow programistyczny. Od agentów przez context engineering po AI-first MVP — ten kurs zmieni sposób w jaki programujesz.',
    href: 'https://10xdevs.pl',
    badge: 'Nabór: 18 maja 2026',
    stats: [
      { value: '3 700+', label: 'Absolwentów' },
      { value: '5 tygodni', label: 'Programu' },
      { value: '40+ godz.', label: 'Materiałów wideo' },
      { value: '1 743 PLN', label: 'Early bird' },
    ],
    features: [
      '10xWorkflow — współpraca z agentami AI',
      'Context Engineering i MCP ecosystem',
      'One-Week AI-First MVP od designu do produkcji',
      'TDG (Test-Driven Generation) i AI debugging',
      'Mentoring i projekt końcowy',
    ],
    featured: true,
    accentFrom: 'from-violet-500',
    accentTo: 'to-indigo-600',
    emoji: '🚀',
  },
  {
    title: 'Opanuj Frontend',
    tagline: 'AI Edition — 10-tygodniowe szkolenie',
    description:
      'Intensywne szkolenie przygotowujące do tworzenia zaawansowanych aplikacji webowych z najnowszymi technologiami i najlepszymi praktykami.',
    href: 'https://opanujfrontend.pl',
    stats: [
      { value: '400+', label: 'Absolwentów' },
      { value: '10 tygodni', label: 'Szkolenia' },
      { value: '25 lekcji', label: 'Wideo' },
      { value: '5 modułów', label: 'Tematycznych' },
    ],
    features: [
      'Patterns & Best Practices w React/Angular',
      'Quality Engineering — testy i a11y',
      'Deployments & CI/CD z GitHub Actions, AWS',
      'Architektura aplikacji frontend',
      'Certyfikat ukończenia',
    ],
    featured: false,
    accentFrom: 'from-cyan-500',
    accentTo: 'to-blue-600',
    emoji: '⚡',
  },
  {
    title: 'Opanuj TypeScript',
    tagline: 'TypeScript 5 + React 19 w praktyce',
    description:
      'Buduj niezawodne aplikacje z TypeScript 5 i React 19. 40+ ćwiczeń z 10+ lat doświadczenia w produkcyjnym kodzie frontendowym.',
    href: 'https://opanujtypescript.pl',
    stats: [
      { value: '40+', label: 'Ćwiczeń' },
      { value: '2 moduły', label: 'Core + React' },
      { value: 'TS 5.7+', label: 'Najnowszy' },
      { value: 'React 19', label: 'Wsparcie' },
    ],
    features: [
      'Generic types, mapped i conditional types',
      'React 19 component typing i hooks',
      'Zod, tRPC, SWR i React Query',
      'Bonus: AI Edition — AI-assisted TS workflow',
      'Dostęp dożywotni',
    ],
    featured: false,
    accentFrom: 'from-amber-500',
    accentTo: 'to-orange-600',
    emoji: '🔷',
  },
];

const latestEpisodes = [
  {
    number: 98,
    title: 'Programista vs. Angielski: Od strachu do sukcesu',
    guest: 'Wiktoria Sitko',
    date: '25 wrz 2025',
    description:
      'Rozmowa o tym, jak przezwyciężyć barierę językową i dlaczego angielski jest kluczowy w karierze programisty.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
    applePodcastsUrl: 'https://podcasts.apple.com/pl/podcast/przeprogramowani/id1471770526',
  },
  {
    number: 97,
    title: 'O dojrzewaniu zawodowym programisty',
    guest: 'Wojciech Trawiński',
    date: '10 wrz 2025',
    description:
      'Czym jest dojrzałość zawodowa w świecie programowania i jak ją rozwijać na każdym etapie kariery.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
    applePodcastsUrl: 'https://podcasts.apple.com/pl/podcast/przeprogramowani/id1471770526',
  },
  {
    number: 96,
    title: 'Architektura frontendu: Co naprawdę ma znaczenie?',
    guest: 'Tomasz Ducin',
    date: '10 paź 2024',
    description:
      'Ekspercka rozmowa o decyzjach architektonicznych w dużych aplikacjach frontendowych.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
    applePodcastsUrl: 'https://podcasts.apple.com/pl/podcast/przeprogramowani/id1471770526',
  },
];

const latestVideos = [
  {
    title: '10xDevs 3.0 — Jak wygląda kurs? Pełne omówienie programu',
    views: '18K',
    date: '2 tyg. temu',
    duration: '24:17',
    href: 'https://www.youtube.com/c/przeprogramowani',
    gradientFrom: 'from-violet-700',
    gradientTo: 'to-indigo-800',
    category: 'Kurs',
  },
  {
    title: 'Claude vs GPT-4o — Który model AI lepiej pisze kod? Porównanie',
    views: '32K',
    date: '1 mies. temu',
    duration: '31:42',
    href: 'https://www.youtube.com/c/przeprogramowani',
    gradientFrom: 'from-cyan-700',
    gradientTo: 'to-blue-800',
    category: 'AI Tools',
  },
  {
    title: 'TypeScript 5.7 — Co nowego? Przegląd najważniejszych zmian',
    views: '24K',
    date: '2 mies. temu',
    duration: '19:55',
    href: 'https://www.youtube.com/c/przeprogramowani',
    gradientFrom: 'from-amber-600',
    gradientTo: 'to-orange-700',
    category: 'TypeScript',
  },
];

const stats = [
  { value: '3 700+', label: 'Absolwentów kursów' },
  { value: '98', label: 'Odcinków podcastu' },
  { value: '8 lat', label: 'Tworzenia treści' },
  { value: '4', label: 'Autorskie kursy' },
];
---

<BaseLayout
  title="Przeprogramowani.pl — Szersze spojrzenie na programowanie"
  description="Kursy, podcast i materiały dla ambitnych programistów. Opanuj Frontend, TypeScript i AI-first development z 10xDevs."
>
  <!-- ======================================================
       HERO
  ======================================================= -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 grid-bg"></div>

    <!-- Gradient orbs -->
    <div
      class="absolute top-1/4 -left-24 w-96 h-96 bg-violet-600/20 rounded-full blur-[120px] pointer-events-none"
    ></div>
    <div
      class="absolute bottom-1/4 -right-24 w-96 h-96 bg-indigo-600/15 rounded-full blur-[120px] pointer-events-none"
    ></div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-violet-900/10 rounded-full blur-[80px] pointer-events-none"
    ></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Announcement badge -->
        <div class="flex justify-center mb-8">
          <a
            href="https://10xdevs.pl"
            target="_blank"
            rel="noopener noreferrer"
            class="badge hover:border-violet-400/60 transition-colors group"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-violet-400 animate-pulse"></span>
            10xDevs 3.0 — Nabór otwarty · Start 18 maja 2026
            <svg
              class="w-3 h-3 group-hover:translate-x-0.5 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              ></path>
            </svg>
          </a>
        </div>

        <!-- Main heading -->
        <h1
          class="text-5xl sm:text-6xl lg:text-7xl font-black leading-[1.08] tracking-tight mb-6"
        >
          <span class="text-white">Szersze spojrzenie</span>
          <br />
          <span class="gradient-text">na programowanie</span>
        </h1>

        <!-- Subtitle -->
        <p class="text-slate-400 text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto mb-10">
          Kursy, podcast i materiały dla ambitnych programistów. Od 2017 roku pomagamy
          programistom rozwijać się szybciej i myśleć szerzej.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
          <a
            href="https://10xdevs.pl"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-violet-600 to-indigo-600 rounded-2xl font-bold text-white text-base hover:opacity-90 transition-all shadow-2xl shadow-violet-900/40 hover:shadow-violet-900/60 hover:translate-y-[-1px]"
          >
            🚀 Dołącz do 10xDevs 3.0
          </a>
          <a
            href="/o-nas"
            class="w-full sm:w-auto px-8 py-4 bg-white/[0.06] border border-white/[0.10] rounded-2xl font-bold text-white text-base hover:bg-white/[0.10] transition-all"
          >
            Poznaj nas →
          </a>
        </div>

        <!-- Stats row -->
        <div
          class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl mx-auto"
        >
          {
            stats.map((s) => (
              <div class="bg-white/[0.03] border border-white/[0.06] rounded-2xl p-4 text-center">
                <div class="text-2xl font-black text-white mb-1">{s.value}</div>
                <div class="text-xs text-slate-500 leading-tight">{s.label}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================
       COURSES
  ======================================================= -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-14">
        <div class="badge mb-5">Nasze kursy</div>
        <h2 class="section-title mb-4">
          Naucz się więcej,<br />
          <span class="gradient-text">szybciej i skuteczniej</span>
        </h2>
        <p class="text-slate-400 text-base max-w-xl mx-auto leading-relaxed">
          Trzy autorskie kursy zaprojektowane z myślą o programistach, którzy chcą wyjść ponad
          przeciętność.
        </p>
      </div>

      <!-- Courses grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          courses.map((course) => (
            <CourseCard client:load {...course} />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ======================================================
       LATEST PODCAST
  ======================================================= -->
  <section class="py-24 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-transparent via-violet-950/5 to-transparent">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Left: Header -->
        <div>
          <div class="badge mb-5">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
              />
            </svg>
            Podcast
          </div>
          <h2 class="section-title mb-4">
            Posłuchaj<br />
            <span class="gradient-text">Przeprogramowani</span>
          </h2>
          <p class="text-slate-400 leading-relaxed mb-8 text-base">
            Ponad <strong class="text-white">98 odcinków</strong> z najlepszymi specjalistami ze
            świata technologii. Oceniony przez słuchaczy na <strong class="text-white">4.88/5</strong>.
          </p>

          <!-- Platform links -->
          <div class="flex flex-wrap gap-3 mb-8">
            <a
              href="https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-[#1DB954]/10 border border-[#1DB954]/25 text-[#1DB954] text-sm font-semibold hover:bg-[#1DB954]/20 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"
                ></path>
              </svg>
              Spotify
            </a>
            <a
              href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1471770526"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-purple-500/10 border border-purple-500/25 text-purple-400 text-sm font-semibold hover:bg-purple-500/20 transition-colors"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M5.34 0A5.328 5.328 0 0 0 0 5.34v13.32A5.328 5.328 0 0 0 5.34 24h13.32A5.328 5.328 0 0 0 24 18.66V5.34A5.328 5.328 0 0 0 18.66 0zm6.525 2.568c2.336 0 4.448.902 6.056 2.587 1.608 1.685 2.467 3.775 2.467 6.22 0 4.644-3.29 9.487-6.87 9.487-1.044 0-2.023-.419-2.737-1.18-.688-.733-1.036-1.688-1.036-2.779 0-.484.064-.972.19-1.45.128-.487.31-.966.54-1.42l.165-.33.165-.33c.117-.262.256-.53.413-.807l.413-.805a12.35 12.35 0 0 0 .408-.905c.052-.14.105-.278.155-.42.15-.43.29-.953.38-1.446.092-.496.138-.978.138-1.447 0-1.18-.287-2.077-.86-2.739-.596-.677-1.443-1.02-2.55-1.02-.74 0-1.396.2-1.982.606-.587.407-1.027.94-1.335 1.618-.31.677-.468 1.408-.468 2.215 0 .72.134 1.36.41 1.895.273.537.63.96 1.086 1.285.237.167.463.282.672.346a.48.48 0 0 1 .315.457.48.48 0 0 1-.47.483c-.15 0-.348-.047-.594-.14a4.573 4.573 0 0 1-1.03-.574 4.78 4.78 0 0 1-.88-.91c-.5-.696-.777-1.565-.777-2.64 0-1.036.218-2.006.655-2.887.44-.88 1.076-1.593 1.914-2.1a5.11 5.11 0 0 1 2.724-.772zm.06 1.098c-1.018 0-1.9.298-2.69.895-.79.597-1.382 1.397-1.784 2.365-.402.968-.6 2.036-.6 3.218 0 1.18.285 2.247.852 3.175.564.926 1.36 1.68 2.403 2.26a.35.35 0 0 1-.07.65 7.25 7.25 0 0 1-.948-.358 6.68 6.68 0 0 1-1.48-.924 5.876 5.876 0 0 1-1.11-1.362 5.68 5.68 0 0 1-.62-1.637 8.66 8.66 0 0 1-.147-1.67c0-1.47.298-2.83.9-4.082.6-1.25 1.45-2.24 2.55-2.976a6.2 6.2 0 0 1 3.49-1.03c1.284 0 2.407.357 3.376 1.064.97.71 1.713 1.665 2.222 2.872.51 1.208.762 2.56.762 4.056 0 1.72-.377 3.428-1.127 5.1-.75 1.673-1.76 3.108-3.03 4.31-1.27 1.2-2.65 1.8-4.134 1.8-.98 0-1.852-.33-2.61-.993-.76-.665-1.143-1.558-1.143-2.694 0-1.294.445-2.402 1.33-3.306.887-.905 2.04-1.356 3.476-1.356.89 0 1.67.237 2.34.716.67.48 1.004 1.09 1.004 1.848 0 .88-.32 1.617-.964 2.215-.643.597-1.42.895-2.34.895-.672 0-1.203-.154-1.607-.458-.403-.305-.6-.698-.6-1.198 0-.477.163-.87.49-1.19.326-.32.76-.48 1.295-.48.397 0 .74.1 1.024.3.285.2.427.447.427.735 0 .352-.143.643-.43.877a1.56 1.56 0 0 1-1.053.354c-.323 0-.61-.06-.857-.174a1.1 1.1 0 0 1-.55-.526 1.13 1.13 0 0 1-.088-.42c0-.303.12-.565.353-.797.236-.23.555-.344.966-.344.3 0 .562.08.783.237.22.16.33.355.33.587 0 .27-.1.48-.302.636a1.098 1.098 0 0 1-.69.235z"
                ></path>
              </svg>
              Apple Podcasts
            </a>
          </div>

          <a href="/podcast" class="text-violet-400 hover:text-violet-300 text-sm font-semibold transition-colors inline-flex items-center gap-1.5">
            Wszystkie odcinki →
          </a>
        </div>

        <!-- Right: Latest episodes -->
        <div class="space-y-3">
          {
            latestEpisodes.map((ep) => (
              <PodcastCard client:load {...ep} compact={false} />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================
       YOUTUBE
  ======================================================= -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-12">
        <div>
          <div class="badge mb-4">
            <svg class="w-3 h-3 text-red-400" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              />
            </svg>
            <span class="text-red-400">YouTube</span>
          </div>
          <h2 class="section-title mb-3">
            Najnowsze na<br />
            <span class="gradient-text">kanale YouTube</span>
          </h2>
          <p class="text-slate-400 text-sm">
            Tutoriale, rozmowy z gośćmi i przeglądy narzędzi AI
          </p>
        </div>
        <a
          href="https://www.youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 flex items-center gap-2 px-5 py-2.5 rounded-xl bg-red-600/10 border border-red-500/25 text-red-400 text-sm font-semibold hover:bg-red-600/20 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            />
          </svg>
          Subskrybuj kanał
        </a>
      </div>

      <!-- Videos grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestVideos.map((v) => <VideoCard client:load {...v} />)}
      </div>

      <div class="text-center mt-8">
        <a href="/youtube" class="text-violet-400 hover:text-violet-300 text-sm font-semibold transition-colors inline-flex items-center gap-1.5">
          Więcej filmów →
        </a>
      </div>
    </div>
  </section>

  <!-- ======================================================
       NEWSLETTER CTA
  ======================================================= -->
  <section class="py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto">
      <div
        class="relative rounded-3xl overflow-hidden border border-violet-500/25 bg-gradient-to-br from-violet-950/50 via-[#0d0d1a] to-indigo-950/30 p-10 sm:p-14 text-center"
      >
        <!-- Decorative glows -->
        <div
          class="absolute -top-20 -left-20 w-60 h-60 bg-violet-600/15 rounded-full blur-[80px] pointer-events-none"
        ></div>
        <div
          class="absolute -bottom-20 -right-20 w-60 h-60 bg-indigo-600/15 rounded-full blur-[80px] pointer-events-none"
        ></div>

        <div class="relative">
