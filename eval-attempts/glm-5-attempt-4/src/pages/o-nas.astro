---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const team = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder, Przeprogramowani',
    image: '/img/przemek.webp',
    bio: 'Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).',
    linkedin: 'https://www.linkedin.com/in/psmyrdek/'
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder, Przeprogramowani',
    image: '/img/marcin.webp',
    bio: 'Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca "Opanuj AI Podcast" — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.',
    linkedin: 'https://www.linkedin.com/in/mkczarkowski/'
  }
];

const brands = [
  'Huuuge Games',
  'Nutridome',
  'SmartRecruiters',
  'Future Processing',
  'Callstack',
  'edrone',
  'Xfive',
  'Euvic',
  'Strabag',
  'Autodesk'
];
---

<Layout title="O nas" description="Poznaj zespół Przeprogramowani - Przemka Smyrdeka i Marcina Czarkowskiego">
  <Navigation />
  
  <main class="pt-16">
    <section class="py-20 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">O nas</h1>
          <p class="text-xl text-slate-400 max-w-2xl mx-auto">
            Łączymy świat programowania, biznesu i rozwoju
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
          {team.map(member => (
            <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-8">
              <div class="flex flex-col sm:flex-row gap-6">
                <div class="w-32 h-32 bg-gradient-to-br from-indigo-600 to-purple-700 rounded-xl flex-shrink-0 overflow-hidden">
                  <img 
                    src={member.image} 
                    alt={member.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <div class="flex-1">
                  <h2 class="text-2xl font-bold text-white mb-1">{member.name}</h2>
                  <p class="text-indigo-400 font-medium mb-4">{member.role}</p>
                  <p class="text-slate-400 text-sm leading-relaxed mb-4">
                    {member.bio}
                  </p>
                  <a 
                    href={member.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-slate-300 hover:text-white transition-colors text-sm"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    LinkedIn
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="bg-slate-900/30 border border-slate-800 rounded-2xl p-8 md:p-12 mb-20">
          <h2 class="text-2xl font-bold text-white mb-4 text-center">Witaj na Przeprogramowanych!</h2>
          <p class="text-slate-300 max-w-3xl mx-auto text-center leading-relaxed">
            Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. 
            Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, 
            na biznes, na ludzi i na siebie.
          </p>
          <p class="text-slate-400 max-w-3xl mx-auto text-center leading-relaxed mt-4">
            Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się 
            na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
          </p>
          <p class="text-indigo-400 font-semibold text-center mt-6">
            Zyskaj szersze spojrzenie na programowanie.
          </p>
        </div>

        <div class="text-center mb-12">
          <h2 class="text-2xl font-bold text-white mb-4">
            7 lat na rynku edukacji technologicznej
          </h2>
          <p class="text-slate-400 mb-8">Współpracujemy z najlepszymi</p>
        </div>
        
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
          {brands.map(brand => (
            <div class="bg-slate-800/50 rounded-xl p-4 flex items-center justify-center">
              <span class="text-slate-400 font-medium text-center text-sm">{brand}</span>
            </div>
          ))}
        </div>
        
        <div class="text-center mt-12">
          <p class="text-slate-400 mb-2">Chcesz nawiązać współpracę?</p>
          <a 
            href="mailto:kontakt@przeprogramowani.pl"
            class="text-indigo-400 hover:text-indigo-300 font-medium"
          >
            kontakt@przeprogramowani.pl
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
