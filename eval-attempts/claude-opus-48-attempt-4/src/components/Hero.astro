---
import { stats } from '../data/site';
---

<section class="relative overflow-hidden">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-grid opacity-60" aria-hidden="true"></div>
  <div
    class="absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-brand-600/20 blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute right-0 top-1/3 h-64 w-64 rounded-full bg-violet-600/20 blur-[100px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-ink-950 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="container-page relative pb-16 pt-20 sm:pb-20 sm:pt-28">
    <div class="mx-auto max-w-3xl text-center">
      <a
        href="https://www.10xdevs.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="animate-fade-up inline-flex items-center gap-2 rounded-full border border-brand-400/30 bg-brand-500/10 py-1.5 pl-2 pr-4 text-sm font-medium text-brand-200 transition hover:border-brand-400/50 hover:bg-brand-500/20"
      >
        <span
          class="rounded-full bg-brand-500 px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide text-white"
          >Nowość</span
        >
        <span>10xDevs 4.0 — start 14 września 2026</span>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      <h1
        class="animate-fade-up mt-8 text-4xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-6xl"
        style="animation-delay: 60ms"
      >
        Szersze spojrzenie na <span class="gradient-text">programowanie</span>
      </h1>

      <p
        class="animate-fade-up mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl"
        style="animation-delay: 120ms"
      >
        Edukacja technologiczna dla ambitnych programistów w erze AI. Łączymy świat
        programowania, biznesu i rozwoju — w podcaście, na YouTube i w naszych kursach.
      </p>

      <div
        class="animate-fade-up mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row"
        style="animation-delay: 180ms"
      >
        <a href="https://www.10xdevs.pl" target="_blank" rel="noopener noreferrer" class="btn-primary w-full sm:w-auto">
          Dołącz do 10xDevs 4.0
        </a>
        <a href="#kursy" class="btn-secondary w-full sm:w-auto">Zobacz wszystkie kursy</a>
      </div>
    </div>

    <!-- Stats -->
    <dl
      class="animate-fade-up mx-auto mt-16 grid max-w-4xl grid-cols-2 gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/10 sm:grid-cols-4"
      style="animation-delay: 240ms"
    >
      {
        stats.map((stat) => (
          <div class="flex flex-col items-center bg-ink-900/80 px-4 py-6 text-center backdrop-blur">
            <dt class="order-2 mt-1 text-xs font-medium text-slate-400">{stat.label}</dt>
            <dd class="order-1 text-2xl font-extrabold text-white sm:text-3xl">{stat.value}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
