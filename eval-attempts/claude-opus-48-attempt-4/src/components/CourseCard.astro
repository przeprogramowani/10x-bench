---
import type { Course } from '../data/site';

interface Props {
  course: Course;
}

const { course } = Astro.props;

const accents = {
  violet: {
    glow: 'from-violet-500/20',
    ring: 'group-hover:border-violet-400/40',
    badge: 'bg-violet-500/15 text-violet-300 border-violet-400/30',
    bar: 'from-violet-400 to-brand-500',
    check: 'text-violet-400',
  },
  sky: {
    glow: 'from-sky-500/20',
    ring: 'group-hover:border-sky-400/40',
    badge: 'bg-sky-500/15 text-sky-300 border-sky-400/30',
    bar: 'from-sky-400 to-cyan-500',
    check: 'text-sky-400',
  },
  amber: {
    glow: 'from-amber-500/20',
    ring: 'group-hover:border-amber-400/40',
    badge: 'bg-amber-500/15 text-amber-300 border-amber-400/30',
    bar: 'from-amber-400 to-orange-500',
    check: 'text-amber-400',
  },
}[course.accent];
---

<article
  class:list={[
    'group relative flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] p-7 transition-all duration-300 hover:-translate-y-1',
    accents.ring,
    course.featured && 'lg:row-span-2 ring-1 ring-brand-400/20',
  ]}
>
  <div
    class:list={[
      'pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-gradient-to-br to-transparent blur-2xl transition-opacity duration-300 opacity-60 group-hover:opacity-100',
      accents.glow,
    ]}
  >
  </div>

  <div class="relative flex items-start justify-between gap-3">
    <div class={`h-1.5 w-12 rounded-full bg-gradient-to-r ${accents.bar}`}></div>
    {
      course.tag && (
        <span class={`rounded-full border px-3 py-1 text-xs font-semibold ${accents.badge}`}>
          {course.tag}
        </span>
      )
    }
  </div>

  <h3 class="relative mt-5 text-xl font-bold text-white">{course.name}</h3>
  <p class="relative mt-1 text-sm font-medium text-slate-300">{course.headline}</p>
  <p class="relative mt-4 text-sm leading-relaxed text-slate-400">{course.description}</p>

  <ul class="relative mt-6 space-y-2.5">
    {
      course.highlights.map((item) => (
        <li class="flex items-start gap-2.5 text-sm text-slate-300">
          <svg
            class={`mt-0.5 h-4 w-4 flex-shrink-0 ${accents.check}`}
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          <span>{item}</span>
        </li>
      ))
    }
  </ul>

  <div class="relative mt-6 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-slate-500">
    <span class="font-mono">{course.duration}</span>
  </div>

  <div class="relative mt-auto flex items-center justify-between gap-4 pt-6">
    <span class="text-xs font-semibold text-slate-400">{course.stats}</span>
    <a
      href={course.href}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-sm font-semibold text-white transition group-hover:gap-2.5"
    >
      Zobacz kurs
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</article>
