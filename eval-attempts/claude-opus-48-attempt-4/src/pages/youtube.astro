---
import BaseLayout from '../layouts/BaseLayout.astro';
import YouTubeGallery from '../components/YouTubeGallery.tsx';
import Newsletter from '../components/Newsletter.astro';
import { videos, social } from '../data/site';
---

<BaseLayout
  title="YouTube"
  description="Kanał YouTube Przeprogramowani — praktyczne filmy o agentach AI, technikach programowania i pracy nowoczesnego developera."
  path="/youtube"
>
  <section class="relative overflow-hidden border-b border-white/10">
    <div
      class="absolute -top-32 left-1/4 h-96 w-[600px] rounded-full bg-red-600/10 blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="container-page relative py-20 sm:py-24">
      <div class="max-w-3xl">
        <span class="eyebrow">YouTube</span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Programowanie z AI <span class="gradient-text">w praktyce</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-300">
          Kanał dla programistów skupionych na własnym rozwoju. Nowości ze świata IT, techniki
          efektywnej pracy i nauki oraz praktyczne materiały o agentach AI, Cursorze, MCP i
          nowoczesnym warsztacie developera.
        </p>
        <div class="mt-8">
          <a href={social.youtube} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4l6.2 3.6z"
              ></path>
            </svg>
            Subskrybuj kanał
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-page">
      <div class="mb-10 flex items-baseline justify-between">
        <h2 class="text-2xl font-bold text-white">Ostatnie filmy</h2>
        <span class="text-sm text-slate-500">Kliknij, aby odtworzyć</span>
      </div>
      <YouTubeGallery client:load videos={videos} />
    </div>
  </section>

  <Newsletter />
</BaseLayout>
