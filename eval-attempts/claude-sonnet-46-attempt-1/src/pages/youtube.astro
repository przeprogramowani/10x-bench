---
import Layout from '../layouts/Layout.astro';
import VideoCard from '../components/VideoCard';
import { videos } from '../data/videos';

const topics = [
  { label: 'AI & Narzędzia', color: '#22d3ee' },
  { label: 'TypeScript', color: '#3b82f6' },
  { label: 'React', color: '#a78bfa' },
  { label: 'Kariera', color: '#f472b6' },
  { label: 'Live Coding', color: '#34d399' },
  { label: 'Architektura', color: '#fb923c' },
];
---

<Layout
  title="YouTube — Przeprogramowani.pl"
  description="Filmy na YouTube — tutoriale, live coding i przeglądy nowości dla programistów"
>
  <!-- Header -->
  <section
    class="py-20 md:py-28"
    style="background: radial-gradient(ellipse at top, #0e7490 0%, #0f0f0f 60%);"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Filmy na <span
          style="background: linear-gradient(to right, #22d3ee, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
        >YouTube</span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-8">
        Tutoriale, przeglądy nowości i sesje live coding. Praktyczna wiedza w przystępnej formie.
      </p>

      <!-- Subscribe button -->
      <a
        href="https://youtube.com/@przeprogramowani"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-6 py-3 rounded-xl font-semibold text-white transition-all hover:scale-105"
        style="background-color: #ff0000;"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Subskrybuj kanał
      </a>
    </div>
  </section>

  <!-- Topic tags -->
  <section class="py-10" style="background-color: #111111;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap gap-3 justify-center">
        {topics.map((topic) => (
          <span
            class="px-4 py-2 rounded-full text-sm font-medium"
            style={`background-color: ${topic.color}15; color: ${topic.color}; border: 1px solid ${topic.color}30;`}
          >
            {topic.label}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Videos grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-2xl md:text-3xl font-bold text-white">Wszystkie filmy</h2>
        <span class="text-gray-500 text-sm">{videos.length} filmów</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map((video) => (
          <VideoCard video={video} client:load />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section
    class="py-20"
    style="background: linear-gradient(135deg, #0e7490 0%, #312e81 100%);"
  >
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Chcesz więcej praktycznej wiedzy?
      </h2>
      <p class="text-cyan-100 text-lg mb-8 max-w-xl mx-auto">
        Filmy to wstęp. W kursach idziemy głębiej — ze strukturą, zadaniami i community.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://10xdevs.pl"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-bold text-gray-900 transition-all hover:scale-105"
          style="background-color: #22d3ee;"
        >
          Sprawdź kurs 10xDevs 3.0
        </a>
        <a
          href="/podcast"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl font-semibold text-white border-2 border-white/30 hover:border-white/60 transition-all hover:scale-105"
        >
          Słuchaj podcastu
        </a>
      </div>
    </div>
  </section>
</Layout>
