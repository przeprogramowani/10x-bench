---
import Layout from '../layouts/Layout.astro';
import { courses, videos, partners } from '../data/content.ts';
---

<Layout title="Strona glowna" description="Przeprogramowani - Edukacja technologiczna w epoce AI. Kursy programowania, podcasty i materialy dla ambitnych programistow.">
  <section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-cyan-900/20 via-transparent to-transparent"></div>
    
    <div class="max-w-7xl mx-auto relative z-10">
      <div class="text-center">
        <span class="inline-block px-4 py-2 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-400 text-sm font-medium mb-6">
          7 lat na rynku edukacji technologicznej
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold mb-6 leading-tight">
          <span class="bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
            Edukacja technologiczna
          </span>
          <br />
          <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
            w epoce AI
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-3xl mx-auto mb-10">
          Topowe programy edukacyjne dla ambitnych programistow i swiadome korzystanie z potencjalu Generative AI
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://10xdevs.pl"
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl font-semibold text-lg hover:from-cyan-400 hover:to-blue-500 transition-all shadow-lg shadow-cyan-500/25"
          >
            Poznaj 10xDevs
          </a>
          <a
            href="/o-nas"
            class="px-8 py-4 bg-slate-800 border border-slate-700 rounded-xl font-semibold text-lg hover:bg-slate-700 transition-all"
          >
            O nas
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-900/50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
            Nasze kursy
          </span>
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Wybierz program dopasowany do Twoich potrzeb i rozwin sie w obszarze, ktory Ciebie interesuje
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {courses.map((course) => (
          <a
            href={course.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative bg-slate-800/50 border border-slate-700/50 rounded-2xl p-8 hover:border-slate-600 transition-all hover:-translate-y-1"
          >
            <div class={`absolute inset-0 bg-gradient-to-br ${course.color} opacity-5 rounded-2xl group-hover:opacity-10 transition-opacity`}></div>
            
            <div class="relative z-10">
              <span class="inline-block px-3 py-1 bg-slate-700/50 rounded-full text-xs text-slate-300 mb-4">
                {course.badge}
              </span>
              <h3 class={`text-2xl font-bold mb-1 bg-gradient-to-r ${course.color} bg-clip-text text-transparent`}>
                {course.title}
              </h3>
              <p class="text-slate-400 text-sm mb-4">{course.subtitle}</p>
              <p class="text-slate-300 mb-6">{course.description}</p>
              
              <ul class="space-y-2 mb-6">
                {course.features.map((feature) => (
                  <li class="flex items-center gap-2 text-slate-400 text-sm">
                    <svg class="w-4 h-4 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <div class="flex items-center text-cyan-400 font-medium group-hover:text-cyan-300 transition-colors">
                Dowiedz sie wiecej
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
            Filmy i podcasty
          </span>
        </h2>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Rozwoj nowoczesnego programisty - materialy video na YouTube
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.slice(0, 6).map((video) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative rounded-xl overflow-hidden bg-slate-800 aspect-video"
          >
            <img
              src={video.thumbnail}
              alt={video.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/50 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="text-white font-medium text-sm line-clamp-2">{video.title}</h3>
            </div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <div class="w-16 h-16 rounded-full bg-cyan-500/90 flex items-center justify-center">
                <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/youtube"
          class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800 border border-slate-700 rounded-xl font-medium hover:bg-slate-700 transition-all"
        >
          Zobacz wiecej filmow
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-slate-900/50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-2xl font-bold text-slate-300 mb-2">Wspolpracujemy z najlepszymi</h2>
        <p class="text-slate-500">Zaufaly nam prowadzicze z topowych firm technologicznych</p>
      </div>

      <div class="flex flex-wrap justify-center gap-8 items-center opacity-60">
        {partners.map((partner) => (
          <span class="text-slate-400 font-medium text-sm sm:text-base">{partner}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-6">
        <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
          Przeprogramowany Newsletter
        </span>
      </h2>
      <p class="text-slate-400 text-lg mb-8 max-w-2xl mx-auto">
        Co tydzien w piatek otrzymaj porcje wartosciowych tresci w formacie 3-2-1:
      </p>
      
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-10">
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-6">
          <div class="text-3xl font-bold text-cyan-400 mb-2">3</div>
          <p class="text-slate-400">rekomendacje techniczne</p>
        </div>
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-6">
          <div class="text-3xl font-bold text-cyan-400 mb-2">2</div>
          <p class="text-slate-400">rekomendacje rozwojowe</p>
        </div>
        <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-6">
          <div class="text-3xl font-bold text-cyan-400 mb-2">1</div>
          <p class="text-slate-400">bonus niespodzianka</p>
        </div>
      </div>

      <a
        href="https://przeprogramowani.substack.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-xl font-semibold text-lg hover:from-cyan-400 hover:to-blue-500 transition-all shadow-lg shadow-cyan-500/25"
      >
        Zapisz sie za darmo
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
