---
import Layout from '../layouts/Layout.astro';
import { videos } from '../data/content.ts';
---

<Layout title="YouTube" description="Filmy i materialy video od Przeprogramowani. Programowanie z AI, frontend, TypeScript i wiecej.">
  <section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6">
          <span class="bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
            YouTube
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-3xl mx-auto">
          Rozwoj nowoczesnego programisty - materialy video
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {videos.map((video) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative rounded-xl overflow-hidden bg-slate-800 aspect-video"
          >
            <img
              src={video.thumbnail}
              alt={video.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/50 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="text-white font-medium line-clamp-2">{video.title}</h3>
            </div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <div class="w-16 h-16 rounded-full bg-red-600/90 flex items-center justify-center">
                <svg class="w-8 h-8 text-white ml-1" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center">
        <a
          href="https://youtube.com/c/przeprogramowani/videos"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-red-600 rounded-xl font-semibold text-lg hover:bg-red-500 transition-all"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Zobacz wszystkie filmy
        </a>
      </div>

      <div class="mt-20 bg-gradient-to-br from-slate-800/50 to-slate-900/50 border border-slate-700/50 rounded-2xl p-8 lg:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Subskrybuj nasz kanal</h2>
            <p class="text-slate-400 mb-6">
              Badz na biezaco z najnowszymi materialami o programowaniu, AI i rozwoju kariery. Nowe filmy co tydzien!
            </p>
            <a
              href="https://youtube.com/c/przeprogramowani?sub_confirmation=1"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 rounded-xl font-semibold hover:bg-red-500 transition-all"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              Subskrybuj
            </a>
          </div>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-slate-700/30 rounded-xl p-4">
              <div class="text-2xl font-bold text-white">15k+</div>
              <div class="text-slate-400 text-sm">subskrybentow</div>
            </div>
            <div class="bg-slate-700/30 rounded-xl p-4">
              <div class="text-2xl font-bold text-white">500+</div>
              <div class="text-slate-400 text-sm">filmow</div>
            </div>
            <div class="bg-slate-700/30 rounded-xl p-4">
              <div class="text-2xl font-bold text-white">7+</div>
              <div class="text-slate-400 text-sm">lat na YT</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
