---
import Layout from '../layouts/Layout.astro';
import { podcasts } from '../data/content.ts';
---

<Layout title="Podcast" description="Sluchaj naszych podcastow o technologii, AI i programowaniu. Opanuj.AI Podcast i Przeprogramowani ft. Gosc.">
  <section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6">
          <span class="bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
            Podcasty
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-3xl mx-auto">
          Sluchaj naszych podcastow o technologii, AI i programowaniu
        </p>
      </div>

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-white">Opanuj.AI Podcast</h2>
            <p class="text-slate-400">Ponad 4000 sluchaczy - Comiesieczne podsumowanie najwazniejszych wydarzen ze swiata AI</p>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {podcasts.filter(p => p.show === 'Opanuj.AI Podcast').map((episode) => (
            <a
              href={episode.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-slate-800/50 border border-slate-700/50 rounded-xl p-6 hover:border-slate-600 transition-all"
            >
              <div class="flex gap-4">
                <img
                  src={episode.image}
                  alt={episode.title}
                  class="w-20 h-20 rounded-lg object-cover flex-shrink-0"
                />
                <div class="flex-1 min-w-0">
                  <h3 class="text-white font-medium mb-2 line-clamp-2 group-hover:text-cyan-400 transition-colors">
                    {episode.title}
                  </h3>
                  <p class="text-slate-400 text-sm mb-3 line-clamp-2">{episode.description}</p>
                  <div class="flex items-center gap-4 text-sm text-slate-500">
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                      </svg>
                      {episode.duration}
                    </span>
                    <span>{episode.date}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500 to-blue-500 flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M18 3a1 1 0 00-1.196-.98l-10 2A1 1 0 006 5v9.114A4.369 4.369 0 005 14c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V7.82l8-1.6v5.894A4.37 4.37 0 0015 12c-1.657 0-3 .895-3 2s1.343 2 3 2 3-.895 3-2V3z" />
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-white">Przeprogramowani ft. Gosc</h2>
            <p class="text-slate-400">Ponad 3800 sluchaczy - Rozmowy dla glodnych wiedzy</p>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {podcasts.filter(p => p.show === 'Przeprogramowani ft. Gosc').map((episode) => (
            <a
              href={episode.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-slate-800/50 border border-slate-700/50 rounded-xl p-6 hover:border-slate-600 transition-all"
            >
              <div class="flex gap-4">
                <img
                  src={episode.image}
                  alt={episode.title}
                  class="w-20 h-20 rounded-lg object-cover flex-shrink-0"
                />
                <div class="flex-1 min-w-0">
                  <h3 class="text-white font-medium mb-2 line-clamp-2 group-hover:text-cyan-400 transition-colors">
                    {episode.title}
                  </h3>
                  <p class="text-slate-400 text-sm mb-3 line-clamp-2">{episode.description}</p>
                  <div class="flex items-center gap-4 text-sm text-slate-500">
                    <span class="flex items-center gap-1">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                      </svg>
                      {episode.duration}
                    </span>
                    <span>{episode.date}</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="bg-gradient-to-br from-slate-800/50 to-slate-900/50 border border-slate-700/50 rounded-2xl p-8 text-center">
        <h3 class="text-xl font-bold text-white mb-4">Jestesmy na twojej ulubionej platformie</h3>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1508387250"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-slate-700/50 rounded-lg hover:bg-slate-700 transition-colors"
          >
            <svg class="w-5 h-5 text-slate-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            <span class="text-slate-300">Apple Podcasts</span>
          </a>
          <a
            href="https://open.spotify.com/show/4qHUZJpeBK8Ij9e2wTVm2o"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-slate-700/50 rounded-lg hover:bg-slate-700 transition-colors"
          >
            <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
            </svg>
            <span class="text-slate-300">Spotify</span>
          </a>
          <a
            href="https://anchor.fm/s/22544b7c/podcast/rss"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-slate-700/50 rounded-lg hover:bg-slate-700 transition-colors"
          >
            <svg class="w-5 h-5 text-orange-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            <span class="text-slate-300">RSS</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
