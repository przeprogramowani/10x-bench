---
import Layout from '../layouts/Layout.astro';
import VideoGrid from '../components/VideoGrid.tsx';
---

<Layout>
  <div class="pt-24 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 text-sm text-brand-gray-500 mb-4">
          <a href="/" class="hover:text-white transition-colors">Strona główna</a>
          <span>/</span>
          <span class="text-brand-gray-300">YouTube</span>
        </div>
        <h1 class="section-title mb-4">
          <span class="gradient-text">YouTube</span>
        </h1>
        <p class="section-subtitle mx-auto text-lg">
          Oglądaj nasze najnowsze materiały o programowaniu, AI i rozwoju
        </p>
      </div>

      <div class="flex items-center justify-between mb-10">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-red-500/20 flex items-center justify-center">
            <svg class="w-6 h-6 text-red-500" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold">Ostatnie filmy</h2>
            <p class="text-sm text-brand-gray-500">Subskrybuj, aby nie przegapić nowych materiałów</p>
          </div>
        </div>
        <a
          href="https://youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary hidden sm:inline-flex"
        >
          Subskrybuj kanał
        </a>
      </div>

      <VideoGrid client:load />

      <div class="text-center mt-12">
        <a
          href="https://youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary sm:hidden"
        >
          Subskrybuj kanał
        </a>
      </div>

      <div class="mt-20">
        <div class="glass rounded-2xl p-8 sm:p-10 max-w-2xl mx-auto text-center">
          <h3 class="text-xl font-bold mb-4">Zasubskrybuj i bądź na bieżąco</h3>
          <p class="text-brand-gray-400 mb-6">
            Na naszym kanale YouTube znajdziesz materiały o AI, frontendzie, TypeScript i nowoczesnych praktykach programistycznych.
          </p>
          <a
            href="https://youtube.com/c/przeprogramowani"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary"
          >
            Przejdź do kanału YouTube
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>