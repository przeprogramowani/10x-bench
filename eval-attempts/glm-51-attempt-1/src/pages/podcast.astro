---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import { podcastEpisodes, siteConfig } from '../data/site';
---

<Layout title="Podcast — Przeprogramowani" description="Przeprogramowany Podcast — rozmowy z najciekawszymi osobami z branży IT.">
  <Navbar client:load />

  <main class="pt-16">
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <span class="text-sm font-semibold uppercase tracking-wider text-brand-400">
            Podcast
          </span>
          <h1 class="mt-3 text-4xl sm:text-5xl font-black text-white leading-tight">
            Przeprogramowany Podcast
          </h1>
          <p class="mt-4 text-lg text-gray-400">
            Przeprogramowani czyli szersze spojrzenie na programowanie. Zapraszają Marcin Czarkowski i Przemek Smyrdek.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={siteConfig.podcast}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
              </svg>
              Spotify
            </a>
            <a
              href="https://podcasts.apple.com/us/podcast/przeprogramowany-podcast/id1471770526"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-white/5 hover:bg-white/10 text-white text-sm font-semibold rounded-xl border border-white/10 transition-colors"
            >
              Apple Podcasts
            </a>
          </div>
        </div>

        <div class="mt-16 space-y-4">
          {podcastEpisodes.map((episode, i) => (
            <a
              href={episode.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex gap-5 p-6 rounded-2xl bg-dark-800/50 border border-white/5 hover:border-brand-500/20 transition-all"
            >
              <div class="w-12 h-12 rounded-xl bg-brand-600/10 flex items-center justify-center shrink-0">
                <span class="text-brand-400 font-bold text-sm">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3 mb-1">
                  <h3 class="text-base font-semibold text-white group-hover:text-brand-400 transition-colors">
                    {episode.title}
                  </h3>
                  <div class="flex items-center gap-3 text-xs text-gray-500">
                    <span>{episode.guest}</span>
                    <span>&middot;</span>
                    <span>{episode.duration}</span>
                  </div>
                </div>
                <p class="text-sm text-gray-400 leading-relaxed line-clamp-2 mt-2">
                  {episode.description}
                </p>
                <div class="text-xs text-gray-600 mt-2">{episode.date}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Layout>
