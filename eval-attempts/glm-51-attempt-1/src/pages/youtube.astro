---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import { youtubeVideos, siteConfig } from '../data/site';
---

<Layout title="YouTube — Przeprogramowani" description="Filmy i podcasty o rozwoju nowoczesnego programisty od Przeprogramowanych.">
  <Navbar client:load />

  <main class="pt-16">
    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl">
          <span class="text-sm font-semibold uppercase tracking-wider text-red-400">
            YouTube
          </span>
          <h1 class="mt-3 text-4xl sm:text-5xl font-black text-white leading-tight">
            Rozwój nowoczesnego programisty
          </h1>
          <p class="mt-4 text-lg text-gray-400">
            Filmy o programowaniu, AI, TypeScript i frontendzie. Dołącz do społeczności na YouTube.
          </p>
          <div class="mt-6">
            <a
              href={siteConfig.youtube}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
              </svg>
              Zasubskrybuj kanał
            </a>
          </div>
        </div>

        <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-6">
          {youtubeVideos.map((video) => (
            <a
              href={`https://www.youtube.com/watch?v=${video.videoId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-2xl overflow-hidden bg-dark-800/50 border border-white/5 hover:border-red-500/20 transition-all hover:shadow-lg"
            >
              <div class="relative aspect-video bg-dark-700 overflow-hidden">
                <img
                  src={`https://i3.ytimg.com/vi/${video.videoId}/maxresdefault.jpg`}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors flex items-center justify-center">
                  <div class="w-16 h-16 rounded-full bg-red-600/90 flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg">
                    <svg class="w-7 h-7 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-5">
                <h3 class="text-base font-semibold text-white group-hover:text-red-400 transition-colors">
                  {video.title}
                </h3>
                <p class="text-sm text-gray-500 mt-2">{video.date}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Layout>
