---
import "../styles/global.css";
import MobileNav from "../components/MobileNav";
import { navItems, socialLinks } from "../lib/content";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Przeprogramowani - szersze spojrzenie na programowanie",
  description = "Kursy, podcasty i materiały dla programistów, którzy chcą pracować nowocześnie z front-endem, TypeScriptem i AI.",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09111f" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://przeprogramowani.pl/img/page-cover.jpg" />
    <link rel="icon" href="https://przeprogramowani.pl/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&family=Sora:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-mint focus:px-4 focus:py-2 focus:font-bold focus:text-ink">
      Przejdź do treści
    </a>

    <div class="border-b border-white/10 bg-panel/70 px-4 py-2 text-center text-sm text-slate-300">
      <span class="font-semibold text-white">10xDevs 3.0</span> jest w centrum nowej odsłony pracy z AI.
      <a href="https://10xdevs.pl" class="ml-2 font-bold text-mint hover:text-white">Sprawdź program</a>
    </div>

    <header class="sticky top-0 z-40 border-b border-white/10 bg-ink/82 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="focus-ring flex items-center gap-3 rounded-md">
          <span class="grid h-10 w-10 place-items-center rounded-md bg-mint font-mono text-lg font-black text-ink">&lt;/&gt;</span>
          <span class="font-display text-lg font-extrabold tracking-tight text-white">Przeprogramowani</span>
        </a>
        <nav aria-label="Nawigacja główna" class="hidden items-center gap-1 md:flex">
          {navItems.map((item) => (
            <a
              href={item.href}
              target={item.external ? "_blank" : undefined}
              rel={item.external ? "noreferrer" : undefined}
              class="focus-ring rounded-md px-3 py-2 text-sm font-semibold text-slate-300 hover:bg-white/10 hover:text-white"
            >
              {item.label}
            </a>
          ))}
        </nav>
        <MobileNav client:load items={navItems} />
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="border-t border-white/10 bg-panel/75">
      <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-[1fr_auto] lg:px-8">
        <div>
          <p class="font-display text-xl font-extrabold text-white">Przeprogramowani.pl</p>
          <p class="mt-2 max-w-xl text-sm leading-6 text-slate-400">
            Szersze spojrzenie na programowanie: frontend, TypeScript, AI, architektura i zawodowy rozwój programisty.
          </p>
        </div>
        <nav aria-label="Linki w stopce" class="flex flex-wrap items-start gap-3 md:justify-end">
          {socialLinks.map((link) => (
            <a href={link.href} class="focus-ring rounded-md border border-white/10 px-3 py-2 text-sm font-semibold text-slate-300 hover:bg-white/10 hover:text-white">
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </footer>
  </body>
</html>
