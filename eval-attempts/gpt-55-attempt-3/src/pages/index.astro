---
import BaseLayout from "../layouts/BaseLayout.astro";
import CourseCard from "../components/CourseCard.astro";
import PodcastCard from "../components/PodcastCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import VideoCard from "../components/VideoCard.astro";
import { courses, partners, podcasts, videos } from "../lib/content";

const featuredCourse = courses.find((course) => course.featured);
const otherCourses = courses.filter((course) => !course.featured);
---

<BaseLayout>
  <section class="noise-mask surface-grid relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/88 to-ink/30"></div>
    <img
      src={featuredCourse?.image}
      alt=""
      class="absolute inset-y-0 right-0 h-full w-full object-cover object-[62%_center] opacity-25 lg:w-[58%] lg:opacity-70"
      fetchpriority="high"
    />
    <div class="relative mx-auto grid min-h-[calc(100svh-7rem)] max-w-7xl items-center px-4 py-20 sm:px-6 lg:grid-cols-[0.92fr_1.08fr] lg:px-8">
      <div class="max-w-3xl">
        <p class="font-mono text-xs font-bold uppercase tracking-[0.22em] text-coral">10xDevs 3.0</p>
        <h1 class="mt-5 font-display text-5xl font-extrabold tracking-tight text-white sm:text-6xl lg:text-7xl text-balance">
          Czas na AI-Native Software Engineering
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-200">
          Przeprogramowani pomagają programistom rozumieć technologię szerzej: od solidnego frontendu i TypeScriptu po świadome projektowanie workflow z agentami AI.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="https://10xdevs.pl" class="focus-ring rounded-md bg-coral px-5 py-3 text-sm font-extrabold text-white shadow-lg shadow-coral/20 hover:bg-orange-400">
            Zobacz 10xDevs
          </a>
          <a href="#kursy" class="focus-ring rounded-md border border-white/18 px-5 py-3 text-sm font-extrabold text-white hover:bg-white/10">
            Przegląd kursów
          </a>
        </div>
        <dl class="mt-10 grid max-w-2xl gap-3 sm:grid-cols-3">
          <div class="rounded-lg border border-white/10 bg-white/[0.055] p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Rynek</dt>
            <dd class="mt-2 font-display text-2xl font-extrabold text-white">7 lat</dd>
          </div>
          <div class="rounded-lg border border-white/10 bg-white/[0.055] p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Kursy</dt>
            <dd class="mt-2 font-display text-2xl font-extrabold text-white">3+</dd>
          </div>
          <div class="rounded-lg border border-white/10 bg-white/[0.055] p-4">
            <dt class="text-xs font-semibold uppercase tracking-wide text-slate-400">Media</dt>
            <dd class="mt-2 font-display text-2xl font-extrabold text-white">YT + audio</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="border-y border-white/10 bg-white/[0.035]">
    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-8 sm:px-6 md:grid-cols-[0.7fr_1.3fr] lg:px-8">
      <p class="font-display text-2xl font-extrabold text-white">Współpracujemy z zespołami technologicznymi i produktowymi.</p>
      <div class="flex flex-wrap gap-2">
        {partners.map((partner) => (
          <span class="rounded-md border border-white/10 bg-ink/50 px-3 py-2 text-sm font-semibold text-slate-300">{partner}</span>
        ))}
      </div>
    </div>
  </section>

  <section id="kursy" class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <SectionHeader
      eyebrow="Edukacja"
      title="Programy dla developerów, którzy chcą dowozić lepsze oprogramowanie"
      copy="Trzon oferty łączy trzy praktyczne ścieżki: AI-native engineering, kompletny frontend i zaawansowany TypeScript."
    />
    <div class="mt-10 grid gap-6">
      {featuredCourse && <CourseCard course={featuredCourse} />}
      <div class="grid gap-6 lg:grid-cols-2">
        {otherCourses.map((course) => <CourseCard course={course} />)}
      </div>
    </div>
  </section>

  <section class="bg-paper py-20 text-ink">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
      <div>
        <p class="font-mono text-xs font-bold uppercase tracking-[0.22em] text-rosebrand">Media</p>
        <h2 class="mt-3 font-display text-3xl font-extrabold tracking-tight sm:text-4xl text-balance">
          Ostatnie materiały z podcastu i YouTube
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-700">
          Najnowsze publikacje są dobrane z oficjalnej strony podcastu i feedu kanału YouTube Przeprogramowanych.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/podcast" class="rounded-md bg-ink px-4 py-2 text-sm font-bold text-white hover:bg-panel">Podcast</a>
          <a href="/youtube" class="rounded-md border border-ink/15 px-4 py-2 text-sm font-bold text-ink hover:bg-ink/5">YouTube</a>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="[&_*]:text-inherit">
          <PodcastCard episode={podcasts[0]} />
        </div>
        <div class="[&_*]:text-inherit">
          <VideoCard video={videos[0]} compact />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
