---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { founders, partners } from "../lib/content";
---

<BaseLayout
  title="O nas - Przeprogramowani"
  description="Poznaj Przeprogramowanych: Przemka Smyrdka i Marcina Czarkowskiego, twórców kursów, podcastów i programów edukacyjnych dla developerów."
>
  <section class="surface-grid border-b border-white/10 px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <SectionHeader
        eyebrow="O nas"
        title="Łączymy programowanie, biznes i rozwój zawodowy"
        copy="Przeprogramowani to platforma edukacyjna dla developerów, którzy chcą pracować dojrzalej: pisać lepszy kod, rozumieć decyzje techniczne i świadomie korzystać z narzędzi AI."
      />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-2">
      {founders.map((person) => (
        <article class="overflow-hidden rounded-lg border border-white/10 bg-white/[0.045]">
          <div class="grid sm:grid-cols-[220px_1fr]">
            <img src={person.image} alt={person.name} class="h-full min-h-72 w-full object-cover" />
            <div class="p-6">
              <p class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-mint">{person.role}</p>
              <h2 class="mt-3 font-display text-3xl font-extrabold text-white">{person.name}</h2>
              <p class="mt-4 text-sm leading-7 text-slate-300">{person.bio}</p>
              <div class="mt-6 flex flex-wrap gap-2">
                {person.tags.map((tag) => (
                  <span class="rounded-md border border-white/10 bg-panel px-3 py-1.5 text-xs font-semibold text-slate-300">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-paper py-16 text-ink">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="font-mono text-xs font-bold uppercase tracking-[0.22em] text-rosebrand">Doświadczenie</p>
          <h2 class="mt-3 font-display text-3xl font-extrabold tracking-tight">7 lat na rynku edukacji technologicznej</h2>
          <p class="mt-4 leading-7 text-slate-700">
            Tworzymy kursy, podcasty, newslettery i materiały dla ambitnych programistów. Wspieramy osoby indywidualne i zespoły, które chcą budować kompetencje techniczne bez odrywania ich od realnej pracy produktowej.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
          {partners.map((partner) => (
            <div class="grid min-h-20 place-items-center rounded-lg border border-slate-200 bg-white px-3 text-center text-sm font-bold text-slate-700 shadow-sm">
              {partner}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
