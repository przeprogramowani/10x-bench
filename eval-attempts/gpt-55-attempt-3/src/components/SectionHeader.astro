---
interface Props {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: "left" | "center";
}

const { eyebrow, title, copy, align = "left" } = Astro.props;
---

<div class:list={["max-w-3xl", align === "center" && "mx-auto text-center"]}>
  {eyebrow && (
    <p class="font-mono text-xs font-bold uppercase tracking-[0.22em] text-mint">{eyebrow}</p>
  )}
  <h2 class="mt-3 font-display text-3xl font-extrabold tracking-tight text-white sm:text-4xl text-balance">
    {title}
  </h2>
  {copy && <p class="mt-4 text-base leading-7 text-slate-300 sm:text-lg">{copy}</p>}
</div>
