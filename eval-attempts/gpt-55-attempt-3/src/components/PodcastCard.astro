---
const { episode } = Astro.props;
---

<a
  href={episode.href}
  target="_blank"
  rel="noreferrer"
  class="group flex h-full flex-col rounded-lg border border-white/10 bg-white/[0.045] p-6 transition duration-200 hover:-translate-y-1 hover:border-mint/45 hover:bg-white/[0.07]"
>
  <div class="flex items-start justify-between gap-4">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.18em] text-mint">{episode.show}</p>
    <span class="shrink-0 rounded-md bg-white/10 px-2 py-1 text-xs font-semibold text-slate-300">{episode.duration}</span>
  </div>
  <h3 class="mt-5 font-display text-xl font-bold leading-snug text-white group-hover:text-mint">
    {episode.title}
  </h3>
  <p class="mt-3 flex-1 text-sm leading-6 text-slate-300">{episode.summary}</p>
  <span class="mt-6 text-sm font-bold text-coral">Słuchaj odcinka -></span>
</a>
