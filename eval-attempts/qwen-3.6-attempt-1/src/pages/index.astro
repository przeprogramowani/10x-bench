---
import Layout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard';
import { courses, episodes, videos } from '../data/content';
---

<Layout title="Przeprogramowani.pl">
  <!-- ==================== HERO ==================== -->
  <section class="relative pt-12 pb-20 lg:pt-24 lg:pb-28 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-50/50 via-white to-white" />
      <div class="absolute top-20 left-1/4 w-96 h-96 bg-brand-200/20 rounded-full blur-3xl" />
      <div class="absolute top-40 right-1/4 w-80 h-80 bg-violet-200/20 rounded-full blur-3xl" />
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-brand-100 text-brand-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-8">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Szersze spojrzenie na programowanie
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-display font-extrabold tracking-tight mb-8">
        <span class="block text-gray-900">Edukacja technologiczna</span>
        <span class="block mt-2 bg-gradient-to-r from-brand-600 via-brand-700 to-violet-600 bg-clip-text text-transparent">
          w epoce AI
        </span>
      </h1>

      <p class="max-w-2xl mx-auto text-lg text-gray-600 leading-relaxed mb-12">
        Od <span class="font-semibold text-gray-800">7 lat</span> tworzymy treści, które mają realne przełożenie na Twoją pracę.
        Kursy, podcast i YouTube - wszystko w jednym miejscu.
      </p>

      <!-- Course Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {courses.map((course, i) => (
          <CourseCard course={course} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== LATEST CONTENT ==================== -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">
        <!-- Podcast -->
        <div>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM8.5 8a1.5 1.5 0 100 3 1.5 1.5 0 000-3zM12 18c-3.31 0-6-2.69-6-6 0-.72.13-1.41.36-2.05.13-.29.43-.33.69-.16a.75.75 0 01.27.98A4.48 4.48 0 007.5 12c0 2.49 2.01 4.5 4.5 4.5.54 0 1.06-.08 1.55-.23a.75.75 0 01.98.37.75.75 0 01-.16.98A5.98 5.98 0 0112 18z"/></svg>
            </div>
            <div>
              <h2 class="text-2xl font-display font-bold text-gray-900">Ostatnie odcinki</h2>
              <p class="text-sm text-gray-500">Słuchaj na YouTube</p>
            </div>
          </div>

          <div class="space-y-4">
            {episodes.slice(0, 3).map((ep) => (
              <a
                href={ep.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors"
              >
                <div class="flex-shrink-0 w-28 h-16 rounded-lg bg-gradient-to-br from-gray-100 to-gray-50 flex items-center justify-center">
                  <svg class="w-7 h-7 text-violet-400 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-violet-600 transition-colors line-clamp-2 mb-1">
                    {ep.title}
                  </p>
                  <span class="text-xs text-gray-400">
                    {ep.season} · {ep.duration}
                  </span>
                </div>
              </a>
            ))}
          </div>

          <a
            href="/podcast"
            class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors"
          >
            Wszystkie odcinki
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}><path strokeLinecap="round" strokeLinejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>

        <!-- YouTube -->
        <div>
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-red-500 to-red-600 flex items-center justify-center text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186c0 1.57 0 4.638.503 6.213a3.016 3.016 0 0 0 2.122 2.136c1.872.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136c.503-1.576.503-4.643.503-6.213zM9.64 15.198V8.802l5.77 3.199-5.77 3.197z"/></svg>
            </div>
            <div>
              <h2 class="text-2xl font-display font-bold text-gray-900">Nowe filmy</h2>
              <p class="text-sm text-gray-500">Subskrybuj kanał</p>
            </div>
          </div>

          <div class="space-y-4">
            {videos.slice(0, 3).map((video) => (
              <a
                href={video.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-start gap-4 p-4 rounded-xl hover:bg-gray-50 transition-colors"
              >
                <div class="flex-shrink-0 w-28 h-16 rounded-lg bg-gradient-to-br from-gray-100 to-gray-50 overflow-hidden">
                  {new URL(video.link).searchParams.get('v') && (
                    <img
                      src={`https://img.youtube.com/vi/${new URL(video.link).searchParams.get('v')}/mqdefault.jpg`}
                      alt={video.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                      loading="lazy"
                    />
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-semibold text-gray-900 group-hover:text-red-600 transition-colors line-clamp-2 mb-1">
                    {video.title}
                  </p>
                  <span class="text-xs text-gray-400">
                    {new Date(video.date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' })}
                    {video.duration && ` · ${video.duration}`}
                  </span>
                </div>
              </a>
            ))}
          </div>

          <a
            href="/youtube"
            class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-red-600 hover:text-red-700 transition-colors"
          >
            Wszystkie filmy
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}><path strokeLinecap="round" strokeLinejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-3xl bg-gradient-to-br from-gray-950 via-gray-900 to-brand-950 overflow-hidden p-10 sm:p-16 text-center">
        <div class="absolute inset-0 -z-10">
          <div class="absolute top-10 left-10 w-64 h-64 bg-brand-500/10 rounded-full blur-3xl" />
          <div class="absolute bottom-10 right-10 w-80 h-80 bg-violet-500/10 rounded-full blur-3xl" />
        </div>

        <div class="relative">
          <h2 class="text-3xl sm:text-4xl font-display font-bold text-white mb-4">
            Dołącz do naszej społeczności
          </h2>
          <p class="text-gray-400 text-lg max-w-xl mx-auto mb-10">
            Bądź na bieżąco z najnowszą wiedzą o AI, programowaniu i nowych technologiach.
          </p>

          <div class="flex flex-wrap items-center justify-center gap-4">
            <a
              href="https://linktr.ee/przeprogramowani"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-8 py-4 bg-white text-gray-900 font-semibold rounded-xl hover:bg-brand-50 transition-all shadow-xl"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M21.395 15.045a9.76 9.76 0 0 0-1.184-1.052 8.793 8.793 0 0 0-1.017-.872l1.59-6.203-1.017-.262-1.384 5.398a8.905 8.905 0 0 0-2.356-.366c-.743 0-1.482.1-2.18.3l-1.186-5.06-.997.262 1.452 5.666a9.38 9.38 0 0 0-1.337 1.04 8.625 8.625 0 0 0-1.225-1.12l1.382-5.396-1.017-.262-1.59 6.203a8.77 8.77 0 0 0-1.052 1.052 8.416 8.416 0 0 0-1.184 1.052l-2.128-8.289-.997.262 2.47 9.63a.587.587 0 0 0 .376.376l1.04-.262a.602.602 0 0 0 .376-.376l.724-2.826c.338.296.698.566 1.077.808.068.838.22 1.666.454 2.472l-.724 2.826.376.094a.587.587 0 0 0 .376-.376l2.47-9.63-.997-.262-2.128 8.29c.384-.072.774-.11 1.165-.115.696-.005 1.39-.1 2.066-.274.296-.078.582-.176.858-.292l1.384-5.398 1.017.262-1.452 5.666.376.094a.587.587 0 0 0 .376-.376l.724-2.826c.379.242.779.426 1.198.548.7.196 1.422.296 2.152.297.73 0 1.452-.1 2.148-.297a5.3 5.3 0 0 0 1.198-.548l.724 2.826.376-.094-1.452-5.666 1.017-.262 1.384 5.398c.38-.242.74-.512 1.078-.808l.724 2.826a.587.587 0 0 0 .376.376l1.04-.262a.587.587 0 0 0 .376-.376l2.47-9.63-.997-.262-2.128 8.29a8.416 8.416 0 0 0-1.184-1.052z"/></svg>
              Wszystkie linki
            </a>
            <a
              href="https://youtube.com/c/przeprogramowani"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-8 py-4 border-2 border-gray-700 text-white font-semibold rounded-xl hover:border-red-500 hover:text-red-400 transition-all"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186c0 1.57 0 4.638.503 6.213a3.016 3.016 0 0 0 2.122 2.136c1.872.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136c.503-1.576.503-4.643.503-6.213zM9.64 15.198V8.802l5.77 3.199-5.77 3.197z"/></svg>
              YouTube
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
