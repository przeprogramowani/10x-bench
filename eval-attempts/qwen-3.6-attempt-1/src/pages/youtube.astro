---
import Layout from '../layouts/Layout.astro';
import VideoCard from '../components/VideoCard';
import { videos } from '../data/content';
---

<Layout title="YouTube" description="Filmy na kanale Przeprogramowani.pl na YouTube. Poradniki, demo i rozmowy o AI i programowaniu.">

  <!-- ==================== HERO ==================== -->
  <section class="relative pt-16 pb-16 lg:pt-24 lg:pb-20 overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-red-50/50 via-white to-white" />
      <div class="absolute top-10 right-1/4 w-96 h-96 bg-red-200/20 rounded-full blur-3xl" />
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-red-500 to-red-600 flex items-center justify-center text-white shadow-lg">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186c0 1.57 0 4.638.503 6.213a3.016 3.016 0 0 0 2.122 2.136c1.872.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136c.503-1.576.503-4.643.503-6.213zM9.64 15.198V8.802l5.77 3.199-5.77 3.197z"/></svg>
        </div>
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-extrabold tracking-tight text-gray-900 mb-6">
        YouTube
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-8">
        Filmowe poradniki, demo, live coding i rozmowy o AI oraz nowoczesnym programowaniu.
      </p>

      <a
        href="https://youtube.com/c/przeprogramowani"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-red-500 to-red-600 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl hover:shadow-red-500/20 transition-all text-lg"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186c0 1.57 0 4.638.503 6.213a3.016 3.016 0 0 0 2.122 2.136c1.872.505 9.377.505 9.377.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136c.503-1.576.503-4.643.503-6.213zM9.64 15.198V8.802l5.77 3.199-5.77 3.197z"/></svg>
        Subskrybuj kanał
      </a>
    </div>
  </section>

  <!-- ==================== VIDEOS ==================== -->
  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map((video) => (
          <VideoCard video={video} />
        ))}
      </div>
    </div>
  </section>
</Layout>
