---
import { site } from '../data/site';

const year = new Date().getFullYear();

const footerLinks = [
  { label: 'O nas', href: '/o-nas' },
  { label: 'Podcast', href: '/podcast' },
  { label: 'YouTube', href: '/youtube' },
  { label: '10xDevs', href: 'https://10xdevs.pl' },
  { label: 'Opanuj Frontend', href: 'https://opanujfrontend.pl' },
  { label: 'Opanuj TypeScript', href: 'https://opanujtypescript.pl' },
];
---

<footer class="mt-24 border-t border-white/5 bg-ink-950">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <a href="/" class="flex items-center gap-2 font-mono text-lg font-bold text-white">
          <span class="grid h-9 w-9 place-items-center rounded-lg bg-gradient-to-br from-brand-400 to-fuchsia-500 text-sm">
            &lt;/&gt;
          </span>
          Przeprogramowani
        </a>
        <p class="mt-4 max-w-xs text-sm text-slate-500">
          {site.tagline}. Edukacja technologiczna w epoce AI.
        </p>
        <div class="mt-6 flex gap-3">
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="grid h-10 w-10 place-items-center rounded-lg border border-white/10 text-slate-400 transition hover:border-white/30 hover:text-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="grid h-10 w-10 place-items-center rounded-lg border border-white/10 text-slate-400 transition hover:border-white/30 hover:text-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12a12 12 0 1 0-13.9 11.9v-8.4H7.1V12h3V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9V12h3.3l-.5 3.5h-2.8v8.4A12 12 0 0 0 24 12z"/></svg>
          </a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid h-10 w-10 place-items-center rounded-lg border border-white/10 text-slate-400 transition hover:border-white/30 hover:text-white">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.2c3.2 0 3.6 0 4.9.1 1.2.1 1.8.3 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.1.4.3 1 .4 2.2.1 1.3.1 1.7.1 4.9s0 3.6-.1 4.9c-.1 1.2-.3 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.1-1 .3-2.2.4-1.3.1-1.7.1-4.9.1s-3.6 0-4.9-.1c-1.2-.1-1.8-.3-2.2-.4a3.8 3.8 0 0 1-1.4-.9 3.8 3.8 0 0 1-.9-1.4c-.1-.4-.3-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.9c.1-1.2.3-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.1 1-.3 2.2-.4C8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.1 0-3.5 0-4.7.1-.9 0-1.4.2-1.7.3-.4.2-.7.4-1 .7-.3.3-.5.6-.7 1-.1.3-.3.8-.3 1.7-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 .9.2 1.4.3 1.7.2.4.4.7.7 1 .3.3.6.5 1 .7.3.1.8.3 1.7.3 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c.9 0 1.4-.2 1.7-.3.4-.2.7-.4 1-.7.3-.3.5-.6.7-1 .1-.3.3-.8.3-1.7.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-.9-.2-1.4-.3-1.7a2.7 2.7 0 0 0-.7-1 2.7 2.7 0 0 0-1-.7c-.3-.1-.8-.3-1.7-.3-1.2-.1-1.6-.1-4.7-.1zm0 3.1a4.9 4.9 0 1 1 0 9.8 4.9 4.9 0 0 1 0-9.8zm0 8a3.1 3.1 0 1 0 0-6.2 3.1 3.1 0 0 0 0 6.2zm6.3-8.2a1.1 1.1 0 1 1-2.3 0 1.1 1.1 0 0 1 2.3 0z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white">Strony</h3>
        <ul class="mt-4 space-y-2">
          {footerLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-slate-500 transition hover:text-white" target={l.href.startsWith('http') ? '_blank' : undefined} rel={l.href.startsWith('http') ? 'noopener' : undefined}>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-white">Kontakt</h3>
        <p class="mt-4 text-sm text-slate-500">
          Chcesz nawiązać współpracę? Napisz do nas.
        </p>
        <a href={`mailto:${site.email}`} class="mt-3 inline-block text-sm font-medium text-brand-400 hover:text-brand-300">
          {site.email}
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-8 sm:flex-row">
      <p class="text-xs text-slate-600">© {year} Przeprogramowani.pl — {site.tagline}</p>
      <p class="font-mono text-xs text-slate-600">Built with Astro • React • Tailwind</p>
    </div>
  </div>
</footer>
