---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { founders, brands, site } from '../data/site';

const stats = [
  { value: '7', label: 'lat na rynku edukacji' },
  { value: '15k+', label: 'programistów w społeczności' },
  { value: '4000+', label: 'słuchaczy podcastu' },
  { value: '400+', label: 'absolwentów kursów' },
];
---

<Layout title="O nas">
  <Nav />

  <main id="main">
    <!-- Header -->
    <section class="relative overflow-hidden">
      <div class="pointer-events-none absolute left-1/2 top-0 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-brand-500/20 blur-[120px]"></div>
      <div class="container-page relative py-16 sm:py-20">
        <div class="mx-auto max-w-3xl text-center">
          <span class="font-mono text-xs uppercase tracking-widest text-brand-400">O nas</span>
          <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl">
            Łączymy świat programowania,<br class="hidden sm:block" />
            biznesu i rozwoju
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-slate-400 sm:text-lg">
            Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem
            osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na
            architekturę, na biznes, na ludzi i na siebie.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="container-page">
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        {stats.map((s) => (
          <div class="card p-6 text-center">
            <p class="text-3xl font-extrabold text-white sm:text-4xl">{s.value}</p>
            <p class="mt-2 text-xs text-slate-500 sm:text-sm">{s.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Founders -->
    <section class="container-page py-16">
      <div class="mb-10 text-center">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">Twórcy</h2>
        <p class="mt-2 text-sm text-slate-400">Poznaj ludzi za Przeprogramowanymi</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {founders.map((f) => (
          <article class="card card-hover flex flex-col overflow-hidden p-6 sm:p-8">
            <div class="flex items-center gap-4">
              <img
                src={f.image}
                alt={f.name}
                loading="lazy"
                class="h-16 w-16 rounded-full object-cover ring-2 ring-white/10"
              />
              <div>
                <h3 class="text-lg font-bold text-white">{f.name}</h3>
                <p class="text-sm text-brand-300">{f.role}</p>
              </div>
            </div>
            <p class="mt-5 text-sm leading-relaxed text-slate-400">{f.bio}</p>
            <a
              href={f.linkedin}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-slate-300 transition hover:text-white"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
              LinkedIn
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- Mission -->
    <section class="container-page py-8">
      <div class="card relative overflow-hidden p-8 sm:p-12">
        <div class="pointer-events-none absolute -left-10 -bottom-10 h-40 w-40 rounded-full bg-fuchsia-500/15 blur-3xl"></div>
        <div class="relative">
          <h2 class="text-2xl font-bold text-white sm:text-3xl">Witaj na Przeprogramowanych!</h2>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-slate-400">
            Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na
            wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
          </p>
          <p class="mt-4 text-lg font-semibold gradient-text">Zyskaj szersze spojrzenie na programowanie.</p>
        </div>
      </div>
    </section>

    <!-- Brands -->
    <section class="container-page py-16">
      <div class="text-center">
        <h2 class="text-xl font-bold text-white sm:text-2xl">7 lat na rynku edukacji technologicznej</h2>
        <p class="mt-2 text-sm text-slate-400">Współpracujemy z najlepszymi</p>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {brands.map((b) => (
          <span class="font-mono text-sm font-semibold uppercase tracking-wider text-slate-600 transition hover:text-slate-300">
            {b}
          </span>
        ))}
      </div>
      <div class="mt-10 text-center">
        <a href={`mailto:${site.email}`} class="text-sm font-medium text-brand-300 hover:text-brand-200">
          Chcesz nawiązać współpracę? {site.email}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
