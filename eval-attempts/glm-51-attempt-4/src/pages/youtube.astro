---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Footer from '../components/Footer';
import YouTubeCard from '../components/YouTubeCard';
import { latestVideos } from '../data/videos';
---

<Layout title="YouTube — Przeprogramowani">
  <Header client:load />

  <main class="pt-16">
    <section class="relative overflow-hidden py-16 sm:py-24">
      <div class="absolute inset-0 -z-10">
        <div class="absolute left-1/4 top-0 h-[400px] w-[400px] rounded-full bg-red-600/15 blur-[120px]" />
      </div>

      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-red-600/20 text-3xl">
            ▶️
          </div>
          <div>
            <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
              <span class="gradient-text">YouTube</span>
            </h1>
            <p class="mt-2 text-xl text-gray-300">
              Filmy o programowaniu, AI i rozwoju kariery
            </p>
          </div>
        </div>

        <div class="mt-8">
          <a
            href="https://www.youtube.com/@przeprogramowani"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-red-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-red-700"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            Subskrybuj kanał
          </a>
        </div>
      </div>
    </section>

    <section class="pb-16 sm:pb-24">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold mb-8">Ostatnie filmy</h2>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {latestVideos.map((v) => (
            <YouTubeCard client:load video={v} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Layout>
