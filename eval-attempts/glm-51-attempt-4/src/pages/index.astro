---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import Hero from '../components/Hero';
import Footer from '../components/Footer';
import CourseCard from '../components/CourseCard';
import PodcastCard from '../components/PodcastCard';
import YouTubeCard from '../components/YouTubeCard';
import { courses } from '../data/courses';
import { opanujAiPodcast, przeprogramowaniFtGosc } from '../data/podcasts';
import { latestVideos } from '../data/videos';
---

<Layout title="Przeprogramowani — Szersze spojrzenie na programowanie">
  <Header client:load />

  <main class="pt-16">
    <Hero client:load />

    <section id="kursy" class="py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
            Edukacja technologiczna <span class="gradient-text">w epoce AI</span>
          </h2>
          <p class="mx-auto mt-4 max-w-2xl text-gray-400">
            Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI
          </p>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {courses.map((c, i) => (
            <CourseCard client:load course={c} featured={i === 0} />
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2">
          <div>
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-600/20 text-xl">🎙️</div>
              <div>
                <h2 class="text-2xl font-bold">Podcasty</h2>
                <p class="text-sm text-gray-400">Słuchaj naszych podcastów o technologii i AI</p>
              </div>
            </div>

            <div class="mt-6 space-y-3">
              {opanujAiPodcast.slice(0, 3).map((p) => (
                <PodcastCard client:load podcast={p} />
              ))}
            </div>

            <a
              href="/podcast"
              class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-brand-400 hover:text-brand-300"
            >
              Wszystkie odcinki
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

          <div>
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-red-600/20 text-xl">▶️</div>
              <div>
                <h2 class="text-2xl font-bold">YouTube</h2>
                <p class="text-sm text-gray-400">Filmy o programowaniu, AI i rozwoju kariery</p>
              </div>
            </div>

            <div class="mt-6 grid gap-3 sm:grid-cols-2">
              {latestVideos.slice(0, 4).map((v) => (
                <YouTubeCard client:load video={v} />
              ))}
            </div>

            <a
              href="/youtube"
              class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-red-400 hover:text-red-300"
            >
              Wszystkie filmy
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-gray-800/60 py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
            <span class="gradient-text">7 lat</span> na rynku edukacji technologicznej
          </h2>
          <p class="mt-4 text-gray-400">Współpracujemy z najlepszymi</p>
        </div>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-8 opacity-50 grayscale">
          {['Huuuge Games', 'SmartRecruiters', 'Callstack', 'Future Processing', 'Autodesk', 'Xfive', 'edrone', 'Euvic'].map((b) => (
            <div class="rounded-lg border border-gray-800 px-6 py-3 text-sm font-medium text-gray-400">
              {b}
            </div>
          ))}
        </div>

        <div class="mt-8 text-center">
          <p class="text-sm text-gray-400">
            Chcesz nawiązać współpracę?{' '}
            <a href="mailto:kontakt@przeprogramowani.pl" class="text-brand-400 hover:text-brand-300">
              kontakt@przeprogramowani.pl
            </a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer client:load />
</Layout>
