---
import Layout from '../layouts/Layout.astro';
import { MonitorPlay, Play, Eye, ThumbsUp, ExternalLink } from 'lucide-react';

const videos = [
  {
    title: '5 Agent Skills do jakościowego programowania z AI - Claude Code LIVE DEMO',
    views: '12K',
    likes: '850',
    duration: '45:32',
    description: 'Poznaj 5 kluczowych umiejętności, które pozwolą Ci efektywnie programować z wykorzystaniem AI i Claude Code.',
    gradient: 'from-red-600/20 to-orange-600/20'
  },
  {
    title: 'Product Builders Day | LIVE AI Product Heroes i 10xDevs',
    views: '8.5K',
    likes: '620',
    duration: '1:20:15',
    description: 'Relacja z wydarzenia Product Builders Day - jak AI zmienia sposób budowania produktów technologicznych.',
    gradient: 'from-blue-600/20 to-cyan-600/20'
  },
  {
    title: 'Wybierasz model AI do kodowania? Nie ufaj benchmarkom',
    views: '15K',
    likes: '1.1K',
    duration: '35:18',
    description: 'Dlaczego benchmarki nie zawsze odzwierciedlają rzeczywiste możliwości modeli AI w codziennej pracy programisty.',
    gradient: 'from-green-600/20 to-emerald-600/20'
  },
  {
    title: 'Claude Code w rękach Product Buildera | LIVE AI Product Heroes x 10xDevs',
    views: '9.2K',
    likes: '740',
    duration: '55:42',
    description: 'Live demo pokazujące możliwości Claude Code w rękach doświadczonego Product Buildera.',
    gradient: 'from-purple-600/20 to-pink-600/20'
  },
  {
    title: 'MVP w Claude Code - Context Engineering, kontrola Agenta i refaktoryzacja',
    views: '11K',
    likes: '890',
    duration: '48:25',
    description: 'Jak efektywnie budować MVP wykorzystując Claude Code - techniki Context Engineering i kontroli Agenta.',
    gradient: 'from-yellow-600/20 to-amber-600/20'
  },
  {
    title: 'Od chaosu do AI-Native Infrastructure - budujemy platformę dla zespołu',
    views: '7.8K',
    likes: '580',
    duration: '1:10:33',
    description: 'Case study budowy platformy AI-Native dla zespołu programistycznego - od koncepcji do wdrożenia.',
    gradient: 'from-indigo-600/20 to-violet-600/20'
  }
];
---

<Layout title="YouTube - Przeprogramowani.pl" description="Obejrzyj najnowsze filmy Przeprogramowanych na YouTube.">
  <section class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-sm font-medium mb-6">
          <MonitorPlay className="w-4 h-4" />
          <span>Kanał YouTube</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
          Obejrzyj{' '}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-red-600">
            filmy
          </span>
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Rozwój nowoczesnego programisty - filmy o programowaniu, AI i technologiach webowych.
        </p>
      </div>

      <div class="flex justify-center mb-12 animate-fade-in-up animation-delay-100">
        <a
          href="https://www.youtube.com/@przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-red-600 hover:bg-red-500 text-white font-semibold transition-all hover:scale-105 shadow-lg shadow-red-600/25"
        >
          <MonitorPlay className="w-5 h-5" />
          Subskrybuj kanał
          <ExternalLink className="w-4 h-4" />
        </a>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {videos.map((video, index) => (
          <div class="group bg-dark-800 border border-slate-700/50 rounded-2xl overflow-hidden hover:border-red-500/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-red-500/5 animate-fade-in-up" style={`animation-delay: ${index * 50}ms`}>
            <div class={`relative aspect-video bg-gradient-to-br ${video.gradient} flex items-center justify-center`}>
              <div class="w-16 h-16 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center group-hover:scale-110 transition-transform">
                <Play className="w-8 h-8 text-white ml-1" />
              </div>
              <div class="absolute bottom-3 right-3 px-2 py-1 rounded bg-black/70 text-white text-xs font-medium">
                {video.duration}
              </div>
            </div>
            <div class="p-6">
              <h3 class="text-base font-semibold text-white mb-2 line-clamp-2 group-hover:text-red-400 transition-colors">
                {video.title}
              </h3>
              <p class="text-slate-400 text-sm mb-4 line-clamp-2">{video.description}</p>
              <div class="flex items-center gap-4 text-xs text-slate-500">
                <span class="flex items-center gap-1">
                  <Eye className="w-3 h-3" />
                  {video.views} wyświetleń
                </span>
                <span class="flex items-center gap-1">
                  <ThumbsUp className="w-3 h-3" />
                  {video.likes}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
