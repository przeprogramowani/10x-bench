---
import Layout from '../layouts/Layout.astro';
import { Podcast, Headphones, Calendar, Clock, ExternalLink } from 'lucide-react';

const episodes = [
  {
    title: '5 Agent Skills do jakościowego programowania z AI - Claude Code LIVE DEMO',
    date: 'Maj 2026',
    duration: '45 min',
    description: 'Poznaj 5 kluczowych umiejętności, które pozwolą Ci efektywnie programować z wykorzystaniem AI i Claude Code.'
  },
  {
    title: 'Product Builders Day | LIVE AI Product Heroes i 10xDevs',
    date: 'Maj 2026',
    duration: '1h 20min',
    description: 'Relacja z wydarzenia Product Builders Day - jak AI zmienia sposób budowania produktów technologicznych.'
  },
  {
    title: 'Wybierasz model AI do kodowania? Nie ufaj benchmarkom',
    date: 'Kwi 2026',
    duration: '35 min',
    description: 'Dlaczego benchmarki nie zawsze odzwierciedlają rzeczywiste możliwości modeli AI w codziennej pracy programisty.'
  },
  {
    title: 'Claude Code w rękach Product Buildera | LIVE AI Product Heroes x 10xDevs',
    date: 'Kwi 2026',
    duration: '55 min',
    description: 'Live demo pokazujące możliwości Claude Code w rękach doświadczonego Product Buildera.'
  },
  {
    title: 'MVP w Claude Code - Context Engineering, kontrola Agenta i refaktoryzacja',
    date: 'Kwi 2026',
    duration: '48 min',
    description: 'Jak efektywnie budować MVP wykorzystując Claude Code - techniki Context Engineering i kontroli Agenta.'
  },
  {
    title: 'Od chaosu do AI-Native Infrastructure - budujemy platformę dla zespołu',
    date: 'Mar 2026',
    duration: '1h 10min',
    description: 'Case study budowy platformy AI-Native dla zespołu programistycznego - od koncepcji do wdrożenia.'
  }
];
---

<Layout title="Podcast - Przeprogramowani.pl" description="Posłuchaj podcastu Przeprogramowanych o programowaniu, AI i rozwoju kariery.">
  <section class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-6">
          <Podcast className="w-4 h-4" />
          <span>Przeprogramowany Podcast</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
          Posłuchaj{' '}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">
            podcastu
          </span>
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Rozmowy o programowaniu, sztucznej inteligencji i rozwoju kariery w branży IT.
        </p>
      </div>

      <div class="flex justify-center gap-4 mb-12 animate-fade-in-up animation-delay-100">
        <a
          href="https://open.spotify.com/show/2v0fC8PyeeiQjNiZR7hR1n"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#1DB954]/10 border border-[#1DB954]/20 text-[#1DB954] hover:bg-[#1DB954]/20 transition-colors font-medium"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          Spotify
        </a>
        <a
          href="https://www.youtube.com/@przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition-colors font-medium"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
        <a
          href="https://anchor.fm/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-purple-500/10 border border-purple-500/20 text-purple-400 hover:bg-purple-500/20 transition-colors font-medium"
        >
          <ExternalLink className="w-5 h-5" />
          Anchor
        </a>
      </div>

      <div class="space-y-4">
        {episodes.map((episode, index) => (
          <div class="group bg-dark-800 border border-slate-700/50 rounded-xl p-6 hover:border-brand-500/30 transition-all duration-300 animate-fade-in-up" style={`animation-delay: ${index * 50}ms`}>
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform">
                <Headphones className="w-6 h-6 text-brand-400" />
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-brand-400 transition-colors">
                  {episode.title}
                </h3>
                <p class="text-slate-400 text-sm mb-3">{episode.description}</p>
                <div class="flex items-center gap-4 text-xs text-slate-500">
                  <span class="flex items-center gap-1">
                    <Calendar className="w-3 h-3" />
                    {episode.date}
                  </span>
                  <span class="flex items-center gap-1">
                    <Clock className="w-3 h-3" />
                    {episode.duration}
                  </span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
