---
import Layout from '../layouts/Layout.astro';
import { Users, Target, Heart, Code2, Globe, MessageSquare, Mail } from 'lucide-react';

const founders = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-Founder',
    description: 'Lead Front-End Engineer i Front-End Manager w globalnych firmach produktowych takich jak DAZN i Cabify. Autor programów szkoleniowych, kursów i podcastów promujących szersze spojrzenie na programowanie.',
    image: 'PS',
    color: 'brand',
    links: {
      twitter: 'https://twitter.com/psmyrdek',
      linkedin: 'https://linkedin.com/in/psmyrdek',
      email: 'mailto:przemek@przeprogramowani.pl'
    }
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-Founder',
    description: 'Lead techniczny Platformy Frontendowej w SmartRecruiters. Pasjonat neuronauki, tworzy materiały edukacyjne z uwzględnieniem badań dot. efektywnego przyswajania wiedzy. Autor podcastów z najciekawszymi osobami z branży IT.',
    image: 'MC',
    color: 'blue',
    links: {
      twitter: 'https://twitter.com/mczarkowski',
      linkedin: 'https://linkedin.com/in/marcinczarkowski',
      email: 'mailto:marcin@przeprogramowani.pl'
    }
  }
];

const values = [
  {
    icon: Target,
    title: 'Pragmatyzm',
    description: 'Łączymy teorię z praktyką w najbardziej użyteczny dla programisty sposób.'
  },
  {
    icon: Heart,
    title: 'Społeczność',
    description: 'Tworzymy przestrzeń do wzajemnego rozwoju i wymiany wiedzy między programistami.'
  },
  {
    icon: Code2,
    title: 'Jakość',
    description: 'Stawiamy na najwyższą jakość materiałów edukacyjnych i doświadczenie uczestników.'
  }
];
---

<Layout title="O nas - Przeprogramowani.pl" description="Poznaj zespół Przeprogramowanych i naszą misję edukacyjną.">
  <section class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium mb-6">
          <Users className="w-4 h-4" />
          <span>Zespół</span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6">
          Poznaj{' '}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">
            Przeprogramowanych
          </span>
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Działamy od 2019 roku, tworząc wartościowe treści dla społeczności programistów. Naszą misją jest promowanie szerszego spojrzenia na programowanie.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-20">
        {founders.map((founder, index) => (
          <div class={`group bg-dark-800 border border-slate-700/50 rounded-2xl p-8 hover:border-brand-500/30 transition-all duration-300 animate-fade-in-up animation-delay-${(index + 1) * 100}`}>
            <div class="flex items-start gap-6">
              <div class={`w-20 h-20 rounded-2xl flex items-center justify-center text-2xl font-bold text-white shrink-0 ${
                founder.color === 'brand' ? 'bg-gradient-to-br from-brand-500 to-brand-700' : 'bg-gradient-to-br from-blue-500 to-blue-700'
              }`}>
                {founder.image}
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-white mb-1">{founder.name}</h3>
                <p class="text-brand-400 text-sm font-medium mb-4">{founder.role}</p>
                <p class="text-slate-400 text-sm leading-relaxed mb-6">{founder.description}</p>
                <div class="flex items-center gap-3">
                  <a href={founder.links.twitter} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg bg-slate-800 text-slate-400 hover:text-brand-400 hover:bg-slate-700 transition-colors" aria-label="Twitter">
                    <MessageSquare className="w-4 h-4" />
                  </a>
                  <a href={founder.links.linkedin} target="_blank" rel="noopener noreferrer" class="p-2 rounded-lg bg-slate-800 text-slate-400 hover:text-brand-400 hover:bg-slate-700 transition-colors" aria-label="LinkedIn">
                    <Globe className="w-4 h-4" />
                  </a>
                  <a href={founder.links.email} class="p-2 rounded-lg bg-slate-800 text-slate-400 hover:text-brand-400 hover:bg-slate-700 transition-colors" aria-label="Email">
                    <Mail className="w-4 h-4" />
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-dark-800 border border-slate-700/50 rounded-2xl p-8 sm:p-12">
        <h2 class="text-2xl sm:text-3xl font-bold text-white text-center mb-12">Nasze wartości</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {values.map((value, index) => (
            <div class="text-center animate-fade-in-up" style={`animation-delay: ${index * 100}ms`}>
              <div class="w-14 h-14 rounded-xl bg-brand-500/10 flex items-center justify-center mx-auto mb-4">
                <value.icon className="w-7 h-7 text-brand-400" />
              </div>
              <h3 class="text-lg font-bold text-white mb-2">{value.title}</h3>
              <p class="text-slate-400 text-sm leading-relaxed">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
