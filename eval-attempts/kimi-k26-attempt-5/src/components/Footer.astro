---
import { Code2, MonitorPlay, Podcast, Mail, ExternalLink } from 'lucide-react';

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark-800 border-t border-slate-800/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 text-brand-400 mb-4">
          <Code2 className="w-6 h-6" />
          <span class="font-bold text-lg">Przeprogramowani</span>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed max-w-md">
          Szersze spojrzenie na programowanie. Edukacja technologiczna, podcasty, kursy i społeczność dla ambitnych programistów.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4">Nawigacja</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-slate-400 hover:text-brand-400 text-sm transition-colors">Strona główna</a></li>
          <li><a href="/o-nas" class="text-slate-400 hover:text-brand-400 text-sm transition-colors">O nas</a></li>
          <li><a href="/podcast" class="text-slate-400 hover:text-brand-400 text-sm transition-colors">Podcast</a></li>
          <li><a href="/youtube" class="text-slate-400 hover:text-brand-400 text-sm transition-colors">YouTube</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-white mb-4">Kursy</h3>
        <ul class="space-y-2">
          <li>
            <a href="https://opanujfrontend.pl" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-brand-400 text-sm transition-colors inline-flex items-center gap-1">
              Opanuj Frontend <ExternalLink className="w-3 h-3" />
            </a>
          </li>
          <li>
            <a href="https://opanujtypescript.pl" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-brand-400 text-sm transition-colors inline-flex items-center gap-1">
              Opanuj TypeScript <ExternalLink className="w-3 h-3" />
            </a>
          </li>
          <li>
            <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-brand-400 text-sm transition-colors inline-flex items-center gap-1">
              10xDevs <ExternalLink className="w-3 h-3" />
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800/50 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-slate-500 text-sm">
        &copy; {currentYear} Przeprogramowani.pl. Wszystkie prawa zastrzeżone.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://www.youtube.com/@przeprogramowani" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-brand-400 transition-colors" aria-label="YouTube">
          <MonitorPlay className="w-5 h-5" />
        </a>
        <a href="https://open.spotify.com/show/2v0fC8PyeeiQjNiZR7hR1n" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-brand-400 transition-colors" aria-label="Spotify">
          <Podcast className="w-5 h-5" />
        </a>
        <a href="mailto:kontakt@przeprogramowani.pl" class="text-slate-400 hover:text-brand-400 transition-colors" aria-label="Email">
          <Mail className="w-5 h-5" />
        </a>
      </div>
    </div>
  </div>
</footer>
