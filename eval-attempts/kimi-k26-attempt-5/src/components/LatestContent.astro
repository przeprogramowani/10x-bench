---
import { MonitorPlay, Podcast, ArrowRight, Play, Headphones } from 'lucide-react';

const latestVideos = [
  {
    title: '5 Agent Skills do jakościowego programowania z AI - Claude Code LIVE DEMO',
    duration: '45 min',
    thumbnail: 'bg-gradient-to-br from-red-600/20 to-red-900/20'
  },
  {
    title: 'Product Builders Day | LIVE AI Product Heroes i 10xDevs',
    duration: '1h 20min',
    thumbnail: 'bg-gradient-to-br from-blue-600/20 to-blue-900/20'
  },
  {
    title: 'Wybierasz model AI do kodowania? Nie ufaj benchmarkom',
    duration: '35 min',
    thumbnail: 'bg-gradient-to-br from-green-600/20 to-green-900/20'
  }
];

const latestEpisodes = [
  {
    title: 'Claude Code w rękach Product Buildera | LIVE AI Product Heroes x 10xDevs',
    date: 'Maj 2026',
    duration: '55 min'
  },
  {
    title: 'MVP w Claude Code - Context Engineering, kontrola Agenta i refaktoryzacja',
    date: 'Kwi 2026',
    duration: '48 min'
  },
  {
    title: 'Od chaosu do AI-Native Infrastructure - budujemy platformę dla zespołu',
    date: 'Kwi 2026',
    duration: '1h 10min'
  }
];
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 animate-fade-in-up">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
        Najnowsze{' '}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">
          treści
        </span>
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        Rozwój nowoczesnego programista - filmy i podcasty
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <div class="animate-fade-in-up animation-delay-100">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-red-500/10 flex items-center justify-center">
              <MonitorPlay className="w-5 h-5 text-red-400" />
            </div>
            <h3 class="text-xl font-bold text-white">YouTube</h3>
          </div>
          <a
            href="/youtube"
            class="inline-flex items-center gap-1 text-sm text-brand-400 hover:text-brand-300 font-medium transition-colors"
          >
            Zobacz wszystkie
            <ArrowRight className="w-4 h-4" />
          </a>
        </div>

        <div class="space-y-4">
          {latestVideos.map(video => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-dark-800 border border-slate-700/50 hover:border-red-500/30 transition-all cursor-pointer">
              <div class={`w-24 h-16 rounded-lg ${video.thumbnail} flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform`}>
                <Play className="w-6 h-6 text-white/80" />
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-medium text-white line-clamp-2 group-hover:text-red-400 transition-colors">
                  {video.title}
                </h4>
                <p class="text-xs text-slate-500 mt-1">{video.duration}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="animate-fade-in-up animation-delay-200">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center">
              <Podcast className="w-5 h-5 text-brand-400" />
            </div>
            <h3 class="text-xl font-bold text-white">Podcast</h3>
          </div>
          <a
            href="/podcast"
            class="inline-flex items-center gap-1 text-sm text-brand-400 hover:text-brand-300 font-medium transition-colors"
          >
            Zobacz wszystkie
            <ArrowRight className="w-4 h-4" />
          </a>
        </div>

        <div class="space-y-4">
          {latestEpisodes.map(episode => (
            <div class="group flex items-start gap-4 p-4 rounded-xl bg-dark-800 border border-slate-700/50 hover:border-brand-500/30 transition-all cursor-pointer">
              <div class="w-12 h-12 rounded-lg bg-brand-500/10 flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform">
                <Headphones className="w-5 h-5 text-brand-400" />
              </div>
              <div class="flex-1 min-w-0">
                <h4 class="text-sm font-medium text-white line-clamp-2 group-hover:text-brand-400 transition-colors">
                  {episode.title}
                </h4>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-xs text-slate-500">{episode.date}</span>
                  <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                  <span class="text-xs text-slate-500">{episode.duration}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
