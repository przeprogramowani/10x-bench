---
import { ArrowRight, Zap, BookOpen, Users } from 'lucide-react';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-900/20 via-dark-900 to-dark-900"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-brand-800/10 via-transparent to-transparent"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="space-y-8 animate-fade-in-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-400 text-sm font-medium">
          <Zap className="w-4 h-4" />
          <span>Nowość! 10xDevs 3.0 - Programuj z AI</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight">
          Szersze spojrzenie na{' '}
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-400 to-brand-600">
            programowanie
          </span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-400 leading-relaxed max-w-xl">
          Edukacja technologiczna w epoce AI. Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://10xdevs.pl"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-brand-600 hover:bg-brand-500 text-white font-semibold transition-all hover:scale-105 shadow-lg shadow-brand-600/25"
          >
            <Zap className="w-5 h-5" />
            Poznaj 10xDevs
            <ArrowRight className="w-5 h-5" />
          </a>
          <a
            href="/o-nas"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl bg-slate-800 hover:bg-slate-700 text-white font-semibold transition-all border border-slate-700"
          >
            <Users className="w-5 h-5" />
            Poznaj nas
          </a>
        </div>

        <div class="flex items-center gap-6 pt-4">
          <div class="flex items-center gap-2 text-slate-500 text-sm">
            <BookOpen className="w-4 h-4" />
            <span>7 lat na rynku</span>
          </div>
          <div class="w-1 h-1 rounded-full bg-slate-600"></div>
          <div class="flex items-center gap-2 text-slate-500 text-sm">
            <Users className="w-4 h-4" />
            <span>15 000+ programistów</span>
          </div>
        </div>
      </div>

      <div class="relative animate-fade-in-up animation-delay-200">
        <div class="absolute -inset-4 bg-gradient-to-r from-brand-500/20 to-brand-700/20 rounded-3xl blur-2xl"></div>
        <div class="relative bg-dark-800 border border-slate-700/50 rounded-2xl p-6 sm:p-8 shadow-2xl">
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-xl bg-brand-500/10 flex items-center justify-center">
                <Zap className="w-6 h-6 text-brand-400" />
              </div>
              <div>
                <h3 class="font-bold text-white">10xDevs 3.0</h3>
                <p class="text-sm text-slate-400">Nowe oblicze programowania z AI</p>
              </div>
            </div>

            <div class="space-y-3">
              <div class="flex items-start gap-3 p-3 rounded-lg bg-dark-900/50 border border-slate-800/50">
                <div class="w-2 h-2 rounded-full bg-brand-400 mt-2 shrink-0"></div>
                <p class="text-sm text-slate-300">Techniki i narzędzia pozwalające świadomie stosować AI w całym cyklu wytwarzania oprogramowania</p>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-dark-900/50 border border-slate-800/50">
                <div class="w-2 h-2 rounded-full bg-brand-400 mt-2 shrink-0"></div>
                <p class="text-sm text-slate-300">Generatywne AI w praktyce programistycznej</p>
              </div>
              <div class="flex items-start gap-3 p-3 rounded-lg bg-dark-900/50 border border-slate-800/50">
                <div class="w-2 h-2 rounded-full bg-brand-400 mt-2 shrink-0"></div>
                <p class="text-sm text-slate-300">Od chaosu do AI-Native Infrastructure</p>
              </div>
            </div>

            <a
              href="https://10xdevs.pl"
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full text-center py-3 rounded-lg bg-brand-600 hover:bg-brand-500 text-white font-medium transition-colors"
            >
              Zobacz szczegóły
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
