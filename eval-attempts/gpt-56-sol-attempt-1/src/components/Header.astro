---
import Logo from './Logo.astro';
import MobileMenu from './MobileMenu';

const path = Astro.url.pathname;
const links = [
  { href: '/o-nas', label: 'O nas' },
  { href: '/podcast', label: 'Podcast' },
  { href: '/youtube', label: 'YouTube' },
  { href: '/#kursy', label: 'Kursy' },
];
---

<header class="sticky top-0 z-50 border-b border-white/[.06] bg-ink/80 backdrop-blur-xl">
  <div class="container-shell flex h-[4.5rem] items-center justify-between">
    <Logo light />
    <nav class="hidden items-center gap-1 md:flex" aria-label="Nawigacja główna">
      {links.map(link => (
        <a href={link.href} class:list={["rounded-full px-4 py-2 text-sm font-semibold transition", path === link.href ? "bg-white/10 text-white" : "text-white/60 hover:text-white"]}>{link.label}</a>
      ))}
    </nav>
    <a href="https://10xdevs.pl" target="_blank" rel="noreferrer" class="group hidden items-center gap-2 rounded-full bg-electric px-5 py-2.5 text-sm font-extrabold text-ink transition hover:bg-white md:inline-flex">
      10xDevs <span class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">↗</span>
    </a>
    <MobileMenu client:load />
  </div>
</header>
