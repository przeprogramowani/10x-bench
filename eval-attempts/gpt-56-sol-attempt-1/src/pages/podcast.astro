---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PodcastCard from '../components/PodcastCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { podcastEpisodes } from '../data/content';
---

<BaseLayout title="Podcast — Przeprogramowani" description="Najnowsze odcinki podcastów Opanuj.AI i Przeprogramowani ft. Gość. Rozmowy o technologii, AI, programowaniu i karierze.">
  <PageHero eyebrow="Podcasty" title="Wiedza, która dobrze" accent="brzmi." description="Dwie serie, jedno szersze spojrzenie. Comiesięczny radar AI oraz rozmowy z ludźmi, którzy wiedzą, co dzieje się poza tutorialem." />

  <section class="section-pad container-shell">
    <div class="grid gap-5 lg:grid-cols-2">
      <a href="https://open.spotify.com/show/3D6LmchBdoqL2sWkQjvWOy" target="_blank" rel="noreferrer" class="group grid overflow-hidden rounded-[1.75rem] border border-violet/20 bg-[linear-gradient(135deg,rgba(131,120,255,.18),rgba(16,19,29,.8))] sm:grid-cols-[.6fr_1fr]">
        <img src="/images/opanuj-ai-podcast.jpg" alt="Okładka Opanuj.AI Podcast" width="400" height="400" class="size-full min-h-60 object-cover" />
        <div class="flex flex-col justify-center p-7 sm:p-8"><p class="text-[10px] font-extrabold uppercase tracking-[.15em] text-violet">Ponad 4000 słuchaczy</p><h2 class="mt-3 font-display text-3xl font-bold tracking-[-.05em]">Opanuj.AI Podcast</h2><p class="mt-3 text-sm leading-6 text-white/50">Comiesięczne podsumowanie najważniejszych wydarzeń ze świata AI.</p><span class="mt-7 text-sm font-bold text-white/60 group-hover:text-electric">Słuchaj na Spotify ↗</span></div>
      </a>
      <a href="https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo" target="_blank" rel="noreferrer" class="group grid overflow-hidden rounded-[1.75rem] border border-electric/20 bg-[linear-gradient(135deg,rgba(201,255,85,.11),rgba(16,19,29,.8))] sm:grid-cols-[.6fr_1fr]">
        <img src="/images/przeprogramowani-podcast.jpg" alt="Okładka Przeprogramowani Podcast" width="400" height="400" class="size-full min-h-60 object-cover" />
        <div class="flex flex-col justify-center p-7 sm:p-8"><p class="text-[10px] font-extrabold uppercase tracking-[.15em] text-electric">Ponad 3800 słuchaczy</p><h2 class="mt-3 font-display text-3xl font-bold tracking-[-.05em]">Przeprogramowani ft. Gość</h2><p class="mt-3 text-sm leading-6 text-white/50">Rozmowy dla głodnych wiedzy — technologia, kariera i rozwój.</p><span class="mt-7 text-sm font-bold text-white/60 group-hover:text-electric">Słuchaj na Spotify ↗</span></div>
      </a>
    </div>
  </section>

  <section class="border-y border-white/[.06] bg-white/[.015]">
    <div class="section-pad container-shell">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between"><div><span class="eyebrow">Ostatnie odcinki</span><h2 class="section-title mt-5">Włącz <span class="text-white/30">ciekawość.</span></h2></div><p class="max-w-sm text-sm leading-6 text-white/45">Nowe modele, praktyka programowania i szczere rozmowy o pracy w IT.</p></div>
      <div class="mt-12 space-y-3">{podcastEpisodes.map((episode, index) => <PodcastCard episode={episode} index={index} />)}</div>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="https://open.spotify.com/show/3D6LmchBdoqL2sWkQjvWOy" target="_blank" rel="noreferrer" class="rounded-full bg-[#1ed760] px-6 py-3 text-sm font-extrabold text-ink">Spotify ↗</a>
        <a href="https://podcasts.apple.com/pl/podcast/opanuj-ai-podcast/id1690353799" target="_blank" rel="noreferrer" class="rounded-full border border-white/15 px-6 py-3 text-sm font-bold text-white">Apple Podcasts ↗</a>
        <a href="https://www.youtube.com/c/przeprogramowani" target="_blank" rel="noreferrer" class="rounded-full border border-white/15 px-6 py-3 text-sm font-bold text-white">YouTube ↗</a>
      </div>
    </div>
  </section>
  <div class="pt-20 sm:pt-28"><Newsletter /></div>
</BaseLayout>
