---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { episodes, podcastShow } from '../data/podcast';

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });

const platforms = [
  { label: 'Spotify', href: podcastShow.platforms.spotify, icon: 'spotify' },
  { label: 'Apple Podcasts', href: podcastShow.platforms.apple, icon: 'apple' },
  { label: 'opanuj.ai', href: podcastShow.platforms.web, icon: 'web' },
];
---
<BaseLayout
  title="Podcast Opanuj.AI"
  description="Opanuj.AI Podcast — najpopularniejszy polski podcast o LLM i AI. Marcin Czarkowski i Przemek Smyrdek co kilka tygodni analizują najważniejsze wydarzenia z branży."
>
  <section class="container-page pt-14 sm:pt-20">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_1fr] lg:items-center">
      <div>
        <span class="eyebrow">Podcast</span>
        <h1 class="mt-5 font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-balance sm:text-5xl md:text-6xl">
          {podcastShow.name}
        </h1>
        <p class="mt-4 font-display text-xl font-medium text-brand-700 dark:text-brand-300">
          {podcastShow.tagline}
        </p>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-600 dark:text-ink-300">
          {podcastShow.description}
        </p>
        <div class="mt-6 flex items-center gap-3 text-sm text-ink-600 dark:text-ink-300">
          <div class="flex -space-x-2">
            <span class="flex h-9 w-9 items-center justify-center rounded-full border-2 border-white bg-gradient-to-br from-brand-500 to-brand-700 font-bold text-white dark:border-ink-950">PS</span>
            <span class="flex h-9 w-9 items-center justify-center rounded-full border-2 border-white bg-gradient-to-br from-accent-400 to-accent-600 font-bold text-white dark:border-ink-950">MC</span>
          </div>
          <span>Prowadzą: {podcastShow.hosts.join(' & ')}</span>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          {platforms.map((p) => (
            <a href={p.href} target="_blank" rel="noreferrer" class="btn-ghost">
              {p.icon === 'spotify' ? (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.52 17.34c-.24.36-.72.48-1.08.24-2.94-1.8-6.66-2.22-11.04-1.2-.42.12-.84-.18-.96-.6-.12-.42.18-.84.6-.96 4.8-1.08 8.94-.6 12.18 1.38.42.18.48.72.3 1.14zm1.44-3.3c-.3.42-.9.6-1.32.3-3.36-2.1-8.52-2.7-12.48-1.5-.48.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14 4.56-1.38 10.2-.66 14.04 1.68.42.24.6.84.3 1.26zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.3c-.6.18-1.2-.18-1.38-.72-.18-.6.18-1.2.72-1.38 4.26-1.26 11.28-1.02 15.72 1.62.54.3.72 1.02.42 1.56-.3.42-1.02.6-1.56.3z"/></svg>
              ) : p.icon === 'apple' ? (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
              ) : (
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20"/></svg>
              )}
              {p.label}
            </a>
          ))}
        </div>
      </div>
      <div class="relative">
        <div class="absolute -inset-6 -z-10 rounded-3xl bg-gradient-to-br from-brand-500/30 to-accent-500/30 blur-3xl"></div>
        <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-brand-700 to-ink-900 p-8 text-white shadow-glow">
          <div class="flex items-center justify-between">
            <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider">Najnowszy odcinek</span>
            <span class="font-mono text-xs opacity-80">{formatDate(episodes[0].date)}</span>
          </div>
          <h2 class="mt-4 font-display text-2xl font-extrabold leading-tight sm:text-3xl">
            {episodes[0].title}
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-white/80">{episodes[0].summary}</p>
          <div class="mt-5 flex items-center gap-4">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-brand-700">
              <svg viewBox="0 0 24 24" class="ml-0.5 h-5 w-5" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </span>
            <div>
              <p class="font-mono text-xs text-white/60">Czas trwania</p>
              <p class="font-display text-lg font-bold">{episodes[0].duration}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page mt-24">
    <SectionHeader
      eyebrow="Odcinki"
      title="Wszystkie ostatnie odcinki"
      description="Przegląd najnowszych rozmów o AI — od benchmarków, przez modele i agentów, po zmiany w branży."
    />
    <ul class="mt-10 space-y-4">
      {episodes.map((ep, idx) => (
        <li>
          <article class="card card-hover group grid gap-5 sm:grid-cols-[auto_1fr_auto] sm:items-center">
            <div class="flex items-center gap-4 sm:flex-col sm:items-start">
              <span class="font-mono text-2xl font-extrabold text-brand-600 dark:text-brand-400">
                #{String(episodes.length - idx).padStart(2, '0')}
              </span>
              <span class="font-mono text-xs text-ink-500 dark:text-ink-400">{ep.duration}</span>
            </div>
            <div class="min-w-0">
              <p class="text-xs text-ink-500 dark:text-ink-400">{formatDate(ep.date)}</p>
              <h3 class="mt-1 font-display text-lg font-bold leading-snug text-ink-900 group-hover:text-brand-700 dark:text-white dark:group-hover:text-brand-300 sm:text-xl">
                {ep.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-300">{ep.summary}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {ep.tags.map((t) => (
                  <span class="rounded-full border border-ink-200/60 bg-ink-50/60 px-2 py-0.5 text-[11px] font-medium text-ink-600 dark:border-white/10 dark:bg-white/5 dark:text-ink-300">#{t}</span>
                ))}
              </div>
            </div>
            <div class="flex flex-col gap-2 sm:w-36">
              <a href={ep.url} target="_blank" rel="noreferrer" class="btn-primary justify-center text-sm">Słuchaj</a>
              <a href={podcastShow.platforms.spotify} target="_blank" rel="noreferrer" class="btn-ghost justify-center text-xs">
                Spotify
              </a>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
