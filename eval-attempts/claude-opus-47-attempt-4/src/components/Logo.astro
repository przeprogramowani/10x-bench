---
const { showText = true, className = '' } = Astro.props as { showText?: boolean; className?: string };
---
<a href="/" class={`inline-flex items-center gap-2.5 ${className}`} aria-label="Przeprogramowani – strona główna">
  <span class="relative inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-accent-500 text-white shadow-glow">
    <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 6l-4 6 4 6" />
      <path d="M16 6l4 6-4 6" />
    </svg>
  </span>
  {showText ? (
    <span class="font-display text-lg font-extrabold tracking-tight text-ink-900 dark:text-white">
      Przeprogramowani<span class="text-brand-600 dark:text-brand-400">.pl</span>
    </span>
  ) : null}
</a>
