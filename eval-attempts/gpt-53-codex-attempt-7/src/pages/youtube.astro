---
import MainLayout from '../layouts/MainLayout.astro';
import { getYouTubeVideos } from '../lib/feeds';
import { formatDate } from '../lib/format';
import { site } from '../lib/site';

const videos = await getYouTubeVideos(12);
---

<MainLayout
  title="YouTube | Przeprogramowani"
  description="Najnowsze filmy YouTube od Przeprogramowani."
  currentPath={Astro.url.pathname}
>
  <section class="enter-up">
    <h1 class="font-display text-4xl font-bold text-white md:text-5xl">YouTube</h1>
    <p class="mt-4 max-w-3xl text-white/75">
      Ostatnie filmy z oficjalnego kanału Przeprogramowani. Aktualizacja odbywa się automatycznie na podstawie feedu YouTube.
    </p>
  </section>

  <section class="enter-up-delay-1 mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {
      videos.map((video) => (
        <article class="card-surface overflow-hidden rounded-3xl">
          <a href={video.url} target="_blank" rel="noopener noreferrer" class="block">
            <img src={video.thumbnail} alt={video.title} loading="lazy" class="aspect-video w-full object-cover" />
            <div class="p-5">
              <p class="text-xs uppercase tracking-wide text-white/60">{formatDate(video.publishedAt)}</p>
              <h2 class="font-display mt-2 text-lg font-semibold text-white">{video.title}</h2>
              <span class="mt-4 inline-flex rounded-full border border-white/30 px-3 py-1 text-xs font-semibold text-white/90">
                Obejrzyj
              </span>
            </div>
          </a>
        </article>
      ))
    }
  </section>

  <section class="mt-10 rounded-3xl border border-white/20 bg-slate-900/80 p-6 text-sm text-white/75">
    <p>
      Subskrybuj kanał,
      <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="font-semibold text-cyan-200 hover:text-cyan-100">
        otwórz YouTube
      </a>
      i sprawdź również
      <a href="/podcast" class="font-semibold text-cyan-200 hover:text-cyan-100"> stronę podcastu</a>.
    </p>
  </section>
</MainLayout>
