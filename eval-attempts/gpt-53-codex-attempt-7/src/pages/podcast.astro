---
import MainLayout from '../layouts/MainLayout.astro';
import { getPodcastEpisodes } from '../lib/feeds';
import { formatDate } from '../lib/format';
import { site } from '../lib/site';

const episodes = await getPodcastEpisodes(12);
---

<MainLayout
  title="Podcast | Przeprogramowani"
  description="Najnowsze odcinki podcastu Przeprogramowani."
  currentPath={Astro.url.pathname}
>
  <section class="enter-up">
    <h1 class="font-display text-4xl font-bold text-white md:text-5xl">Podcast</h1>
    <p class="mt-4 max-w-3xl text-white/75">
      Najnowsze odcinki pobierane automatycznie z oficjalnego feedu podcastu. Rozmowy o programowaniu, rozwoju i AI.
    </p>
  </section>

  <section class="enter-up-delay-1 mt-10 grid gap-5 md:grid-cols-2">
    {
      episodes.map((episode) => (
        <article class="card-surface rounded-3xl p-6">
          <p class="text-xs uppercase tracking-wide text-white/60">
            {formatDate(episode.publishedAt)}
            {episode.duration ? ` · ${episode.duration}` : ''}
          </p>
          <h2 class="font-display mt-3 text-2xl font-semibold text-white">{episode.title}</h2>
          <p class="mt-4 text-sm leading-relaxed text-white/75">{episode.excerpt}</p>
          <a
            href={episode.url}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex rounded-full border border-white/30 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Słuchaj odcinka
          </a>
        </article>
      ))
    }
  </section>

  <section class="mt-10 rounded-3xl border border-white/20 bg-slate-900/80 p-6 text-sm text-white/75">
    <p>
      Chcesz więcej? Sprawdź też
      <a href="/youtube" class="font-semibold text-cyan-200 hover:text-cyan-100"> najnowsze filmy na YouTube</a>
      lub
      <a href={site.social.podcast} target="_blank" rel="noopener noreferrer" class="font-semibold text-cyan-200 hover:text-cyan-100">
        otwórz podcast na Spotify
      </a>.
    </p>
  </section>
</MainLayout>
