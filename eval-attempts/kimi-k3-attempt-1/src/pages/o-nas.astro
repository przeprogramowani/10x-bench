---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsletterCta from '../components/NewsletterCta.astro';
import { founders } from '../data/founders';
import { site } from '../data/site';

const stats = [
  { value: `${site.yearsOnMarket} lat`, label: 'na rynku edukacji technologicznej' },
  { value: '6700+', label: 'absolwentów 10xDevs' },
  { value: '4000+', label: 'słuchaczy Opanuj.AI Podcast' },
  { value: '3800+', label: 'słuchaczy podcastu ft. Gość' },
];
---

<Layout
  title="O nas — Przeprogramowani"
  description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Poznaj Przemka Smyrdka i Marcina Czarkowskiego."
>
  <section class="relative overflow-hidden border-b border-zinc-800/60">
    <div class="bg-grid absolute inset-0" aria-hidden="true"></div>
    <div
      class="absolute -top-32 left-1/2 h-72 w-[36rem] -translate-x-1/2 rounded-full bg-yellow-400/10 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-24 lg:px-8">
      <nav class="mb-6 text-sm text-zinc-500" aria-label="Okruszki">
        <a href="/" class="transition hover:text-yellow-400">Strona główna</a>
        <span class="mx-2">/</span>
        <span class="text-zinc-300">O nas</span>
      </nav>
      <SectionHeading
        align="left"
        eyebrow="O nas"
        title="Witaj na Przeprogramowanych!"
        description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie. Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach — od technicznych deep-dive'ów po rozmowy o karierze i rozwoju."
      />
      <p class="mt-6 font-display text-xl font-semibold text-yellow-400">
        Zyskaj szersze spojrzenie na programowanie.
      </p>
    </div>
  </section>

  {/* Statystyki */}
  <section class="border-b border-zinc-800/60 bg-zinc-900/30">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-px lg:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="px-6 py-10 text-center">
            <p class="font-display text-3xl font-bold text-yellow-400 sm:text-4xl">{stat.value}</p>
            <p class="mt-2 text-sm text-zinc-400">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* Założyciele */}
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <SectionHeading
      eyebrow="Założyciele"
      title="Łączymy świat programowania, biznesu i rozwoju"
      description="Dwóch inżynierów i liderów z wieloletnim doświadczeniem w międzynarodowych firmach produktowych."
    />
    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      {
        founders.map((founder) => (
          <article class="flex flex-col gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/60 p-7 transition hover:border-zinc-600 sm:flex-row">
            <img
              src={founder.photo}
              alt={founder.name}
              loading="lazy"
              class="h-28 w-28 shrink-0 rounded-2xl border border-zinc-800 object-cover"
            />
            <div>
              <h3 class="font-display text-xl font-bold text-zinc-50">{founder.name}</h3>
              <p class="mt-1 text-sm font-semibold text-yellow-400">{founder.role}</p>
              <p class="mt-3 text-sm leading-relaxed text-zinc-400">{founder.bio}</p>
              <ul class="mt-4 space-y-1.5">
                {founder.facts.map((fact) => (
                  <li class="flex items-start gap-2 text-sm text-zinc-400">
                    <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-yellow-400" aria-hidden="true" />
                    {fact}
                  </li>
                ))}
              </ul>
              <a
                href={founder.linkedin}
                target="_blank"
                rel="noopener"
                class="mt-5 inline-flex items-center gap-2 rounded-full border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-zinc-500 hover:bg-zinc-800/60"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 text-[#0a66c2]">
                  <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57z" />
                </svg>
                LinkedIn
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  {/* Zaufali nam */}
  <section class="border-y border-zinc-800/60 bg-zinc-900/30">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Zaufali nam"
        title="Firmy, z którymi współpracowaliśmy"
        description={`${site.yearsOnMarket} lat na rynku edukacji technologicznej. Chcesz nawiązać współpracę? Napisz: `}
      />
      <p class="mt-2 text-center">
        <a href={`mailto:${site.email}`} class="font-semibold text-yellow-400 hover:underline">
          {site.email}
        </a>
      </p>
      <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
        {
          site.brands.map((brand) => (
            <div class="flex items-center justify-center rounded-2xl border border-zinc-800 bg-zinc-900/60 px-4 py-6 text-center transition hover:border-zinc-600">
              <span class="font-display text-sm font-semibold text-zinc-300">{brand}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <NewsletterCta />
</Layout>
