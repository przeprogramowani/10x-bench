---
import { navLinks } from '../data/site';
import MobileNav from './MobileNav';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : !href.includes('#') && pathname.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-zinc-800/80 bg-zinc-950/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="flex items-center gap-2.5 font-display text-lg font-bold tracking-tight text-zinc-50 transition hover:text-yellow-400"
    >
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-yellow-400 font-mono text-sm font-bold text-zinc-950"
        aria-hidden="true">&lt;/&gt;</span
      >
      Przeprogramowani
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Nawigacja główna">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-full px-4 py-2 text-sm font-medium transition',
              isActive(link.href)
                ? 'bg-zinc-800 text-yellow-400'
                : 'text-zinc-400 hover:bg-zinc-800/60 hover:text-zinc-100',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="https://10xdevs.pl"
        target="_blank"
        rel="noopener"
        class="ml-3 rounded-full bg-yellow-400 px-5 py-2 text-sm font-semibold text-zinc-950 transition hover:bg-yellow-300"
      >
        10xDevs
      </a>
    </nav>

    <MobileNav client:load currentPath={pathname} />
  </div>
</header>
