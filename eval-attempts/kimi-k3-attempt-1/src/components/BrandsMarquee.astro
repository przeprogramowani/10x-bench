---
import { site } from '../data/site';

const doubled = [...site.brands, ...site.brands];
---

<section class="border-b border-zinc-800/60 bg-zinc-950 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center gap-3 text-center">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-zinc-500">Zaufali nam</p>
      <p class="text-sm text-zinc-400">
        <strong class="font-display text-xl font-bold text-yellow-400">{site.yearsOnMarket} lat</strong>
        na rynku edukacji technologicznej
      </p>
    </div>
  </div>
  <div class="relative mt-8 overflow-hidden" aria-hidden="true">
    <div
      class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-zinc-950 to-transparent"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-zinc-950 to-transparent"
    >
    </div>
    <div class="flex w-max animate-marquee gap-4">
      {
        doubled.map((brand) => (
          <span class="whitespace-nowrap rounded-full border border-zinc-800 bg-zinc-900/60 px-6 py-2.5 font-display text-sm font-semibold text-zinc-400">
            {brand}
          </span>
        ))
      }
    </div>
  </div>
</section>
