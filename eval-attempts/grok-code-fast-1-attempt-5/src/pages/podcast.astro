---
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';
---

<html lang="pl">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Podcast - Przeprogramowani.pl</title>
	</head>
	<body class="bg-gray-100">
		<Navbar client:load />
		<main class="py-12">
			<div class="max-w-7xl mx-auto px-4">
				<h1 class="text-4xl font-bold mb-8">Podcast</h1>
				<p class="text-gray-700 mb-8">Rozwój nowoczesnego programisty - słuchaj najnowszych odcinków.</p>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					<article class="bg-white rounded-lg shadow-md p-6">
						<h3 class="text-xl font-bold mb-2">Episode Title 1</h3>
						<p class="text-gray-700 mb-4">Description of the episode...</p>
						<a href="#" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">Słuchaj</a>
					</article>
					<article class="bg-white rounded-lg shadow-md p-6">
						<h3 class="text-xl font-bold mb-2">Episode Title 2</h3>
						<p class="text-gray-700 mb-4">Description of the episode...</p>
						<a href="#" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">Słuchaj</a>
					</article>
				</div>
			</div>
		</main>
		<Footer client:load />
	</body>
</html>