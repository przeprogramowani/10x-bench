---
import { navLinks, site } from '../data/site';
import MobileMenu from './MobileMenu.tsx';

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  if (href.startsWith('/#')) return false;
  return pathname.startsWith(href);
};
---

<header class="sticky top-0 z-40 backdrop-blur-xl">
  <div class="absolute inset-0 -z-10 bg-ink-950/70 border-b border-white/5"></div>
  <div class="container-page flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-2.5" aria-label={site.name}>
      <span class="relative grid h-9 w-9 place-items-center overflow-hidden rounded-xl bg-gradient-to-br from-brand-500 to-accent-500">
        <span class="font-display text-lg font-bold text-white">P</span>
        <span class="absolute -inset-0.5 rounded-xl bg-gradient-to-br from-brand-400 to-accent-400 opacity-0 blur transition-opacity group-hover:opacity-60"></span>
      </span>
      <span class="font-display text-lg font-semibold tracking-tight text-white">
        Przeprogramowani
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Główna nawigacja">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'rounded-full px-4 py-2 text-sm font-medium transition-colors',
            isActive(href)
              ? 'text-white bg-white/10'
              : 'text-slate-400 hover:text-white hover:bg-white/5',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a href="https://10xdevs.pl" class="btn-primary text-sm px-5 py-2.5" target="_blank" rel="noreferrer">
        10xDevs
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M7 17 17 7M8 7h9v9" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <MobileMenu client:load links={navLinks} />
  </div>
</header>
