---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="relative mt-24 border-t border-white/5 bg-ink-950/80">
  <div class="absolute inset-0 -z-10 bg-hero-glow opacity-20"></div>
  <div class="container-page grid gap-12 py-16 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2.5">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-accent-500">
          <span class="font-display text-lg font-bold text-white">P</span>
        </span>
        <span class="font-display text-lg font-semibold text-white">Przeprogramowani</span>
      </div>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-slate-400">
        {site.description}
      </p>
      <div class="mt-6 flex flex-wrap gap-2">
        <a href={site.social.youtube} target="_blank" rel="noreferrer" class="chip hover:border-white/30 hover:text-white">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23 7.5c-.3-1.1-1.1-1.9-2.2-2.2C18.7 4.8 12 4.8 12 4.8s-6.7 0-8.8.5C2.1 5.6 1.3 6.4 1 7.5.5 9.6.5 12 .5 12s0 2.4.5 4.5c.3 1.1 1.1 1.9 2.2 2.2 2.1.5 8.8.5 8.8.5s6.7 0 8.8-.5c1.1-.3 1.9-1.1 2.2-2.2.5-2.1.5-4.5.5-4.5s0-2.4-.5-4.5zM9.8 15.5V8.5l5.8 3.5-5.8 3.5z"/></svg>
          YouTube
        </a>
        <a href={site.social.spotify} target="_blank" rel="noreferrer" class="chip hover:border-white/30 hover:text-white">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.6.6 0 01-.9.2c-2.4-1.5-5.5-1.8-9.1-1a.6.6 0 11-.3-1.2c4-.9 7.4-.5 10.1 1.1.3.2.4.6.2.9zm1.2-2.7a.8.8 0 01-1 .3c-2.7-1.7-6.9-2.2-10.2-1.2a.8.8 0 11-.4-1.5c3.7-1.1 8.3-.6 11.4 1.3.3.2.4.7.2 1.1zm.1-2.8c-3.3-1.9-8.6-2.1-11.7-1.2a.9.9 0 11-.5-1.8c3.6-1.1 9.4-.9 13.2 1.4a.9.9 0 11-1 1.6z"/></svg>
          Spotify
        </a>
        <a href={site.social.substack} target="_blank" rel="noreferrer" class="chip hover:border-white/30 hover:text-white">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h16v2.5H4zm0 4.5h16V11H4zm0 4.5h16v8l-8-4.5-8 4.5z"/></svg>
          Newsletter
        </a>
        <a href={site.social.github} target="_blank" rel="noreferrer" class="chip hover:border-white/30 hover:text-white">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A11.5 11.5 0 00.5 12a11.5 11.5 0 007.9 10.9c.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.2c0 .3.2.7.8.6A11.5 11.5 0 0023.5 12 11.5 11.5 0 0012 .5z"/></svg>
          GitHub
        </a>
      </div>
    </div>

    <div>
      <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-300">Nawigacja</h4>
      <ul class="space-y-2 text-sm text-slate-400">
        <li><a href="/" class="hover:text-white">Start</a></li>
        <li><a href="/o-nas" class="hover:text-white">O nas</a></li>
        <li><a href="/podcast" class="hover:text-white">Podcast</a></li>
        <li><a href="/youtube" class="hover:text-white">YouTube</a></li>
        <li><a href="/#kursy" class="hover:text-white">Kursy</a></li>
      </ul>
    </div>

    <div>
      <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-300">Kontakt</h4>
      <ul class="space-y-2 text-sm text-slate-400">
        <li><a href={`mailto:${site.email}`} class="hover:text-white">{site.email}</a></li>
        <li><a href="https://10xdevs.pl" target="_blank" rel="noreferrer" class="hover:text-white">10xDevs.pl</a></li>
        <li><a href="https://opanujfrontend.pl" target="_blank" rel="noreferrer" class="hover:text-white">Opanuj Frontend</a></li>
        <li><a href="https://opanujtypescript.pl" target="_blank" rel="noreferrer" class="hover:text-white">Opanuj TypeScript</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/5 py-6">
    <div class="container-page flex flex-col items-center justify-between gap-3 text-xs text-slate-500 sm:flex-row">
      <span>© {year} Przeprogramowani. Edukacja technologiczna w epoce AI.</span>
      <span>Zbudowane z Astro, React i Tailwind · deploy na Cloudflare</span>
    </div>
  </div>
</footer>
