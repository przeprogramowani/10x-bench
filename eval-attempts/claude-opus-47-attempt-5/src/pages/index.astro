---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CourseCard from '../components/CourseCard.tsx';
import { courses } from '../data/courses';
import { episodes } from '../data/episodes';
import { videos } from '../data/videos';
import { site } from '../data/site';

const latestEpisodes = episodes.slice(0, 3);
const latestVideos = videos.slice(0, 3);
const otherCourses = courses.filter((c) => c.id !== '10xdevs');

const partnerLogos = ['Autodesk', 'Huuuge Games', 'SmartRecruiters', 'Callstack', 'DAZN', 'Cabify'];
---

<BaseLayout>
  <Hero />

  <!-- Social proof / partners -->
  <section class="border-y border-white/5 bg-ink-950/50" aria-label="Zaufali nam">
    <div class="container-x py-10">
      <p class="text-center text-xs uppercase tracking-[0.25em] text-ink-400">
        Pracowaliśmy i współpracujemy z
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 text-ink-300">
        {partnerLogos.map((logo) => (
          <span class="text-base font-semibold tracking-tight opacity-70 transition-opacity hover:opacity-100">
            {logo}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Courses section -->
  <section class="py-20" aria-labelledby="kursy-heading">
    <div class="container-x">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <SectionHeading
            eyebrow="Nasze kursy"
            title="Kursy, które przenoszą Cię na kolejny poziom"
            lead="Trzy programy, jedna filozofia — szersze spojrzenie na programowanie. Wybierz ten, który najlepiej pasuje do Twojej ścieżki rozwoju."
          />
          <h2 id="kursy-heading" class="sr-only">Kursy</h2>
        </div>
        <a href="/kursy" class="btn-secondary text-sm">Wszystkie kursy →</a>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {otherCourses.map((course) => (
          <CourseCard course={course} client:visible />
        ))}
      </div>
    </div>
  </section>

  <!-- Podcast section -->
  <section class="py-20" aria-labelledby="podcast-heading">
    <div class="container-x">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <SectionHeading
            eyebrow="Podcast"
            title="Szersze spojrzenie na programowanie"
            lead="Rozmawiamy z ekspertami o architekturze, karierze, nauce i tym, co kształtuje dobrych programistów."
          />
          <h2 id="podcast-heading" class="sr-only">Podcast</h2>
        </div>
        <div class="flex gap-3">
          <a href={site.social.spotify} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
            Spotify
          </a>
          <a href="/podcast" class="btn-secondary text-sm">Wszystkie odcinki →</a>
        </div>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {latestEpisodes.map((ep) => (
          <a
            href={ep.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group card flex flex-col"
          >
            <div class="flex items-center gap-2 text-xs text-ink-400">
              <time datetime={ep.date}>{new Date(ep.date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'short', year: 'numeric' })}</time>
              <span aria-hidden="true">·</span>
              <span>{ep.duration}</span>
            </div>
            <h3 class="mt-3 text-lg font-semibold text-white group-hover:text-brand-200 transition-colors">
              {ep.title}
            </h3>
            <p class="mt-3 flex-1 text-sm text-ink-300 line-clamp-3">{ep.description}</p>
            <span class="mt-4 text-sm font-medium text-ink-200 group-hover:text-white">
              Posłuchaj →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- YouTube section -->
  <section class="py-20" aria-labelledby="youtube-heading">
    <div class="container-x">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <SectionHeading
            eyebrow="YouTube"
            title="Najnowsze filmy z naszego kanału"
            lead="Praktyczny frontend, TypeScript, AI i wszystko to, co w codziennej pracy programisty naprawdę ma znaczenie."
          />
          <h2 id="youtube-heading" class="sr-only">YouTube</h2>
        </div>
        <div class="flex gap-3">
          <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm">
            Subskrybuj
          </a>
          <a href="/youtube" class="btn-secondary text-sm">Wszystkie filmy →</a>
        </div>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {latestVideos.map((video) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-white/[0.03] transition-colors hover:border-white/20 hover:bg-white/[0.05]"
          >
            <div class="relative aspect-video overflow-hidden">
              <div aria-hidden="true" class="absolute inset-0 bg-gradient-to-br from-brand-600/40 via-accent-600/30 to-ink-900"></div>
              <div aria-hidden="true" class="absolute inset-0 bg-grid opacity-30"></div>
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="grid h-14 w-14 place-items-center rounded-full bg-white/10 backdrop-blur transition-transform group-hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="h-6 w-6" aria-hidden="true">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </div>
              <span class="absolute bottom-3 right-3 rounded-md bg-ink-950/80 px-2 py-0.5 text-xs font-mono text-ink-100 backdrop-blur">
                {video.duration}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-5">
              <time datetime={video.date} class="text-xs text-ink-400">
                {new Date(video.date).toLocaleDateString('pl-PL', { day: 'numeric', month: 'short', year: 'numeric' })}
              </time>
              <h3 class="mt-2 text-base font-semibold text-white group-hover:text-brand-200 transition-colors">
                {video.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section class="py-20">
    <div class="container-x">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-ink-900/70 p-10 md:p-16">
        <div aria-hidden="true" class="pointer-events-none absolute -top-32 -right-32 h-[400px] w-[400px] rounded-full bg-gradient-to-br from-brand-600/40 to-accent-600/40 blur-3xl"></div>
        <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-grid opacity-20"></div>

        <div class="relative max-w-2xl">
          <span class="badge">Newsletter</span>
          <h2 class="mt-4 text-3xl font-bold text-white md:text-4xl">
            Cotygodniowa dawka technicznej wiedzy.
          </h2>
          <p class="mt-4 text-ink-300">
            Dołącz do ponad 15 000 programistów, którzy co tydzień dostają od nas przegląd tego, co w świecie programowania naprawdę warte uwagi.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={site.social.newsletter} target="_blank" rel="noopener noreferrer" class="btn-primary">
              Zapisz się do newslettera
              <span aria-hidden="true">→</span>
            </a>
            <a href="/o-nas" class="btn-secondary">Poznaj nas</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
