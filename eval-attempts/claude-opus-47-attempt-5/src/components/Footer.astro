---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-white/5 bg-ink-950">
  <div class="container-x grid gap-10 py-14 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 font-semibold text-white">
        <span class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-accent-600 font-mono text-sm font-bold">
          &gt;_
        </span>
        <span class="text-lg tracking-tight">{site.name}</span>
      </div>
      <p class="mt-4 max-w-md text-sm leading-relaxed text-ink-300">
        {site.description}
      </p>
      <a href={site.social.newsletter} target="_blank" rel="noopener noreferrer" class="btn-secondary mt-6 text-sm">
        Zapisz się do newslettera
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-ink-200">Nawigacja</h3>
      <ul class="mt-4 space-y-3 text-sm">
        {site.nav.map((item) => (
          <li>
            <a href={item.href} class="text-ink-300 hover:text-white">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-ink-200">Znajdź nas</h3>
      <ul class="mt-4 space-y-3 text-sm">
        <li>
          <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="text-ink-300 hover:text-white">
            YouTube
          </a>
        </li>
        <li>
          <a href={site.social.spotify} target="_blank" rel="noopener noreferrer" class="text-ink-300 hover:text-white">
            Spotify — Podcast
          </a>
        </li>
        <li>
          <a href={site.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-ink-300 hover:text-white">
            LinkedIn
          </a>
        </li>
        <li>
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="text-ink-300 hover:text-white">
            Instagram
          </a>
        </li>
        <li>
          <a href={site.social.github} target="_blank" rel="noopener noreferrer" class="text-ink-300 hover:text-white">
            GitHub
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/5 py-6">
    <div class="container-x flex flex-col items-start justify-between gap-2 text-xs text-ink-400 md:flex-row md:items-center">
      <p>© {year} {site.name}. Wszystkie prawa zastrzeżone.</p>
      <p class="text-ink-500">Zbudowane z Astro, React i Tailwind — wdrożone na Cloudflare.</p>
    </div>
  </div>
</footer>
