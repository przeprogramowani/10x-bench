---
import Layout from '../layouts/Layout.astro';
import { Award, Code2, Users2, BookOpen, Star, Sparkles, Send, ShieldCheck } from 'lucide-react';

const team = [
  {
    name: 'Przemysław Smyrdek',
    role: 'Współzałożyciel & Mentor',
    image: 'https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?q=80&w=400&auto=format&fit=crop', // Bio photo placeholder
    bio: 'Architekt frontendu, konsultant i trener z wieloletnim doświadczeniem w projektowaniu skalowalnych aplikacji. W Przeprogramowanych odpowiada za inżynierskie podejście do kodu, zaawansowane wzorce projektowe i architekturę. Przemek dba o to, by każda linijka kodu miała swoje uzasadnienie architektoniczne i była w pełni testowalna.',
    specialties: ['Architektura aplikacji', 'React / Next.js', 'Zaawansowany TypeScript', 'Wzorce projektowe'],
    social: {
      github: 'https://github.com',
      linkedin: 'https://linkedin.com'
    }
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Współzałożyciel & Mentor',
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=400&auto=format&fit=crop',
    bio: 'Technical Leader, Product Owner i mentor kariery IT. Specjalizuje się w łączeniu celów biznesowych z pracą inżynierską oraz optymalizacji procesów dostarczania oprogramowania. Marcin dzieli się z deweloperami unikalną wiedzą o budowaniu stabilnych karier, negocjowaniu kontraktów B2B oraz rozwijaniu umiejętności miękkich, bez których nie ma mowy o poziomie Senior.',
    specialties: ['Przywództwo techniczne', 'Kariera w IT', 'Biznes i B2B', 'Zwinne metodyki (Agile)'],
    social: {
      github: 'https://github.com',
      linkedin: 'https://linkedin.com'
    }
  },
  {
    name: 'Damian Wielgosik',
    role: 'Współzałożyciel & Mentor',
    image: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=400&auto=format&fit=crop',
    bio: 'Weteran polskiej sceny frontendowej, programista, konsultant i autor tekstów technicznych. Twórca kultowych portali edukacyjnych. Ekspert od detali technicznych i działania silników JavaScript pod maską. Damian z pasją rozkłada technologie na czynniki pierwsze, ucząc rzemiosła z dala od "magii" i powierzchownych odpowiedzi.',
    specialties: ['JavaScript / V8 Engine', 'Standardy Webowe i HTML', 'Automatyzacja pracy z AI', 'Game Development'],
    social: {
      github: 'https://github.com',
      linkedin: 'https://linkedin.com'
    }
  }
];

const values = [
  {
    icon: 'Code2',
    title: 'Rzemiosło Ponad Magią',
    desc: 'Unikamy powierzchowności. Pokazujemy, jak technologie działają pod maską (silniki przeglądarek, protokoły sieciowe, bazy danych), abyś pisał świadomy kod.'
  },
  {
    icon: 'Users2',
    title: 'Edukacja Oparta o Projekty',
    desc: 'Wiedzę teoretyczną natychmiast przekładamy na praktykę. Piszesz kod, tworzysz architekturę, przechodzisz code review - dokładnie tak, jak w komercyjnych projektach.'
  },
  {
    icon: 'BookOpen',
    title: 'Niezależność i Elastyczność',
    desc: 'Dążymy do tego, by nasi absolwenci nie byli przywiązani do jednego frameworka, lecz potrafili z łatwością adaptować się do stale zmieniającego się rynku.'
  }
];
---

<Layout title="O nas | Założyciele i Misja">
  {/* Header Section */}
  <section class="relative overflow-hidden py-20 lg:py-28 bg-brand-dark">
    <div class="absolute top-1/4 left-1/2 -z-10 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-brand-orange/10 blur-[120px]" />
    
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center space-y-6">
      <div class="inline-flex items-center gap-1.5 rounded-full border border-brand-orange/30 bg-brand-orange/10 px-4 py-1.5 text-xs font-semibold text-brand-orange-light">
        <Sparkles class="h-3.5 w-3.5" />
        Poznaj autorów projektu
      </div>
      <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl text-white">
        Trzy różne perspektywy,<br />
        <span class="gradient-text-orange font-black">jeden wspólny cel</span>
      </h1>
      <p class="text-lg text-gray-400 max-w-2xl mx-auto leading-relaxed">
        Założyliśmy Przeprogramowani.pl, ponieważ brakowało nam w sieci miejsca, które uczy programowania od strony inżynierskiej, pragmatycznej i biznesowej. Chcieliśmy stworzyć standard edukacji, którego sami szukaliśmy na początku naszych karier.
      </p>
    </div>
  </section>

  {/* Founders Bios Grid */}
  <section class="py-16 bg-brand-dark/95 relative border-t border-gray-800/60">
    <div class="absolute bottom-1/3 right-10 -z-10 h-72 w-72 rounded-full bg-brand-purple/5 blur-[100px]" />
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        {team.map((founder, idx) => (
          <div key={idx} class="group flex flex-col justify-between overflow-hidden rounded-3xl border border-gray-800 bg-brand-dark-card/40 p-6 sm:p-8 hover:border-brand-orange/30 transition-all duration-300">
            <div class="space-y-6">
              {/* Photo & Identity */}
              <div class="flex items-center gap-4">
                <div class="relative h-16 w-16 overflow-hidden rounded-2xl bg-gray-800 border-2 border-brand-orange/20">
                  <img
                    src={founder.image}
                    alt={founder.name}
                    class="h-full w-full object-cover grayscale transition-all duration-500 group-hover:grayscale-0 group-hover:scale-105"
                  />
                </div>
                <div>
                  <h3 class="text-lg font-black text-white">{founder.name}</h3>
                  <p class="text-xs font-bold text-brand-orange uppercase tracking-wider mt-0.5">{founder.role}</p>
                </div>
              </div>

              {/* Bio description */}
              <p class="text-sm text-gray-400 leading-relaxed">
                {founder.bio}
              </p>

              {/* Specialties */}
              <div class="space-y-2.5 pt-4 border-t border-gray-800/80">
                <span class="text-xs font-bold text-gray-500 uppercase tracking-widest block">Specjalizacje naukowe:</span>
                <div class="flex flex-wrap gap-1.5">
                  {founder.specialties.map((spec, sidx) => (
                    <span key={sidx} class="inline-flex rounded-lg bg-gray-900 px-2.5 py-1 text-xs text-gray-400 border border-gray-800/50">
                      {spec}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            {/* Social links */}
            <div class="mt-8 pt-4 border-t border-gray-800/80 flex items-center gap-4 text-xs font-bold text-gray-500">
              <a href={founder.social.github} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">GitHub</a>
              <span class="h-3 w-px bg-gray-800" />
              <a href={founder.social.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">LinkedIn</a>
              <span class="h-3 w-px bg-gray-800" />
              <span class="text-brand-orange">Przeprogramowani</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  {/* Our Philosophy/Values */}
  <section class="py-24 bg-brand-dark border-t border-gray-800/80">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto space-y-4 mb-16">
        <span class="text-xs font-bold text-brand-orange uppercase tracking-widest">Filozofia Przeprogramowanych</span>
        <h2 class="text-3xl font-black tracking-tight text-white sm:text-4xl">Wartości, którymi się kierujemy</h2>
        <p class="text-sm sm:text-base text-gray-400 leading-relaxed">Nasze zasady przekładają się na sukcesy tysięcy naszych absolwentów na rynku pracy.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {values.map((val, idx) => (
          <div key={idx} class="rounded-2xl border border-gray-800 bg-brand-dark-card/20 p-8 space-y-4 hover:bg-brand-dark-card/40 transition-colors">
            <div class="inline-flex rounded-xl bg-gray-900 p-3 shadow-inner">
              {val.icon === 'Code2' && <Code2 class="h-6 w-6 text-brand-orange" />}
              {val.icon === 'Users2' && <Users2 class="h-6 w-6 text-brand-purple" />}
              {val.icon === 'BookOpen' && <BookOpen class="h-6 w-6 text-brand-cyan" />}
            </div>
            <h3 class="text-lg font-bold text-white">{val.title}</h3>
            <p class="text-sm text-gray-400 leading-relaxed">{val.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Dynamic Quote / Trust Section */}
  <section class="py-20 bg-gradient-to-tr from-brand-purple/10 to-brand-orange/5 border-t border-b border-gray-850">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="max-w-3xl mx-auto space-y-6">
        <p class="text-xl sm:text-2xl font-medium text-white italic leading-relaxed">
          "Nie interesuje nas uczenie frameworków, które za rok wyjdą z mody. Interesuje nas uczenie inżynierskich nawyków, które zostaną z Tobą do końca Twojej kariery deweloperskiej."
        </p>
        <div class="flex items-center justify-center gap-3">
          <div class="flex -space-x-2">
            {[1, 2, 3].map(n => (
              <div key={n} class="h-10 w-10 rounded-full bg-gray-800 border-2 border-brand-dark flex items-center justify-center text-xs font-bold text-gray-400">
                {n === 1 ? 'MC' : n === 2 ? 'PS' : 'DW'}
              </div>
            ))}
          </div>
          <div class="text-left text-xs">
            <p class="font-bold text-white">Marcin, Przemek & Damian</p>
            <p class="text-gray-500">Założyciele Przeprogramowani.pl</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-24 bg-brand-dark relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-orange/10 blur-[130px]" />
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center space-y-8">
      <h2 class="text-3xl font-black tracking-tight sm:text-4xl text-white">Chcesz uczyć się z nami?</h2>
      <p class="text-base text-gray-400 max-w-xl mx-auto leading-relaxed">
        Dołącz do grona zadowolonych kursantów i wejdź na poziom 10x dewelopera. Wybierz program, który najbardziej pasuje do Twojego aktualnego etapu rozwoju.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#courses" class="flex items-center justify-center gap-2 rounded-xl bg-brand-orange hover:bg-brand-orange-light px-8 py-4 text-sm font-bold text-white shadow-xl shadow-brand-orange/20 transition-all">
          Przeglądaj programy online
        </a>
        <a href="/#10xdevs" class="flex items-center justify-center gap-2 rounded-xl border border-gray-800 bg-gray-900/40 px-8 py-4 text-sm font-bold text-gray-300 hover:text-white transition-all">
          Społeczność 10xDevs
        </a>
      </div>
    </div>
  </section>
</Layout>
