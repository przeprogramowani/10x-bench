---
import Layout from '../layouts/Layout.astro';
import PodcastList from '../components/PodcastList';
import { Radio, Heart, Award, ArrowUpRight, HelpCircle } from 'lucide-react';
---

<Layout title="Podcast | Opanuj Frontend" description="Opanuj Frontend Podcast - merytoryczne dyskusje o technologii, architekturze, karierze i realiach pracy w IT. Słuchaj bezpośrednio na stronie!">
  {/* Header Section */}
  <section class="relative overflow-hidden py-20 lg:py-28 bg-brand-dark">
    {/* Grid Overlay */}
    <div class="absolute top-1/4 left-1/2 -z-10 h-[450px] w-[450px] -translate-x-1/2 rounded-full bg-brand-cyan/10 blur-[130px]" />

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-6 max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-1.5 rounded-full border border-brand-cyan/30 bg-brand-cyan/10 px-4 py-1.5 text-xs font-semibold text-brand-cyan">
          <Radio class="h-4 w-4 animate-pulse" />
          Podcast Inżynierii Oprogramowania
        </div>
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl text-white">
          Opanuj Frontend <br />
          <span class="gradient-text-purple-cyan font-black">Podcast</span>
        </h1>
        <p class="text-lg text-gray-400 leading-relaxed">
          Zajrzyj za kulisy polskiej i światowej branży IT. Co tydzień dyskutujemy o architekturze oprogramowania, nowoczesnych frameworkach, wyzwaniach kariery oraz o tym, jak AI redefiniuje pracę deweloperów.
        </p>
      </div>
    </div>
  </section>

  {/* Podcast Players / List */}
  <section class="py-12 pb-32 bg-brand-dark/95 border-t border-gray-800/60 relative">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      {/* Real-time player wrapper */}
      <PodcastList client:load />

    </div>
  </section>

  {/* Podcast platforms promo */}
  <section class="py-20 bg-brand-dark border-t border-gray-800/80">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center space-y-8">
      <h3 class="text-xl font-bold text-white">Słuchaj nas na swojej ulubionej platformie</h3>
      <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
        <a
          href="https://spotify.com"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 rounded-2xl bg-gray-900 border border-gray-800 hover:border-emerald-500/30 hover:bg-emerald-500/5 px-6 py-4 text-sm font-bold text-gray-300 hover:text-white transition-all cursor-pointer"
        >
          <span class="text-emerald-400 font-black">Spotify</span>
          <ArrowUpRight class="h-4 w-4 text-gray-500" />
        </a>
        <a
          href="https://podcasts.apple.com"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 rounded-2xl bg-gray-900 border border-gray-800 hover:border-purple-500/30 hover:bg-purple-500/5 px-6 py-4 text-sm font-bold text-gray-300 hover:text-white transition-all cursor-pointer"
        >
          <span class="text-purple-400 font-black">Apple Podcasts</span>
          <ArrowUpRight class="h-4 w-4 text-gray-500" />
        </a>
        <a
          href="https://youtube.com/@Przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 rounded-2xl bg-gray-900 border border-gray-800 hover:border-red-500/30 hover:bg-red-500/5 px-6 py-4 text-sm font-bold text-gray-300 hover:text-white transition-all cursor-pointer"
        >
          <span class="text-red-500 font-black">YouTube</span>
          <ArrowUpRight class="h-4 w-4 text-gray-500" />
        </a>
        <a
          href="#"
          class="flex items-center gap-2.5 rounded-2xl bg-gray-900 border border-gray-800 hover:border-orange-500/30 hover:bg-orange-500/5 px-6 py-4 text-sm font-bold text-gray-300 hover:text-white transition-all cursor-pointer"
        >
          <span class="text-brand-orange font-black">Kanał RSS</span>
          <ArrowUpRight class="h-4 w-4 text-gray-500" />
        </a>
      </div>
    </div>
  </section>
</Layout>
