---
import Layout from '../layouts/Layout.astro';
import RecentPodcasts from '../components/RecentPodcasts';
---

<Layout title="Podcast - Przeprogramowani">
  <div className="pt-24 pb-12 bg-gray-950">
    <div className="container mx-auto px-4 text-center max-w-3xl">
      <h1 className="text-4xl md:text-6xl font-extrabold text-white mb-6 tracking-tight">Opanuj.AI <span className="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">Podcast</span></h1>
      <p className="text-xl text-gray-400 leading-relaxed">
        Najpopularniejszy podcast techniczny w Polsce. Ponad 4000 stałych słuchaczy śledzi z nami co miesiąc najważniejsze zmiany w świecie sztucznej inteligencji.
      </p>
    </div>
  </div>

  <RecentPodcasts client:load showAll={true} />
</Layout>
