---
import Layout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.astro';
import EpisodeList from '../components/EpisodeList';
import VideoGrid from '../components/VideoGrid';
import { site, courses, episodes, videos, stats } from '../data/site';
---

<Layout title="Przeprogramowani.pl — Szersze spojrzenie na programowanie">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-hero-glow">
    <div class="mx-auto max-w-6xl px-4 pb-20 pt-16 sm:px-6 sm:pt-24 lg:pb-28">
      <div class="mx-auto max-w-3xl text-center">
        <a
          href={courses[0].url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300 transition-colors hover:border-brand-400/50 hover:text-brand-200"
        >
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
          </span>
          Trwa nabór do <strong class="font-bold">10xDevs</strong> — programowanie z GenAI
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>

        <h1 class="mt-8 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Szersze spojrzenie<br />
          <span class="bg-gradient-to-r from-brand-400 via-violet-400 to-fuchsia-400 bg-clip-text text-transparent">
            na programowanie
          </span>
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-400">
          {site.description}
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href={courses[0].url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full rounded-xl bg-gradient-to-r from-brand-500 to-fuchsia-500 px-8 py-3.5 text-center font-semibold text-white shadow-lg shadow-brand-500/25 transition-opacity hover:opacity-90 sm:w-auto"
          >
            Dołącz do 10xDevs
          </a>
          <a
            href="#kursy"
            class="w-full rounded-xl border border-white/10 bg-white/5 px-8 py-3.5 text-center font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto"
          >
            Zobacz wszystkie kursy
          </a>
        </div>
      </div>

      <dl class="mx-auto mt-16 grid max-w-4xl grid-cols-2 gap-6 sm:mt-20 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="rounded-2xl border border-white/5 bg-ink-800/40 px-4 py-6 text-center">
              <dd class="text-3xl font-extrabold text-white">{stat.value}</dd>
              <dt class="mt-1 text-sm text-slate-400">{stat.label}</dt>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Kursy -->
  <section id="kursy" class="scroll-mt-20 border-t border-white/5 bg-ink-900/50">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-400">Kursy i programy</p>
        <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">
          Rozwijaj się z naszymi programami edukacyjnymi
        </h2>
        <p class="mt-4 text-slate-400">
          Od nowoczesnego frontendu, przez TypeScript w produkcji, po programowanie z Generatywnym
          AI — wybierz ścieżkę dopasowaną do swoich celów.
        </p>
      </div>
      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {courses.map((course, index) => <CourseCard course={course} featured={index === 0} />)}
      </div>
    </div>
  </section>

  <!-- Podcast -->
  <section class="border-t border-white/5">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-brand-400">Podcast</p>
          <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Ostatnie odcinki podcastu</h2>
          <p class="mt-4 text-slate-400">
            98 odcinków rozmów o programowaniu, karierze i rozwoju — dla juniorów szukających
            kierunku i seniorów rozważających kolejne kroki.
          </p>
        </div>
        <a
          href="/podcast"
          class="inline-flex shrink-0 items-center gap-2 text-sm font-semibold text-brand-300 transition-colors hover:text-brand-200"
        >
          Wszystkie odcinki
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="mt-10">
        <EpisodeList client:visible episodes={episodes.slice(0, 3)} />
      </div>
    </div>
  </section>

  <!-- YouTube -->
  <section class="border-t border-white/5 bg-ink-900/50">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-red-400">YouTube</p>
          <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Najnowsze filmy na kanale</h2>
          <p class="mt-4 text-slate-400">
            Newsy ze świata IT, techniki efektywnej pracy i nauki oraz praktyczne materiały o
            programowaniu z AI.
          </p>
        </div>
        <a
          href="/youtube"
          class="inline-flex shrink-0 items-center gap-2 text-sm font-semibold text-red-300 transition-colors hover:text-red-200"
        >
          Wszystkie filmy
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      <div class="mt-10">
        <VideoGrid client:visible videos={videos.slice(0, 3)} />
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="border-t border-white/5">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div
        class="relative overflow-hidden rounded-3xl border border-brand-500/20 bg-gradient-to-br from-ink-800 to-ink-900 p-8 text-center sm:p-14"
      >
        <div class="absolute inset-0 bg-hero-glow"></div>
        <div class="relative">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">Przeprogramowany Newsletter</h2>
          <p class="mx-auto mt-4 max-w-xl text-slate-400">
            W każdy piątek: 3 rekomendacje techniczne, 2 rekomendacje rozwojowe i 1 bonus
            niespodzianka. Dołącz do społeczności programistów, którzy stawiają na rozwój.
          </p>
          <a
            href={site.socials.newsletter}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-block rounded-xl bg-gradient-to-r from-brand-500 to-fuchsia-500 px-8 py-3.5 font-semibold text-white shadow-lg shadow-brand-500/25 transition-opacity hover:opacity-90"
          >
            Zapisz się do newslettera
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
