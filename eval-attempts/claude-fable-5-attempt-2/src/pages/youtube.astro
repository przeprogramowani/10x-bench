---
import Layout from '../layouts/Layout.astro';
import VideoGrid from '../components/VideoGrid';
import { site, videos } from '../data/site';
---

<Layout
  title="YouTube — Przeprogramowani.pl"
  description="Kanał YouTube Przeprogramowani — newsy ze świata IT, techniki efektywnej pracy i nauki oraz programowanie z AI."
>
  <section class="relative overflow-hidden bg-hero-glow">
    <div class="mx-auto max-w-6xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-red-400">YouTube</p>
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Przeprogramowani na YouTube
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          Kanał dla programistów stawiających na rozwój: newsy ze świata IT, techniki efektywnej
          pracy i nauki oraz praktyczne materiały o programowaniu z Generatywnym AI — od Claude
          Code, przez benchmarki modeli, po context engineering.
        </p>
        <a
          href={site.socials.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 rounded-xl bg-red-600 px-5 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Subskrybuj kanał
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-ink-900/50">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Najnowsze filmy</h2>
      <p class="mt-2 text-slate-400">Kliknij miniaturkę, aby obejrzeć film na YouTube.</p>
      <div class="mt-8">
        <VideoGrid client:load videos={videos} />
      </div>
    </div>
  </section>
</Layout>
