---
import Layout from '../layouts/Layout.astro';
import { site, founders, stats, partners } from '../data/site';
---

<Layout
  title="O nas — Przeprogramowani.pl"
  description="Poznaj twórców Przeprogramowani.pl — Przemka Smyrdka i Marcina Czarkowskiego. Od 7 lat łączymy programowanie, biznes i rozwój."
>
  <section class="relative overflow-hidden bg-hero-glow">
    <div class="mx-auto max-w-6xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-400">O nas</p>
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Witaj na Przeprogramowanych!
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          Przeprogramowani to miejsce na styku <strong class="text-slate-200">programowania,
          biznesu i rozwoju</strong>. Wierzymy, że świetni programiści patrzą szerzej — na
          architekturę, działanie biznesu i czynnik ludzki. Dlatego od 7 lat tworzymy treści, kursy
          i narzędzia, które pomagają rozwijać się na wielu płaszczyznach.
        </p>
      </div>

      <dl class="mt-14 grid grid-cols-2 gap-6 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="rounded-2xl border border-white/5 bg-ink-800/40 px-4 py-6 text-center">
              <dd class="text-3xl font-extrabold text-white">{stat.value}</dd>
              <dt class="mt-1 text-sm text-slate-400">{stat.label}</dt>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <section class="border-t border-white/5 bg-ink-900/50">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Twórcy projektu</h2>
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {
          founders.map((founder) => (
            <article class="rounded-2xl border border-white/5 bg-ink-800/60 p-8 transition-colors hover:border-brand-500/30">
              <div class="flex items-center gap-4">
                <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500 to-fuchsia-500 text-xl font-extrabold text-white">
                  {founder.initials}
                </span>
                <div>
                  <h3 class="text-xl font-bold text-white">{founder.name}</h3>
                  <p class="text-sm text-brand-300">{founder.role}</p>
                </div>
              </div>
              <p class="mt-6 leading-relaxed text-slate-400">{founder.bio}</p>
              <a
                href={founder.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-brand-300 transition-colors hover:text-brand-200"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                </svg>
                LinkedIn
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-white/5">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-bold text-white">Co robimy?</h2>
          <ul class="mt-8 space-y-6">
            <li class="flex gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300">🎓</span>
              <div>
                <h3 class="font-semibold text-white">Programy edukacyjne</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">
                  10xDevs, Opanuj Frontend: AI Edition i Opanuj TypeScript — praktyczne kursy, które
                  ukończyły już setki programistów.
                </p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300">🎙️</span>
              <div>
                <h3 class="font-semibold text-white">Podcast i YouTube</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">
                  Rozmowy z ekspertami, newsy ze świata IT i materiały o efektywnej pracy z AI — w
                  formie audio i wideo.
                </p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300">📬</span>
              <div>
                <h3 class="font-semibold text-white">Newsletter</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">
                  Cotygodniowa dawka rekomendacji technicznych i rozwojowych, prosto na Twoją
                  skrzynkę.
                </p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-500/10 text-brand-300">🛠️</span>
              <div>
                <h3 class="font-semibold text-white">Narzędzia dla developerów</h3>
                <p class="mt-1 text-sm leading-relaxed text-slate-400">
                  10xRules.ai — platforma do zarządzania regułami i promptami AI dla programistów i
                  zespołów.
                </p>
              </div>
            </li>
          </ul>
        </div>

        <div>
          <h2 class="text-3xl font-bold text-white">Zaufali nam</h2>
          <p class="mt-4 text-slate-400">
            Współpracujemy z czołowymi firmami technologicznymi, wspierając rozwój ich zespołów
            inżynierskich.
          </p>
          <ul class="mt-8 grid grid-cols-2 gap-4">
            {
              partners.map((partner) => (
                <li class="flex items-center justify-center rounded-2xl border border-white/5 bg-ink-800/60 px-4 py-6 text-center font-semibold text-slate-300">
                  {partner}
                </li>
              ))
            }
          </ul>
          <div class="mt-8 rounded-2xl border border-brand-500/20 bg-brand-500/5 p-6">
            <h3 class="font-semibold text-white">Skontaktuj się z nami</h3>
            <p class="mt-2 text-sm text-slate-400">
              Masz pytanie o kursy, współpracę lub szkolenia dla firm?
            </p>
            <a
              href={`mailto:${site.email}`}
              class="mt-4 inline-block font-semibold text-brand-300 transition-colors hover:text-brand-200"
            >
              {site.email}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
