---
import Layout from '../layouts/Layout.astro';
import EpisodeList from '../components/EpisodeList';
import { site, episodes } from '../data/site';
---

<Layout
  title="Podcast — Przeprogramowani.pl"
  description="Podcast Przeprogramowani — szersze spojrzenie na programowanie. 98 odcinków dla programistów na każdym etapie kariery."
>
  <section class="relative overflow-hidden bg-hero-glow">
    <div class="mx-auto max-w-6xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-400">Podcast</p>
        <h1 class="mt-2 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          Przeprogramowani — podcast
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          Podcast skierowany do programistów na każdym etapie kariery — od juniorów szukających
          kierunku, po seniorów rozważających kolejne kroki. <strong class="text-slate-200">98
          odcinków</strong>, ocena <strong class="text-slate-200">4.9/5</strong> w Apple Podcasts.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={site.socials.spotify}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl bg-[#1DB954] px-5 py-3 text-sm font-semibold text-black transition-opacity hover:opacity-90"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
            </svg>
            Słuchaj na Spotify
          </a>
          <a
            href={site.socials.applePodcasts}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
          >
            🎧 Apple Podcasts
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-ink-900/50">
    <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Ostatnie odcinki</h2>
      <p class="mt-2 text-slate-400">Kliknij odcinek, aby zobaczyć jego opis.</p>
      <div class="mt-8">
        <EpisodeList client:load episodes={episodes} />
      </div>
      <p class="mt-10 text-center">
        <a
          href={site.socials.spotify}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-semibold text-brand-300 transition-colors hover:text-brand-200"
        >
          Pełne archiwum odcinków znajdziesz na Spotify
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </p>
    </div>
  </section>
</Layout>
