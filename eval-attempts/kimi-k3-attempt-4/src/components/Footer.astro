---
import { socialLinks, brands } from '../data/content';
---

<footer class="border-t border-white/10 bg-ink-950">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="font-mono text-lg font-bold text-white">
          <span class="text-amber-400">&lt;/&gt;</span> Przeprogramowani
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-zinc-400">
          Szersze spojrzenie na programowanie. Łączymy świat programowania, biznesu i rozwoju
          osobistego. Kursy, podcasty i filmy dla ambitnych programistów.
        </p>
        <div class="mt-6 flex gap-3">
          <a
            href={socialLinks.youtube}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="YouTube"
            class="rounded-lg border border-white/10 p-2.5 text-zinc-400 transition-colors hover:border-amber-400/50 hover:text-amber-400"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.38.5A3.02 3.02 0 0 0 .5 6.19C0 8.07 0 12 0 12s0 3.93.5 5.81a3.02 3.02 0 0 0 2.12 2.14c1.88.5 9.38.5 9.38.5s7.5 0 9.38-.5a3.02 3.02 0 0 0 2.12-2.14C24 15.93 24 12 24 12s0-3.93-.5-5.81zM9.55 15.57V8.43L15.82 12l-6.27 3.57z"/>
            </svg>
          </a>
          <a
            href={socialLinks.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="rounded-lg border border-white/10 p-2.5 text-zinc-400 transition-colors hover:border-amber-400/50 hover:text-amber-400"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.09 10.13 24v-8.44H7.08v-3.49h3.04V9.41c0-3.02 1.8-4.7 4.54-4.7 1.31 0 2.68.24 2.68.24v2.97h-1.5c-1.5 0-1.96.93-1.96 1.89v2.26h3.32l-.53 3.49h-2.8V24C19.62 23.09 24 18.1 24 12.07z"/>
            </svg>
          </a>
          <a
            href={socialLinks.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="rounded-lg border border-white/10 p-2.5 text-zinc-400 transition-colors hover:border-amber-400/50 hover:text-amber-400"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41 1.27-.06 1.65-.07 4.85-.07M12 0C8.74 0 8.33.01 7.05.07 5.78.13 4.9.33 4.14.63a5.9 5.9 0 0 0-2.13 1.38A5.9 5.9 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.31.8.72 1.47 1.38 2.13a5.9 5.9 0 0 0 2.13 1.38c.76.3 1.64.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.9 5.9 0 0 0 2.13-1.38 5.9 5.9 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.9 5.9 0 0 0-1.38-2.13A5.9 5.9 0 0 0 19.86.63C19.1.33 18.22.13 16.95.07 15.67.01 15.26 0 12 0zm0 5.84A6.16 6.16 0 1 0 18.16 12 6.16 6.16 0 0 0 12 5.84zm0 10.15A4 4 0 1 1 16 12a4 4 0 0 1-4 3.99zm7.85-10.4a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0z"/>
            </svg>
          </a>
          <a
            href={`mailto:${socialLinks.email}`}
            aria-label="E-mail"
            class="rounded-lg border border-white/10 p-2.5 text-zinc-400 transition-colors hover:border-amber-400/50 hover:text-amber-400"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Nawigacja</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a href="/o-nas" class="text-zinc-400 transition-colors hover:text-amber-400">O nas</a></li>
          <li><a href="/podcast" class="text-zinc-400 transition-colors hover:text-amber-400">Podcast</a></li>
          <li><a href="/youtube" class="text-zinc-400 transition-colors hover:text-amber-400">YouTube</a></li>
          <li>
            <a href={socialLinks.newsletter} target="_blank" rel="noopener noreferrer" class="text-zinc-400 transition-colors hover:text-amber-400">
              Newsletter
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Kursy</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="text-zinc-400 transition-colors hover:text-amber-400">
              10xDevs
            </a>
          </li>
          <li>
            <a href="https://www.opanujfrontend.pl" target="_blank" rel="noopener noreferrer" class="text-zinc-400 transition-colors hover:text-amber-400">
              Opanuj Frontend
            </a>
          </li>
          <li>
            <a href="https://www.opanujtypescript.pl" target="_blank" rel="noopener noreferrer" class="text-zinc-400 transition-colors hover:text-amber-400">
              Opanuj TypeScript
            </a>
          </li>
          <li>
            <a href="https://opanuj.ai" target="_blank" rel="noopener noreferrer" class="text-zinc-400 transition-colors hover:text-amber-400">
              Opanuj AI
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="text-xs leading-relaxed text-zinc-500">
        Zaufali nam: {brands.join(' · ')}
      </p>
      <p class="mt-4 text-xs text-zinc-600">
        © {new Date().getFullYear()} Przeprogramowani.pl — Szersze spojrzenie na programowanie
      </p>
    </div>
  </div>
</footer>
