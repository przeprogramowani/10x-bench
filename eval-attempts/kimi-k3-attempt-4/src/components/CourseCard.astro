---
import type { Course } from '../data/content';

interface Props {
  course: Course;
}

const { course } = Astro.props;
---

<a
  href={course.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.07] to-white/[0.02] p-8 transition-all duration-300 hover:-translate-y-1 hover:border-amber-400/40 hover:shadow-2xl hover:shadow-amber-400/10"
>
  <div class="flex items-center justify-between">
    <span class="rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-amber-300">
      {course.tag}
    </span>
    {
      course.badge && (
        <span class="rounded-full bg-amber-400 px-3 py-1 text-xs font-bold uppercase tracking-wider text-ink-950">
          {course.badge}
        </span>
      )
    }
  </div>

  <h3 class="mt-6 text-2xl font-bold text-white transition-colors group-hover:text-amber-300">
    {course.name}
  </h3>
  <p class="mt-1 text-sm font-medium text-amber-400/80">{course.tagline}</p>
  <p class="mt-4 flex-1 text-sm leading-relaxed text-zinc-400">{course.description}</p>

  <ul class="mt-6 space-y-2.5">
    {
      course.features.map((feature) => (
        <li class="flex items-start gap-2.5 text-sm text-zinc-300">
          <svg
            class="mt-0.5 h-4 w-4 flex-shrink-0 text-amber-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2.5"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
          <span>{feature}</span>
        </li>
      ))
    }
  </ul>

  <span class="mt-8 inline-flex items-center gap-2 text-sm font-bold text-amber-400 transition-all group-hover:gap-3">
    Szczegóły
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
    </svg>
  </span>
</a>
