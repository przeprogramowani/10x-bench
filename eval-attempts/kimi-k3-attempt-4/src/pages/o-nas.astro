---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { founders, brands, socialLinks } from '../data/content';
---

<Layout
  title="O nas — Przeprogramowani"
  description="Łączymy świat programowania, biznesu i rozwoju. Poznaj założycieli Przeprogramowanych — Przemka Smyrdka i Marcina Czarkowskiego."
>
  <!-- Page header -->
  <section class="relative overflow-hidden pb-16 pt-32 sm:pt-40">
    <div
      class="pointer-events-none absolute -top-32 left-1/2 h-96 w-[700px] -translate-x-1/2 rounded-full bg-amber-400/10 blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-zinc-500" aria-label="Okruszki">
        <a href="/" class="transition-colors hover:text-amber-400">Strona główna</a>
        <span class="mx-2">/</span>
        <span class="text-zinc-300">O nas</span>
      </nav>
      <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl">O nas</h1>
      <p class="mt-4 max-w-2xl text-xl leading-relaxed text-zinc-400">
        Łączymy świat programowania, biznesu i rozwoju
      </p>
    </div>
  </section>

  <!-- Founders -->
  <section class="py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 md:grid-cols-2">
        {
          founders.map((founder) => (
            <article class="group rounded-2xl border border-white/10 bg-gradient-to-b from-white/[0.07] to-white/[0.02] p-8 transition-all duration-300 hover:border-amber-400/40">
              <div class="flex items-center gap-5">
                <div class="flex h-20 w-20 flex-shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 font-mono text-2xl font-black text-ink-950 shadow-lg shadow-amber-400/20">
                  {founder.initials}
                </div>
                <div>
                  <h2 class="text-2xl font-bold text-white">{founder.name}</h2>
                  <p class="mt-1 text-sm font-medium text-amber-400">{founder.role}</p>
                </div>
              </div>
              <p class="mt-6 leading-relaxed text-zinc-400">{founder.bio}</p>
              <a
                href={founder.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex items-center gap-2 rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-zinc-300 transition-all hover:border-amber-400/50 hover:text-amber-400"
              >
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z" />
                </svg>
                LinkedIn
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-white/[0.07] to-transparent p-10 sm:p-16">
        <div
          class="pointer-events-none absolute -left-24 -top-24 h-72 w-72 rounded-full bg-indigo-500/10 blur-[80px]"
          aria-hidden="true"
        >
        </div>
        <div class="relative max-w-3xl">
          <p class="font-mono text-sm font-semibold uppercase tracking-widest text-amber-400">
            Nasza misja
          </p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
            Witaj na Przeprogramowanych!
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-zinc-300">
            Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym.
            Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na
            biznes, na ludzi i na siebie.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-zinc-300">
            Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu
            płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
          </p>
          <p class="mt-6 text-xl font-bold text-amber-400">
            Zyskaj szersze spojrzenie na programowanie.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted by -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Zaufali nam"
        title="7 lat na rynku edukacji technologicznej"
        subtitle="Współpracowaliśmy z najlepszymi firmami technologicznymi w Polsce i za granicą."
      />
      <div class="mt-14 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
        {
          brands.map((brand) => (
            <div class="flex items-center justify-center rounded-xl border border-white/10 bg-white/[0.03] px-4 py-6 text-center text-sm font-semibold text-zinc-400 transition-all hover:border-amber-400/30 hover:text-white">
              {brand}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-amber-400/20 bg-gradient-to-br from-amber-400/10 to-transparent p-10 text-center sm:p-16">
        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Chcesz nawiązać współpracę?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-zinc-400">
          Szkolenia dla zespołów, współpraca przy treściach, prelekcje — napisz do nas.
        </p>
        <a
          href={`mailto:${socialLinks.email}`}
          class="mt-8 inline-flex items-center gap-2 rounded-xl bg-amber-400 px-8 py-4 text-base font-bold text-ink-950 transition-all hover:bg-amber-300 hover:shadow-xl hover:shadow-amber-400/25"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path>
          </svg>
          {socialLinks.email}
        </a>
      </div>
    </div>
  </section>
</Layout>
