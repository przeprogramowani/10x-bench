---
import Layout from '../layouts/Layout.astro';
import PodcastTabs from '../components/PodcastTabs';
import { podcastPlatforms } from '../data/content';
---

<Layout
  title="Podcast — Przeprogramowani"
  description="Słuchaj naszych podcastów o technologii, AI i programowaniu. Opanuj.AI Podcast i Przeprogramowani ft. Gość."
>
  <!-- Page header -->
  <section class="relative overflow-hidden pb-16 pt-32 sm:pt-40">
    <div
      class="pointer-events-none absolute -top-32 left-1/2 h-96 w-[700px] -translate-x-1/2 rounded-full bg-amber-400/10 blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="mb-6 text-sm text-zinc-500" aria-label="Okruszki">
        <a href="/" class="transition-colors hover:text-amber-400">Strona główna</a>
        <span class="mx-2">/</span>
        <span class="text-zinc-300">Podcast</span>
      </nav>
      <h1 class="text-4xl font-black tracking-tight text-white sm:text-6xl">Podcasty</h1>
      <p class="mt-4 max-w-2xl text-xl leading-relaxed text-zinc-400">
        Słuchaj naszych podcastów o technologii, AI i programowaniu
      </p>
    </div>
  </section>

  <!-- Podcast tabs + episodes -->
  <section class="py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <PodcastTabs client:load />
    </div>
  </section>

  <!-- Platforms -->
  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-white/[0.07] to-transparent p-10 sm:p-16">
        <div
          class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-green-500/10 blur-[80px]"
          aria-hidden="true"
        >
        </div>
        <div class="relative text-center">
          <p class="font-mono text-sm font-semibold uppercase tracking-widest text-amber-400">
            Gdzie słuchać
          </p>
          <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
            Jesteśmy na Twojej ulubionej platformie
          </h2>
          <div class="mx-auto mt-10 grid max-w-3xl grid-cols-2 gap-4 lg:grid-cols-4">
            {
              podcastPlatforms.map((platform) => (
                <a
                  href={platform.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex flex-col items-center gap-3 rounded-2xl border border-white/10 bg-ink-950/60 p-6 backdrop-blur transition-all duration-300 hover:-translate-y-1 hover:border-amber-400/40"
                >
                  {platform.name === 'Apple Podcasts' && (
                    <svg class="h-8 w-8 text-purple-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm0 4.5a7.5 7.5 0 0 1 7.5 7.5c0 2.9-1.65 5.42-4.07 6.69l-.53-2.06a5.14 5.14 0 0 0 2.6-4.63A5.5 5.5 0 1 0 6.5 12c0 1.9.97 3.58 2.6 4.63l-.53 2.06A7.48 7.48 0 0 1 4.5 12 7.5 7.5 0 0 1 12 4.5zm0 4A3.5 3.5 0 0 0 8.5 12c0 1.21.62 2.28 1.55 2.9l.42-1.6A2 2 0 0 1 10 12a2 2 0 1 1 4 0c0 .55-.22 1.05-.58 1.41l.42 1.6A3.5 3.5 0 0 0 15.5 12 3.5 3.5 0 0 0 12 8.5zm-.17 5.02c-.44.13-1.47.13-1.91 0l-1.42 5.48c.4.64 1.5 1.35 3.25 1.35s2.86-.71 3.25-1.35l-1.17-5.48z" />
                    </svg>
                  )}
                  {platform.name === 'Spotify' && (
                    <svg class="h-8 w-8 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.52 17.34c-.24.36-.66.48-1.02.24-2.82-1.74-6.36-2.1-10.56-1.14-.42.12-.78-.18-.9-.54-.12-.42.18-.78.54-.9 4.56-1.02 8.52-.6 11.7 1.32.36.18.48.66.24 1.02zm1.44-3.3c-.3.42-.84.6-1.26.3-3.24-1.98-8.16-2.58-11.94-1.38-.48.12-1.02-.12-1.14-.6-.12-.48.12-1.02.6-1.14 4.26-1.26 9.6-.6 13.26 1.62.42.24.6.78.48 1.2zm.12-3.36C15.24 8.46 8.88 8.16 5.16 9.3c-.6.18-1.2-.18-1.38-.72-.18-.6.18-1.2.72-1.38 4.26-1.26 11.28-1.02 15.72 1.62.54.3.72.96.42 1.5-.3.54-.96.72-1.56.36z" />
                    </svg>
                  )}
                  {platform.name === 'Google Podcasts' && (
                    <svg class="h-8 w-8 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24zM8.5 10.5v3a1 1 0 1 1-2 0v-3a1 1 0 1 1 2 0zm4.5-3v9a1 1 0 1 1-2 0v-9a1 1 0 1 1 2 0zm4.5 3v3a1 1 0 1 1-2 0v-3a1 1 0 1 1 2 0z" />
                    </svg>
                  )}
                  {platform.name === 'RSS' && (
                    <svg class="h-8 w-8 text-orange-400" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M6.18 17.82a2.18 2.18 0 1 1-4.36 0 2.18 2.18 0 0 1 4.36 0zM1.82 8.73v3.09c6.3 0 11.45 5.12 11.45 11.45h3.1c0-8.04-6.51-14.54-14.55-14.54zM1.82 1.64v3.09C11.4 4.73 19.27 12.6 19.27 22.36h3.09c0-11.4-9.14-20.72-20.54-20.72z" />
                    </svg>
                  )}
                  <span class="text-sm font-semibold text-zinc-300 transition-colors group-hover:text-white">
                    {platform.name}
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
