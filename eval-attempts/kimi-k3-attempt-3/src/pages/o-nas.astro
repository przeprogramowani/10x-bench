---
import BaseLayout from '../layouts/BaseLayout.astro';

const founders = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder, Przeprogramowani',
    photo: '/img/profiles/przemek.webp',
    bio: 'Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).',
    linkedin: 'https://www.linkedin.com/in/psmyrdek/',
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder, Przeprogramowani',
    photo: '/img/profiles/marcin.webp',
    bio: 'Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca „Opanuj AI Podcast" — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.',
    linkedin: 'https://www.linkedin.com/in/mkczarkowski/',
  },
];

const values = [
  {
    title: 'Szersze spojrzenie',
    description:
      'Wierzymy, że najlepsi programiści patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.',
  },
  {
    title: 'Pragmatyzm',
    description:
      'Łączymy teorię z praktyką w najbardziej użyteczny dla programisty sposób — bez lania wody, z realnych projektów produkcyjnych.',
  },
  {
    title: 'Społeczność',
    description:
      'Od 2019 roku tworzymy darmowe treści dla społeczności 15 tysięcy programistów i słuchamy feedbacku, który dostajemy każdego dnia.',
  },
  {
    title: 'Edukacja w epoce AI',
    description:
      'Uczymy świadomego korzystania z Generatywnego AI w całym cyklu wytwarzania oprogramowania — od researchu po deployment.',
  },
];

const facts = [
  { value: '2019', label: 'rok założenia' },
  { value: '8000+', label: 'absolwentów programów' },
  { value: '1500+', label: 'przeszkolonych devów w O:FE i O:JS' },
  { value: '4000+', label: 'słuchaczy Opanuj.AI Podcast' },
];
---

<BaseLayout
  title="O nas — Przeprogramowani"
  description="Łączymy świat programowania, biznesu i rozwoju. Poznaj Przemka i Marcina — założycieli Przeprogramowanych, autorów kursów 10xDevs, Opanuj Frontend i Opanuj TypeScript."
>
  <section class="relative overflow-hidden pb-16 pt-36 sm:pt-40">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-32 left-1/3 h-[400px] w-[600px] -translate-x-1/2 rounded-full bg-indigo-600/15 blur-[130px]"></div>
    </div>
    <div class="container-page relative">
      <nav class="text-xs text-slate-500" aria-label="Okruszki">
        <a href="/" class="transition-colors hover:text-slate-300">Strona główna</a>
        <span class="mx-2">/</span>
        <span class="text-slate-300">O nas</span>
      </nav>
      <h1 class="mt-6 max-w-3xl font-display text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Łączymy świat <span class="text-gradient">programowania, biznesu i rozwoju</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-400">
        Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym.
        Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu
        płaszczyznach — od technicznych deep-dive'ów po rozmowy o karierze.
      </p>
    </div>
  </section>

  <!-- Założyciele -->
  <section class="py-12">
    <div class="container-page grid gap-8 md:grid-cols-2">
      {founders.map((founder) => (
        <article class="card-glass group p-7 transition-all duration-300 hover:border-white/25 sm:p-9">
          <div class="flex items-center gap-5">
            <img
              src={founder.photo}
              alt={`Zdjęcie: ${founder.name}`}
              loading="lazy"
              class="h-20 w-20 rounded-2xl object-cover ring-2 ring-white/10 sm:h-24 sm:w-24"
            />
            <div>
              <h2 class="font-display text-2xl font-bold text-white">{founder.name}</h2>
              <p class="mt-1 text-sm font-medium text-indigo-300">{founder.role}</p>
            </div>
          </div>
          <p class="mt-6 text-sm leading-relaxed text-slate-400">{founder.bio}</p>
          <a
            href={founder.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-indigo-300 transition-colors hover:text-indigo-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45z" />
            </svg>
            LinkedIn
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- Nasze wartości -->
  <section class="py-16">
    <div class="container-page">
      <div class="max-w-2xl">
        <p class="section-eyebrow">W co wierzymy</p>
        <h2 class="section-title mt-3">
          Zyskaj <span class="text-gradient">szersze spojrzenie</span> na programowanie
        </h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((value, index) => (
          <div class="card-glass p-6 transition-colors duration-200 hover:border-white/25">
            <span class="font-display text-sm font-bold text-indigo-300">
              {String(index + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-3 font-display text-lg font-semibold text-white">{value.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Liczby -->
  <section class="py-16">
    <div class="container-page">
      <div class="card-glass grid gap-8 p-8 text-center sm:grid-cols-2 sm:p-10 lg:grid-cols-4">
        {facts.map((fact) => (
          <div>
            <p class="font-display text-4xl font-bold text-gradient">{fact.value}</p>
            <p class="mt-2 text-sm text-slate-400">{fact.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pb-24 pt-8">
    <div class="container-page">
      <div class="relative overflow-hidden rounded-3xl border border-indigo-400/25 bg-gradient-to-br from-indigo-600/25 via-night-900 to-fuchsia-600/20 p-8 text-center sm:p-14">
        <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
          Chcesz nawiązać współpracę?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-slate-300">
          Szkolenia dla firm, warsztaty z AI, współpraca przy treściach — napisz do nas
          i porozmawiajmy o możliwościach.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="mailto:kontakt@przeprogramowani.pl" class="btn-primary">
            kontakt@przeprogramowani.pl
          </a>
          <a href="/#kursy" class="btn-secondary">Zobacz nasze kursy</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
