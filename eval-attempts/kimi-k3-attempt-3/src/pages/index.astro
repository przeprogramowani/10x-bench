---
import BaseLayout from '../layouts/BaseLayout.astro';
import { courses } from '../data/courses';
import { latestVideos, formatDate, youtubeChannelUrl } from '../data/videos';
import { podcastShows } from '../data/podcasts';

const featuredCourse = courses.find((course) => course.featured)!;
const otherCourses = courses.filter((course) => !course.featured);
const homeVideos = latestVideos.slice(0, 3);

const stats = [
  { value: '7 lat', label: 'na rynku edukacji technologicznej' },
  { value: '8000+', label: 'absolwentów naszych programów' },
  { value: '15 000+', label: 'programistów w społeczności' },
  { value: '2', label: 'podcasty o technologii i AI' },
];

const trustedBrands = [
  'Huuuge Games',
  'SmartRecruiters',
  'Callstack',
  'Autodesk',
  'Xfive',
  'edrone',
  'Euvic',
  'Future Processing',
  'Strabag',
  'Nutridome',
];
---

<BaseLayout title="Przeprogramowani.pl — Szersze spojrzenie na programowanie">
  <!-- HERO z 10xDevs -->
  <section class="relative overflow-hidden pb-20 pt-36 sm:pt-40">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-40 left-1/2 h-[480px] w-[720px] -translate-x-1/2 rounded-full bg-indigo-600/20 blur-[140px]"></div>
      <div class="absolute -right-40 top-40 h-[360px] w-[360px] rounded-full bg-fuchsia-600/15 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(148,163,184,0.05)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.05)_1px,transparent_1px)] bg-[size:56px_56px] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_0%,black,transparent)]"></div>
    </div>

    <div class="container-page relative grid items-center gap-14 lg:grid-cols-[1.1fr_1fr]">
      <div class="animate-fade-up">
        <a
          href={featuredCourse.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-indigo-400/30 bg-indigo-500/10 px-4 py-1.5 text-xs font-semibold text-indigo-200 transition-colors hover:border-indigo-300/50 hover:bg-indigo-500/20"
        >
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400 opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo-300"></span>
          </span>
          {featuredCourse.badge}
          <span aria-hidden="true">→</span>
        </a>

        <h1 class="mt-6 font-display text-4xl font-bold leading-[1.08] tracking-tight text-white sm:text-5xl lg:text-6xl">
          Szersze spojrzenie na
          <span class="text-gradient"> programowanie</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
          Edukacja technologiczna w epoce AI. Topowe programy dla ambitnych programistów
          i świadome korzystanie z potencjału Generatywnego AI — od 10xDevs, przez
          Opanuj Frontend, po Opanuj TypeScript.
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <a href={featuredCourse.url} target="_blank" rel="noopener noreferrer" class="btn-primary">
            Poznaj 10xDevs 4.0
            <span aria-hidden="true">→</span>
          </a>
          <a href="#kursy" class="btn-secondary">Zobacz wszystkie kursy</a>
        </div>

        <dl class="mt-12 grid grid-cols-2 gap-6 sm:grid-cols-4">
          {stats.map((stat) => (
            <div>
              <dt class="sr-only">{stat.label}</dt>
              <dd class="font-display text-2xl font-bold text-white">{stat.value}</dd>
              <dd class="mt-1 text-xs leading-snug text-slate-500">{stat.label}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Karta hero: 10xDevs -->
      <div class="relative animate-fade-up lg:justify-self-end" style="animation-delay: 150ms">
        <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-br from-indigo-500/30 via-violet-500/20 to-fuchsia-500/30 blur-2xl" aria-hidden="true"></div>
        <a
          href={featuredCourse.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative block overflow-hidden rounded-[1.75rem] border border-white/15 bg-night-900 shadow-2xl shadow-indigo-950/50 transition-transform duration-300 hover:-translate-y-1.5"
        >
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={featuredCourse.image}
              alt="10xDevs 4.0 — nowe oblicze programowania z AI"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-night-900 via-night-900/20 to-transparent"></div>
            <span class="absolute left-4 top-4 rounded-full bg-gradient-to-r from-indigo-500 to-fuchsia-500 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-white shadow-lg">
              Bestseller — 6700+ absolwentów
            </span>
          </div>
          <div class="relative -mt-10 p-6 sm:p-7">
            <p class="section-eyebrow">{featuredCourse.tag}</p>
            <h2 class="mt-2 font-display text-3xl font-bold text-white">{featuredCourse.name}</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{featuredCourse.description}</p>
            <ul class="mt-4 space-y-2">
              {featuredCourse.highlights.slice(0, 3).map((highlight) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-300">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="mt-0.5 h-4 w-4 shrink-0 text-indigo-300" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-8 8a1 1 0 0 1-1.4 0l-4-4a1 1 0 1 1 1.4-1.4L8 12.58l7.3-7.3a1 1 0 0 1 1.4 0z" clip-rule="evenodd" />
                  </svg>
                  {highlight}
                </li>
              ))}
            </ul>
            <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-indigo-300 transition-colors group-hover:text-indigo-200">
              Dołącz do programu
              <span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- KURSY -->
  <section id="kursy" class="relative py-20 sm:py-24">
    <div class="container-page">
      <div class="max-w-2xl">
        <p class="section-eyebrow">Nasze programy edukacyjne</p>
        <h2 class="section-title mt-3">
          Kursy, które <span class="text-gradient">przyspieszą Twój rozwój</span>
        </h2>
        <p class="mt-4 text-slate-400">
          Pragmatyczna wiedza z projektów produkcyjnych, wsparcie mentorów i społeczność
          ambitnych programistów. Wybierz program dla siebie.
        </p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {otherCourses.map((course) => (
          <a
            href={course.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card-glass group flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:border-indigo-400/40 hover:shadow-2xl hover:shadow-indigo-950/40"
          >
            <div class="relative aspect-[16/7] overflow-hidden">
              <img
                src={course.image}
                alt={`${course.name} — baner programu`}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-night-950/90 via-transparent to-transparent"></div>
              <span class="absolute left-4 top-4 rounded-full border border-white/20 bg-night-950/70 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-indigo-200 backdrop-blur">
                {course.tag}
              </span>
            </div>
            <div class="flex flex-1 flex-col p-6 sm:p-7">
              <h3 class="font-display text-2xl font-bold text-white">{course.name}</h3>
              <p class="mt-1 text-sm font-medium text-indigo-300">{course.tagline}</p>
              <p class="mt-3 text-sm leading-relaxed text-slate-400">{course.description}</p>
              <ul class="mt-4 grid gap-2 sm:grid-cols-2">
                {course.highlights.map((highlight) => (
                  <li class="flex items-start gap-2 text-xs leading-relaxed text-slate-300">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-indigo-300" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-8 8a1 1 0 0 1-1.4 0l-4-4a1 1 0 1 1 1.4-1.4L8 12.58l7.3-7.3a1 1 0 0 1 1.4 0z" clip-rule="evenodd" />
                    </svg>
                    {highlight}
                  </li>
                ))}
              </ul>
              <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-white">
                Szczegóły programu
                <span class="text-indigo-300 transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Baner 10xDevs pod siatką kursów -->
      <a
        href={featuredCourse.url}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative mt-6 flex flex-col items-start gap-4 overflow-hidden rounded-2xl border border-indigo-400/30 bg-gradient-to-r from-indigo-600/20 via-violet-600/15 to-fuchsia-600/20 p-6 transition-all duration-300 hover:border-indigo-300/50 sm:flex-row sm:items-center sm:justify-between sm:p-8"
      >
        <div>
          <p class="section-eyebrow">Flagowy program</p>
          <h3 class="mt-1 font-display text-xl font-bold text-white sm:text-2xl">
            10xDevs 4.0 — AI-Native Software Engineering
          </h3>
          <p class="mt-1.5 max-w-2xl text-sm text-slate-300">
            Praktyczny workflow pracy z agentami AI: od pomysłu, przez plan i implementację,
            po testy i wdrożenie. Start nowej edycji: 14 września 2026.
          </p>
        </div>
        <span class="btn-primary shrink-0">
          Zobacz program
          <span aria-hidden="true">→</span>
        </span>
      </a>
    </div>
  </section>

  <!-- YOUTUBE -->
  <section class="relative py-20 sm:py-24">
    <div class="container-page">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-2xl">
          <p class="section-eyebrow">YouTube</p>
          <h2 class="section-title mt-3">
            Ostatnie filmy <span class="text-gradient">na kanale</span>
          </h2>
          <p class="mt-4 text-slate-400">
            Programowanie z AI, relacje z konferencji i praktyczne pokazy narzędzi —
            regularnie publikujemy nowe materiały wideo.
          </p>
        </div>
        <a href="/youtube" class="btn-secondary">
          Wszystkie filmy
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {homeVideos.map((video) => (
          <a
            href={`https://www.youtube.com/watch?v=${video.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="card-glass group overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:border-white/25"
          >
            <div class="relative aspect-video overflow-hidden bg-slate-900">
              <img
                src={`https://i.ytimg.com/vi/${video.id}/maxresdefault.jpg`}
                alt=""
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <span class="absolute inset-0 flex items-center justify-center bg-black/25 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-white/90 text-slate-900 shadow-xl">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="ml-0.5 h-6 w-6" aria-hidden="true">
                    <path d="M8 5.14v14l11-7-11-7z" />
                  </svg>
                </span>
              </span>
            </div>
            <div class="p-5">
              <h3 class="line-clamp-2 font-display text-base font-semibold leading-snug text-white">
                {video.title}
              </h3>
              <p class="mt-2 text-xs text-slate-500">{formatDate(video.publishedAt)}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PODCAST -->
  <section class="relative py-20 sm:py-24">
    <div class="container-page">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div class="max-w-2xl">
          <p class="section-eyebrow">Podcasty</p>
          <h2 class="section-title mt-3">
            Słuchaj nas <span class="text-gradient">gdzie chcesz</span>
          </h2>
          <p class="mt-4 text-slate-400">
            Dwa podcasty o technologii, AI i programowaniu — comiesięczne podsumowania
            świata AI oraz rozmowy z gośćmi dla głodnych wiedzy.
          </p>
        </div>
        <a href="/podcast" class="btn-secondary">
          Wszystkie odcinki
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {podcastShows.map((show) => (
          <a
            href="/podcast"
            class="card-glass group flex items-center gap-6 p-6 transition-all duration-300 hover:-translate-y-1.5 hover:border-white/25 sm:p-8"
          >
            <img
              src={show.cover}
              alt={`Okładka podcastu ${show.name}`}
              loading="lazy"
              class="h-24 w-24 shrink-0 rounded-2xl object-cover shadow-lg sm:h-32 sm:w-32"
            />
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-wider text-indigo-300">{show.listeners}</p>
              <h3 class="mt-1.5 font-display text-xl font-bold text-white sm:text-2xl">{show.name}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{show.tagline}</p>
              <p class="mt-3 line-clamp-1 text-xs text-slate-500">
                Najnowszy odcinek: {show.episodes[0].title}
              </p>
              <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-indigo-300 transition-colors group-hover:text-indigo-200">
                Posłuchaj
                <span class="transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="relative py-20 sm:py-24">
    <div class="container-page">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-indigo-600/25 via-night-900 to-fuchsia-600/20 p-8 sm:p-12">
        <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-fuchsia-500/20 blur-[100px]" aria-hidden="true"></div>
        <div class="relative grid items-center gap-10 lg:grid-cols-[1.4fr_1fr]">
          <div>
            <p class="section-eyebrow">Przeprogramowany Newsletter</p>
            <h2 class="section-title mt-3">Co tydzień w piątek — format 3-2-1</h2>
            <ul class="mt-6 space-y-3">
              <li class="flex items-center gap-3 text-slate-200">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-indigo-500/20 font-display text-sm font-bold text-indigo-200">3</span>
                rekomendacje techniczne
              </li>
              <li class="flex items-center gap-3 text-slate-200">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-violet-500/20 font-display text-sm font-bold text-violet-200">2</span>
                rekomendacje rozwojowe
              </li>
              <li class="flex items-center gap-3 text-slate-200">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-fuchsia-500/20 font-display text-sm font-bold text-fuchsia-200">1</span>
                bonus niespodzianka
              </li>
            </ul>
            <p class="mt-6 text-sm text-slate-400">
              Nie przegapisz też nowości od Przeprogramowanych i ofert specjalnych.
            </p>
            <a
              href="https://przeprogramowani.substack.com"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary mt-8"
            >
              Zapisz się za darmo
              <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="hidden justify-center lg:flex" aria-hidden="true">
            <div class="animate-float rounded-3xl border border-white/10 bg-white/[0.04] p-8 text-center backdrop-blur">
              <p class="font-display text-7xl font-bold text-gradient">3-2-1</p>
              <p class="mt-3 text-sm text-slate-400">piątek, prosto na Twoją skrzynkę</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ZAUFALI NAM -->
  <section class="border-t border-white/5 py-16">
    <div class="container-page">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.25em] text-slate-500">
        Zaufali nam — szkoliliśmy zespoły w
      </p>
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-3">
        {trustedBrands.map((brand) => (
          <li class="rounded-full border border-white/10 bg-white/[0.03] px-5 py-2.5 text-sm font-medium text-slate-400 transition-colors hover:border-white/20 hover:text-slate-200">
            {brand}
          </li>
        ))}
      </ul>
      <p class="mt-8 text-center text-sm text-slate-500">
        Chcesz nawiązać współpracę?{' '}
        <a href="mailto:kontakt@przeprogramowani.pl" class="font-medium text-indigo-300 transition-colors hover:text-indigo-200">
          kontakt@przeprogramowani.pl
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
