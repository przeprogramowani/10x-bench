---
import BaseLayout from '../layouts/BaseLayout.astro';
import { podcasts, siteConfig } from '../data/content';
---

<BaseLayout title="Podcast — Przeprogramowani" description="Słuchaj naszych podcastów o technologii, AI i programowaniu.">
  <section class="container-pp py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-eyebrow">Podcasty</p>
      <h1 class="mt-3 section-title">Słuchaj nas na ulubionej platformie</h1>
      <p class="mt-6 text-lg text-slate-300">
        Podcasty o technologii, AI i programowaniu — comiesięczne podsumowania i rozmowy z gośćmi.
      </p>
    </div>

    {
      podcasts.map((show) => (
        <div class="mt-16">
          <div class="flex flex-col gap-2 border-b border-slate-800 pb-6 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="text-2xl font-bold text-white">{show.show}</h2>
              <p class="mt-1 text-sm text-slate-400">{show.description}</p>
            </div>
            <span class="inline-flex w-fit items-center gap-2 rounded-full bg-brand-600/10 px-3 py-1 text-xs font-semibold text-brand-300">
              {show.listeners}
            </span>
          </div>

          <div class="mt-8 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {show.episodes.map((ep) => (
              <a
                href={ep.url}
                target="_blank"
                rel="noopener"
                class="group flex flex-col rounded-2xl border border-slate-800 bg-slate-900/60 p-6 transition hover:-translate-y-1 hover:border-slate-600"
              >
                <div class="flex items-center justify-between">
                  <span class="inline-flex items-center gap-1 rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-300">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-14 0m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V6a3 3 0 116 0v4a3 3 0 01-3 3z" />
                    </svg>
                    Podcast
                  </span>
                  <span class="text-xs font-mono text-slate-400">{ep.duration}</span>
                </div>
                <h3 class="mt-4 flex-1 text-base font-semibold leading-snug text-white">{ep.title}</h3>
                <p class="mt-3 line-clamp-3 text-sm text-slate-400">{ep.description}</p>
                <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-400">
                  Posłuchaj na Spotify
                  <svg class="h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))
    }

    <div class="mt-20 rounded-3xl border border-slate-800 bg-slate-900/60 p-10 text-center">
      <h2 class="section-title">Jesteśmy na twojej ulubionej platformie</h2>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1508387250" target="_blank" rel="noopener" class="btn-ghost">Apple Podcasts</a>
        <a href="https://open.spotify.com/show/4qHUZJpeBK8Ij9e2wTVm2o" target="_blank" rel="noopener" class="btn-ghost">Spotify</a>
        <a href="https://podcasts.google.com/feed/aHR0cHM6Ly9hbmNob3IuZm0vcy8yMjU0NGI3Yy9wb2RjYXN0L3Jzcw" target="_blank" rel="noopener" class="btn-ghost">Google Podcasts</a>
        <a href="https://anchor.fm/s/22544b7c/podcast/rss" target="_blank" rel="noopener" class="btn-ghost">RSS</a>
      </div>
    </div>
  </section>
</BaseLayout>
