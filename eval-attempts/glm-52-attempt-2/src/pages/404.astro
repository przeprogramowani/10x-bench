---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Przeprogramowani">
  <section class="container-pp py-32 text-center">
    <p class="font-mono text-sm text-brand-400">404</p>
    <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl">Nie znaleziono strony</h1>
    <p class="mt-4 text-slate-400">Ta strona prawdopodobnie przeniosła się w inne miejsce.</p>
    <a href="/" class="btn-primary mt-8">Wróć na stronę główną</a>
  </section>
</BaseLayout>
