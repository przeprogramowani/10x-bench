---
import BaseLayout from '../layouts/BaseLayout.astro';
import { team, brands } from '../data/content';
---

<BaseLayout title="O nas — Przeprogramowani" description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Poznaj nasz zespół.">
  <section class="container-pp py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-eyebrow">O nas</p>
      <h1 class="mt-3 section-title">Łączymy świat programowania, biznesu i rozwoju</h1>
      <p class="mt-6 text-lg text-slate-300">
        Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2">
      {
        team.map((person) => (
          <article class="card p-8">
            <div class="flex items-center gap-4">
              <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500 to-purple-600 text-xl font-bold text-white">
                {person.initials}
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">{person.name}</h2>
                <p class="text-sm text-brand-400">{person.role}</p>
              </div>
            </div>
            <p class="mt-5 text-sm leading-relaxed text-slate-300">{person.bio}</p>
            <a
              href={person.linkedin}
              target="_blank"
              rel="noopener"
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-400 hover:text-brand-300"
            >
              LinkedIn
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="container-pp py-16">
    <div class="mx-auto max-w-3xl rounded-3xl border border-slate-800 bg-gradient-to-br from-slate-900/80 to-slate-900/40 p-10 text-center">
      <h2 class="section-title">Witaj na Przeprogramowanych!</h2>
      <p class="mt-4 text-slate-300">
        Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
      </p>
      <p class="mt-4 text-xl font-semibold text-white">Zyskaj szersze spojrzenie na programowanie.</p>
    </div>
  </section>

  <section class="container-pp py-16">
    <div class="mx-auto max-w-2xl text-center">
      <p class="section-eyebrow">7 lat na rynku</p>
      <h2 class="mt-3 section-title">Współpracujemy z najlepszymi</h2>
    </div>
    <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
      {
        brands.map((brand) => (
          <div class="flex items-center justify-center rounded-xl border border-slate-800 bg-slate-900/40 px-4 py-6 text-center text-sm font-semibold text-slate-300">
            {brand}
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
