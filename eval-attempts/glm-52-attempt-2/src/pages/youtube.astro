---
import BaseLayout from '../layouts/BaseLayout.astro';
import { youtubeVideos, siteConfig } from '../data/content';
---

<BaseLayout title="YouTube — Przeprogramowani" description="Najnowsze filmy Przeprogramowani na YouTube — AI, programowanie i rozwój nowoczesnego programisty.">
  <section class="container-pp py-20 sm:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-eyebrow">YouTube</p>
      <h1 class="mt-3 section-title">Rozwój nowoczesnego programisty</h1>
      <p class="mt-6 text-lg text-slate-300">
        Najnowsze filmy o AI, programowaniu i narzędziach, które zmieniają sposób tworzenia oprogramowania.
      </p>
      <div class="mt-8">
        <a href={siteConfig.social.youtube} target="_blank" rel="noopener" class="btn-primary">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
          </svg>
          Subskrybuj kanał
        </a>
      </div>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        youtubeVideos.map((video) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener"
            class="group overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 transition hover:-translate-y-1 hover:border-slate-600"
          >
            <div class="relative aspect-video overflow-hidden">
              <img
                src={`https://i3.ytimg.com/vi/${video.id}/maxresdefault.jpg`}
                alt={video.title}
                loading="lazy"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 flex items-center justify-center bg-slate-950/30 transition group-hover:bg-slate-950/50">
                <span class="flex h-14 w-14 items-center justify-center rounded-full bg-red-600/90 shadow-lg transition group-hover:scale-110">
                  <svg class="ml-1 h-6 w-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </div>
            </div>
            <div class="p-5">
              <h3 class="text-sm font-semibold leading-snug text-white">{video.title}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
