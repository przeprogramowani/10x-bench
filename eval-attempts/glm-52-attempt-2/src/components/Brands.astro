---
import { brands } from '../data/content';
---

<section class="container-pp py-16">
  <div class="mx-auto max-w-2xl text-center">
    <p class="section-eyebrow">7 lat na rynku edukacji technologicznej</p>
    <h2 class="mt-3 section-title">Współpracujemy z najlepszymi</h2>
  </div>
  <div class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-5">
    {
      brands.map((brand) => (
        <div class="flex items-center justify-center rounded-xl border border-slate-800 bg-slate-900/40 px-4 py-6 text-center text-sm font-semibold text-slate-300">
          {brand}
        </div>
      ))
    }
  </div>
</section>
