---
import { siteConfig, youtubeVideos, podcasts } from '../data/content';

const featuredVideos = youtubeVideos.slice(0, 3);
const featuredPodcasts = [
  podcasts[0].episodes[0],
  podcasts[0].episodes[1],
];
---

<section id="kursy" class="container-pp py-20 sm:py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="section-eyebrow">Edukacja technologiczna w epoce AI</p>
    <h2 class="mt-3 section-title">Topowe programy edukacyjne</h2>
    <p class="mt-4 text-slate-400">
      Dla ambitnych programistów i świadome korzystanie z potencjału Generative AI.
    </p>
  </div>

  <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      siteConfig.courses.map((course) => (
        <a
          href={course.url}
          target="_blank"
          rel="noopener"
          class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 p-6 transition hover:-translate-y-1 hover:border-slate-600"
        >
          <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${course.accent}`} />
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">{course.tag}</span>
          <h3 class="mt-3 text-xl font-bold text-white">{course.title}</h3>
          <p class="mt-3 flex-1 text-sm text-slate-400">{course.description}</p>
          <div class="mt-6 flex items-center justify-between">
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-brand-400">
              Szczegóły
              <svg class="h-4 w-4 transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </span>
            <span class="rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-300">{course.badge}</span>
          </div>
        </a>
      ))
    }
  </div>
</section>

<section class="container-pp py-20 sm:py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="section-eyebrow">Filmy i podcasty</p>
    <h2 class="mt-3 section-title">Rozwój nowoczesnego programisty</h2>
  </div>

  <div class="mt-12 grid gap-6 lg:grid-cols-3">
    {
      featuredVideos.map((video) => (
        <a
          href={video.url}
          target="_blank"
          rel="noopener"
          class="group overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60 transition hover:-translate-y-1 hover:border-slate-600"
        >
          <div class="relative aspect-video overflow-hidden">
            <img
              src={`https://i3.ytimg.com/vi/${video.id}/maxresdefault.jpg`}
              alt={video.title}
              loading="lazy"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 flex items-center justify-center bg-slate-950/30 opacity-100 transition group-hover:bg-slate-950/50">
              <span class="flex h-14 w-14 items-center justify-center rounded-full bg-red-600/90 shadow-lg">
                <svg class="ml-1 h-6 w-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="line-clamp-2 text-sm font-semibold text-white">{video.title}</h3>
          </div>
        </a>
      ))
    }
  </div>

  <div class="mt-8 text-center">
    <a href="/youtube" class="btn-ghost">Zobacz wszystkie filmy</a>
  </div>
</section>

<section class="container-pp py-20 sm:py-24">
  <div class="mx-auto max-w-2xl text-center">
    <p class="section-eyebrow">Przeprogramowany Newsletter</p>
    <h2 class="mt-3 section-title">Co tydzień w piątek</h2>
    <p class="mt-4 text-slate-400">
      Porcja wartościowych treści w formacie 3-2-1: 3 rekomendacje techniczne, 2 rozwojowe i 1 bonus niespodzianka.
    </p>
    <div class="mt-8">
      <a href="https://przeprogramowani.substack.com" target="_blank" rel="noopener" class="btn-primary">
        Zapisz się za darmo
      </a>
    </div>
  </div>
</section>
