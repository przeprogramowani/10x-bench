---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { site, founders, clients, values } from '../data/site';
---

<Layout
  title="O nas"
  description="Poznaj Przeprogramowani — miejsce, w którym programowanie spotyka się z rozwojem osobistym. Od 7 lat tworzymy kursy, treści i narzędzia dla ambitnych programistów."
  path="/o-nas"
>
  <!-- Intro -->
  <section class="relative overflow-hidden">
    <div class="bg-grid absolute inset-0" aria-hidden="true"></div>
    <div class="pointer-events-none absolute left-1/2 top-[-20%] h-[380px] w-[640px] -translate-x-1/2 rounded-full bg-brand-600/20 blur-[120px]" aria-hidden="true"></div>
    <div class="container-page relative py-20 sm:py-28">
      <div class="max-w-3xl">
        <span class="eyebrow"><span class="h-px w-6 bg-brand-400"></span>O nas</span>
        <h1 class="mt-5 text-4xl font-extrabold leading-tight sm:text-5xl">
          Miejsce, w którym programowanie spotyka się z rozwojem osobistym
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-300">
          Wierzymy, że wyjątkowi programiści patrzą szerzej — widzą architekturę, biznes i relacje
          międzyludzkie, nie tylko kod. Dlatego od {site.yearsActive} lat tworzymy treści, kursy i
          narzędzia, które pomagają rozwijać się w wielu wymiarach: od technicznych deep-dive’ów po
          rozmowy o karierze i rozwoju osobistym.
        </p>
      </div>

      <dl class="mt-14 grid gap-6 sm:grid-cols-3">
        <div class="card p-6">
          <dt class="text-4xl font-extrabold text-white">{site.yearsActive} lat</dt>
          <dd class="mt-2 text-sm text-slate-400">na rynku edukacji technicznej</dd>
        </div>
        <div class="card p-6">
          <dt class="text-4xl font-extrabold text-white">Tysiące</dt>
          <dd class="mt-2 text-sm text-slate-400">absolwentów naszych programów</dd>
        </div>
        <div class="card p-6">
          <dt class="text-4xl font-extrabold text-white">#1</dt>
          <dd class="mt-2 text-sm text-slate-400">techniczny podcast o LLM-ach w Polsce</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- Founders -->
  <section class="border-t border-white/10 py-20 sm:py-24">
    <div class="container-page">
      <SectionHeading eyebrow="Twórcy" title="Za Przeprogramowani stoją" />
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {
          founders.map((f) => (
            <article class="card flex flex-col gap-5 p-7 sm:flex-row sm:items-start">
              <div class="grid h-16 w-16 flex-none place-items-center rounded-2xl bg-gradient-to-br from-brand-400 to-brand-600 text-lg font-bold text-white shadow-lg shadow-brand-500/25">
                {f.initials}
              </div>
              <div>
                <h3 class="text-xl">{f.name}</h3>
                <p class="mt-1 text-sm font-medium text-brand-300">{f.role}</p>
                <p class="mt-3 text-sm leading-relaxed text-slate-300">{f.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="border-t border-white/10 bg-ink-900/40 py-20 sm:py-24">
    <div class="container-page">
      <SectionHeading eyebrow="Wartości" title="Co nas wyróżnia" />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          values.map((v, i) => (
            <article class="card p-7">
              <span class="font-mono text-sm text-brand-400">0{i + 1}</span>
              <h3 class="mt-3 text-lg">{v.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{v.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Clients -->
  <section class="border-t border-white/10 py-20 sm:py-24">
    <div class="container-page">
      <SectionHeading
        eyebrow="Zaufali nam"
        title="Szkoliliśmy zespoły z topowych firm technologicznych"
      />
      <ul class="mt-10 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {
          clients.map((c) => (
            <li class="card flex items-center justify-center px-4 py-8 text-center text-base font-semibold text-slate-300">
              {c}
            </li>
          ))
        }
      </ul>

      <div class="mt-14 flex flex-col items-center gap-4 rounded-2xl border border-white/10 bg-white/[0.02] px-8 py-12 text-center">
        <h3 class="text-2xl">Masz pytanie lub propozycję współpracy?</h3>
        <p class="max-w-md text-slate-400">Napisz do nas — chętnie porozmawiamy o kursach, warsztatach dla zespołów i wspólnych projektach.</p>
        <a href={`mailto:${site.email}`} class="btn-primary mt-2">{site.email}</a>
      </div>
    </div>
  </section>
</Layout>
