---
import Layout from '../layouts/Layout.astro';
import { site, videos } from '../data/site';

const [featured, ...rest] = videos;
const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Layout
  title="YouTube"
  description="Najnowsze filmy z kanału YouTube Przeprogramowani — AI, agenci do programowania, frontend i rozwój kariery."
  path="/youtube"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="bg-grid absolute inset-0" aria-hidden="true"></div>
    <div class="pointer-events-none absolute left-[-5%] top-[-20%] h-[360px] w-[520px] rounded-full bg-red-600/15 blur-[120px]" aria-hidden="true"></div>
    <div class="container-page relative py-20 sm:py-24">
      <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
        <div class="max-w-2xl">
          <span class="eyebrow"><span class="h-px w-6 bg-red-400"></span>YouTube</span>
          <h1 class="mt-5 text-4xl font-extrabold leading-tight sm:text-5xl">Najnowsze filmy</h1>
          <p class="mt-6 text-lg leading-relaxed text-slate-300">
            AI, agenci do programowania, frontend i rozwój kariery — praktyczna wiedza prosto z naszego
            kanału. Subskrybuj, żeby nie przegapić kolejnych materiałów.
          </p>
        </div>
        <a
          href={site.socials.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary flex-none !bg-red-500 !shadow-red-500/25 hover:!bg-red-400"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 12s0-3.8-.5-5.6a2.9 2.9 0 0 0-2-2C18.7 4 12 4 12 4s-6.7 0-8.5.4a2.9 2.9 0 0 0-2 2C1 8.2 1 12 1 12s0 3.8.5 5.6a2.9 2.9 0 0 0 2 2C5.3 20 12 20 12 20s6.7 0 8.5-.4a2.9 2.9 0 0 0 2-2C23 15.8 23 12 23 12ZM10 15.5v-7l6 3.5-6 3.5Z"/></svg>
          Subskrybuj kanał
        </a>
      </div>
    </div>
  </section>

  <!-- Featured -->
  <section class="pb-6">
    <div class="container-page">
      <a
        href={`https://www.youtube.com/watch?v=${featured.id}`}
        target="_blank"
        rel="noopener noreferrer"
        class="card group grid gap-6 overflow-hidden p-4 transition-colors hover:border-red-400/30 lg:grid-cols-[1.4fr_1fr] lg:p-5"
      >
        <div class="relative overflow-hidden rounded-xl">
          <img
            src={`https://i.ytimg.com/vi/${featured.id}/maxresdefault.jpg`}
            alt={featured.title}
            width="1280"
            height="720"
            class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
          />
          <span class="absolute inset-0 grid place-items-center">
            <span class="grid h-16 w-16 place-items-center rounded-full bg-red-500/90 text-white shadow-xl transition-transform group-hover:scale-110">
              <svg class="ml-1 h-7 w-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            </span>
          </span>
        </div>
        <div class="flex flex-col justify-center p-2 lg:p-4">
          <span class="inline-flex w-fit items-center gap-2 rounded-full bg-red-500/15 px-3 py-1 text-xs font-semibold text-red-400">
            <span class="h-1.5 w-1.5 rounded-full bg-red-400"></span>Najnowszy film
          </span>
          <h2 class="mt-4 text-2xl leading-snug">{featured.title}</h2>
          <p class="mt-3 text-sm text-slate-500">{fmtDate(featured.date)}</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-red-400">
            Obejrzyj na YouTube
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 10h12M12 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Grid -->
  <section class="py-14">
    <div class="container-page">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          rest.map((v) => (
            <a
              href={`https://www.youtube.com/watch?v=${v.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="card group flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-red-400/30"
            >
              <div class="relative overflow-hidden">
                <img
                  src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
                  alt={v.title}
                  loading="lazy"
                  width="480"
                  height="360"
                  class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <span class="absolute inset-0 grid place-items-center opacity-0 transition-opacity group-hover:opacity-100">
                  <span class="grid h-12 w-12 place-items-center rounded-full bg-red-500/90 text-white">
                    <svg class="ml-0.5 h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                </span>
              </div>
              <div class="flex flex-1 flex-col p-5">
                <h3 class="line-clamp-2 text-base font-semibold text-white">{v.title}</h3>
                <p class="mt-auto pt-3 text-xs text-slate-500">{fmtDate(v.date)}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
