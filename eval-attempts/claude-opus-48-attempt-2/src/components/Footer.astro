---
import { site, nav, courses } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-ink-900/60">
  <div class="container-page py-14">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr_1.2fr]">
      <div>
        <a href="/" class="flex items-center gap-2.5 font-semibold text-white">
          <span
            class="grid h-9 w-9 place-items-center rounded-xl bg-gradient-to-br from-brand-400 to-brand-600 font-mono text-sm font-bold text-white"
            >{'</>'}</span
          >
          <span class="text-[15px] tracking-tight">{site.name}</span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
          {site.tagline}. Od {site.yearsActive} lat wspieramy programistów w rozwoju technicznym i
          świadomej pracy z AI.
        </p>
        <a
          href={`mailto:${site.email}`}
          class="mt-4 inline-block text-sm font-medium text-brand-300 hover:text-brand-200"
        >
          {site.email}
        </a>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Nawigacja</h4>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="link-underline">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Kursy</h4>
        <ul class="mt-4 space-y-2.5 text-sm">
          {
            courses.map((course) => (
              <li>
                <a
                  href={course.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="link-underline"
                >
                  {course.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-slate-500">Znajdź nas</h4>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href={site.socials.youtube} target="_blank" rel="noopener noreferrer" class="link-underline">YouTube</a></li>
          <li><a href={site.socials.spotify} target="_blank" rel="noopener noreferrer" class="link-underline">Spotify</a></li>
          <li><a href={site.socials.applePodcasts} target="_blank" rel="noopener noreferrer" class="link-underline">Apple Podcasts</a></li>
          <li><a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" class="link-underline">Instagram</a></li>
          <li><a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" class="link-underline">Facebook</a></li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-white/10 pt-6 text-sm text-slate-500 sm:flex-row sm:items-center"
    >
      <p>© {year} {site.name}. Wszelkie prawa zastrzeżone.</p>
      <p>Szersze spojrzenie na programowanie.</p>
    </div>
  </div>
</footer>
