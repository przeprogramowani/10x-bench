---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsletterCta from '../components/NewsletterCta.astro';
import { site, founders } from '../data/site';

const values = [
  {
    title: 'Praktyka ponad teorię',
    description:
      'Uczymy tego, co sami stosujemy w komercyjnych projektach — od architektury frontendu po agentowe workflow z AI na produkcji.',
    icon: 'M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085',
  },
  {
    title: 'Szersze spojrzenie',
    description:
      'Programowanie to nie tylko kod. Mówimy o karierze, komunikacji, produktach i decyzjach technicznych, które naprawdę mają znaczenie.',
    icon: 'M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z',
  },
  {
    title: 'Społeczność',
    description:
      'Tysiące programistów w społecznościach naszych kursów, na live’ach i w newsletterze. Rozwijamy się razem, nie w pojedynkę.',
    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
];

const milestones = [
  { year: '2019', text: 'Start podcastu Przeprogramowani — pierwsze rozmowy o szerszym spojrzeniu na programowanie.' },
  { year: '2023', text: 'Premiera programu Opanuj Frontend: AI Edition — kompleksowa ścieżka dla frontend developerów.' },
  { year: '2024', text: 'Opanuj TypeScript i Frontend Tech Radar. Społeczność kursów przekracza tysiąc uczestników.' },
  { year: '2025', text: '10xDevs — flagowy program AI-Native Software Engineering z tysiącami absolwentów.' },
  { year: '2026', text: '10xDevs 3.0 i dalszy rozwój narzędzi takich jak 10xRules.ai dla zespołów pracujących z AI.' },
];
---

<Layout
  title="O nas — Przeprogramowani.pl"
  description="Poznaj Przemka Smyrdka i Marcina Czarkowskiego — twórców projektu Przeprogramowani.pl, podcastu, kanału YouTube i szkoleń 10xDevs, Opanuj Frontend i Opanuj TypeScript."
>
  <section class="mx-auto max-w-6xl px-4 pb-16 pt-32 sm:px-6 sm:pt-40">
    <SectionHeading
      eyebrow="O nas"
      title="Pomagamy programistom patrzeć szerzej"
      subtitle="Przeprogramowani.pl to projekt edukacyjny tworzony przez praktyków. Od 2019 roku łączymy podcast, YouTube, newsletter i szkolenia, by tysiące programistów rozwijały się szybciej i mądrzej."
    />
  </section>

  <!-- Founders -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <div class="grid gap-7 md:grid-cols-2">
      {founders.map((person) => (
        <article class="flex flex-col gap-5 rounded-2xl border border-white/10 bg-ink-800/60 p-8 sm:flex-row">
          <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500 to-violet-600 text-2xl font-black text-white shadow-lg shadow-brand-900/40">
            {person.initials}
          </div>
          <div>
            <h2 class="text-xl font-bold text-white">{person.name}</h2>
            <p class="text-sm font-semibold uppercase tracking-wider text-brand-400">{person.role}</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{person.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Values -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <SectionHeading eyebrow="Wartości" title="W co wierzymy" />
    <div class="mt-12 grid gap-7 md:grid-cols-3">
      {values.map((value) => (
        <div class="rounded-2xl border border-white/10 bg-ink-800/60 p-7">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/15">
            <svg class="h-6 w-6 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
              {value.title === 'Szersze spojrzenie' && (
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              )}
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold text-white">{value.title}</h3>
          <p class="mt-2.5 text-sm leading-relaxed text-slate-400">{value.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="border-t border-white/5 bg-ink-900/50 py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <SectionHeading eyebrow="Historia" title="Jak rozwijał się projekt" />
      <ol class="mt-12 space-y-0">
        {milestones.map((m, i) => (
          <li class="relative flex gap-6 pb-10 last:pb-0">
            <div class="flex flex-col items-center">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-brand-500/40 bg-ink-800 text-xs font-bold text-brand-300">
                {m.year}
              </span>
              {i < milestones.length - 1 && <span class="mt-1 w-px flex-1 bg-white/10"></span>}
            </div>
            <p class="pt-2 text-sm leading-relaxed text-slate-300">{m.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Contact -->
  <section class="mx-auto max-w-6xl px-4 py-20 text-center sm:px-6">
    <SectionHeading
      eyebrow="Kontakt"
      title="Porozmawiajmy"
      subtitle="Współpraca, patronaty, pytania o kursy — napisz do nas."
    />
    <a
      href={`mailto:${site.email}`}
      class="mt-8 inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-brand-600/30 transition-all hover:bg-brand-500"
    >
      {site.email}
    </a>
  </section>

  <NewsletterCta />
</Layout>
