---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import NewsletterCta from '../components/NewsletterCta.astro';
import { site } from '../data/site';
import { videos, channelDescription } from '../data/videos';
---

<Layout
  title="YouTube — Przeprogramowani.pl"
  description={`Kanał YouTube Przeprogramowani: ${channelDescription}`}
>
  <section class="mx-auto max-w-6xl px-4 pb-12 pt-32 sm:px-6 sm:pt-40">
    <SectionHeading eyebrow="YouTube" title="Przeprogramowani na YouTube" subtitle={channelDescription} />
    <div class="mt-10 text-center">
      <a
        href={site.links.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 rounded-xl bg-red-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-red-600/30 transition-all hover:bg-red-500"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/></svg>
        Subskrybuj kanał
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <h2 class="sr-only">Najnowsze filmy</h2>
    <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
      {videos.map((video) => (
        <a
          href={video.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col overflow-hidden rounded-2xl border border-white/10 bg-ink-800/60 transition-all hover:-translate-y-1 hover:border-red-500/40 hover:shadow-2xl hover:shadow-red-900/20"
        >
          <div class="relative flex aspect-video items-center justify-center bg-gradient-to-br from-ink-700 via-ink-800 to-red-950/40">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(239,68,68,0.12),transparent_60%)]"></div>
            <span class="flex h-14 w-14 items-center justify-center rounded-full bg-red-600/90 text-white shadow-xl transition-transform group-hover:scale-110">
              <svg class="ml-1 h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5.14v14l11-7-11-7z"/></svg>
            </span>
            <span class="absolute left-4 top-4 rounded-full bg-black/50 px-3 py-1 text-xs font-semibold text-white backdrop-blur">
              {video.category}
            </span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-lg font-bold leading-snug text-white group-hover:text-red-300">{video.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{video.description}</p>
            <span class="mt-auto flex items-center gap-1.5 pt-4 text-sm font-semibold text-red-400">
              Oglądaj na YouTube
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <p class="mt-10 text-center text-sm text-slate-500">
      Live'y 10xDevs odbywają się we wtorki o 19:00 — wszystkie nagrania trafiają na
      <a href={site.links.youtube} target="_blank" rel="noopener noreferrer" class="font-semibold text-brand-400 hover:text-brand-300">kanał Przeprogramowani</a>.
    </p>
  </section>

  <NewsletterCta />
</Layout>
