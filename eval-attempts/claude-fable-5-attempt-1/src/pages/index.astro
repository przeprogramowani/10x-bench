---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CourseCard from '../components/CourseCard.astro';
import NewsletterCta from '../components/NewsletterCta.astro';
import { site } from '../data/site';
import { courses } from '../data/courses';
import { episodes } from '../data/episodes';
import { videos } from '../data/videos';

const featured = courses.find((c) => c.id === '10xdevs')!;
const latestEpisodes = episodes.slice(0, 3);
const latestVideos = videos.slice(0, 3);

const stats = [
  { value: '3700+', label: 'absolwentów 10xDevs' },
  { value: '100', label: 'odcinków podcastu' },
  { value: '7 lat', label: 'edukacji programistów' },
  { value: '2000+', label: 'osób w społeczności' },
];
---

<Layout title="Przeprogramowani.pl — Szersze spojrzenie na programowanie">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 h-[32rem] w-[60rem] -translate-x-1/2 rounded-full bg-brand-700/25 blur-3xl"></div>
      <div class="absolute right-[-10rem] top-40 h-80 w-80 rounded-full bg-violet-600/15 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-6xl px-4 pb-20 pt-32 sm:px-6 sm:pt-40">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="animate-fade-up">
          <p class="inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
            </span>
            Trwają zapisy do 10xDevs 3.0
          </p>
          <h1 class="mt-6 text-4xl font-black leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
            Szersze spojrzenie na <span class="bg-gradient-to-r from-brand-400 to-violet-400 bg-clip-text text-transparent">programowanie</span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
            Podcast, YouTube i praktyczne szkolenia dla programistów. Uczymy
            AI-Native Software Engineering — świadomej i precyzyjnej pracy z AI
            w całym cyklu życia oprogramowania.
          </p>
          <div class="mt-9 flex flex-wrap items-center gap-4">
            <a
              href={site.links.tenXDevs}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-sm font-bold text-white shadow-xl shadow-brand-600/30 transition-all hover:bg-brand-500 hover:shadow-brand-500/40"
            >
              Dołącz do 10xDevs
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="#kursy"
              class="inline-flex items-center gap-2 rounded-xl border border-white/15 px-6 py-3.5 text-sm font-semibold text-white transition-colors hover:border-white/30 hover:bg-white/5"
            >
              Zobacz wszystkie kursy
            </a>
          </div>
        </div>

        <!-- Hero card: 10xDevs -->
        <div class="animate-fade-up [animation-delay:150ms]">
          <div class="relative rounded-3xl border border-brand-500/30 bg-gradient-to-br from-ink-800 via-ink-800 to-brand-900/40 p-8 shadow-2xl shadow-brand-900/40">
            <div class="flex items-center justify-between">
              <span class={`inline-flex items-center rounded-full bg-gradient-to-r ${featured.accent} px-3 py-1 text-xs font-semibold text-white`}>
                {featured.badge}
              </span>
              <span class="text-xs font-medium uppercase tracking-wider text-slate-500">Edycja 3.0</span>
            </div>
            <h2 class="mt-6 text-3xl font-extrabold text-white">10xDevs</h2>
            <p class="mt-2 text-base font-medium text-brand-300">{featured.tagline}</p>
            <p class="mt-4 text-sm leading-relaxed text-slate-400">{featured.description}</p>
            <ul class="mt-6 space-y-3">
              {featured.highlights.slice(0, 3).map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-slate-300">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <a
              href={featured.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-white px-5 py-3 text-sm font-bold text-ink-900 transition-transform hover:scale-[1.02]"
            >
              Sprawdź program
            </a>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <dl class="mt-20 grid grid-cols-2 gap-6 rounded-2xl border border-white/10 bg-ink-800/40 p-8 sm:grid-cols-4">
        {stats.map((stat) => (
          <div class="text-center">
            <dt class="order-2 mt-1 text-sm text-slate-400">{stat.label}</dt>
            <dd class="order-1 text-3xl font-extrabold text-white">{stat.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Courses -->
  <section id="kursy" class="scroll-mt-24 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeading
        eyebrow="Szkolenia"
        title="Kursy, które zmieniają sposób pracy"
        subtitle="Praktyczne programy szkoleniowe tworzone przez praktyków — od fundamentów frontendu i TypeScriptu po pracę z agentami AI na produkcji."
      />
      <div class="mt-14 grid gap-7 md:grid-cols-2 lg:grid-cols-3">
        {courses.map((course) => (
          <CourseCard course={course} />
        ))}
      </div>
    </div>
  </section>

  <!-- Podcast teaser -->
  <section class="border-t border-white/5 bg-ink-900/50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
        <SectionHeading
          align="left"
          eyebrow="Podcast"
          title="Ostatnie odcinki"
          subtitle="Rozmowy o programowaniu, karierze i technologii — dostępne na Spotify i Apple Podcasts."
        />
        <a href="/podcast" class="shrink-0 text-sm font-semibold text-brand-400 hover:text-brand-300">
          Wszystkie odcinki →
        </a>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {latestEpisodes.map((ep) => (
          <article class="flex flex-col rounded-2xl border border-white/10 bg-ink-800/60 p-6 transition-colors hover:border-brand-500/40">
            <div class="flex items-center gap-3 text-xs text-slate-500">
              <span>{ep.date}</span>
              <span aria-hidden="true">•</span>
              <span>{ep.duration}</span>
            </div>
            <h3 class="mt-3 text-lg font-bold leading-snug text-white">{ep.title}</h3>
            {ep.guest && <p class="mt-1 text-sm font-medium text-brand-300">Gość: {ep.guest}</p>}
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{ep.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- YouTube teaser -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
        <SectionHeading
          align="left"
          eyebrow="YouTube"
          title="Najnowsze materiały wideo"
          subtitle="Deep dive'y, live'y i praktyczne poradniki o narzędziach AI dla programistów."
        />
        <a href="/youtube" class="shrink-0 text-sm font-semibold text-brand-400 hover:text-brand-300">
          Wszystkie filmy →
        </a>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {latestVideos.map((video) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-2xl border border-white/10 bg-ink-800/60 p-6 transition-all hover:-translate-y-1 hover:border-red-500/40"
          >
            <div class="flex items-center justify-between">
              <span class="inline-flex items-center rounded-full bg-red-500/15 px-3 py-1 text-xs font-semibold text-red-400">
                {video.category}
              </span>
              <svg class="h-5 w-5 text-slate-600 transition-colors group-hover:text-red-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/>
              </svg>
            </div>
            <h3 class="mt-4 text-lg font-bold leading-snug text-white group-hover:text-red-300">{video.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">{video.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <NewsletterCta />
</Layout>
