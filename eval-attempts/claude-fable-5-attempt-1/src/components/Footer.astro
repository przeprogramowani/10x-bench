---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-white/10 bg-ink-900">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5">
          <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 text-sm font-black text-white">
            {'</>'}
          </span>
          <span class="text-base font-bold tracking-tight text-white">
            przeprogramowani<span class="text-brand-400">.pl</span>
          </span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-slate-400">
          {site.tagline}. Podcast, YouTube i praktyczne szkolenia dla programistów,
          którzy chcą rozwijać się szybciej w erze AI.
        </p>
        <a
          href={`mailto:${site.email}`}
          class="mt-4 inline-block text-sm font-medium text-brand-400 hover:text-brand-300"
        >
          {site.email}
        </a>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Na skróty</h3>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li><a href="/o-nas" class="text-slate-400 hover:text-white">O nas</a></li>
          <li><a href="/podcast" class="text-slate-400 hover:text-white">Podcast</a></li>
          <li><a href="/youtube" class="text-slate-400 hover:text-white">YouTube</a></li>
          <li><a href="/#kursy" class="text-slate-400 hover:text-white">Kursy</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Szkolenia</h3>
        <ul class="mt-4 space-y-2.5 text-sm">
          <li>
            <a href={site.links.tenXDevs} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white">10xDevs</a>
          </li>
          <li>
            <a href={site.links.opanujFrontend} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white">Opanuj Frontend</a>
          </li>
          <li>
            <a href={site.links.opanujTypescript} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white">Opanuj TypeScript</a>
          </li>
          <li>
            <a href={site.links.newsletter} target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-white">Newsletter</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
      <p class="text-sm text-slate-500">© {year} Przeprogramowani.pl. Wszystkie prawa zastrzeżone.</p>
      <div class="flex items-center gap-4">
        <a href={site.links.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-slate-400 transition-colors hover:text-white">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/></svg>
        </a>
        <a href={site.links.spotify} target="_blank" rel="noopener noreferrer" aria-label="Spotify" class="text-slate-400 transition-colors hover:text-white">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24zm5.5 17.3a.75.75 0 0 1-1 .25c-2.8-1.7-6.4-2.1-10.5-1.2a.75.75 0 1 1-.33-1.46c4.5-1 8.4-.55 11.6 1.4.35.21.46.67.24 1.02zm1.47-3.27a.94.94 0 0 1-1.29.31c-3.2-2-8.1-2.55-12-1.4a.94.94 0 1 1-.54-1.8c4.4-1.3 9.8-.67 13.5 1.6.44.27.58.85.31 1.29zm.13-3.4C15.3 8.35 9 8.13 5.3 9.25a1.13 1.13 0 1 1-.65-2.16c4.3-1.3 11.2-1.05 15.6 1.55a1.13 1.13 0 0 1-1.15 1.94z"/></svg>
        </a>
        <a href={site.links.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-slate-400 transition-colors hover:text-white">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"/></svg>
        </a>
        <a href={site.links.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-slate-400 transition-colors hover:text-white">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
