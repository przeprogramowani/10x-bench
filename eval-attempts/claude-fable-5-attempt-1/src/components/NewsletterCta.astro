---
import { site } from '../data/site';
---

<section class="mx-auto max-w-6xl px-4 py-20 sm:px-6">
  <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-brand-900/60 via-ink-800 to-ink-900 px-6 py-14 text-center sm:px-12">
    <div class="pointer-events-none absolute -top-24 left-1/2 h-64 w-[36rem] -translate-x-1/2 rounded-full bg-brand-600/20 blur-3xl"></div>
    <h2 class="relative text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
      Przeprogramowany Newsletter
    </h2>
    <p class="relative mx-auto mt-4 max-w-xl text-base leading-relaxed text-slate-300">
      W każdy piątek: 3 techniczne polecajki, 2 wskazówki rozwojowe i 1 niespodzianka.
      Dołącz do tysięcy programistów, którzy zaczynają weekend z szerszym spojrzeniem.
    </p>
    <a
      href={site.links.newsletter}
      target="_blank"
      rel="noopener noreferrer"
      class="relative mt-8 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3.5 text-sm font-bold text-ink-900 shadow-xl transition-transform hover:scale-105"
    >
      Zapisuję się
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
