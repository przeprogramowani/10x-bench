---
import type { Founder } from "../data/site";

type Props = {
  founder: Founder;
};

const { founder } = Astro.props;
---

<article class="rounded-[2rem] border border-white/10 bg-white/5 p-6">
  <div class={`mb-6 h-32 rounded-[1.5rem] bg-gradient-to-br ${founder.accent} p-[1px]`}>
    <div class="flex h-full items-end rounded-[calc(1.5rem-1px)] bg-[var(--color-surface)]/96 p-5">
      <div>
        <p class="font-display text-2xl text-white">{founder.name}</p>
        <p class="mt-1 text-sm text-[var(--color-muted)]">{founder.role}</p>
      </div>
    </div>
  </div>
  <p class="text-sm leading-7 text-[var(--color-muted)]">{founder.bio}</p>
  <a
    href={founder.linkedin}
    target="_blank"
    rel="noreferrer"
    class="mt-6 inline-flex items-center gap-2 rounded-full border border-white/12 px-4 py-2 text-sm font-semibold text-[var(--color-text)] transition hover:border-[var(--color-brand)] hover:text-white"
  >
    LinkedIn
    <span aria-hidden="true">↗</span>
  </a>
</article>
