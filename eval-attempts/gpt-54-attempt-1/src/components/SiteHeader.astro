---
import MobileMenu from "./MobileMenu";
import { navigation, siteMeta } from "../data/site";

const normalizePath = (value: string) => (value !== "/" && value.endsWith("/") ? value.slice(0, -1) : value);
const pathname = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-50">
  <div class="border-b border-white/8 bg-[rgba(5,10,21,0.76)] backdrop-blur-xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-4 sm:px-6 lg:px-8">
      <a href="/" class="flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-[linear-gradient(135deg,var(--color-brand),var(--color-brand-2))] text-base font-black text-[var(--color-surface)]">
          &lt;/&gt;
        </span>
        <div>
          <p class="font-display text-sm uppercase tracking-[0.22em] text-[var(--color-muted)]">Przeprogramowani</p>
          <p class="text-sm text-[var(--color-text)]">{siteMeta.tagline}</p>
        </div>
      </a>

      <div class="relative flex items-center gap-3">
        <nav class="hidden items-center gap-2 lg:flex">
          {
            navigation.map((item) => {
              const isActive = pathname === normalizePath(item.href);

              return (
                <a
                  href={item.href}
                  class:list={[
                    "rounded-full px-4 py-2 text-sm font-semibold transition",
                    isActive
                      ? "bg-[var(--color-brand)] text-[var(--color-surface)]"
                      : "text-[var(--color-text)] hover:bg-white/6 hover:text-white",
                  ]}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>

        <a
          href="https://10xdevs.pl/"
          target="_blank"
          rel="noreferrer"
          class="hidden rounded-full border border-[var(--color-brand)]/60 bg-[var(--color-brand)]/12 px-4 py-2 text-sm font-semibold text-[var(--color-text)] transition hover:border-[var(--color-brand)] hover:bg-[var(--color-brand)] hover:text-[var(--color-surface)] sm:inline-flex"
        >
          10xDevs
        </a>

        <MobileMenu client:load items={navigation} currentPath={pathname} />
      </div>
    </div>
  </div>
</header>
