---
import ContentCard from "../components/ContentCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { podcastPlatforms, podcastSeries } from "../data/site";
---

<MainLayout title="Podcast | Przeprogramowani.pl" description="Ostatnie odcinki podcastów Przeprogramowanych i Opanuj.AI.">
  <section class="mx-auto max-w-7xl px-5 pb-12 pt-10 sm:px-6 lg:px-8 lg:pt-16">
    <div class="max-w-4xl space-y-6">
      <p class="font-display text-xs uppercase tracking-[0.3em] text-[var(--color-brand-2)]">Podcast</p>
      <h1 class="font-display text-5xl leading-tight text-white sm:text-6xl">Słuchaj podcastów o technologii, AI i programowaniu</h1>
      <p class="text-lg leading-8 text-[var(--color-muted)]">
        Ta strona zbiera najnowsze odcinki z dwóch głównych formatów audio Przeprogramowanych: Opanuj.AI Podcast oraz Przeprogramowani ft. Gość.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-8 sm:px-6 lg:px-8">
    <div class="grid gap-4 lg:grid-cols-3">
      {
        podcastPlatforms.map((platform) => (
          <a
            href={platform.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-[1.5rem] border border-white/10 bg-white/5 px-5 py-5 text-sm font-semibold text-[var(--color-text)] transition hover:border-white/20 hover:bg-white/7"
          >
            {platform.name}
          </a>
        ))
      }
    </div>
  </section>

  {
    podcastSeries.map((series) => (
      <section class="mx-auto max-w-7xl px-5 py-14 sm:px-6 lg:px-8">
        <div class="grid gap-10 xl:grid-cols-[0.72fr_1.28fr]">
          <aside class="rounded-[2rem] border border-white/10 bg-white/5 p-6">
            <img src={series.cover} alt={series.name} class="h-56 w-full rounded-[1.5rem] object-cover" loading="lazy" />
            <p class="mt-6 text-xs uppercase tracking-[0.24em] text-[var(--color-brand-2)]">{series.badge}</p>
            <h2 class="mt-3 font-display text-3xl text-white">{series.name}</h2>
            <p class="mt-4 text-sm leading-7 text-[var(--color-muted)]">{series.summary}</p>
            <a
              href={series.href}
              target="_blank"
              rel="noreferrer"
              class="mt-8 inline-flex items-center gap-2 rounded-full border border-white/12 px-4 py-2 text-sm font-semibold text-[var(--color-text)] transition hover:border-[var(--color-brand)] hover:text-white"
            >
              Oficjalna strona podcastu
              <span aria-hidden="true">↗</span>
            </a>
          </aside>

          <div class="space-y-6">
            <SectionHeading eyebrow="Ostatnie odcinki" title={series.name} description={series.summary} />
            <div class="grid gap-6 xl:grid-cols-2">
              {series.items.map((item) => <ContentCard item={item} kind="podcast" />)}
            </div>
          </div>
        </div>
      </section>
    ))
  }
</MainLayout>
