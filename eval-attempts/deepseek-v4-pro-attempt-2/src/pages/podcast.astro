---
import BaseLayout from '../layouts/BaseLayout.astro';
import shows from '../data/podcast-episodes.json';
---

<BaseLayout title="Podcast" description="Słuchaj podcastów Przeprogramowanych o technologii, AI i programowaniu">

  <section class="relative overflow-hidden pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-600/5 to-transparent" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
          <span class="gradient-text">Podcasty</span>
        </h1>
        <p class="mt-4 text-lg text-gray-400">
          Słuchaj naszych podcastów o technologii, AI i programowaniu
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      {
        shows.map((show, showIdx) => (
          <div class={showIdx > 0 ? 'mt-16' : ''}>
            <div class="mb-8">
              <h2 class="text-2xl font-bold text-white">{show.title}</h2>
              <p class="mt-1 text-gray-400">{show.subtitle}</p>
            </div>

            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
              {show.episodes.map((episode) => (
                <a
                  href={episode.url}
                  class="group relative overflow-hidden rounded-xl bg-gray-800/30 border border-gray-700/30 card-hover flex flex-col"
                >
                  <div class="aspect-square overflow-hidden relative">
                    <img
                      src={episode.image}
                      alt={episode.title}
                      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-transparent to-transparent" />
                    <span class="absolute bottom-3 left-3 rounded-md bg-gray-900/80 px-2 py-1 text-xs font-mono text-gray-300 backdrop-blur-sm">
                      {episode.duration}
                    </span>
                  </div>
                  <div class="p-5 flex-1 flex flex-col">
                    <h3 class="text-sm font-semibold text-gray-200 group-hover:text-white transition-colors line-clamp-2 flex-1">
                      {episode.title}
                    </h3>
                    <p class="mt-2 text-xs text-gray-500 line-clamp-2">{episode.description}</p>
                    <div class="mt-3 flex items-center gap-1.5 text-xs font-medium text-green-400">
                      <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.48.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                      </svg>
                      Słuchaj na Spotify
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="section-padding pt-0 pb-24">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-gradient-to-br from-blue-600/10 to-purple-600/10 border border-gray-700/30 p-8 sm:p-12">
        <h2 class="text-2xl font-bold text-center mb-8">
          Jesteśmy na twojej ulubionej <span class="gradient-text">platformie</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <a href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1508387250" class="flex items-center justify-center rounded-xl bg-gray-800/50 border border-gray-700/30 p-4 hover:bg-gray-800 hover:border-gray-600 transition-all">
            <span class="text-sm font-semibold text-gray-300">Apple Podcasts</span>
          </a>
          <a href="https://open.spotify.com/show/4qHUZJpeBK8Ij9e2wTVm2o" class="flex items-center justify-center rounded-xl bg-gray-800/50 border border-gray-700/30 p-4 hover:bg-gray-800 hover:border-gray-600 transition-all">
            <span class="text-sm font-semibold text-gray-300">Spotify</span>
          </a>
          <a href="https://podcasts.google.com/feed/aHR0cHM6Ly9hbmNob3IuZm0vcy8yMjU0NGI3Yy9wb2RjYXN0L3Jzcw" class="flex items-center justify-center rounded-xl bg-gray-800/50 border border-gray-700/30 p-4 hover:bg-gray-800 hover:border-gray-600 transition-all">
            <span class="text-sm font-semibold text-gray-300">Google Podcasts</span>
          </a>
          <a href="https://anchor.fm/s/22544b7c/podcast/rss" class="flex items-center justify-center rounded-xl bg-gray-800/50 border border-gray-700/30 p-4 hover:bg-gray-800 hover:border-gray-600 transition-all">
            <span class="text-sm font-semibold text-gray-300">RSS</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>