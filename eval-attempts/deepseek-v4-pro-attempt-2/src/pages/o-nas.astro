---
import BaseLayout from '../layouts/BaseLayout.astro';
import team from '../data/team.json';
---

<BaseLayout title="O nas" description="Łączymy świat programowania, biznesu i rozwoju — poznaj zespół Przeprogramowanych">

  <section class="relative overflow-hidden pt-32 pb-16 lg:pt-40 lg:pb-20">
    <div class="absolute inset-0 bg-gradient-to-b from-blue-600/5 to-transparent" />
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl">
          O <span class="gradient-text">nas</span>
        </h1>
        <p class="mt-4 text-lg text-gray-400">
          Łączymy świat programowania, biznesu i rozwoju
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-invert prose-lg mx-auto">
        <p class="text-xl leading-relaxed text-gray-300">
          Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
        </p>
        <p class="text-lg leading-relaxed text-gray-400 mt-6">
          Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju. Zyskaj szersze spojrzenie na programowanie.
        </p>
      </div>
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-12">
        Poznaj <span class="gradient-text">zespół</span>
      </h2>

      <div class="grid gap-12 lg:grid-cols-2 max-w-4xl mx-auto">
        {team.map((member) => (
          <div class="group relative overflow-hidden rounded-2xl bg-gray-800/30 border border-gray-700/30 p-8 card-hover">
            <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 text-center sm:text-left">
              <img
                src={member.image}
                alt={member.name}
                class="h-24 w-24 rounded-2xl object-cover ring-2 ring-gray-700/50"
                loading="lazy"
              />
              <div class="flex-1">
                <h3 class="text-xl font-bold text-white">{member.name}</h3>
                <p class="text-sm font-medium text-blue-400">{member.role}</p>
                <p class="mt-3 text-sm text-gray-400 leading-relaxed">{member.bio}</p>
                <a
                  href={member.linkedin}
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-blue-400 hover:text-blue-300 transition-colors"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding pt-0">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3 max-w-4xl mx-auto">
        <div class="rounded-xl bg-gray-800/30 border border-gray-700/30 p-6 text-center">
          <div class="text-3xl font-bold gradient-text">7+</div>
          <p class="mt-2 text-sm text-gray-400">lat na rynku edukacji</p>
        </div>
        <div class="rounded-xl bg-gray-800/30 border border-gray-700/30 p-6 text-center">
          <div class="text-3xl font-bold gradient-text">400+</div>
          <p class="mt-2 text-sm text-gray-400">absolwentów Opanuj Frontend</p>
        </div>
        <div class="rounded-xl bg-gray-800/30 border border-gray-700/30 p-6 text-center">
          <div class="text-3xl font-bold gradient-text">7800+</div>
          <p class="mt-2 text-sm text-gray-400">słuchaczy podcastów</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>