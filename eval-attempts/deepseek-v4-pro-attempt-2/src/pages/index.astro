---
import BaseLayout from '../layouts/BaseLayout.astro';
import courses from '../data/courses.json';
import youtubeVideos from '../data/youtube-videos.json';

const heroCourse = courses.find(c => c.type === 'hero');
const otherCourses = courses.filter(c => c.type === 'course');
---

<BaseLayout title="Strona główna" description="Przeprogramowani — Szersze spojrzenie na programowanie. Edukacja technologiczna w epoce AI dla ambitnych programistów.">

  <section class="relative overflow-hidden pt-24 pb-16 lg:pt-40 lg:pb-24">
    <div class="absolute inset-0 bg-gradient-to-br from-blue-600/10 via-purple-600/10 to-pink-600/10" />
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-blue-500/5 rounded-full blur-3xl" />

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="text-center lg:text-left">
          <span class="inline-flex items-center gap-2 rounded-full bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-400 ring-1 ring-inset ring-blue-500/20 mb-6">
            {heroCourse?.badge || 'Nowość'}
          </span>
          <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
            Szersze spojrzenie<br />na <span class="gradient-text">programowanie</span>
          </h1>
          <p class="mt-6 text-lg leading-relaxed text-gray-400 max-w-xl mx-auto lg:mx-0">
            Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start">
            <a href="https://10xdevs.pl" class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 px-8 py-4 text-base font-semibold text-white hover:from-blue-500 hover:to-purple-500 transition-all shadow-xl shadow-blue-500/25">
              Poznaj 10xDevs
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="/podcast" class="inline-flex items-center gap-2 rounded-xl border border-gray-700 px-8 py-4 text-base font-semibold text-gray-300 hover:border-gray-500 hover:text-white transition-all">
              Podcasty
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div class="rounded-2xl bg-gradient-to-br from-blue-600/20 to-purple-600/20 p-1">
            <div class="rounded-xl bg-gray-900 p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="flex gap-1.5">
                  <div class="h-3 w-3 rounded-full bg-red-500" />
                  <div class="h-3 w-3 rounded-full bg-yellow-500" />
                  <div class="h-3 w-3 rounded-full bg-green-500" />
                </div>
                <span class="text-xs text-gray-500 font-mono">~/projects/10xDevs</span>
              </div>
              <div class="space-y-2 font-mono text-sm">
                <p class="text-green-400">$ <span class="text-gray-300">npx create-10x-app</span></p>
                <p class="text-gray-400">✓ Scaffolding project with AI agents...</p>
                <p class="text-gray-400">✓ Configuring LLM-powered pipelines...</p>
                <p class="text-gray-400">✓ Setting up autonomous coding agents...</p>
                <p class="text-blue-400 mt-3">10xDevs 3.0 is ready! 🚀</p>
                <p class="text-gray-500">$ <span class="animate-pulse">▌</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-gray-900/50">
    <div class="mx-auto max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          Nasze <span class="gradient-text">programy</span>
        </h2>
        <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">
          Kompleksowe szkolenia dla programistów na każdym poziomie zaawansowania
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {otherCourses.map((course) => (
          <a
            href={course.url}
            class="group relative overflow-hidden rounded-2xl bg-gray-800/50 border border-gray-700/50 card-hover"
          >
            <div class="aspect-video overflow-hidden">
              <img
                src={course.image}
                alt={course.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">
                {course.title}
              </h3>
              <p class="mt-2 text-sm font-medium text-gray-400">{course.subtitle}</p>
              <p class="mt-3 text-sm text-gray-500 leading-relaxed">{course.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-blue-400 group-hover:text-blue-300 transition-colors">
                Szczegóły
                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="mx-auto max-w-7xl">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            Najnowsze <span class="gradient-text">filmy</span>
          </h2>
          <p class="mt-2 text-lg text-gray-400">Z kanału YouTube</p>
        </div>
        <a href="/youtube" class="hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors">
          Zobacz wszystkie
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {youtubeVideos.slice(0, 3).map((video) => (
          <a
            href={video.url}
            class="group relative overflow-hidden rounded-xl bg-gray-800/50 border border-gray-700/50 card-hover"
          >
            <div class="aspect-video overflow-hidden">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="rounded-full bg-red-600 p-3 shadow-lg">
                  <svg class="h-6 w-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </div>
              </div>
            </div>
            <div class="p-4">
              <h3 class="text-sm font-medium text-gray-200 group-hover:text-white transition-colors line-clamp-2">
                {video.title}
              </h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-gray-900/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        7 lat na rynku <span class="gradient-text">edukacji technologicznej</span>
      </h2>
      <p class="mt-4 text-lg text-gray-400">Współpracujemy z najlepszymi</p>
      <div class="mt-10 grid grid-cols-2 gap-8 sm:grid-cols-3 md:grid-cols-5 lg:grid-cols-10 items-center justify-items-center opacity-60">
        <span class="text-sm font-semibold text-gray-500">Huuuge Games</span>
        <span class="text-sm font-semibold text-gray-500">Nutridome</span>
        <span class="text-sm font-semibold text-gray-500">SmartRecruiters</span>
        <span class="text-sm font-semibold text-gray-500">Future Processing</span>
        <span class="text-sm font-semibold text-gray-500">Callstack</span>
        <span class="text-sm font-semibold text-gray-500">edrone</span>
        <span class="text-sm font-semibold text-gray-500">Xfive</span>
        <span class="text-sm font-semibold text-gray-500">Euvic</span>
        <span class="text-sm font-semibold text-gray-500">Strabag</span>
        <span class="text-sm font-semibold text-gray-500">Autodesk</span>
      </div>
    </div>
  </section>

</BaseLayout>