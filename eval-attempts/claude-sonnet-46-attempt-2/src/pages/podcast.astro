---
import Layout from '../layouts/Layout.astro';

const mainPodcastEpisodes = [
  {
    number: 98,
    title: 'Programista vs. Angielski: Od strachu do sukcesu',
    guest: 'Wiktoria Sitko',
    date: '25 września 2025',
    duration: '33:45',
    description: 'Czy angielski to bariera, która blokuje Twoją karierę? Rozmawiamy o tym, jak pokonać strach przed językiem i jak angielski otwiera drzwi w branży IT.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    number: 97,
    title: 'O dojrzewaniu zawodowym programisty',
    guest: 'Wojciech Trawiński',
    date: '10 września 2025',
    duration: '45:56',
    description: 'Czym jest dojrzałość zawodowa w programowaniu? Jak zmieniają się priorytety wraz z doświadczeniem i jak mądrze planować dalszą karierę?',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    number: 96,
    title: 'Architektura frontendu: Co naprawdę ma znaczenie?',
    guest: 'Tomasz Ducin',
    date: '10 października 2024',
    duration: '1:16:44',
    description: 'Głęboka rozmowa o architekturze frontendowej — mikrofrontendy, monolity, design systemy i jak podejmować dobre decyzje architektoniczne w praktyce.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    number: 95,
    title: 'Co nowego w TypeScript?',
    guest: 'Specjalny odcinek',
    date: '21 sierpnia 2024',
    duration: '1:37:00',
    description: 'Przegląd najnowszych funkcji TypeScript, omówienie zmian wpływających na codzienną pracę i tego, co przyniesie przyszłość języka.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    number: 94,
    title: 'No-code i Low-code — przyszłość tworzenia aplikacji?',
    guest: 'Kamil Tarczyński',
    date: '13 czerwca 2024',
    duration: '36:32',
    description: 'Czy no-code/low-code zastąpi programistów? Kiedy warto sięgać po te narzędzia, a kiedy tradycyjne programowanie ma przewagę?',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    number: 93,
    title: 'Frontend Tech Radar 2024',
    guest: 'Marcin & Przemek',
    date: '14 stycznia 2024',
    duration: '35:50',
    description: 'Które technologie frontendowe zyskują, a które tracą? Nasz autorski radar technologiczny na 2024 rok z rekomendacjami dla profesjonalnych developerów.',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
];

const aiPodcastEpisodes = [
  {
    title: 'Doktor AI nadchodzi — ChatGPT Health vs Google MedGemma',
    date: 'Maj 2025',
    duration: '1:23:04',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    title: 'Wielkie Podsumowanie AI w 2025',
    date: 'Styczeń 2026',
    duration: '1:47:28',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    title: 'GPT-5.2 to GEMINI KILLER?',
    date: 'Grudzień 2025',
    duration: '0:58:41',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    title: 'Gemini 3 to hit, ale konkurencja nie śpi!',
    date: 'Listopad 2025',
    duration: '1:03:20',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
  {
    title: 'Cursor 2.0 vs Windsurf SWE-1.5 — kto wygrywa?',
    date: 'Październik 2025',
    duration: '1:14:37',
    spotifyUrl: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
  },
];

const platforms = [
  {
    name: 'Spotify',
    url: 'https://open.spotify.com/show/3yVvOAXSYq6sQB02w4A4wo',
    color: '#1DB954',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>`,
  },
  {
    name: 'Apple Podcasts',
    url: 'https://podcasts.apple.com/us/podcast/przeprogramowani/id1471770526',
    color: '#9872F5',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm.25 4.25c3.6 0 6.5 2.9 6.5 6.5 0 3.35-2.55 6.1-5.8 6.45v1.8c0 .4-.35.75-.75.75s-.75-.35-.75-.75v-1.8c-3.25-.35-5.8-3.1-5.8-6.45 0-3.6 2.9-6.5 6.5-6.5h.1zm0 2.5c-2.2 0-4 1.8-4 4s1.8 4 4 4 4-1.8 4-4-1.8-4-4-4zm0 5.5c-.85 0-1.5-.65-1.5-1.5s.65-1.5 1.5-1.5 1.5.65 1.5 1.5-.65 1.5-1.5 1.5z"/></svg>`,
  },
  {
    name: 'RSS Feed',
    url: 'https://anchor.fm/s/c72d808/podcast/rss',
    color: '#F4A261',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>`,
  },
];
---

<Layout title="Podcast" description="Przeprogramowani ft. Gość — rozmowy dla głodnych wiedzy. 98 odcinków o programowaniu, karierze i technologii.">
  <!-- Hero -->
  <section class="pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-1/4 left-1/3 w-80 h-80 bg-brand-green/8 rounded-full blur-3xl"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-green/10 border border-brand-green/20 text-brand-green text-sm font-medium mb-6">
          🎙️ Podcast
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">
          Przeprogramowani<br />
          <span class="text-gradient-green">ft. Gość</span>
        </h1>
        <p class="text-xl text-gray-400 leading-relaxed mb-8">
          Rozmowy dla głodnych wiedzy. Codzienna dawka inspiracji i wiedzy o programowaniu, architekturze,
          AI i karierze developera. <strong class="text-white">98 odcinków</strong>, <strong class="text-white">3 800+ słuchaczy</strong>, ocena <strong class="text-white">4.9/5</strong>.
        </p>

        <!-- Platform buttons -->
        <div class="flex flex-wrap gap-3">
          {platforms.map(p => (
            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-dark-700 border border-white/10 text-white text-sm font-medium hover:border-white/20 hover:bg-dark-600 transition-all"
            >
              <span set:html={p.icon} />
              {p.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Main Podcast Episodes -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8">Ostatnie odcinki</h2>

      <div class="space-y-4">
        {mainPodcastEpisodes.map(ep => (
          <a
            href={ep.spotifyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-5 p-6 rounded-2xl bg-dark-700 border border-white/5 hover:border-brand-green/20 hover:bg-dark-600 transition-all group"
          >
            <!-- Episode badge -->
            <div class="hidden sm:flex flex-col items-center gap-1 flex-shrink-0">
              <div class="w-12 h-12 rounded-xl bg-dark-500 border border-white/10 flex items-center justify-center group-hover:bg-brand-green/10 group-hover:border-brand-green/20 transition-all">
                <svg class="w-5 h-5 text-gray-500 group-hover:text-brand-green transition-colors ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              <span class="text-gray-600 text-xs font-mono">#{ep.number}</span>
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-white font-semibold text-lg leading-snug group-hover:text-brand-green transition-colors">
                  {ep.title}
                </h3>
                <span class="hidden sm:block text-gray-600 text-sm font-mono flex-shrink-0 pt-1">{ep.duration}</span>
              </div>
              <div class="flex items-center gap-2 mt-1 mb-3">
                {ep.guest && ep.guest !== 'Specjalny odcinek' && ep.guest !== 'Marcin & Przemek' && (
                  <span class="px-2 py-0.5 rounded-full bg-brand-green/10 text-brand-green text-xs font-medium">
                    Gość: {ep.guest}
                  </span>
                )}
                <span class="text-gray-600 text-xs">{ep.date}</span>
              </div>
              <p class="text-gray-500 text-sm leading-relaxed">{ep.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Opanuj AI Podcast -->
  <section class="py-16 bg-dark-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <h2 class="text-2xl font-bold text-white">Opanuj.AI Podcast</h2>
            <span class="px-3 py-0.5 rounded-full bg-purple-500/20 text-purple-400 text-xs font-bold border border-purple-500/20">
              AI Focus
            </span>
          </div>
          <p class="text-gray-400">Comiesięczne podsumowanie najważniejszych wydarzeń ze świata AI · 4 000+ słuchaczy</p>
        </div>
        <a
          href="https://opanuj.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:flex items-center gap-2 text-purple-400 text-sm font-semibold hover:opacity-80 transition-opacity"
        >
          opanuj.ai ↗
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {aiPodcastEpisodes.map(ep => (
          <a
            href={ep.spotifyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-4 p-5 rounded-xl bg-dark-700 border border-white/5 hover:border-purple-500/20 hover:bg-dark-600 transition-all group"
          >
            <div class="w-10 h-10 rounded-lg bg-purple-500/10 border border-purple-500/20 flex items-center justify-center flex-shrink-0 group-hover:bg-purple-500/20 transition-all">
              <svg class="w-4 h-4 text-purple-400 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-white text-sm font-medium leading-snug group-hover:text-purple-400 transition-colors line-clamp-2">
                {ep.title}
              </p>
              <div class="flex items-center gap-2 mt-2">
                <span class="text-gray-600 text-xs">{ep.date}</span>
                <span class="text-gray-700">·</span>
                <span class="text-gray-600 text-xs font-mono">{ep.duration}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Subscribe CTA -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="p-12 rounded-3xl bg-dark-700 border border-brand-green/10 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-radial from-brand-green/5 via-transparent to-transparent"></div>
        <div class="relative">
          <div class="text-5xl mb-6">🎙️</div>
          <h2 class="text-3xl font-extrabold text-white mb-4">Dołącz do 3 800+ słuchaczy</h2>
          <p class="text-gray-400 mb-8 max-w-md mx-auto">
            Subskrybuj podcast na swojej ulubionej platformie i nie przegap żadnego odcinka.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            {platforms.map(p => (
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 hover:border-white/20 transition-all"
              >
                <span set:html={p.icon} />
                {p.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
