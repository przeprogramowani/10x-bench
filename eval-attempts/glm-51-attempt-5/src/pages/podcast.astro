---
import Layout from '../layouts/Layout.astro'
import PodcastCard from '../components/PodcastCard'
import { podcasts } from '../data/podcasts'

const aiPodcasts = podcasts.filter((p) => p.podcastName === 'Opanuj.AI Podcast')
const guestPodcasts = podcasts.filter((p) => p.podcastName === 'Przeprogramowani ft. Gość')
---

<Layout title="Podcast — Przeprogramowani" description="Słuchaj naszych podcastów o technologii, AI i programowaniu">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-3xl">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-green-600/10 border border-green-500/20 text-green-300 text-xs font-semibold mb-6">
        Podcast
      </span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight">
        Słuchaj naszych podcastów
      </h1>
      <p class="mt-4 text-lg text-surface-300 leading-relaxed">
        O technologii, AI i programowaniu — z najciekawszymi osobami z branży IT
      </p>
    </div>
  </section>

  <section class="border-t border-surface-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-brand-600/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-white">Opanuj.AI Podcast</h2>
          <p class="text-surface-400 text-sm">Ponad 4000 słuchaczy · Comiesięczne podsumowanie świata AI</p>
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {aiPodcasts.map((ep) => (
          <PodcastCard {...ep} />
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-surface-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-lg bg-blue-600/20 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-white">Przeprogramowani ft. Gość</h2>
          <p class="text-surface-400 text-sm">Ponad 3800 słuchaczy · Rozmowy dla głodnych wiedzy</p>
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-4">
        {guestPodcasts.map((ep) => (
          <PodcastCard {...ep} />
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-surface-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <h2 class="text-2xl font-bold text-white mb-6">Jesteśmy na Twojej ulubionej platformie</h2>
      <div class="flex flex-wrap gap-4">
        <a href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1508387250" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-900/50 border border-surface-800/50 rounded-xl hover:border-brand-600/30 transition-colors text-surface-300 hover:text-white text-sm font-medium">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          Apple Podcasts
        </a>
        <a href="https://open.spotify.com/show/4qHUZJpeBK8Ij9e2wTVm2o" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-900/50 border border-surface-800/50 rounded-xl hover:border-brand-600/30 transition-colors text-surface-300 hover:text-white text-sm font-medium">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
          Spotify
        </a>
        <a href="https://anchor.fm/s/22544b7c/podcast/rss" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-900/50 border border-surface-800/50 rounded-xl hover:border-brand-600/30 transition-colors text-surface-300 hover:text-white text-sm font-medium">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12.75 19.5v-.75a7.5 7.5 0 00-7.5-7.5H4.5m0-6.75h.75c7.87 0 14.25 6.38 14.25 14.25v.75M6 18.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
          </svg>
          RSS
        </a>
      </div>
    </div>
  </section>
</Layout>
