---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero'
import CourseCard from '../components/CourseCard'
import PodcastCard from '../components/PodcastCard'
import YouTubeCard from '../components/YouTubeCard'
import { podcasts } from '../data/podcasts'
import { videos } from '../data/videos'

const latestPodcasts = podcasts.slice(0, 4)
const latestVideos = videos.slice(0, 3)

const partners = [
  'Huuuge Games', 'SmartRecruiters', 'Callstack', 'Future Processing',
  'edrone', 'Xfive', 'Euvic', 'Autodesk', 'Nutridome', 'Strabag',
]
---

<Layout title="Przeprogramowani — Szersze spojrzenie na programowanie">
  <Hero client:load />

  <section id="kursy" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="text-center mb-12">
      <span class="inline-flex items-center px-3 py-1 rounded-full bg-brand-600/10 border border-brand-500/20 text-brand-300 text-xs font-semibold mb-4">
        Edukacja
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        Topowe programy edukacyjne
      </h2>
      <p class="mt-3 text-surface-400 max-w-2xl mx-auto">
        Dla ambitnych programistów i świadome korzystanie z potencjału Generative AI
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <CourseCard
        tag="KURS"
        tagColor="bg-blue-600/15 text-blue-300 border border-blue-500/20"
        title="Opanuj Frontend: AI Edition"
        description="Zostań nowoczesnym frontend developerem — 5 obszernych modułów o frontendzie, testowaniu, CI/CD, open source i architekturze aplikacji webowych."
        features={[
          '10 tygodni intensywnego szkolenia',
          '5 modułów + lekcje AI Edition',
          '383 absolwentów w 4 edycjach',
          'Codzienne wsparcie mentorów',
        ]}
        cta="Szczegóły Opanuj Frontend"
        href="https://opanujfrontend.pl"
        stats="4 edycje"
      />

      <CourseCard
        tag="KURS"
        tagColor="bg-cyan-600/15 text-cyan-300 border border-cyan-500/20"
        title="Opanuj TypeScript"
        description="Buduj niezawodne aplikacje z TypeScriptem 5 i React 19. Typy generyczne, wzorce typowania i topowe narzędzia ekosystemu React."
        features={[
          'TypeScript 5.7+ i React 19',
          'Ponad 40 ćwiczeń praktycznych',
          'Moduły Core Pro i React Pro',
          'SWR, React Query, Zod, tRPC, Astro 5',
        ]}
        cta="Szczegóły Opanuj TypeScript"
        href="https://opanujtypescript.pl"
        stats="121+ devów"
      />

      <CourseCard
        tag="BESTSELLER"
        tagColor="bg-brand-600/15 text-brand-300 border border-brand-500/20"
        title="10xDevs 3.0"
        description="5-tygodniowy program uczący developerów pracować z AI w całym cyklu tworzenia oprogramowania: od researchu, przez implementację, aż po utrzymanie produkcji."
        features={[
          '5+1 tygodni nauki z AI',
          '3700+ absolwentów',
          'Cursor, Claude Code i MCP',
          'AI-Native Software Engineering',
        ]}
        cta="Szczegóły 10xDevs"
        href="https://10xdevs.pl"
        stats="3 edycje"
      />
    </div>
  </section>

  <section class="border-t border-surface-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-green-600/10 border border-green-500/20 text-green-300 text-xs font-semibold mb-4">
            Podcast
          </span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
            Najnowsze odcinki
          </h2>
          <p class="mt-3 text-surface-400 mb-8">
            Słuchaj naszych podcastów o technologii, AI i programowaniu
          </p>
          <div class="space-y-3">
            {latestPodcasts.map((ep) => (
              <PodcastCard {...ep} />
            ))}
          </div>
          <a
            href="/podcast"
            class="inline-flex items-center gap-2 mt-6 text-brand-400 hover:text-brand-300 font-semibold text-sm transition-colors"
          >
            Wszystkie odcinki
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>

        <div>
          <span class="inline-flex items-center px-3 py-1 rounded-full bg-red-600/10 border border-red-500/20 text-red-300 text-xs font-semibold mb-4">
            YouTube
          </span>
          <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
            Najnowsze filmy
          </h2>
          <p class="mt-3 text-surface-400 mb-8">
            Rozwój nowoczesnego programisty
          </p>
          <div class="grid gap-4">
            {latestVideos.map((v) => (
              <YouTubeCard {...v} />
            ))}
          </div>
          <a
            href="/youtube"
            class="inline-flex items-center gap-2 mt-6 text-brand-400 hover:text-brand-300 font-semibold text-sm transition-colors"
          >
            Wszystkie filmy
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-surface-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
          7 lat na rynku edukacji technologicznej
        </h2>
        <p class="mt-3 text-surface-400">Współpracujemy z najlepszymi</p>
      </div>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-4">
        {partners.map((p) => (
          <span class="text-surface-500 font-semibold text-sm tracking-wide uppercase">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-surface-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="bg-gradient-to-br from-brand-600/10 to-brand-950/20 border border-brand-600/20 rounded-2xl p-8 lg:p-12 text-center">
        <h2 class="text-2xl sm:text-3xl font-extrabold text-white tracking-tight">
          Przeprogramowany Newsletter
        </h2>
        <p class="mt-3 text-surface-300 max-w-xl mx-auto">
          Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1:
          3 rekomendacje techniczne, 2 rozwojowe i 1 bonus niespodzianka.
        </p>
        <a
          href="https://przeprogramowani.substack.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-6 px-6 py-3 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl transition-colors text-sm shadow-lg shadow-brand-600/25"
        >
          Zapisz się za darmo
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width={2}>
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
