---
import '../styles/global.css'
import Navbar from '../components/Navbar'
import Footer from '../components/Footer'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Przeprogramowani — Szersze spojrzenie na programowanie' } = Astro.props
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-surface-950 text-surface-100 min-h-screen flex flex-col antialiased">
    <Navbar client:load />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
