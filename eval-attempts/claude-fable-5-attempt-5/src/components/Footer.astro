---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 bg-ink-900">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 font-bold text-white">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-violet-600 text-sm font-black">
            P
          </span>
          <span class="text-lg tracking-tight">
            Przeprogramowani<span class="text-brand-400">.pl</span>
          </span>
        </a>
        <p class="mt-4 max-w-sm text-sm text-slate-400">
          Szersze spojrzenie na programowanie. Edukacja technologiczna w erze AI — kursy,
          podcast i YouTube dla ambitnych programistów.
        </p>
        <p class="mt-4 text-sm text-slate-400">
          Kontakt:
          <a href="mailto:kontakt@przeprogramowani.pl" class="text-brand-300 hover:text-brand-200">
            kontakt@przeprogramowani.pl
          </a>
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Strona</h3>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm text-slate-400">
          <li><a href="/o-nas" class="hover:text-white">O nas</a></li>
          <li><a href="/podcast" class="hover:text-white">Podcast</a></li>
          <li><a href="/youtube" class="hover:text-white">YouTube</a></li>
          <li><a href="/#kursy" class="hover:text-white">Kursy</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Kursy</h3>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm text-slate-400">
          <li>
            <a href="https://www.10xdevs.pl/" target="_blank" rel="noopener noreferrer" class="hover:text-white">
              10xDevs
            </a>
          </li>
          <li>
            <a href="https://opanujfrontend.pl/" target="_blank" rel="noopener noreferrer" class="hover:text-white">
              Opanuj Frontend
            </a>
          </li>
          <li><a href="/#kursy" class="hover:text-white">Opanuj TypeScript</a></li>
          <li>
            <a href="https://opanuj.ai/" target="_blank" rel="noopener noreferrer" class="hover:text-white">
              Opanuj.AI
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-6 text-sm text-slate-500 sm:flex-row">
      <p>© {year} Przeprogramowani.pl. Wszystkie prawa zastrzeżone.</p>
      <div class="flex items-center gap-4">
        <a
          href="https://www.youtube.com/@przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
          class="text-slate-400 transition-colors hover:text-white"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z" />
          </svg>
        </a>
        <a
          href="https://creators.spotify.com/pod/profile/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Spotify"
          class="text-slate-400 transition-colors hover:text-white"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0a12 12 0 1 0 0 24 12 12 0 0 0 0-24zm5.5 17.3a.75.75 0 0 1-1 .25c-2.8-1.7-6.4-2.1-10.6-1.2a.75.75 0 0 1-.3-1.5c4.6-1 8.5-.5 11.7 1.4.35.2.45.65.2 1.05zm1.5-3.3a.94.94 0 0 1-1.3.3c-3.2-2-8.2-2.6-12-1.4a.94.94 0 1 1-.55-1.8c4.4-1.3 9.9-.7 13.6 1.6.44.27.57.85.25 1.3zm.1-3.4C15.3 8.3 9 8.1 5.4 9.2a1.12 1.12 0 1 1-.65-2.15C8.9 5.8 15.9 6 20.2 8.6a1.13 1.13 0 0 1-1.1 1.95z" />
          </svg>
        </a>
        <a
          href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1471770526"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Apple Podcasts"
          class="text-slate-400 transition-colors hover:text-white"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2a4 4 0 0 0-4 4v6a4 4 0 0 0 8 0V6a4 4 0 0 0-4-4z" />
            <path d="M19 10v2a7 7 0 0 1-14 0v-2M12 19v3M8 22h8" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
