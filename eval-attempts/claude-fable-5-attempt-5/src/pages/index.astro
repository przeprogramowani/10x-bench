---
import Layout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.astro';
import EpisodeList from '../components/EpisodeList';
import VideoGrid from '../components/VideoGrid';
import { courses } from '../data/courses';
import { episodes } from '../data/episodes';
import { videos } from '../data/videos';

const stats = [
  { value: '7 lat', label: 'edukacji technologicznej' },
  { value: '3700+', label: 'absolwentów 10xDevs' },
  { value: '98', label: 'odcinków podcastu' },
  { value: '383+', label: 'uczestników Opanuj Frontend' },
];
---

<Layout
  title="Przeprogramowani.pl — Szersze spojrzenie na programowanie"
  description="Edukacja technologiczna w erze AI. Kursy 10xDevs, Opanuj Frontend i Opanuj TypeScript, podcast i YouTube dla ambitnych programistów. Prowadzą Przemek Smyrdek i Marcin Czarkowski."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-32 left-1/2 h-[480px] w-[720px] -translate-x-1/2 rounded-full bg-brand-600/20 blur-3xl"></div>
      <div class="absolute -bottom-40 right-0 h-[360px] w-[480px] rounded-full bg-violet-600/10 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-6xl px-4 pb-20 pt-20 sm:px-6 sm:pt-28">
      <div class="animate-fade-up mx-auto max-w-3xl text-center">
        <a
          href="https://www.10xdevs.pl/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-brand-400/30 bg-brand-500/10 px-4 py-1.5 text-sm font-medium text-brand-300 transition-colors hover:bg-brand-500/20"
        >
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
          </span>
          Trwa edycja 10xDevs 3.0 — AI-Native Software Engineering
        </a>
        <h1 class="mt-6 text-4xl font-black leading-tight tracking-tight text-white sm:text-6xl">
          Szersze spojrzenie<br />
          <span class="bg-gradient-to-r from-brand-400 via-violet-400 to-fuchsia-400 bg-clip-text text-transparent">
            na programowanie
          </span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300 sm:text-xl">
          Jesteśmy Przemek i Marcin — od 7 lat uczymy programistów budować lepsze
          oprogramowanie. Dziś pomagamy Ci świadomie łączyć inżynierską dyscyplinę
          z możliwościami generatywnej AI.
        </p>
        <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="https://www.10xdevs.pl/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full rounded-xl bg-gradient-to-r from-brand-500 to-violet-600 px-7 py-3.5 text-base font-bold text-white shadow-xl shadow-brand-500/30 transition-transform hover:scale-105 sm:w-auto"
          >
            Dołącz do 10xDevs →
          </a>
          <a
            href="#kursy"
            class="w-full rounded-xl border border-white/15 bg-white/5 px-7 py-3.5 text-base font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto"
          >
            Zobacz wszystkie kursy
          </a>
        </div>
      </div>

      <dl class="mt-16 grid grid-cols-2 gap-4 sm:mt-20 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="flex flex-col rounded-2xl border border-white/10 bg-ink-800/60 p-5 text-center">
              <dd class="order-1 text-3xl font-black text-white">{stat.value}</dd>
              <dt class="order-2 mt-1 text-sm text-slate-400">{stat.label}</dt>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Kursy -->
  <section id="kursy" class="scroll-mt-20 border-t border-white/5 bg-ink-900/50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-400">Kursy</p>
      <h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">
        Programy, które zmieniają sposób pracy
      </h2>
      <p class="mt-4 max-w-2xl text-lg text-slate-300">
        Praktyczne szkolenia tworzone przez praktyków — od fundamentów frontendu,
        przez TypeScript, po pracę z agentami AI w całym cyklu wytwarzania oprogramowania.
      </p>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {courses.map((course) => <CourseCard course={course} />)}
      </div>
    </div>
  </section>

  <!-- Podcast -->
  <section class="border-t border-white/5 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-brand-400">Podcast</p>
          <h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">Ostatnie odcinki</h2>
        </div>
        <a
          href="/podcast"
          class="inline-flex items-center gap-2 text-sm font-semibold text-brand-300 hover:text-brand-200"
        >
          Wszystkie odcinki
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
      <div class="mt-8">
        <EpisodeList client:visible episodes={episodes} limit={3} />
      </div>
    </div>
  </section>

  <!-- YouTube -->
  <section class="border-t border-white/5 bg-ink-900/50 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="text-sm font-bold uppercase tracking-widest text-brand-400">YouTube</p>
          <h2 class="mt-2 text-3xl font-black text-white sm:text-4xl">Ostatnie filmy</h2>
        </div>
        <a
          href="/youtube"
          class="inline-flex items-center gap-2 text-sm font-semibold text-brand-300 hover:text-brand-200"
        >
          Wszystkie filmy
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>
      <div class="mt-8">
        <VideoGrid videos={videos} limit={6} />
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="border-t border-white/5 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="relative overflow-hidden rounded-3xl border border-brand-400/20 bg-gradient-to-br from-brand-600/20 via-ink-800 to-violet-600/20 p-8 text-center sm:p-14">
        <h2 class="text-3xl font-black text-white sm:text-4xl">Newsletter Przeprogramowanych</h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-slate-300">
          W każdy piątek format 3-2-1: trzy rekomendacje techniczne, dwie rozwojowe
          i jedna niespodzianka. Konkretnie, bez spamu.
        </p>
        <a
          href="https://przeprogramowani.pl/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-block rounded-xl bg-white px-7 py-3.5 text-base font-bold text-ink-950 transition-transform hover:scale-105"
        >
          Zapisz się na newsletter
        </a>
      </div>
    </div>
  </section>
</Layout>
