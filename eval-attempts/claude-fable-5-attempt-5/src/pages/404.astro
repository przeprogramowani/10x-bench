---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Przeprogramowani.pl"
  description="Strona nie została znaleziona."
>
  <section class="flex min-h-[60vh] items-center justify-center px-4 py-24 text-center">
    <div>
      <p class="text-7xl font-black text-brand-400">404</p>
      <h1 class="mt-4 text-3xl font-black text-white">Ta strona nie istnieje</h1>
      <p class="mt-3 text-slate-300">
        Wygląda na to, że trafiłeś na nieistniejący adres.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-xl bg-gradient-to-r from-brand-500 to-violet-600 px-7 py-3.5 font-bold text-white transition-transform hover:scale-105"
      >
        Wróć na stronę główną
      </a>
    </div>
  </section>
</Layout>
