---
import Layout from '../layouts/Layout.astro';

const hosts = [
  {
    name: 'Przemek Smyrdek',
    role: 'Co-founder',
    bio: 'Były lead engineer w DAZN i Cabify. Od lat łączy praktykę inżynierską z edukacją — projektuje programy szkoleniowe, prowadzi podcast i pokazuje, jak budować oprogramowanie wysokiej jakości w erze AI.',
    initials: 'PS',
  },
  {
    name: 'Marcin Czarkowski',
    role: 'Co-founder',
    bio: 'Lead Technical w SmartRecruiters i gospodarz podcastu Opanuj AI. Specjalizuje się we frontendzie, jakości kodu i praktycznym wdrażaniu narzędzi AI do codziennej pracy zespołów developerskich.',
    initials: 'MC',
  },
];

const milestones = [
  {
    year: '2019',
    title: 'Początek Przeprogramowanych',
    description:
      'Startujemy jako projekt weekendowy — podcast i pierwszy kurs „Opanuj JavaScript". Przez kolejne edycje przeszło ponad 900 uczestników.',
  },
  {
    year: '2022',
    title: 'Opanuj Frontend',
    description:
      'Rozwijamy flagowy program frontendowy. Cztery edycje i 383+ programistów, którzy przyspieszyli swój rozwój — od wzorców i testów po architekturę.',
  },
  {
    year: '2024',
    title: 'Full-time na edukacji',
    description:
      'Decydujemy się w pełni poświęcić Przeprogramowanym. Powstaje Opanuj.AI — warsztaty, podcast i materiały o praktycznym wykorzystaniu AI.',
  },
  {
    year: '2025–2026',
    title: '10xDevs i AI-Native Software Engineering',
    description:
      'Uruchamiamy 10xDevs — program o świadomej współpracy z agentami AI. Pierwsza edycja zgromadziła ponad 1250 uczestników, a łącznie wykształciliśmy już 3700+ absolwentów.',
  },
];

const partners = [
  'Huuuge Games',
  'SmartRecruiters',
  'Future Processing',
  'Autodesk',
  'BRAVE Education',
];
---

<Layout
  title="O nas — Przeprogramowani.pl"
  description="Poznaj Przemka Smyrdka i Marcina Czarkowskiego — twórców Przeprogramowanych. Od 7 lat uczymy programistów budować lepsze oprogramowanie, dziś w erze AI."
>
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute -top-32 left-1/2 h-[400px] w-[640px] -translate-x-1/2 rounded-full bg-brand-600/15 blur-3xl"></div>
    <div class="relative mx-auto max-w-6xl px-4 pb-16 pt-20 sm:px-6 sm:pt-24">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-400">O nas</p>
      <h1 class="mt-2 max-w-3xl text-4xl font-black leading-tight text-white sm:text-5xl">
        Uczymy programistów od <span class="text-brand-400">7 lat</span>.
        Teraz pomagamy im wejść w erę AI.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-300">
        Przeprogramowani to szersze spojrzenie na programowanie. Wierzymy, że dobry
        software powstaje z połączenia inżynierskiej dyscypliny, ciągłej nauki
        i mądrego wykorzystania nowych technologii — w tym generatywnej AI.
        Tworzymy kursy, podcast, kanał YouTube i cotygodniowy newsletter.
      </p>
    </div>
  </section>

  <section class="border-t border-white/5 bg-ink-900/50 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl font-black text-white">Kto za tym stoi</h2>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {
          hosts.map((host) => (
            <article class="flex flex-col gap-5 rounded-2xl border border-white/10 bg-ink-800/60 p-6 sm:flex-row sm:items-start">
              <div class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500 to-violet-600 text-2xl font-black text-white">
                {host.initials}
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">{host.name}</h3>
                <p class="text-sm font-semibold uppercase tracking-wide text-brand-400">
                  {host.role}
                </p>
                <p class="mt-3 text-slate-300">{host.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl font-black text-white">Nasza historia</h2>
      <ol class="relative mt-10 flex flex-col gap-10 border-l border-white/10 pl-8">
        {
          milestones.map((milestone) => (
            <li class="relative">
              <span class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full border-2 border-brand-400 bg-ink-950">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-400" />
              </span>
              <p class="text-sm font-bold uppercase tracking-widest text-brand-400">
                {milestone.year}
              </p>
              <h3 class="mt-1 text-xl font-bold text-white">{milestone.title}</h3>
              <p class="mt-2 max-w-2xl text-slate-300">{milestone.description}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="border-t border-white/5 bg-ink-900/50 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl font-black text-white">Zaufali nam</h2>
      <p class="mt-3 max-w-2xl text-slate-300">
        Współpracowaliśmy z zespołami inżynierskimi i działami edukacji firm technologicznych:
      </p>
      <ul class="mt-8 flex flex-wrap gap-3">
        {
          partners.map((partner) => (
            <li class="rounded-full border border-white/10 bg-ink-800/60 px-5 py-2.5 text-sm font-semibold text-slate-200">
              {partner}
            </li>
          ))
        }
      </ul>
      <div class="mt-12 rounded-3xl border border-brand-400/20 bg-gradient-to-br from-brand-600/15 via-ink-800 to-violet-600/15 p-8 text-center sm:p-12">
        <h3 class="text-2xl font-black text-white sm:text-3xl">Chcesz z nami pracować?</h3>
        <p class="mx-auto mt-3 max-w-xl text-slate-300">
          Szkolenia dla zespołów, partnerstwa edukacyjne, występy na konferencjach —
          napisz do nas.
        </p>
        <a
          href="mailto:kontakt@przeprogramowani.pl"
          class="mt-6 inline-block rounded-xl bg-white px-7 py-3.5 text-base font-bold text-ink-950 transition-transform hover:scale-105"
        >
          kontakt@przeprogramowani.pl
        </a>
      </div>
    </div>
  </section>
</Layout>
