---
import Layout from '../layouts/Layout.astro';

const categories = ['Wszystkie', 'AI Tools', 'TypeScript', 'React', 'Kariera', 'Architektura', 'Podcast'];

const videos = [
  {
    title: 'Cursor 2.0 vs Windsurf SWE-1.5 – który wybrać w 2025?',
    description: 'Szczegółowe porównanie dwóch platform do AI-wspomaganego programowania. Testy, cena, UX i moja rekomendacja dla codziennej pracy.',
    category: 'AI Tools',
    date: 'Grudzień 2025',
    duration: '1h 14min',
    color: 'from-violet-700/50 to-purple-900/30',
    icon: '🤖',
  },
  {
    title: 'React 19 – kompletny przegląd nowości',
    description: 'Server Actions, use() hook, nowe API formularzy i wszystko co przynosi React 19. Praktyczne przykłady z produkcyjnego kodu.',
    category: 'React',
    date: 'Listopad 2025',
    duration: '48 min',
    color: 'from-blue-700/50 to-sky-900/30',
    icon: '⚛️',
  },
  {
    title: 'Jak Claude Code zmienił mój workflow – 3 miesiące później',
    description: 'Szczera recenzja Claude Code po 3 miesiącach codziennego użytkowania. Co działa, co nie i jak wyglądają moje reguły AI.',
    category: 'AI Tools',
    date: 'Listopad 2025',
    duration: '31 min',
    color: 'from-amber-700/50 to-orange-900/30',
    icon: '✨',
  },
  {
    title: 'TypeScript 5.7 – nowe możliwości typowania',
    description: 'Przegląd nowości w TypeScript 5.7: lepsze inferowanie typów, nowe opcje tsconfig i kilka ciekawych zmian w type utilities.',
    category: 'TypeScript',
    date: 'Październik 2025',
    duration: '42 min',
    color: 'from-emerald-700/50 to-teal-900/30',
    icon: '📘',
  },
  {
    title: 'Jak wdrożyć się do nowego projektu – framework dla seniorów',
    description: 'Mój sprawdzony framework do wdrożenia się w nowy projekt w ciągu 2 tygodni. Jak zbierać wiedzę, zadawać pytania i szybko dostarczać wartość.',
    category: 'Kariera',
    date: 'Październik 2025',
    duration: '37 min',
    color: 'from-rose-700/50 to-pink-900/30',
    icon: '🚀',
  },
  {
    title: 'State Management w 2025 – co wybrać?',
    description: 'Redux Toolkit, Zustand, Jotai, TanStack Query – przegląd opcji zarządzania stanem w React w 2025. Kiedy co stosować?',
    category: 'React',
    date: 'Wrzesień 2025',
    duration: '52 min',
    color: 'from-blue-700/50 to-indigo-900/30',
    icon: '🗂️',
  },
  {
    title: 'Architektura Monorepo – Turborepo w praktyce',
    description: 'Jak skonfigurować i utrzymać monorepo z Turborepo w 2025. Workspace sharing, pipeline caching i CI/CD integration.',
    category: 'Architektura',
    date: 'Wrzesień 2025',
    duration: '1h 5min',
    color: 'from-zinc-700/50 to-slate-900/30',
    icon: '🏗️',
  },
  {
    title: 'Playwright E2E – testy które rzeczywiście pomagają',
    description: 'Jak pisać testy E2E z Playwright, które nie psują się przy każdym deployu. Page Object Model, fixures i best practices z produkcji.',
    category: 'TypeScript',
    date: 'Sierpień 2025',
    duration: '58 min',
    color: 'from-emerald-700/50 to-green-900/30',
    icon: '🧪',
  },
  {
    title: 'Negocjacje wynagrodzenia – jak nie zostawić pieniędzy na stole',
    description: 'Praktyczne techniki negocjacji dla developerów. Research, framing, kontroferty i pułapki których unikać podczas rozmów o podwyżkę.',
    category: 'Kariera',
    date: 'Sierpień 2025',
    duration: '44 min',
    color: 'from-amber-700/50 to-yellow-900/30',
    icon: '💰',
  },
  {
    title: 'AI-First MVP w 7 dni – build log',
    description: 'Build log z budowania MVP z użyciem Claude Code, Cursor i GitHub Copilot. Co działało, co zawaliłem i wnioski z tygodnia pracy.',
    category: 'AI Tools',
    date: 'Lipiec 2025',
    duration: '1h 28min',
    color: 'from-violet-700/50 to-indigo-900/30',
    icon: '⚡',
  },
  {
    title: 'Server Components – kiedy naprawdę warto?',
    description: 'Demistyfikacja React Server Components. Kiedy mają sens, kiedy tylko komplikują życie i jak wdrożyć je w istniejącej aplikacji.',
    category: 'React',
    date: 'Lipiec 2025',
    duration: '39 min',
    color: 'from-sky-700/50 to-blue-900/30',
    icon: '🌐',
  },
  {
    title: 'Design System od zera – 6 miesięcy doświadczeń',
    description: 'Co zrobiłem i czego nie zrobiłbym ponownie przy budowaniu design systemu. Storybook, Figma tokens i componenty dla 10 teamów.',
    category: 'Architektura',
    date: 'Czerwiec 2025',
    duration: '1h 12min',
    color: 'from-pink-700/50 to-rose-900/30',
    icon: '🎨',
  },
];

const stats = [
  { value: '200+', label: 'filmów' },
  { value: '10 000+', label: 'subskrybentów' },
  { value: '5 lat', label: 'tworzenia' },
  { value: 'Co tydzień', label: 'nowy content' },
];
---

<Layout
  title="YouTube"
  description="Kanał YouTube Przeprogramowani.pl – filmy o frontendzie, TypeScript, AI tools, karierze i architekturze. Nowe materiały co tydzień."
>

  <!-- Page Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-red-950/20 via-zinc-950 to-transparent pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-red-600/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800 text-xs text-zinc-400 mb-6">
            YOUTUBE
          </div>
          <h1 class="text-5xl sm:text-6xl font-black text-white mb-6 leading-tight">
            Oglądaj i ucz się<br />
            <span class="bg-gradient-to-r from-red-400 to-orange-400 bg-clip-text text-transparent">
              w swoim tempie.
            </span>
          </h1>
          <p class="text-xl text-zinc-400 leading-relaxed">
            Filmy o frontendzie, TypeScript, narzędziach AI i karierze developera. Ponad <strong class="text-zinc-200">200 nagrań</strong>, nowe co tydzień.
          </p>
        </div>

        <a
          href="https://youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-6 py-4 rounded-xl bg-red-600 hover:bg-red-500 text-white font-semibold transition-all hover:shadow-xl hover:shadow-red-500/25"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Subskrybuj kanał
        </a>
      </div>

      <!-- Stats -->
      <div class="flex flex-wrap gap-8 mt-12">
        {stats.map(stat => (
          <div>
            <div class="text-2xl font-black text-white">{stat.value}</div>
            <div class="text-sm text-zinc-500">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Category filter (visual only) -->
  <section class="border-t border-zinc-800/40 sticky top-16 z-30 bg-zinc-950/95 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 py-4 overflow-x-auto scrollbar-none">
        {categories.map((cat, i) => (
          <button
            class={`flex-shrink-0 px-3 py-1.5 rounded-full text-sm font-medium transition-colors ${
              i === 0
                ? 'bg-violet-600 text-white'
                : 'bg-zinc-900 text-zinc-400 hover:text-white hover:bg-zinc-800 border border-zinc-800'
            }`}
          >
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Videos Grid -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
        {videos.map((video) => (
          <a
            href="https://youtube.com/c/przeprogramowani"
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-xl overflow-hidden bg-zinc-900/60 border border-zinc-800/60 hover:border-zinc-600/80 transition-all duration-200 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/30"
          >
            <!-- Thumbnail -->
            <div class={`aspect-video bg-gradient-to-br ${video.color} relative overflow-hidden`}>
              <!-- Noise overlay -->
              <div class="absolute inset-0 opacity-20 mix-blend-overlay"
                style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E&quot;)">
              </div>

              <!-- Icon -->
              <div class="absolute inset-0 flex flex-col items-center justify-center gap-3">
                <span class="text-4xl">{video.icon}</span>
              </div>

              <!-- Play button -->
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity bg-black/30">
                <div class="w-14 h-14 rounded-full bg-red-600 flex items-center justify-center shadow-lg">
                  <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>

              <!-- Duration badge -->
              <div class="absolute bottom-2 right-2 px-2 py-0.5 rounded bg-black/70 text-xs text-white font-medium">
                {video.duration}
              </div>
            </div>

            <!-- Info -->
            <div class="p-4">
              <div class="mb-2">
                <span class="text-xs text-zinc-500 bg-zinc-800 px-2 py-0.5 rounded">{video.category}</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-violet-300 transition-colors line-clamp-2 mb-2 leading-snug">
                {video.title}
              </h3>
              <p class="text-xs text-zinc-500 line-clamp-2 leading-relaxed mb-3">
                {video.description}
              </p>
              <div class="flex items-center gap-1.5 text-xs text-zinc-500">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {video.date}
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Load more CTA -->
      <div class="text-center mt-12">
        <a
          href="https://youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-zinc-800 hover:bg-zinc-700 text-white font-semibold rounded-xl transition-all border border-zinc-700 hover:border-zinc-600"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Więcej filmów na YouTube
        </a>
      </div>
    </div>
  </section>

  <!-- GitHub repository mention -->
  <section class="py-16 border-t border-zinc-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6 p-6 rounded-xl bg-zinc-900/60 border border-zinc-800/60">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-zinc-800 flex items-center justify-center">
            <svg class="w-6 h-6 text-zinc-300" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-white text-sm">Kod z filmów na GitHub</h3>
            <p class="text-xs text-zinc-400 mt-0.5">Wszystkie snippety i projekty z kanału dostępne w repozytorium ai-playground</p>
          </div>
        </div>
        <a
          href="https://github.com/przeprogramowani/ai-playground"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 inline-flex items-center gap-2 px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-sm font-medium text-white rounded-lg transition-colors border border-zinc-700"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          Otwórz na GitHub
        </a>
      </div>
    </div>
  </section>

</Layout>
