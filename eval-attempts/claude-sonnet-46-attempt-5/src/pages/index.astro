---
import Layout from '../layouts/Layout.astro';

const courses = [
  {
    id: '10xdevs',
    name: '10xDevs 3.0',
    tagline: 'Kurs AI dla Developerów',
    description: 'Naucz się pracować 10x efektywniej z narzędziami AI. 5-tygodniowy, intensywny program stworzony dla profesjonalistów. Nie vibe coding – realne projekty, realne umiejętności.',
    href: 'https://10xdevs.pl',
    badge: 'Nowa edycja',
    badgeColor: 'bg-amber-400/15 text-amber-400 border border-amber-400/20',
    stats: [
      { value: '3 700+', label: 'absolwentów' },
      { value: '5 tyg.', label: 'intensywny kurs' },
      { value: '40h+', label: 'materiałów' },
    ],
    cta: 'Zapisz się teraz',
    ctaClass: 'bg-violet-600 hover:bg-violet-500 text-white',
    featured: true,
    gradient: 'from-violet-600/20 via-purple-600/10 to-transparent',
    borderGlow: 'hover:border-violet-500/50',
    iconBg: 'bg-violet-600/20',
    icon: '⚡',
    startDate: 'Start: 18 maja 2026',
    price: '1 743 zł',
  },
  {
    id: 'frontend',
    name: 'Opanuj Frontend',
    tagline: 'AI Edition',
    description: '10-tygodniowe szkolenie kohortowe dla doświadczonych frontend developerów. Wzorce, testy, CI/CD, architektura i praca zespołowa.',
    href: 'https://opanujfrontend.pl',
    badge: 'Kohortowy',
    badgeColor: 'bg-blue-400/15 text-blue-400 border border-blue-400/20',
    stats: [
      { value: '383+', label: 'absolwentów' },
      { value: '10 tyg.', label: 'trwania' },
      { value: '25', label: 'lekcji' },
    ],
    cta: 'Dowiedz się więcej',
    ctaClass: 'bg-zinc-700 hover:bg-zinc-600 text-white',
    featured: false,
    gradient: 'from-blue-600/15 via-sky-600/8 to-transparent',
    borderGlow: 'hover:border-blue-500/40',
    iconBg: 'bg-blue-600/20',
    icon: '🎯',
    price: null,
  },
  {
    id: 'typescript',
    name: 'Opanuj TypeScript',
    tagline: 'TypeScript 5 + React 19',
    description: 'Praktyczny kurs TypeScript 5 i React 19. 40+ ćwiczeń z realnym kodem, zaawansowane typowanie, wzorce, integracja z frameworkami.',
    href: 'https://opanujtypescript.pl',
    badge: 'Online',
    badgeColor: 'bg-emerald-400/15 text-emerald-400 border border-emerald-400/20',
    stats: [
      { value: '121+', label: 'studentów' },
      { value: '40+', label: 'ćwiczeń' },
      { value: 'React 19', label: 'najnowszy' },
    ],
    cta: 'Sprawdź kurs',
    ctaClass: 'bg-zinc-700 hover:bg-zinc-600 text-white',
    featured: false,
    gradient: 'from-emerald-600/15 via-teal-600/8 to-transparent',
    borderGlow: 'hover:border-emerald-500/40',
    iconBg: 'bg-emerald-600/20',
    icon: '📘',
    price: '499 zł',
  },
];

const podcastEpisodes = [
  {
    title: 'Programista vs. Angielski: Od strachu do sukcesu',
    guest: 'Wiktoria Sitko',
    date: '25 września 2025',
    duration: '34 min',
    description: 'Dlaczego tradycyjne metody nauki angielskiego zawodzą w IT i jak nauczyć się skutecznie jako programista.',
    series: 'Przeprogramowani ft. Gość',
  },
  {
    title: 'O dojrzewaniu zawodowym programisty',
    guest: 'Wojciech Trawiński',
    date: '10 września 2025',
    duration: '46 min',
    description: 'Droga od juniora do seniora, mity o karierze i strategie negocjacyjne w branży IT.',
    series: 'Przeprogramowani ft. Gość',
  },
  {
    title: 'Architektura frontendu: Co naprawdę ma znaczenie?',
    guest: 'Tomasz Ducin',
    date: '10 października 2024',
    duration: '1h 17min',
    description: 'Frontend architecture poza narzędziami – kluczowe decyzje kształtujące charakterystykę systemu.',
    series: 'Przeprogramowani ft. Gość',
  },
];

const youtubeVideos = [
  {
    title: 'Cursor 2.0 vs Windsurf SWE-1.5 – który wybrać w 2025?',
    category: 'AI Tools',
    date: 'Grudzień 2025',
    duration: '1h 14min',
    color: 'from-violet-600/30 to-purple-800/20',
  },
  {
    title: 'React 19 – kompletny przegląd nowości',
    category: 'React',
    date: 'Listopad 2025',
    duration: '48 min',
    color: 'from-blue-600/30 to-sky-800/20',
  },
  {
    title: 'Jak Claude Code zmienił mój workflow?',
    category: 'AI',
    date: 'Październik 2025',
    duration: '31 min',
    color: 'from-amber-600/30 to-orange-800/20',
  },
  {
    title: 'TypeScript 5.7 – nowe możliwości typowania',
    category: 'TypeScript',
    date: 'Październik 2025',
    duration: '42 min',
    color: 'from-emerald-600/30 to-teal-800/20',
  },
];
---

<Layout title="Przeprogramowani.pl" description="Szersze spojrzenie na programowanie. Kursy 10xDevs, Opanuj Frontend i Opanuj TypeScript. Podcast i materiały wideo dla developerów.">

  <!-- Hero Section -->
  <section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16">
    <!-- Background elements -->
    <div class="absolute inset-0 bg-gradient-to-br from-violet-950/40 via-zinc-950 to-blue-950/20 pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-violet-600/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[400px] bg-blue-600/5 rounded-full blur-3xl pointer-events-none"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.02]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M0 40L40 0H20L0 20M40 40V20L20 40'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;); background-size: 40px 40px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <!-- Top badge -->
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-zinc-900/80 border border-zinc-700/60 text-sm">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-zinc-300">Szersze spojrzenie na programowanie</span>
          <span class="text-zinc-500">·</span>
          <span class="text-zinc-500">od 2017</span>
        </div>
      </div>

      <!-- Main headline -->
      <div class="text-center max-w-4xl mx-auto mb-6">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-none mb-6">
          <span class="text-white">Programuj mądrze.</span>
          <br />
          <span class="bg-gradient-to-r from-violet-400 via-purple-400 to-blue-400 bg-clip-text text-transparent">
            Rozwijaj się 10x szybciej.
          </span>
        </h1>
        <p class="text-lg sm:text-xl text-zinc-400 max-w-2xl mx-auto leading-relaxed">
          Platforma edukacyjna dla developerów, którzy chcą wyjść poza podstawy.
          Kursy, podcast i materiały wideo — wszystko czego potrzebujesz, żeby rosnąć.
        </p>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
        <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-all duration-200 hover:shadow-2xl hover:shadow-violet-500/30 text-base">
          Dołącz do 10xDevs 3.0
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="/podcast"
           class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-zinc-800 hover:bg-zinc-700 text-white font-semibold rounded-xl transition-all duration-200 text-base border border-zinc-700 hover:border-zinc-600">
          Słuchaj podcastu
        </a>
      </div>

      <!-- Stats bar -->
      <div class="flex flex-wrap justify-center gap-8 mb-20">
        {[
          { value: '3 700+', label: 'absolwentów kursów' },
          { value: '100+', label: 'odcinków podcastu' },
          { value: '8 lat', label: 'doświadczenia' },
          { value: '15 000+', label: 'obserwujących' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-2xl sm:text-3xl font-black text-white mb-1">{stat.value}</div>
            <div class="text-sm text-zinc-500">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- COURSES SECTION (in hero) -->
      <div id="kursy">
        <div class="text-center mb-10">
          <h2 class="text-2xl font-bold text-white mb-2">Nasze kursy</h2>
          <p class="text-zinc-400">Praktyczna wiedza, mentoring i społeczność</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
          {courses.map((course) => (
            <a
              href={course.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`relative group rounded-2xl border border-zinc-800/80 bg-zinc-900/60 backdrop-blur-sm overflow-hidden transition-all duration-300 ${course.borderGlow} hover:shadow-xl hover:-translate-y-1 ${course.featured ? 'lg:col-span-1 ring-1 ring-violet-500/30' : ''}`}
            >
              <!-- Gradient overlay -->
              <div class={`absolute inset-0 bg-gradient-to-br ${course.gradient} pointer-events-none`}></div>

              <div class="relative p-6">
                <!-- Top row -->
                <div class="flex items-start justify-between mb-5">
                  <div class={`w-12 h-12 rounded-xl ${course.iconBg} flex items-center justify-center text-2xl`}>
                    {course.icon}
                  </div>
                  <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${course.badgeColor}`}>
                    {course.badge}
                  </span>
                </div>

                <!-- Name & tagline -->
                <h3 class="text-xl font-bold text-white mb-1">{course.name}</h3>
                <p class="text-sm text-zinc-400 mb-4 font-medium">{course.tagline}</p>

                <!-- Description -->
                <p class="text-sm text-zinc-400 leading-relaxed mb-5">{course.description}</p>

                <!-- Stats -->
                <div class="flex items-center gap-4 mb-5">
                  {course.stats.map(stat => (
                    <div>
                      <div class="text-base font-bold text-white">{stat.value}</div>
                      <div class="text-xs text-zinc-500">{stat.label}</div>
                    </div>
                  ))}
                </div>

                <!-- Bottom row -->
                <div class="flex items-center justify-between pt-4 border-t border-zinc-800/60">
                  {course.price && (
                    <span class="text-sm font-semibold text-zinc-300">od {course.price}</span>
                  )}
                  {course.startDate && (
                    <span class="text-xs text-zinc-400">{course.startDate}</span>
                  )}
                  <span class={`inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg transition-colors ${course.ctaClass}`}>
                    {course.cta}
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-24 border-t border-zinc-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800 text-xs text-zinc-400 mb-6">
            O NAS
          </div>
          <h2 class="text-4xl font-black text-white mb-6 leading-tight">
            Budujemy przestrzeń dla developerów, którym zależy.
          </h2>
          <p class="text-zinc-400 leading-relaxed mb-6">
            Przeprogramowani.pl powstało w 2017 roku jako weekendowy projekt Przemka Smyrdka, Marcina Czarkowskiego i Adama Gospodarczyka. Dziś to pełnoprawna platforma edukacyjna z tysiącami absolwentów.
          </p>
          <p class="text-zinc-400 leading-relaxed mb-8">
            Naszą misją jest "szersze spojrzenie na programowanie" – uczymy nie tylko technologii, ale i myślenia o swojej karierze, pracy w zespole i korzystaniu z nowoczesnych narzędzi AI.
          </p>
          <a href="/o-nas" class="inline-flex items-center gap-2 text-violet-400 hover:text-violet-300 font-semibold transition-colors">
            Poznaj nasz zespół
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {[
            { icon: '🎓', title: 'Edukacja oparta na praktyce', desc: 'Każdy kurs bazuje na realnych projektach, nie teorii' },
            { icon: '🤖', title: 'AI-Native', desc: 'Uczymy pracy z narzędziami AI w codziennej pracy developera' },
            { icon: '👥', title: 'Silna społeczność', desc: '15 000+ developerów w naszej społeczności' },
            { icon: '🇵🇱', title: 'Po polsku', desc: 'Wysokiej jakości materiały w języku polskim' },
          ].map(item => (
            <div class="p-5 rounded-xl bg-zinc-900/60 border border-zinc-800/60 hover:border-zinc-700 transition-colors">
              <div class="text-2xl mb-3">{item.icon}</div>
              <h3 class="text-sm font-semibold text-white mb-1.5">{item.title}</h3>
              <p class="text-xs text-zinc-500 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Podcast Episodes -->
  <section class="py-24 border-t border-zinc-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800 text-xs text-zinc-400 mb-4">
            PODCAST
          </div>
          <h2 class="text-3xl font-black text-white">Najnowsze odcinki</h2>
          <p class="text-zinc-400 mt-2">Rozmowy dla głodnych wiedzy</p>
        </div>
        <a href="/podcast" class="hidden sm:inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors">
          Wszystkie odcinki
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {podcastEpisodes.map((ep, i) => (
          <a href="/podcast" class="group p-5 rounded-xl bg-zinc-900/60 border border-zinc-800/60 hover:border-zinc-700 transition-all hover:-translate-y-0.5">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-600 to-purple-700 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2H3v2a9 9 0 0 0 8 8.94V21H8v2h8v-2h-3v-.06A9 9 0 0 0 21 12v-2h-2z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <span class="text-xs text-zinc-500">{ep.series}</span>
                <h3 class="text-sm font-semibold text-white mt-1 line-clamp-2 group-hover:text-violet-300 transition-colors">
                  {ep.title}
                </h3>
              </div>
            </div>
            <p class="text-xs text-zinc-500 leading-relaxed mb-4 line-clamp-2">{ep.description}</p>
            <div class="flex items-center gap-3 text-xs text-zinc-500">
              <span>{ep.duration}</span>
              <span>·</span>
              <span>{ep.date}</span>
              {ep.guest && <>
                <span>·</span>
                <span>{ep.guest}</span>
              </>}
            </div>
          </a>
        ))}
      </div>

      <div class="mt-5 sm:hidden">
        <a href="/podcast" class="flex items-center justify-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors py-3">
          Wszystkie odcinki
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest YouTube Videos -->
  <section class="py-24 border-t border-zinc-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800 text-xs text-zinc-400 mb-4">
            YOUTUBE
          </div>
          <h2 class="text-3xl font-black text-white">Ostatnie filmy</h2>
          <p class="text-zinc-400 mt-2">Oglądaj i ucz się w swoim tempie</p>
        </div>
        <a href="/youtube" class="hidden sm:inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors">
          Wszystkie filmy
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {youtubeVideos.map((video) => (
          <a href="/youtube" class="group rounded-xl overflow-hidden bg-zinc-900/60 border border-zinc-800/60 hover:border-zinc-700 transition-all hover:-translate-y-0.5">
            <!-- Thumbnail placeholder -->
            <div class={`aspect-video bg-gradient-to-br ${video.color} flex items-center justify-center relative overflow-hidden`}>
              <div class="absolute inset-0 opacity-30 bg-[radial-gradient(circle_at_30%_50%,_transparent_20%,_black_100%)]"></div>
              <div class="relative w-12 h-12 rounded-full bg-white/10 backdrop-blur-sm flex items-center justify-center group-hover:bg-white/20 transition-colors border border-white/20">
                <svg class="w-5 h-5 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs text-zinc-500 bg-zinc-800 px-2 py-0.5 rounded">{video.category}</span>
              </div>
              <h3 class="text-sm font-semibold text-white group-hover:text-violet-300 transition-colors line-clamp-2 mb-2">
                {video.title}
              </h3>
              <div class="flex items-center gap-2 text-xs text-zinc-500">
                <span>{video.duration}</span>
                <span>·</span>
                <span>{video.date}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="py-24 border-t border-zinc-800/40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative rounded-2xl overflow-hidden bg-gradient-to-br from-violet-900/40 via-zinc-900 to-blue-900/20 border border-violet-500/20 p-10 lg:p-16 text-center">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="relative">
          <div class="text-4xl mb-4">📬</div>
          <h2 class="text-3xl font-black text-white mb-4">
            Newsletter co piątek
          </h2>
          <p class="text-zinc-400 max-w-xl mx-auto mb-8 text-lg">
            3 materiały techniczne + 2 o rozwoju + 1 bonus. Ponad <strong class="text-zinc-200">2 500 subskrybentów</strong> nie może się mylić.
          </p>
          <a
            href="https://przeprogramowani.substack.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-all duration-200 hover:shadow-xl hover:shadow-violet-500/30"
          >
            Zapisz się za darmo
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
