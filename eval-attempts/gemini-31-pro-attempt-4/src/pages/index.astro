---
import Layout from '../layouts/Layout.astro';
import { ArrowRight, Code, Terminal, Zap } from 'lucide-react';
---

<Layout title="Strona Główna">
	<!-- Hero Section -->
	<section class="relative bg-white overflow-hidden">
		<div class="max-w-7xl mx-auto">
			<div class="relative z-10 pb-8 bg-white sm:pb-16 md:pb-20 lg:max-w-2xl lg:w-full lg:pb-28 xl:pb-32 pt-20 px-4 sm:px-6 lg:px-8">
				<main class="mt-10 mx-auto max-w-7xl sm:mt-12 md:mt-16 lg:mt-20 xl:mt-28">
					<div class="sm:text-center lg:text-left">
						<h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
							<span class="block xl:inline">Zostań programistą</span>{' '}
							<span class="block text-blue-600 xl:inline">10xDevs</span>
						</h1>
						<p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-lg sm:max-w-xl sm:mx-auto md:mt-5 md:text-xl lg:mx-0">
							Dołącz do elitarnego grona programistów. Naucz się nowoczesnego podejścia do tworzenia oprogramowania, wykorzystaj AI i przyspiesz swoją karierę z naszymi materiałami i kursami.
						</p>
						<div class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start">
							<div class="rounded-md shadow">
								<a href="#kursy" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 md:py-4 md:text-lg md:px-10 transition-colors">
									Sprawdź kursy
								</a>
							</div>
							<div class="mt-3 sm:mt-0 sm:ml-3">
								<a href="/o-nas" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-blue-700 bg-blue-100 hover:bg-blue-200 md:py-4 md:text-lg md:px-10 transition-colors">
									Poznaj nas
								</a>
							</div>
						</div>
					</div>
				</main>
			</div>
		</div>
		<div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2 bg-gray-50 flex items-center justify-center p-12">
			<div class="grid grid-cols-2 gap-4 w-full max-w-lg">
				<div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center transform translate-y-4">
					<Terminal className="h-10 w-10 text-blue-500 mb-3" />
					<h3 class="font-bold text-gray-900">Praktyka</h3>
					<p class="text-sm text-gray-500 mt-1">Prawdziwe projekty z życia</p>
				</div>
				<div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center">
					<Code className="h-10 w-10 text-indigo-500 mb-3" />
					<h3 class="font-bold text-gray-900">Nowoczesny Stack</h3>
					<p class="text-sm text-gray-500 mt-1">React, TypeScript, AI</p>
				</div>
				<div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center text-center transform translate-y-4">
					<Zap className="h-10 w-10 text-yellow-500 mb-3" />
					<h3 class="font-bold text-gray-900">Efektywność</h3>
					<p class="text-sm text-gray-500 mt-1">Pracuj mądrzej, nie ciężej</p>
				</div>
				<div class="bg-blue-600 p-6 rounded-xl shadow-md flex flex-col items-center text-center justify-center">
					<h3 class="font-bold text-white text-xl">10xDevs</h3>
					<p class="text-blue-100 mt-2 text-sm">Twój kolejny krok</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Courses Section -->
	<section id="kursy" class="py-20 bg-gray-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center">
				<h2 class="text-base text-blue-600 font-semibold tracking-wide uppercase">Nasze programy</h2>
				<p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
					Zdobądź umiejętności, których szuka rynek
				</p>
				<p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
					Kompleksowe kursy stworzone na bazie lat doświadczeń w pracy nad projektami komercyjnymi.
				</p>
			</div>

			<div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
				<!-- Opanuj Frontend -->
				<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
					<div class="p-8 flex-grow">
						<div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mb-6">
							<Code className="h-6 w-6 text-blue-600" />
						</div>
						<h3 class="text-2xl font-bold text-gray-900 mb-3">Opanuj Frontend</h3>
						<p class="text-gray-500 mb-6">
							Kompletny przewodnik po nowoczesnym frontendzie. Od fundamentów HTML/CSS po zaawansowane wzorce w React.
						</p>
						<ul class="space-y-3 mb-8">
							<li class="flex items-center text-gray-600">
								<ArrowRight className="h-4 w-4 text-blue-500 mr-2 flex-shrink-0" />
								<span>Architektura aplikacji SPA</span>
							</li>
							<li class="flex items-center text-gray-600">
								<ArrowRight className="h-4 w-4 text-blue-500 mr-2 flex-shrink-0" />
								<span>Optymalizacja wydajności</span>
							</li>
							<li class="flex items-center text-gray-600">
								<ArrowRight className="h-4 w-4 text-blue-500 mr-2 flex-shrink-0" />
								<span>Dobre praktyki UI/UX</span>
							</li>
						</ul>
					</div>
					<div class="p-8 pt-0 mt-auto">
						<a href="https://opanujfrontend.pl" class="w-full flex items-center justify-center px-4 py-2 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors">
							Zobacz szczegóły
						</a>
					</div>
				</div>

				<!-- Opanuj TypeScript -->
				<div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
					<div class="p-8 flex-grow">
						<div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center mb-6">
							<Terminal className="h-6 w-6 text-indigo-600" />
						</div>
						<h3 class="text-2xl font-bold text-gray-900 mb-3">Opanuj TypeScript</h3>
						<p class="text-gray-500 mb-6">
							Wejdź na wyższy poziom programowania w JavaScript. Naucz się tworzyć bezpieczny i skalowalny kod z systemem typów.
						</p>
						<ul class="space-y-3 mb-8">
							<li class="flex items-center text-gray-600">
								<ArrowRight className="h-4 w-4 text-indigo-500 mr-2 flex-shrink-0" />
								<span>Zaawansowane typy i generyki</span>
							</li>
							<li class="flex items-center text-gray-600">
								<ArrowRight className="h-4 w-4 text-indigo-500 mr-2 flex-shrink-0" />
								<span>Integracja z React i Node.js</span>
							</li>
							<li class="flex items-center text-gray-600">
								<ArrowRight className="h-4 w-4 text-indigo-500 mr-2 flex-shrink-0" />
								<span>Wzorce projektowe w TS</span>
							</li>
						</ul>
					</div>
					<div class="p-8 pt-0 mt-auto">
						<a href="#" class="w-full flex items-center justify-center px-4 py-2 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-indigo-600 hover:bg-indigo-700 transition-colors">
							Zobacz szczegóły
						</a>
					</div>
				</div>

				<!-- 10xDevs -->
				<div class="bg-gray-900 rounded-2xl shadow-lg border border-gray-800 overflow-hidden transform md:-translate-y-4 relative flex flex-col">
					<div class="absolute top-0 right-0 -mt-4 -mr-4 w-24 h-24 bg-blue-500 rounded-full opacity-20 blur-xl"></div>
					<div class="p-8 flex-grow relative z-10">
						<div class="w-12 h-12 bg-gray-800 rounded-lg flex items-center justify-center mb-6 border border-gray-700">
							<Zap className="h-6 w-6 text-yellow-400" />
						</div>
						<h3 class="text-2xl font-bold text-white mb-3">10xDevs</h3>
						<p class="text-gray-400 mb-6">
							Program mentoringowy dla ambitnych programistów. Zwiększ swoją produktywność wielokrotnie wykorzystując AI i nowoczesne narzędzia.
						</p>
						<ul class="space-y-3 mb-8">
							<li class="flex items-center text-gray-300">
								<ArrowRight className="h-4 w-4 text-yellow-400 mr-2 flex-shrink-0" />
								<span>AI w codziennej pracy (Cursor, Copilot)</span>
							</li>
							<li class="flex items-center text-gray-300">
								<ArrowRight className="h-4 w-4 text-yellow-400 mr-2 flex-shrink-0" />
								<span>Automatyzacja procesów</span>
							</li>
							<li class="flex items-center text-gray-300">
								<ArrowRight className="h-4 w-4 text-yellow-400 mr-2 flex-shrink-0" />
								<span>Architektura systemów</span>
							</li>
						</ul>
					</div>
					<div class="p-8 pt-0 mt-auto relative z-10">
						<a href="#" class="w-full flex items-center justify-center px-4 py-2 border border-transparent rounded-md shadow-sm text-base font-bold text-gray-900 bg-yellow-400 hover:bg-yellow-500 transition-colors">
							Dołącz do elity
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
