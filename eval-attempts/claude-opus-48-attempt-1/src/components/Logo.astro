---
interface Props {
  class?: string;
}
const { class: className = 'h-8 w-8' } = Astro.props;
---

<svg class={className} viewBox="0 0 64 64" fill="none" aria-hidden="true">
  <defs>
    <linearGradient id="logo-grad" x1="0" y1="0" x2="64" y2="64" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="#818cf8" />
      <stop offset="1" stop-color="#4f46e5" />
    </linearGradient>
  </defs>
  <rect width="64" height="64" rx="14" fill="#12121d" />
  <rect x="0.75" y="0.75" width="62.5" height="62.5" rx="13.25" stroke="white" stroke-opacity="0.08" stroke-width="1.5" />
  <path d="M20 22 L12 32 L20 42" stroke="url(#logo-grad)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
  <path d="M44 22 L52 32 L44 42" stroke="url(#logo-grad)" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" />
  <path d="M36 18 L28 46" stroke="#e0e7ff" stroke-width="4.5" stroke-linecap="round" />
</svg>
