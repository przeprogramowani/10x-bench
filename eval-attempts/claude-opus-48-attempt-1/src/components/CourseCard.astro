---
import type { Course } from '../data/courses';
import Icon from './Icon.astro';

interface Props {
  course: Course;
}
const { course } = Astro.props;
---

<article
  class:list={[
    'card card-hover group relative flex flex-col overflow-hidden p-7',
    course.featured && 'ring-1 ring-brand-400/30',
  ]}
>
  <div
    class:list={[
      'pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-gradient-to-br opacity-20 blur-2xl transition-opacity duration-300 group-hover:opacity-40',
      course.accent,
    ]}
  >
  </div>

  <div class="flex items-start justify-between gap-3">
    <div
      class:list={[
        'inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br text-white shadow-lg',
        course.accent,
      ]}
    >
      <Icon name="spark" class="h-5 w-5" />
    </div>
    {
      course.badge && (
        <span class="rounded-full border border-brand-400/30 bg-brand-500/10 px-3 py-1 text-xs font-semibold text-brand-300">
          {course.badge}
        </span>
      )
    }
  </div>

  <h3 class="mt-5 text-xl font-bold text-white">{course.name}</h3>
  <p class="mt-1 text-sm font-medium text-brand-300">{course.tagline}</p>
  <p class="mt-3 text-sm leading-relaxed text-slate-400">{course.description}</p>

  <ul class="mt-5 space-y-2.5">
    {
      course.highlights.map((h) => (
        <li class="flex items-start gap-2.5 text-sm text-slate-300">
          <Icon name="check" class="mt-0.5 h-4 w-4 flex-shrink-0 text-brand-400" />
          <span>{h}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 border-t border-white/5 pt-5">
    {
      course.meta.map((m) => (
        <div>
          <div class="text-xs uppercase tracking-wide text-slate-500">{m.label}</div>
          <div class="text-sm font-semibold text-white">{m.value}</div>
        </div>
      ))
    }
  </div>

  <a
    href={course.url}
    target="_blank"
    rel="noopener"
    class="btn-secondary mt-6 w-full group-hover:border-brand-400/40"
  >
    Poznaj program
    <Icon name="external" class="h-4 w-4" />
  </a>
</article>
