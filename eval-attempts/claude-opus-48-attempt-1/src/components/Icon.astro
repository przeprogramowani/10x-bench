const isBrand = name in brands;
const inner = isBrand ? brands[name] : (paths[name] ?? '');
---

{
  isBrand ? (
    <svg
      class={className}
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      set:html={inner}
    />
  ) : (
    <svg
      class={className}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={inner}
    />
  )
}
