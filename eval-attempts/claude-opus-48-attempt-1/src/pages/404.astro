---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="404 — nie znaleziono strony">
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="gradient-text text-7xl font-extrabold sm:text-8xl">404</p>
    <h1 class="mt-4 text-2xl font-bold text-white sm:text-3xl">Ups, tej strony nie ma</h1>
    <p class="mt-3 max-w-md text-slate-400">
      Strona, której szukasz, mogła zostać przeniesiona lub nigdy nie istniała.
      Wróć na stronę główną i zacznij od nowa.
    </p>
    <a href="/" class="btn-primary mt-8">
      <Icon name="arrow" class="h-4 w-4 rotate-180" />
      Wróć na stronę główną
    </a>
  </section>
</Layout>
