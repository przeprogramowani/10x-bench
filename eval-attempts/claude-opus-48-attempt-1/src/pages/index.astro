---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import CourseCard from '../components/CourseCard.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import VideoCard from '../components/VideoCard.astro';
import Icon from '../components/Icon.astro';
import NewsletterForm from '../components/NewsletterForm.tsx';
import { site, clients } from '../data/site';
import { courses } from '../data/courses';
import { episodes, podcastMeta } from '../data/podcast';
import { videos, youtubeChannel } from '../data/youtube';

const latestEpisodes = episodes.slice(0, 3);
const latestVideos = videos.slice(0, 4);
---

<Layout>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div
        class="absolute -top-40 right-0 h-[36rem] w-[36rem] rounded-full bg-brand-600/20 blur-[120px]"
      >
      </div>
      <div
        class="absolute -left-40 top-40 h-[28rem] w-[28rem] rounded-full bg-indigo-500/10 blur-[120px]"
      >
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(255,255,255,0.04)_1px,transparent_0)] [background-size:32px_32px]"
      >
      </div>
    </div>

    <div class="container-page pb-20 pt-16 sm:pb-28 sm:pt-24">
      <div class="mx-auto max-w-3xl text-center animate-fade-up">
        <span class="eyebrow">
          <Icon name="spark" class="h-3.5 w-3.5" />
          {site.stats.years} · edukacja techniczna
        </span>
        <h1 class="mt-6 text-4xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-6xl">
          Szersze spojrzenie na
          <span class="gradient-text"> programowanie</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-slate-300 sm:text-xl">
          Tworzymy podcast, filmy i kursy, które pomagają programistom rozwijać się
          w każdym wymiarze — technicznym, biznesowym i osobistym.
        </p>

        <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="#kursy" class="btn-primary w-full sm:w-auto">
            Zobacz nasze kursy
            <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a href="/podcast" class="btn-secondary w-full sm:w-auto">
            <Icon name="headphones" class="h-4 w-4" />
            Posłuchaj podcastu
          </a>
        </div>
      </div>

      <!-- 10xDevs highlight w hero -->
      <div class="mx-auto mt-16 max-w-5xl animate-fade-up" style="animation-delay:120ms">
        <a
          href="https://10xdevs.pl"
          target="_blank"
          rel="noopener"
          class="group relative block overflow-hidden rounded-3xl border border-brand-400/30 bg-gradient-to-br from-ink-800 to-ink-700 p-8 transition duration-300 hover:border-brand-400/60 sm:p-10"
        >
          <div
            class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-brand-500/30 blur-3xl transition-opacity duration-300 group-hover:opacity-80"
          >
          </div>
          <div class="relative grid items-center gap-8 md:grid-cols-[1.4fr,1fr]">
            <div>
              <div class="flex items-center gap-3">
                <span
                  class="rounded-full bg-brand-500 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white"
                >
                  Flagowy program
                </span>
                <span class="text-sm font-semibold text-brand-300">10xDevs 4.0</span>
              </div>
              <h2 class="mt-4 text-2xl font-bold text-white sm:text-3xl">
                Czas na AI-Native Software Engineering!
              </h2>
              <p class="mt-3 max-w-xl text-slate-300">
                5-tygodniowa kohorta, w której uczysz się wpinać agentów AI w realny workflow
                inżynierski — od greenfieldu, przez modernizację legacy, po pracę zespołową.
                Zbuduj pełny projekt MVP i wdróż go do chmury.
              </p>
              <div class="mt-6 inline-flex items-center gap-2 font-semibold text-white">
                Dołącz do 10xDevs
                <Icon
                  name="arrow"
                  class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              {
                [
                  { value: '5 tyg.', label: 'Kohorta online' },
                  { value: '12 mies.', label: 'Dostęp' },
                  { value: 'PL / EN', label: 'Dwa języki' },
                  { value: 'MVP', label: 'Projekt w chmurze' },
                ].map((s) => (
                  <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center">
                    <div class="text-2xl font-bold text-white">{s.value}</div>
                    <div class="mt-1 text-xs text-slate-400">{s.label}</div>
                  </div>
                ))
              }
            </div>
          </div>
        </a>
      </div>

      <!-- Statystyki -->
      <div class="mx-auto mt-14 grid max-w-4xl grid-cols-2 gap-6 sm:grid-cols-4">
        {
          [
            { value: site.stats.community, label: 'Programistów w społeczności' },
            { value: site.stats.trained, label: 'Przeszkolonych osób' },
            { value: podcastMeta.episodes + '+', label: 'Odcinków podcastu' },
            { value: podcastMeta.rating, label: 'Ocena podcastu' },
          ].map((s) => (
            <div class="text-center">
              <div class="text-3xl font-bold text-white sm:text-4xl">{s.value}</div>
              <div class="mt-1 text-xs leading-tight text-slate-400 sm:text-sm">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- LOGOTYPY KLIENTÓW -->
  <section class="border-y border-white/5 bg-ink-800/30 py-10">
    <div class="container-page">
      <p class="text-center text-xs font-semibold uppercase tracking-wider text-slate-500">
        Zaufali nam programiści z zespołów m.in.
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {
          clients.map((c) => (
            <span class="text-sm font-semibold text-slate-400 transition hover:text-slate-200">
              {c}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- KURSY -->
  <Section
    id="kursy"
    eyebrow="Kursy i programy"
    title="Ucz się od praktyków, którzy budują produkty"
    description="Trzy programy, które prowadzą Cię od solidnych podstaw do pracy na najwyższym poziomie — z nowoczesnym stackiem i AI w codziennym workflow."
  >
    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {courses.map((course) => <CourseCard course={course} />)}
    </div>
  </Section>

  <!-- PODCAST -->
  <section class="border-t border-white/5 bg-ink-800/20">
    <Section
      eyebrow="Podcast"
      title="Ostatnie odcinki podcastu"
      description={podcastMeta.description}
    >
      <div class="mt-10 space-y-4">
        {latestEpisodes.map((ep, i) => <EpisodeCard episode={ep} index={i} />)}
      </div>
      <div class="mt-8">
        <a href="/podcast" class="btn-secondary">
          Wszystkie odcinki
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </Section>
  </section>

  <!-- YOUTUBE -->
  <Section
    eyebrow="YouTube"
    title="Najnowsze filmy na kanale"
    description={youtubeChannel.description}
  >
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {latestVideos.map((video) => <VideoCard video={video} />)}
    </div>
    <div class="mt-8">
      <a href="/youtube" class="btn-secondary">
        Więcej filmów
        <Icon name="arrow" class="h-4 w-4" />
      </a>
    </div>
  </Section>

  <!-- NEWSLETTER -->
  <section class="border-t border-white/5 py-16 sm:py-24">
    <div class="container-page">
      <div
        class="relative mx-auto max-w-3xl overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-ink-800 to-ink-700 p-8 text-center sm:p-12"
      >
        <div
          class="pointer-events-none absolute -left-16 -top-16 h-48 w-48 rounded-full bg-brand-500/20 blur-3xl"
        >
        </div>
        <div class="relative">
          <div
            class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-brand-500/15 text-brand-300"
          >
            <Icon name="mail" class="h-6 w-6" />
          </div>
          <h2 class="mt-5 text-2xl font-bold text-white sm:text-3xl">
            Przeprogramowany Newsletter
          </h2>
          <p class="mx-auto mt-3 max-w-xl text-slate-400">
            Co piątek wysyłamy skondensowaną dawkę wiedzy: 3 rekomendacje techniczne,
            2 o rozwoju i 1 bonus. Dołącz do {site.stats.community} programistów.
          </p>
          <div class="mx-auto mt-7 max-w-md">
            <NewsletterForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
