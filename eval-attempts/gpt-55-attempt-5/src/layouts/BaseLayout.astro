---
import '../styles/global.css';
import { navItems } from '../data/site';

const {
  title = 'Przeprogramowani.pl',
  description = 'Szersze spojrzenie na programowanie: kursy, podcast, YouTube i praktyczne programy dla developerów.',
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-paper text-ink antialiased">
    <header class="sticky top-0 z-50 border-b border-ink/10 bg-paper/90 px-4 backdrop-blur sm:px-6 lg:px-8">
      <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-4">
        <a class="focus-ring flex items-center gap-3 rounded-sm font-semibold" href="/">
          <span class="grid size-9 place-items-center bg-ink text-sm font-black text-lime">&lt;/&gt;</span>
          <span>Przeprogramowani</span>
        </a>
        <nav class="hidden items-center gap-7 text-sm font-medium md:flex">
          {navItems.map((item) => <a class="focus-ring rounded-sm text-ink/72 hover:text-ink" href={item.href}>{item.label}</a>)}
        </nav>
        <a class="focus-ring rounded-full bg-ink px-4 py-2 text-sm font-semibold text-white hover:bg-coral" href="https://www.10xdevs.pl/" rel="noreferrer" target="_blank">10xDevs</a>
      </div>
      <nav class="mx-auto flex max-w-7xl gap-5 overflow-x-auto border-t border-ink/10 py-3 text-sm font-medium md:hidden">
        {navItems.map((item) => <a class="focus-ring shrink-0 rounded-sm text-ink/72 hover:text-ink" href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-ink/10 px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto flex max-w-7xl flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="font-semibold">Przeprogramowani.pl</p>
          <p class="mt-1 text-sm text-ink/62">Szersze spojrzenie na programowanie.</p>
        </div>
        <div class="flex flex-wrap gap-4 text-sm text-ink/70">
          <a class="hover:text-ink" href="https://www.youtube.com/@Przeprogramowani" rel="noreferrer" target="_blank">YouTube</a>
          <a class="hover:text-ink" href="https://creators.spotify.com/pod/profile/przeprogramowani" rel="noreferrer" target="_blank">Podcast</a>
          <a class="hover:text-ink" href="mailto:kontakt@przeprogramowani.pl">kontakt@przeprogramowani.pl</a>
        </div>
      </div>
    </footer>
  </body>
</html>
