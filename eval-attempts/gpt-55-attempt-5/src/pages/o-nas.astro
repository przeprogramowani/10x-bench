---
import BaseLayout from '../layouts/BaseLayout.astro';
import { founders, stats } from '../data/site';
---

<BaseLayout title="O nas - Przeprogramowani.pl">
  <section class="noise px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase text-coral">O nas</p>
      <h1 class="mt-4 text-5xl font-black leading-none sm:text-7xl">Łączymy świat programowania, biznesu i rozwoju.</h1>
      <p class="mt-7 max-w-3xl text-lg leading-8 text-ink/70">
        Przeprogramowani to projekt edukacyjny prowadzony przez Przemka Smyrdka i Marcina Czarkowskiego. Tworzymy kursy, podcasty i materiały dla programistów, którzy chcą rozumieć technologię szerzej niż przez pryzmat kolejnej biblioteki.
      </p>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-2">
      {founders.map((founder) => (
        <article class="rounded-lg border border-ink/10 bg-white p-7">
          <div class={`grid size-16 place-items-center rounded-md ${founder.accent} font-black text-ink`}>{founder.initials}</div>
          <h2 class="mt-6 text-3xl font-black">{founder.name}</h2>
          <p class="mt-2 text-ink/55">{founder.role}</p>
          <p class="mt-5 leading-8 text-ink/72">{founder.body}</p>
          <a class="mt-6 inline-flex font-semibold underline" href={founder.href} rel="noreferrer" target="_blank">LinkedIn</a>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-ink px-4 py-16 text-white sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => (
        <div class="rounded-lg border border-white/12 p-6">
          <p class="text-4xl font-black text-lime">{stat.value}</p>
          <p class="mt-3 leading-7 text-white/70">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
