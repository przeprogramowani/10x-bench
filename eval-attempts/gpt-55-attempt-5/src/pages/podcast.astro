---
import BaseLayout from '../layouts/BaseLayout.astro';
import { podcastEpisodes } from '../data/site';
---

<BaseLayout title="Podcast - Przeprogramowani.pl">
  <section class="noise px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <p class="text-sm font-semibold uppercase text-coral">Podcast</p>
      <h1 class="mt-4 text-5xl font-black leading-none sm:text-7xl">Rozmowy o programowaniu bez tunelowego widzenia.</h1>
      <p class="mt-7 max-w-3xl text-lg leading-8 text-ink/70">
        Przeprogramowani Podcast to szersze spojrzenie na programowanie: technologia, kariera, architektura, AI i praktyka pracy w zespołach produktowych.
      </p>
    </div>
  </section>

  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-5xl gap-4">
      {podcastEpisodes.map((episode, index) => (
        <a class="focus-ring grid gap-6 rounded-lg border border-ink/10 bg-white p-6 transition hover:-translate-y-1 hover:border-ink/30 md:grid-cols-[96px_1fr_auto]" href={episode.href} rel="noreferrer" target="_blank">
          <div class="grid size-24 place-items-center rounded-md bg-ink text-3xl font-black text-lime">{String(index + 1).padStart(2, '0')}</div>
          <div>
            <p class="text-sm text-ink/55">{episode.date} · {episode.duration}</p>
            <h2 class="mt-2 text-2xl font-black">{episode.title}</h2>
            <p class="mt-3 leading-7 text-ink/70">{episode.body}</p>
          </div>
          <span class="self-center font-semibold text-coral">Słuchaj</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
