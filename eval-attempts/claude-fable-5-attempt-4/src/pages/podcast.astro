---
import Layout from '../layouts/Layout.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import { SITE } from '../data/site';
import { PODCAST_DESCRIPTION, EPISODES } from '../data/podcast';

const platforms = [
  { label: 'Spotify', href: SITE.social.spotify },
  { label: 'Apple Podcasts', href: SITE.social.applePodcasts },
  { label: 'YouTube', href: SITE.social.youtube },
];
---

<Layout
  title="Podcast — Przeprogramowani.pl"
  description="Podcast Przeprogramowani: rozmowy z ekspertami branży IT o nowoczesnym wytwarzaniu oprogramowania, karierze i rozwoju programistów. 98 odcinków, ocena 4.9/5."
>
  <section class="relative overflow-hidden pt-16">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(99,102,241,0.2),transparent_60%)]"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
      <p class="text-sm font-bold uppercase tracking-wider text-brand-400">Podcast</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-black leading-tight text-white sm:text-5xl">
        Przeprogramowani — podcast o szerszym spojrzeniu na programowanie
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
        {PODCAST_DESCRIPTION}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        {
          platforms.map((platform) => (
            <a
              href={platform.href}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-xl border border-white/15 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-white/5"
            >
              Słuchaj: {platform.label}
            </a>
          ))
        }
      </div>

      <div class="mt-8 flex flex-wrap gap-x-8 gap-y-2 text-sm text-slate-400">
        <span><strong class="text-white">98</strong> odcinków</span>
        <span><strong class="text-white">4.9/5</strong> ocena słuchaczy</span>
        <span>Nadajemy od <strong class="text-white">2019</strong> roku</span>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-slate-900/30 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="text-2xl font-black text-white sm:text-3xl">Ostatnie odcinki</h2>
      <div class="mt-8 space-y-5">
        {EPISODES.map((episode, index) => <EpisodeCard episode={episode} number={EPISODES.length - index} />)}
      </div>
      <div class="mt-10 text-center">
        <a
          href={SITE.social.spotify}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-xl bg-gradient-to-r from-brand-500 to-fuchsia-500 px-6 py-3 text-sm font-bold text-white transition-opacity hover:opacity-90"
        >
          Zobacz wszystkie 98 odcinków
        </a>
      </div>
    </div>
  </section>
</Layout>
