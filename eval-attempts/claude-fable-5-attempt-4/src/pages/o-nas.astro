---
import Layout from '../layouts/Layout.astro';
import { SITE, FOUNDERS, STATS, PARTNERS } from '../data/site';
---

<Layout
  title="O nas — Przeprogramowani.pl"
  description="Poznaj Przemka Smyrdka i Marcina Czarkowskiego — twórców Przeprogramowani.pl. Od 7 lat łączymy programowanie z rozwojem osobistym."
>
  <!-- Page hero -->
  <section class="relative overflow-hidden pt-16">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(99,102,241,0.2),transparent_60%)]"
    >
    </div>
    <div class="relative mx-auto max-w-6xl px-4 pb-16 pt-16 sm:px-6 sm:pt-24">
      <p class="text-sm font-bold uppercase tracking-wider text-brand-400">O nas</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-black leading-tight text-white sm:text-5xl">
        Miejsce, w którym programowanie spotyka się z rozwojem
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
        Wierzymy, że najlepsi programiści patrzą szerzej — na architekturę, biznes, ludzi i samych
        siebie. Dlatego od 7 lat tworzymy treści, kursy i narzędzia, które pomagają rozwijać się na
        wielu poziomach: od juniorów szukających kierunku po seniorów planujących kolejne kroki.
      </p>
    </div>
  </section>

  <!-- Founders -->
  <section class="border-t border-white/5 bg-slate-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl font-black text-white sm:text-4xl">Kto stoi za Przeprogramowanymi?</h2>
      <div class="mt-12 grid gap-8 lg:grid-cols-2">
        {
          FOUNDERS.map((founder) => (
            <article class="rounded-2xl border border-white/10 bg-slate-900/60 p-6 sm:p-8">
              <div class="flex items-center gap-4">
                <span class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-brand-500 to-fuchsia-500 text-xl font-black text-white">
                  {founder.initials}
                </span>
                <div>
                  <h3 class="text-xl font-bold text-white">{founder.name}</h3>
                  <p class="text-sm font-medium text-brand-300">{founder.role}</p>
                </div>
              </div>
              <p class="mt-5 text-sm leading-relaxed text-slate-300">{founder.bio}</p>
              <div class="mt-5 flex flex-wrap gap-2">
                {founder.skills.map((skill) => (
                  <span class="rounded-full bg-white/5 px-3 py-1 text-xs font-medium text-slate-300 ring-1 ring-white/10">
                    {skill}
                  </span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="border-t border-white/5 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-3xl font-black text-white sm:text-4xl">Nasza misja</h2>
          <p class="mt-6 leading-relaxed text-slate-300">
            <strong class="text-white">„{SITE.tagline}”</strong> to nie tylko hasło. To przekonanie, że
            rozwój programisty nie kończy się na kolejnym frameworku. Łączymy twarde umiejętności
            techniczne z architekturą, biznesem i nauką o uczeniu się.
          </p>
          <p class="mt-4 leading-relaxed text-slate-300">
            W epoce Generatywnego AI ta perspektywa jest ważniejsza niż kiedykolwiek. Pomagamy
            programistom przejść od chaosu eksperymentów do powtarzalnych, profesjonalnych procesów
            pracy z AI — bez zgadywania, bez halucynacji, bez chaosu.
          </p>
          <p class="mt-4 leading-relaxed text-slate-300">
            Tworzymy podcast, kanał YouTube, cotygodniowy newsletter oraz programy szkoleniowe:
            10xDevs, Opanuj Frontend i Opanuj TypeScript.
          </p>
        </div>
        <dl class="grid grid-cols-2 gap-6">
          {
            STATS.map((stat) => (
              <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6 text-center">
                <dd class="bg-gradient-to-r from-brand-400 to-fuchsia-400 bg-clip-text text-3xl font-black text-transparent">
                  {stat.value}
                </dd>
                <dt class="mt-2 text-xs font-medium text-slate-400 sm:text-sm">{stat.label}</dt>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </section>

  <!-- Partners + contact -->
  <section class="border-t border-white/5 bg-slate-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
      <h2 class="text-2xl font-black text-white sm:text-3xl">Zaufali nam</h2>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
        {
          PARTNERS.map((partner) => (
            <span class="text-base font-bold text-slate-600 transition-colors hover:text-slate-400">
              {partner}
            </span>
          ))
        }
      </div>
      <div class="mx-auto mt-16 max-w-xl rounded-2xl border border-white/10 bg-slate-900/60 p-8">
        <h3 class="text-xl font-bold text-white">Chcesz z nami współpracować?</h3>
        <p class="mt-3 text-sm text-slate-400">
          Szkolenia dla zespołów, współpraca contentowa, patronaty — napisz do nas.
        </p>
        <a
          href={`mailto:${SITE.email}`}
          class="mt-6 inline-block rounded-xl bg-gradient-to-r from-brand-500 to-fuchsia-500 px-6 py-3 text-sm font-bold text-white transition-opacity hover:opacity-90"
        >
          {SITE.email}
        </a>
      </div>
    </div>
  </section>
</Layout>
