---
import type { Course } from '../data/courses';

interface Props {
  course: Course;
}

const { course } = Astro.props;

const accents = {
  violet: {
    badge: 'bg-violet-500/10 text-violet-300 ring-violet-500/30',
    glow: 'from-violet-500/20',
    check: 'text-violet-400',
    link: 'text-violet-300 hover:text-violet-200',
  },
  sky: {
    badge: 'bg-sky-500/10 text-sky-300 ring-sky-500/30',
    glow: 'from-sky-500/20',
    check: 'text-sky-400',
    link: 'text-sky-300 hover:text-sky-200',
  },
  amber: {
    badge: 'bg-amber-500/10 text-amber-300 ring-amber-500/30',
    glow: 'from-amber-500/20',
    check: 'text-amber-400',
    link: 'text-amber-300 hover:text-amber-200',
  },
} as const;

const accent = accents[course.accent];
---

<article
  class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-white/10 bg-slate-900/60 p-6 transition-colors hover:border-white/20 sm:p-8"
>
  <div
    class={`pointer-events-none absolute -top-24 right-0 h-48 w-48 rounded-full bg-gradient-to-b ${accent.glow} to-transparent blur-3xl`}
  >
  </div>

  <span
    class={`inline-flex w-fit items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 ${accent.badge}`}
  >
    {course.badge}
  </span>

  <h3 class="mt-4 text-xl font-bold text-white sm:text-2xl">{course.name}</h3>
  <p class="mt-1 text-sm font-medium text-slate-400">{course.tagline}</p>
  <p class="mt-4 text-sm leading-relaxed text-slate-300">{course.description}</p>

  <ul class="mt-6 flex-1 space-y-3">
    {
      course.highlights.map((item) => (
        <li class="flex items-start gap-3 text-sm text-slate-300">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class={`mt-0.5 h-4 w-4 shrink-0 ${accent.check}`}
          >
            <path
              fill-rule="evenodd"
              d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
              clip-rule="evenodd"
            />
          </svg>
          {item}
        </li>
      ))
    }
  </ul>

  <a
    href={course.url}
    target="_blank"
    rel="noopener noreferrer"
    class={`mt-8 inline-flex items-center gap-2 text-sm font-semibold ${accent.link}`}
  >
    Poznaj szczegóły kursu
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      class="h-4 w-4 transition-transform group-hover:translate-x-1"
    >
      <path
        fill-rule="evenodd"
        d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
        clip-rule="evenodd"
      />
    </svg>
  </a>
</article>
