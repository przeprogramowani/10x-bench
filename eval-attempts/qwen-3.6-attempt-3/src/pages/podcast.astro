---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { podcastEpisodes } from '../lib/data';
import '@/css/main.css';
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Odcinki podcastu Przeprogramowani. Najnowsze odcinki o technologiach, programowaniu i karierze w IT." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet" />
    <title>Podcast - Przeprogramowani.pl</title>
  </head>
  <body class="bg-dark-950 text-white min-h-screen">
    <Header />
    <main class="pt-20">
      <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32">
        <div class="text-center mb-16">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm font-medium mb-6">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18.5a6.5 6.5 0 100-13 6.5 6.5 0 000 13z"/><path d="M7 18.5a11 11 0 100-13"/></svg>
            Posłuchaj nas
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold mb-6">
            Podcast <span class="gradient-text">Przeprogramowani</span>
          </h1>
          <p class="text-xl text-dark-300 max-w-2xl mx-auto leading-relaxed">
            Co tydzień rozmawiamy o technologiach, programowaniu i karierze w IT. Dołącz do społeczności ponad 7-letniego podcastu!
          </p>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-4 mb-16">
          <a href="https://podcasters.spotify.com/pod/show/przeprogramowani" target="_blank" rel="noopener"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-green-500 hover:bg-green-400 text-white font-semibold text-sm transition-all shadow-lg shadow-green-500/20">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.343c-.261.387-.744.521-1.131.26-1.902-1.167-4.312-1.428-7.134-.784-.411.105-.848-.131-.953-.542-.104-.411.131-.848.542-.952 3.192-.716 5.92-.414 8.148.952.387.261.521.743.26 1.132z"/></svg>
            Spotify
          </a>
        </div>

        <div class="space-y-4">
          {podcastEpisodes.map(ep => (
            <a href={ep.url} target="_blank" rel="noopener"
              class="glass-card glass-card-hover p-6 flex items-start gap-5 group">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center text-brand-400 group-hover:bg-brand-500/20 transition-all">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2 flex-wrap">
                  <span class="text-brand-400 text-xs font-semibold">{ep.number}</span>
                  <span class="text-dark-500 text-xs">{ep.date}</span>
                  <span class="text-dark-500 text-xs flex items-center gap-1">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {ep.duration}
                  </span>
                </div>
                <h3 class="text-white font-semibold mb-1 group-hover:text-brand-400 transition-colors truncate">
                  {ep.title}
                </h3>
                <p class="text-dark-400 text-sm">{ep.description}</p>
              </div>
              <svg class="w-5 h-5 text-dark-500 flex-shrink-0 mt-1 group-hover:text-brand-400 group-hover:translate-x-1 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
