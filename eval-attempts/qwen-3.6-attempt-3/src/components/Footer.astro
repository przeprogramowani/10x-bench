---
import { PodcastIcon, YoutubeIcon, SpotifyIcon, SubstackIcon, GithubIcon, HeartIcon, MailIcon, GlobeIcon } from './Icons';
import { site, socialLinks } from '../lib/data';
---

<footer class="relative border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-accent-500 flex items-center justify-center">
            <PodcastIcon className="w-5 h-5 text-white" />
          </div>
          <span class="text-white font-display font-bold text-lg">
            Przeprogramowani<span class="text-accent-400">.pl</span>
          </span>
        </a>
        <p class="text-dark-400 text-sm leading-relaxed mb-6">
          Edukacja technologiczna nowej generacji. Od 7 lat tworzymy materiały, które pomagają programistom rosnąć.
        </p>
        <div class="flex gap-3">
          {socialLinks.map(s => (
            <a href={s.url} target="_blank" rel="noopener" class="w-9 h-9 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-dark-400 hover:text-white hover:bg-white/10 transition-all" aria-label={s.name}>
              {s.name === 'YouTube' && <YoutubeIcon className="w-4 h-4" />}
              {s.name === 'Spotify' && <SpotifyIcon className="w-4 h-4" />}
              {s.name === 'Substack' && <SubstackIcon className="w-4 h-4" />}
              {s.name === 'GitHub' && <GithubIcon className="w-4 h-4" />}
            </a>
          ))}
        </div>
      </div>

      <!-- Oferta -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">OFERTA</h3>
        <ul class="space-y-3">
          <li><a href="https://www.opanujfrontend.pl?utm_source=przeprogramowani_website" class="text-dark-400 hover:text-white text-sm transition-colors">Opanuj Frontend</a></li>
          <li><a href="https://www.opanujtypescript.pl?utm_source=przeprogramowani_website" class="text-dark-400 hover:text-white text-sm transition-colors">Opanuj TypeScript</a></li>
          <li><a href="https://10xdevs.pl" class="text-dark-400 hover:text-white text-sm transition-colors">10xDevs</a></li>
          <li><a href="https://opanuj.ai" class="text-dark-400 hover:text-white text-sm transition-colors">Opanuj AI</a></li>
          <li><a href="https://10xrules.ai" class="text-dark-400 hover:text-white text-sm transition-colors">10xRules AI</a></li>
        </ul>
      </div>

      <!-- Multimedia -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">MULTIMEDIA</h3>
        <ul class="space-y-3">
          <li><a href="https://podcasters.spotify.com/pod/show/przeprogramowani" class="text-dark-400 hover:text-white text-sm transition-colors flex items-center gap-2"><SpotifyIcon className="w-3.5 h-3.5" /> Podcast</a></li>
          <li><a href="https://www.youtube.com/@przeprogramowani" class="text-dark-400 hover:text-white text-sm transition-colors flex items-center gap-2"><YoutubeIcon className="w-3.5 h-3.5" /> YouTube</a></li>
          <li><a href="https://przeprogramowani.substack.com" class="text-dark-400 hover:text-white text-sm transition-colors flex items-center gap-2"><SubstackIcon className="w-3.5 h-3.5" /> Newsletter</a></li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">KONTAKT</h3>
        <ul class="space-y-3">
          <li><a href="mailto:kontakt@przeprogramowani.pl" class="text-dark-400 hover:text-white text-sm transition-colors flex items-center gap-2"><MailIcon className="w-3.5 h-3.5" /> kontakt@przeprogramowani.pl</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-16 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-dark-500 text-sm">
        &copy; {new Date().getFullYear()} Przeprogramowani.pl. Wszystkie prawa zastrzeżone.
      </p>
      <p class="text-dark-500 text-sm flex items-center gap-1.5">
        Stworzone z <HeartIcon className="w-3.5 h-3.5 text-accent-500" /> dla społeczności dev
      </p>
    </div>
  </div>
</footer>
