---
import { podcastEpisodes } from '../lib/data';
---

<section id="podcast" class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-dark-900 to-dark-950" />

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-green-500/5 rounded-full blur-3xl pointer-events-none" />

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16 gap-6">
      <div>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm font-medium mb-6">
          Podcast
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-display font-bold mb-4">
          <span class="text-white">Ostatnie </span>
          <span class="gradient-text">odcinki</span>
        </h2>
        <p class="text-dark-300 text-lg max-w-xl">
          Co tydzień nowa dawka wiedzy o technologiach, programowaniu i karierze w IT.
        </p>
      </div>
      <a href="https://podcasters.spotify.com/pod/show/przeprogramowani" target="_blank" rel="noopener"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-green-500 hover:bg-green-400 text-white font-semibold text-sm transition-all shadow-lg shadow-green-500/20 self-start md:self-auto">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.343c-.261.387-.744.521-1.131.26-1.902-1.167-4.312-1.428-7.134-.784-.411.105-.848-.131-.953-.542-.104-.411.131-.848.542-.952 3.192-.716 5.92-.414 8.148.952.387.261.521.743.26 1.132z"/></svg>
        Posłuchaj wszystkich
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {podcastEpisodes.map(ep => (
        <a href={ep.url} target="_blank" rel="noopener"
          class="glass-card glass-card-hover p-6 group">
          <!-- Play button -->
          <div class="relative w-full aspect-square rounded-xl bg-gradient-to-br from-brand-600/20 to-brand-800/20 border border-brand-500/10 mb-5 flex items-center justify-center overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-brand-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
            <div class="w-14 h-14 rounded-full bg-brand-500/20 border border-brand-500/30 flex items-center justify-center group-hover:bg-brand-500/30 group-hover:scale-110 transition-all z-10">
              <svg class="w-6 h-6 text-brand-400 ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>

          <div class="flex items-center gap-3 mb-3">
            <span class="text-brand-400 text-xs font-semibold">{ep.number}</span>
            <span class="text-dark-500 text-xs flex items-center gap-1">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {ep.duration}
            </span>
          </div>
          <h3 class="text-white font-semibold mb-2 group-hover:text-brand-400 transition-colors leading-snug">
            {ep.title}
          </h3>
          <p class="text-dark-400 text-sm leading-relaxed line-clamp-3">
            {ep.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
