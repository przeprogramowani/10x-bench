---
import '../styles/global.css';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Przeprogramowani.pl - Platforma edukacyjna dla programistów." } = Astro.props;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Przeprogramowani.pl</title>
		<meta name="description" content={description} />
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col antialiased">
		<Navigation client:load />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
	</body>
</html>
