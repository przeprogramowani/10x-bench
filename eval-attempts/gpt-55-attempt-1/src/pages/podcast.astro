---
import { Radio } from "lucide-react";
import SectionTitle from "../components/SectionTitle.astro";
import { podcastEpisodes } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Podcast - Przeprogramowani"
  description="Najnowsze odcinki podcastu Przeprogramowani: rozmowy o programowaniu, rozwoju kariery, architekturze i pracy w IT."
>
  <section class="bg-ink py-16 text-white sm:py-20">
    <div class="page-shell grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div class="max-w-[220px] rounded-md bg-lime p-3 text-ink shadow-soft">
        <img
          src="https://is1-ssl.mzstatic.com/image/thumb/Podcasts126/v4/7d/08/59/7d0859c8-f171-f279-908c-4938548c6dee/mza_17346134690248137847.jpg/600x600bb.webp"
          alt="Okładka podcastu Przeprogramowani"
          class="aspect-square w-full rounded object-cover"
          loading="eager"
        />
      </div>
      <div>
        <p class="text-sm font-bold uppercase text-lime">Podcast</p>
        <h1 class="mt-4 font-display text-5xl font-black leading-tight sm:text-6xl">
          Przeprogramowani, czyli szersze spojrzenie na programowanie
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-white/72">
          Rozmowy Marcina Czarkowskiego i Przemka Smyrdka z gośćmi o technologii, karierze, architekturze i świadomym rozwoju w IT.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="page-shell">
      <SectionTitle
        eyebrow="Ostatnie odcinki"
        title="Najnowsze rozmowy z Apple Podcasts"
        text="Statyczny snapshot najnowszych publicznie widocznych odcinków, gotowy do wdrożenia jako strona Astro."
      />
      <div class="mt-10 grid gap-5">
        {podcastEpisodes.map((episode) => (
          <article class="rounded-md border border-line bg-white p-6 shadow-soft">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div class="max-w-3xl">
                <p class="flex items-center gap-2 text-sm font-black uppercase text-fern">
                  <Radio size={16} aria-hidden="true" />
                  {episode.date} / {episode.duration}
                </p>
                <h2 class="mt-3 font-display text-2xl font-extrabold">{episode.title}</h2>
                <p class="mt-3 text-base leading-7 text-ink/68">{episode.summary}</p>
              </div>
              <a href={episode.href} class="focus-ring inline-flex shrink-0 items-center justify-center rounded-md bg-ink px-4 py-3 text-sm font-black text-white hover:bg-fern">
                Otwórz odcinek
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
