---
import { ArrowRight, Check, ExternalLink, ShieldCheck, Sparkles, Users } from "lucide-react";
import FeaturedMedia from "../components/FeaturedMedia";
import SectionTitle from "../components/SectionTitle.astro";
import { courses, podcastEpisodes, youtubeVideos } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Przeprogramowani.pl - szersze spojrzenie na programowanie"
  description="Nowoczesna strona projektu Przeprogramowani: kursy 10xDevs, Opanuj Frontend, Opanuj TypeScript, podcast i YouTube."
>
  <section class="relative isolate overflow-hidden bg-ink text-white">
    <img
      src="https://cdn.prod.website-files.com/698b104fda97d1c7b03d1f59/698eee61bd0cba7404e03d70_hero-image-webp.webp"
      alt=""
      class="absolute inset-0 -z-20 h-full w-full object-cover opacity-50"
      fetchpriority="high"
    />
    <div class="absolute inset-0 -z-10 bg-ink/72"></div>
    <div class="page-shell grid min-h-[calc(100svh-64px)] gap-10 py-16 sm:py-20 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="max-w-3xl">
        <p class="inline-flex rounded-md bg-lime px-3 py-1 text-sm font-black uppercase text-ink">Nowość - 10xDevs 3.0</p>
        <h1 class="mt-6 font-display text-5xl font-black leading-[1.02] sm:text-6xl lg:text-7xl">
          Czas na AI-Native Software Engineering
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/78 sm:text-xl">
          Przeprogramowani łączą programowanie, biznes i rozwój osobisty. W 10xDevs pokazujemy, jak świadomie korzystać z AI w całym cyklu tworzenia oprogramowania.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="https://www.10xdevs.pl/"
            class="focus-ring inline-flex items-center justify-center gap-2 rounded-md bg-lime px-5 py-3 text-sm font-black text-ink hover:bg-white"
          >
            Zobacz 10xDevs
            <ArrowRight size={18} aria-hidden="true" />
          </a>
          <a
            href="#kursy"
            class="focus-ring inline-flex items-center justify-center gap-2 rounded-md border border-white/25 px-5 py-3 text-sm font-bold text-white hover:bg-white/10"
          >
            Sprawdź kursy
          </a>
        </div>
      </div>

      <div class="grid gap-3 rounded-md border border-white/14 bg-white/10 p-4 backdrop-blur-md">
        <div class="grid grid-cols-3 gap-3">
          <div class="rounded bg-white p-4 text-ink">
            <div class="font-display text-3xl font-black">7</div>
            <div class="mt-1 text-xs font-bold uppercase text-ink/60">lat edukacji</div>
          </div>
          <div class="rounded bg-white p-4 text-ink">
            <div class="font-display text-3xl font-black">3700+</div>
            <div class="mt-1 text-xs font-bold uppercase text-ink/60">absolwentów 10xDevs</div>
          </div>
          <div class="rounded bg-white p-4 text-ink">
            <div class="font-display text-3xl font-black">98</div>
            <div class="mt-1 text-xs font-bold uppercase text-ink/60">odcinków podcastu</div>
          </div>
        </div>
        <p class="rounded bg-ink/80 p-4 text-sm leading-6 text-white/78">
          Techniczne deep-dive'y, kursy produkcyjne, podcasty, YouTube i społeczność dla programistów, którzy chcą rozumieć kontekst decyzji, nie tylko narzędzia.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-14">
    <div class="page-shell grid gap-6 md:grid-cols-3">
      {[
        { icon: Sparkles, title: "AI bez autopilota", text: "Proces, kontrola i świadome użycie narzędzi zamiast krótkich demek bez odpowiedzialności." },
        { icon: ShieldCheck, title: "Jakość inżynierska", text: "Architektura, testy, utrzymanie i decyzje projektowe, które działają w prawdziwych codebase'ach." },
        { icon: Users, title: "Społeczność praktyków", text: "Materiały, konsultacje i rozmowy dla osób, które chcą rozwijać się technicznie i zawodowo." }
      ].map((item) => {
        const Icon = item.icon;
        return (
          <article class="rounded-md border border-line bg-paper p-6">
            <span class="grid h-11 w-11 place-items-center rounded-md bg-ink text-lime">
              <Icon size={22} aria-hidden="true" />
            </span>
            <h2 class="mt-5 text-xl font-extrabold">{item.title}</h2>
            <p class="mt-3 text-sm leading-6 text-ink/66">{item.text}</p>
          </article>
        );
      })}
    </div>
  </section>

  <section id="kursy" class="py-16 sm:py-20">
    <div class="page-shell">
      <SectionTitle
        eyebrow="Programy edukacyjne"
        title="Kursy dla programistów, którzy chcą pracować skuteczniej"
        text="Trzy ścieżki: AI-native software engineering, nowoczesny frontend oraz TypeScript w projektach produkcyjnych."
      />
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {courses.map((course) => (
          <article class="overflow-hidden rounded-md border border-line bg-white shadow-soft">
            <a href={course.href} class="focus-ring group block rounded-md">
              <div class="aspect-[16/10] overflow-hidden bg-ink/5">
                <img src={course.image} alt="" class="h-full w-full object-cover transition duration-300 group-hover:scale-105" loading="lazy" />
              </div>
              <div class="p-6">
                <p class="text-xs font-black uppercase text-fern">{course.eyebrow}</p>
                <h3 class="mt-2 font-display text-2xl font-extrabold">{course.name}</h3>
                <p class="mt-4 text-sm leading-6 text-ink/68">{course.summary}</p>
                <ul class="mt-5 grid gap-2">
                  {course.points.map((point) => (
                    <li class="flex gap-2 text-sm font-semibold text-ink/78">
                      <Check className="mt-0.5 h-4 w-4 shrink-0 text-fern" aria-hidden="true" />
                      {point}
                    </li>
                  ))}
                </ul>
                <span class="mt-6 inline-flex items-center gap-2 text-sm font-black text-ink">
                  Szczegóły
                  <ExternalLink size={16} aria-hidden="true" />
                </span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FeaturedMedia episodes={podcastEpisodes} videos={youtubeVideos} client:load />

  <section class="bg-white py-16 sm:py-20">
    <div class="page-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <SectionTitle
        eyebrow="Szersze spojrzenie"
        title="Miejsce, w którym programowanie spotyka się z rozwojem"
        text="Tworzymy treści, kursy i narzędzia, które pomagają programistom patrzeć szerzej: na architekturę, biznes, ludzi i własną karierę."
      />
      <div class="grid gap-4 sm:grid-cols-2">
        {["Techniczne deep-dive'y", "Podcasty o karierze i pracy", "Materiały o AI w praktyce", "Programy szkoleniowe", "Społeczność absolwentów", "Newsletter 3-2-1"].map((item) => (
          <div class="rounded-md border border-line bg-paper p-5 text-sm font-bold text-ink">{item}</div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
