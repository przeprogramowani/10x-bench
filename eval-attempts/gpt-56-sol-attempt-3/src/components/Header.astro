---
import MobileNav from './MobileNav';
const path = Astro.url.pathname;
const links = [
  { label: 'O nas', href: '/o-nas' },
  { label: 'Podcast', href: '/podcast' },
  { label: 'YouTube', href: '/youtube' },
  { label: 'Kursy', href: '/#kursy' },
];
---
<header class="fixed inset-x-0 top-0 z-50 border-b border-white/8 bg-[#070908]/82 backdrop-blur-xl">
  <div class="container-shell flex h-[72px] items-center justify-between">
    <a href="/" class="group flex items-center gap-3" aria-label="Przeprogramowani — strona główna">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-acid font-mono text-sm font-bold text-ink transition-transform group-hover:rotate-6">&lt;/&gt;</span>
      <span class="text-sm font-bold tracking-[-.03em] sm:text-base">Przeprogramowani</span>
    </a>
    <nav class="hidden items-center gap-1 md:flex">
      {links.map(link => <a href={link.href} class:list={['rounded-full px-4 py-2 text-sm transition-colors hover:bg-white/8 hover:text-white', path === link.href ? 'text-acid' : 'text-white/65']}>{link.label}</a>)}
    </nav>
    <a href="https://www.10xdevs.pl/" target="_blank" rel="noreferrer" class="arrow-link hidden items-center gap-3 rounded-full bg-acid px-5 py-2.5 text-sm font-bold text-ink transition-colors hover:bg-white md:flex">10xDevs <span class="arrow">↗</span></a>
    <MobileNav client:load />
  </div>
</header>
