---
import Layout from '../layouts/Layout.astro';
import { videos } from '../data/content';
---
<Layout title="YouTube — Przeprogramowani" description="Najnowsze filmy Przeprogramowanych o AI, frontendzie i nowoczesnym programowaniu.">
  <section class="relative overflow-hidden border-b border-white/10 pb-16 pt-36 md:pb-24 md:pt-48"><div class="grid-lines absolute inset-0"></div><div class="absolute right-1/4 top-10 h-96 w-96 rounded-full bg-red-500/10 blur-[120px]"></div><div class="container-shell relative"><div class="flex flex-col justify-between gap-10 lg:flex-row lg:items-end"><div><span class="eyebrow">YouTube</span><h1 class="display mt-7 text-[clamp(4rem,11vw,9.5rem)]">Patrz szerzej.<br/><span class="stroke-text">Buduj lepiej.</span></h1></div><div class="max-w-sm"><p class="text-lg leading-8 text-white/55">Techniczne deep-dive’y, relacje z eventów i praktyczne spojrzenie na AI w pracy developera.</p><a href="https://www.youtube.com/c/przeprogramowani" target="_blank" rel="noreferrer" class="mt-7 inline-flex rounded-full bg-[#ff0033] px-6 py-3.5 font-semibold text-white transition hover:bg-white hover:text-black">Subskrybuj kanał ↗</a></div></div></div></section>

  <section class="section-pad"><div class="container-shell"><div class="mb-12 flex items-end justify-between gap-6"><div><span class="eyebrow">Najnowsze materiały</span><h2 class="display mt-5 text-6xl md:text-8xl">Na ekranie.</h2></div><span class="hidden font-mono text-xs uppercase tracking-widest text-white/30 md:block">6 najnowszych filmów</span></div>
    <div class="grid gap-x-5 gap-y-12 md:grid-cols-2 lg:grid-cols-3">{videos.map((video, i) => <a href={`https://youtube.com/watch?v=${video.id}`} target="_blank" rel="noreferrer" class:list={['group', i === 0 ? 'md:col-span-2 lg:col-span-2' : '']}><div class:list={['relative overflow-hidden rounded-2xl border border-white/10 bg-surface', i === 0 ? 'aspect-video' : 'aspect-video']}><img src={video.image} alt={`Miniatura filmu: ${video.title}`} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading={i > 1 ? 'lazy' : 'eager'} /><div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent"></div><div class:list={['absolute grid place-items-center rounded-full bg-acid text-ink shadow-2xl transition-transform group-hover:scale-110', i === 0 ? 'bottom-5 left-5 h-14 w-14 text-base md:bottom-7 md:left-7 md:h-16 md:w-16' : 'bottom-4 left-4 h-11 w-11 text-xs']}>▶</div></div><div class="mt-5 flex gap-4"><span class="font-mono text-xs text-acid">0{i+1}</span><div><p class="mb-2 font-mono text-[10px] uppercase tracking-widest text-white/35">{video.meta}</p><h3 class:list={['font-medium leading-snug tracking-[-.03em]', i === 0 ? 'text-2xl md:text-4xl' : 'text-xl']}>{video.title}</h3></div></div></a>)}</div>
  </div></section>

  <section class="border-y border-white/10 bg-[#0c0f0d] py-16 md:py-20"><div class="container-shell grid gap-8 md:grid-cols-3">{[['01', 'Bez uproszczeń', 'Pokazujemy kontekst, decyzje i trade-offy — nie tylko końcowy snippet.'], ['02', 'Bez hype’u', 'Sprawdzamy narzędzia w praktyce i mówimy wprost, gdzie nie dowożą.'], ['03', 'Z perspektywą', 'Łączymy technologię z produktem, biznesem i rozwojem zawodowym.']].map(([n,t,d]) => <div class="border-l border-white/15 pl-6"><span class="font-mono text-xs text-acid">{n}</span><h3 class="mt-7 text-2xl font-semibold tracking-tight">{t}</h3><p class="mt-3 text-sm leading-6 text-white/45">{d}</p></div>)}</div></section>

  <section class="section-pad text-center"><div class="container-shell"><span class="eyebrow">Dołącz do społeczności</span><h2 class="display mx-auto mt-6 max-w-5xl text-6xl md:text-8xl">Następny materiał<br/>może zmienić <span class="text-acid">Twój workflow.</span></h2><a href="https://www.youtube.com/c/przeprogramowani" class="mt-9 inline-flex rounded-full bg-white px-7 py-4 font-semibold text-ink transition hover:bg-acid">Przejdź na YouTube ↗</a></div></section>
</Layout>
