---
import { site } from "../data/content";

const navItems = [
  { href: "/", label: "Strona główna" },
  { href: "/o-nas", label: "O nas" },
  { href: "/podcast", label: "Podcast" },
  { href: "/youtube", label: "YouTube" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header
  class="sticky top-0 z-40 border-b border-white/10 bg-slate-950/80 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-lg font-bold tracking-tight">
      <span class="text-brand-400">&lt;/&gt;</span>
      <span>{site.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Główna nawigacja">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "rounded-md px-3 py-2 text-sm font-medium transition-colors",
              isActive(item.href)
                ? "bg-white/10 text-white"
                : "text-slate-300 hover:bg-white/5 hover:text-white",
            ]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="https://10xdevs.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden rounded-lg bg-gradient-to-r from-violet-600 to-fuchsia-600 px-4 py-2 text-sm font-semibold text-white shadow-lg shadow-fuchsia-900/30 transition hover:from-violet-500 hover:to-fuchsia-500 sm:inline-block"
      >
        10xDevs →
      </a>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex items-center justify-center rounded-md p-2 text-slate-300 hover:bg-white/5 hover:text-white md:hidden"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/10 md:hidden">
    <nav class="space-y-1 px-4 py-3" aria-label="Nawigacja mobilna">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "block rounded-md px-3 py-2 text-base font-medium transition-colors",
              isActive(item.href)
                ? "bg-white/10 text-white"
                : "text-slate-300 hover:bg-white/5 hover:text-white",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="https://10xdevs.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-md bg-gradient-to-r from-violet-600 to-fuchsia-600 px-3 py-2 text-base font-semibold text-white"
      >
        10xDevs →
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>
