---
import Layout from "../layouts/Layout.astro";
import VideoGrid from "../components/VideoGrid.tsx";
import { youtubeVideos, site } from "../data/content";
---

<Layout
  title="YouTube"
  description="Najnowsze filmy Przeprogramowani — AI, programowanie, rozwój nowoczesnego programisty."
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="absolute inset-0 -z-10 bg-gradient-to-br from-red-900/30 via-slate-950 to-slate-950" aria-hidden="true"></div>
    <div class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6 lg:px-8 lg:py-28">
      <span class="inline-flex items-center gap-2 rounded-full border border-red-500/30 bg-red-500/10 px-4 py-1.5 text-sm font-medium text-red-300">
        ▶ YouTube
      </span>
      <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Najnowsze filmy
      </h1>
      <p class="mt-6 text-lg text-slate-300">
        Rozwój nowoczesnego programisty — AI, agenty, Context Engineering i praktyczne workflow.
      </p>
      <a
        href={site.social.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-flex items-center gap-2 rounded-xl bg-red-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-red-900/40 transition hover:bg-red-500"
      >
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
        </svg>
        Subskrybuj kanał
      </a>
    </div>
  </section>

  <!-- Videos -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <VideoGrid videos={youtubeVideos} client:visible />
  </section>
</Layout>
