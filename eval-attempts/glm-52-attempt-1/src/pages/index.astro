---
import Layout from "../layouts/Layout.astro";
import CourseCards from "../components/CourseCards.tsx";
import VideoGrid from "../components/VideoGrid.tsx";
import EpisodeList from "../components/EpisodeList.tsx";
import BrandStrip from "../components/BrandStrip.tsx";
import { courses, youtubeVideos, podcastEpisodes, brands, site } from "../data/content";

const heroCourse = courses.find((c) => c.slug === "10xdevs")!;
const otherCourses = courses.filter((c) => c.slug !== "10xdevs");
---

<Layout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950" aria-hidden="true"></div>
    <div class="absolute inset-0 -z-10 opacity-30" aria-hidden="true">
      <div class="absolute left-1/4 top-0 h-96 w-96 -translate-x-1/2 rounded-full bg-violet-600/30 blur-3xl"></div>
      <div class="absolute right-1/4 top-32 h-96 w-96 translate-x-1/2 rounded-full bg-fuchsia-600/20 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-32">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full border border-violet-500/30 bg-violet-500/10 px-4 py-1.5 text-sm font-medium text-violet-300">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-violet-400 opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-violet-500"></span>
            </span>
            Nowość — Maj 2026
          </span>

          <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
            Programuj z AI<br />
            <span class="bg-gradient-to-r from-violet-400 via-fuchsia-400 to-pink-400 bg-clip-text text-transparent">
              10xDevs 3.0
            </span>
          </h1>

          <p class="mt-6 max-w-xl text-lg text-slate-300">
            Nowe oblicze programowania z wykorzystaniem Generatywnego AI. Techniki i narzędzia
            pozwalające świadomie stosować AI w całym cyklu wytwarzania oprogramowania.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href={heroCourse.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-violet-600 to-fuchsia-600 px-6 py-3 text-base font-semibold text-white shadow-lg shadow-fuchsia-900/40 transition hover:from-violet-500 hover:to-fuchsia-500"
            >
              Zobacz 10xDevs
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
            <a
              href="/o-nas"
              class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-6 py-3 text-base font-semibold text-white transition hover:bg-white/5"
            >
              Poznaj nas
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-violet-600/20 to-fuchsia-600/20 blur-2xl" aria-hidden="true"></div>
          <div class="relative rounded-3xl border border-white/10 bg-slate-900/60 p-8 backdrop-blur">
            <div class="flex items-center gap-3">
              <span class="text-4xl">🚀</span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-violet-300">10xDevs</p>
                <p class="text-2xl font-bold text-white">3.0</p>
              </div>
            </div>
            <div class="mt-6 space-y-4">
              {[
                "Świadome stosowanie AI w całym cyklu wytwarzania",
                "Agent Skills, Context Engineering, MCP",
                "Praktyczne workflow z Claude Code i Cursor",
                "Budowanie i utrzymanie AI-Native Infrastructure",
              ].map((feature) => (
                <div class="flex items-start gap-3">
                  <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-violet-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-sm text-slate-300">{feature}</span>
                </div>
              ))}
            </div>
            <a
              href={heroCourse.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 block rounded-lg bg-white/5 py-2 text-center text-sm font-semibold text-white transition hover:bg-white/10"
            >
              Dołącz do programu →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Courses -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Edukacja technologiczna w epoce AI
      </h2>
      <p class="mt-4 text-slate-400">
        Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału
        Generative AI.
      </p>
    </div>
    <div class="mt-12">
      <CourseCards courses={courses} client:load />
    </div>
  </section>

  <!-- Latest content -->
  <section class="border-y border-white/10 bg-slate-900/40">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- YouTube -->
        <div>
          <div class="mb-8 flex items-end justify-between">
            <div>
              <h2 class="text-2xl font-bold text-white">Ostatnie filmy</h2>
              <p class="mt-1 text-sm text-slate-400">YouTube — rozwój nowoczesnego programisty</p>
            </div>
            <a href="/youtube" class="text-sm font-semibold text-brand-400 hover:text-brand-300">
              Wszystkie →
            </a>
          </div>
          <VideoGrid videos={youtubeVideos} limit={3} client:visible />
        </div>

        <!-- Podcast -->
        <div>
          <div class="mb-8 flex items-end justify-between">
            <div>
              <h2 class="text-2xl font-bold text-white">Ostatnie odcinki</h2>
              <p class="mt-1 text-sm text-slate-400">Podcast — AI, technologia, programowanie</p>
            </div>
            <a href="/podcast" class="text-sm font-semibold text-brand-400 hover:text-brand-300">
              Wszystkie →
            </a>
          </div>
          <EpisodeList episodes={podcastEpisodes} limit={4} client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-brand-700/30 via-slate-900 to-slate-900 p-8 sm:p-12">
      <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-brand-500/20 blur-3xl" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="text-3xl font-bold text-white">Przeprogramowany Newsletter</h2>
        <p class="mt-3 max-w-2xl text-slate-300">
          Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1: trzy
          rekomendacje techniczne, dwie rozwojowe i jeden bonus niespodzianka. Nie przegapisz też
          nowości i ofert specjalnych.
        </p>
        <a
          href="https://przeprogramowani.substack.com"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center gap-2 rounded-xl bg-white px-6 py-3 text-base font-semibold text-slate-900 transition hover:bg-slate-100"
        >
          Zapisz się za darmo →
        </a>
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-white">7 lat na rynku edukacji technologicznej</h2>
      <p class="mt-2 text-sm text-slate-400">Współpracujemy z najlepszymi</p>
    </div>
    <div class="mt-10">
      <BrandStrip brands={brands} client:visible />
    </div>
    <p class="mt-10 text-center text-sm text-slate-400">
      Chcesz nawiązać współpracę?{" "}
      <a href={`mailto:${site.email}`} class="font-semibold text-brand-400 hover:text-brand-300">
        {site.email}
      </a>
    </p>
  </section>
</Layout>
