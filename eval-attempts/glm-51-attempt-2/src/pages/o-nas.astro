---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../data/config';
---

<Layout title="O nas" description="Przeprogramowani - łączymy świat programowania, biznesu i rozwoju">
  <Header />

  <main class="pt-16">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-950/50 via-gray-950 to-gray-950"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-600/10 via-transparent to-transparent"></div>

      <div class="relative mx-auto max-w-7xl px-4 pb-16 pt-20 sm:px-6 sm:pb-24 sm:pt-28 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            O nas
          </h1>
          <p class="mt-6 text-xl text-gray-400">
            Łączymy świat programowania, biznesu i rozwoju
          </p>
        </div>
      </div>
    </section>

    <!-- Founders -->
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-2">
        {siteConfig.founders.map((founder) => (
          <div class="group rounded-2xl border border-white/5 bg-white/[0.02] p-8 transition-all hover:border-white/10 hover:bg-white/[0.04]">
            <div class="flex items-start gap-6">
              <img
                src={founder.image}
                alt={founder.name}
                loading="lazy"
                class="h-24 w-24 shrink-0 rounded-xl object-cover grayscale transition-all group-hover:grayscale-0"
              />
              <div class="min-w-0">
                <h3 class="text-xl font-bold text-white">{founder.name}</h3>
                <p class="mt-1 text-sm font-medium text-brand-400">{founder.role}</p>
                <p class="mt-4 text-sm leading-relaxed text-gray-400">{founder.bio}</p>
                <a
                  href={founder.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 transition-colors hover:text-brand-400"
                >
                  <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- About description -->
    <section class="border-y border-white/5 bg-white/[0.01]">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
        <div class="mx-auto max-w-3xl">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">
            Witaj na Przeprogramowanych!
          </h2>
          <div class="mt-6 space-y-4 text-lg leading-relaxed text-gray-400">
            <p>
              Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
            </p>
            <p>
              Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
            </p>
            <p class="text-2xl font-bold text-brand-400">
              Zyskaj szersze spojrzenie na programowanie.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Partners -->
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-2xl font-bold text-white">7 lat na rynku edukacji technologicznej</h2>
        <p class="mt-2 text-sm text-gray-500">Współpracujemy z najlepszymi</p>
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-8">
        {siteConfig.partners.map((partner) => (
          <span class="rounded-lg border border-white/5 bg-white/[0.02] px-5 py-3 text-sm font-medium text-gray-500">
            {partner}
          </span>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-500">Chcesz nawiązać współpracę?</p>
        <a
          href={`mailto:${siteConfig.socials.email}`}
          class="mt-2 inline-flex items-center gap-2 text-brand-400 transition-colors hover:text-brand-300"
        >
          {siteConfig.socials.email}
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
