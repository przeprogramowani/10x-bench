---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PodcastEpisode from '../components/PodcastEpisode';
import { siteConfig } from '../data/config';

const podcasts = siteConfig.podcastEpisodes;
---

<Layout title="Podcast" description="Podcasty Przeprogramowanych o technologii, AI i programowaniu">
  <Header />

  <main class="pt-16">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-brand-950/50 via-gray-950 to-gray-950"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-600/10 via-transparent to-transparent"></div>

      <div class="relative mx-auto max-w-7xl px-4 pb-16 pt-20 sm:px-6 sm:pb-24 sm:pt-28 lg:px-8">
        <div class="mx-auto max-w-3xl text-center">
          <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            Podcasty
          </h1>
          <p class="mt-6 text-xl text-gray-400">
            Słuchaj naszych podcastów o technologii, AI i programowaniu
          </p>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Opanuj.AI Podcast -->
        <div>
          <div class="mb-6 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-brand-600/20">
              <svg class="h-5 w-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.866-.354-1.695-.985-2.314l-.548-.547z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl font-bold text-white">{podcasts.opanujAI.title}</h2>
              <p class="text-sm text-gray-500">{podcasts.opanujAI.listeners}</p>
            </div>
          </div>
          <p class="mb-6 text-sm text-gray-400">{podcasts.opanujAI.description}</p>
          <div class="space-y-3">
            {podcasts.opanujAI.episodes.map((ep, i) => (
              <PodcastEpisode client:load title={ep.title} duration={ep.duration} url={ep.url} index={i + 1} />
            ))}
          </div>
        </div>

        <!-- Przeprogramowani ft. Gość -->
        <div>
          <div class="mb-6 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-600/20">
              <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl font-bold text-white">{podcasts.przeprogramowaniFtGosc.title}</h2>
              <p class="text-sm text-gray-500">{podcasts.przeprogramowaniFtGosc.listeners}</p>
            </div>
          </div>
          <p class="mb-6 text-sm text-gray-400">{podcasts.przeprogramowaniFtGosc.description}</p>
          <div class="space-y-3">
            {podcasts.przeprogramowaniFtGosc.episodes.map((ep, i) => (
              <PodcastEpisode client:load title={ep.title} duration={ep.duration} url={ep.url} index={i + 1} />
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Platforms -->
    <section class="border-y border-white/5 bg-white/[0.01]">
      <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
        <h2 class="text-center text-2xl font-bold text-white">Jesteśmy na twojej ulubionej platformie</h2>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
          <a
            href={siteConfig.socials.applePodcasts}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-medium text-gray-300 transition-all hover:bg-white/10 hover:text-white"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.4c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.51-2.35 1.05-3.11z"/>
            </svg>
            Apple Podcasts
          </a>
          <a
            href={siteConfig.socials.spotify}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-medium text-gray-300 transition-all hover:bg-white/10 hover:text-white"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.36z"/>
            </svg>
            Spotify
          </a>
          <a
            href={siteConfig.socials.rss}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-medium text-gray-300 transition-all hover:bg-white/10 hover:text-white"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20c-1.19 0-2.18-.99-2.18-2.18 0-1.2.99-2.18 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            RSS
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
