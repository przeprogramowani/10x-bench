---
import BaseLayout from '../layouts/BaseLayout.astro';
import { youtubeVideos } from '../data/content';
---

<BaseLayout title="YouTube" description="Oglądaj najnowsze filmy Przeprogramowani na YouTube o programowaniu, AI i rozwoju.">
  <section class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">YouTube</h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Subskrybuj nasz kanał, aby być na bieżąco z najnowszymi treściami o programowaniu i AI
      </p>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          youtubeVideos.map(video => (
            <a
              href={`https://www.youtube.com/watch?v=${video.id}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-xl overflow-hidden bg-white/5 border border-white/5 hover:border-white/10 transition-all duration-300 hover:-translate-y-1"
            >
              <div class="aspect-video bg-brand-dark relative overflow-hidden">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors flex items-center justify-center">
                  <div class="w-14 h-14 rounded-full bg-red-600/90 flex items-center justify-center group-hover:scale-110 transition-transform">
                    <svg class="w-6 h-6 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-5">
                <h3 class="text-white font-medium line-clamp-2 group-hover:text-brand-accent-light transition-colors">
                  {video.title}
                </h3>
              </div>
            </a>
          ))
        }
      </div>

      <div class="text-center mt-16 py-16 bg-gradient-to-br from-red-600/10 to-brand-dark/50 rounded-2xl">
        <h3 class="text-2xl font-bold text-white mb-4">Zasubskrybuj nasz kanał!</h3>
        <p class="text-gray-400 mb-8 max-w-md mx-auto">
          Dołącz do społeczności i bądź na bieżąco z najnowszymi treściami o programowaniu.
        </p>
        <a
          href="https://youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-red-600 hover:bg-red-500 text-white font-semibold rounded-xl transition-all transform hover:scale-105"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Subskrybuj na YouTube
        </a>
      </div>
    </div>
  </section>
</BaseLayout>