---
import BaseLayout from '../layouts/BaseLayout.astro';
import { teamMembers } from '../data/content';
---

<BaseLayout title="O nas" description="Poznaj zespół Przeprogramowani.pl - Przemek Smyrdek i Marcin Czarkowski. Łączymy świat programowania, biznesu i rozwoju.">
  <section class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">O nas</h1>
        <p class="text-xl text-gray-400 max-w-2xl mx-auto">
          Łączymy świat programowania, biznesu i rozwoju
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-brand-dark/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h2 class="text-3xl font-bold text-white mb-6">Witaj na Przeprogramowanych!</h2>
        <p class="text-gray-300 text-lg leading-relaxed">
          Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
        </p>
        <p class="text-gray-400 mt-4 leading-relaxed">
          Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
        </p>
        <p class="text-brand-accent-light font-semibold mt-6 text-lg">
          Zyskaj szersze spojrzenie na programowanie.
        </p>
      </div>

      <h2 class="text-3xl font-bold text-white text-center mb-12">Nasz zespół</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        {
          teamMembers.map((member) => (
            <div class="bg-white/5 rounded-2xl p-8 border border-white/5">
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-brand-accent to-brand-purple flex items-center justify-center text-white text-2xl font-bold mb-6 mx-auto">
                {member.name.split(' ').map(n => n[0]).join('')}
              </div>
              <h3 class="text-xl font-bold text-white text-center mb-1">{member.name}</h3>
              <p class="text-brand-accent-light text-sm text-center mb-4">{member.role}</p>
              <p class="text-gray-400 text-sm leading-relaxed mb-6">
                {member.description}
              </p>
              <div class="text-center">
                <a
                  href={member.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-brand-accent-light hover:text-white text-sm font-medium transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white mb-2">7 lat na rynku edukacji technologicznej</h2>
      <p class="text-gray-400 mb-10">Współpracujemy z najlepszymi</p>
      <div class="flex flex-wrap items-center justify-center gap-8 gap-y-6">
        {
          ['Huuuge Games', 'Nutridome', 'SmartRecruiters', 'Future Processing', 'Callstack', 'edrone', 'Xfive', 'Euvic', 'Strabag', 'Autodesk'].map(partner => (
            <span class="text-gray-500 text-sm font-semibold tracking-wider uppercase">{partner}</span>
          ))
        }
      </div>
      <a href="mailto:kontakt@przeprogramowani.pl" class="inline-block mt-10 text-gray-400 hover:text-white transition-colors text-sm">
        Chcesz nawiązać współpracę? <span class="text-brand-accent-light underline">kontakt@przeprogramowani.pl</span>
      </a>
    </div>
  </section>
</BaseLayout>