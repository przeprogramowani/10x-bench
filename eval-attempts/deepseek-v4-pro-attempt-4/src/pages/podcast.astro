---
import BaseLayout from '../layouts/BaseLayout.astro';
import { podcastEpisodes } from '../data/content';
---

<BaseLayout title="Podcasty" description="Słuchaj podcastów Przeprogramowani o technologii, AI i programowaniu. Opanuj.AI Podcast i Przeprogramowani ft. Gość.">
  <section class="pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6">Podcasty</h1>
      <p class="text-xl text-gray-400 max-w-2xl mx-auto">
        Słuchaj naszych podcastów o technologii, AI i programowaniu
      </p>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-accent to-brand-purple flex items-center justify-center text-white text-lg font-bold">AI</div>
          <div>
            <h2 class="text-2xl font-bold text-white">Opanuj.AI Podcast</h2>
            <p class="text-gray-400 text-sm">Ponad 4000 słuchaczy &middot; Comiesięczne podsumowanie najważniejszych wydarzeń ze świata AI</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            podcastEpisodes.filter(e => e.podcast === 'Opanuj.AI Podcast').map(episode => (
              <a
                href={episode.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white/5 hover:bg-white/10 rounded-xl p-6 border border-white/5 hover:border-white/10 transition-all duration-300"
              >
                <span class="text-gray-500 text-xs mb-2 block">{episode.date}</span>
                <h3 class="text-white font-semibold mb-2 line-clamp-2 group-hover:text-brand-accent-light transition-colors">
                  {episode.title}
                </h3>
                <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-4">
                  {episode.description}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-gray-500 text-sm flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {episode.duration}
                  </span>
                  <span class="text-brand-accent-light text-sm font-medium group-hover:underline">Słuchaj</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-brand-green to-brand-accent flex items-center justify-center text-white text-lg font-bold">G</div>
          <div>
            <h2 class="text-2xl font-bold text-white">Przeprogramowani ft. Gość</h2>
            <p class="text-gray-400 text-sm">Ponad 3800 słuchaczy &middot; Rozmowy dla głodnych wiedzy</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            podcastEpisodes.filter(e => e.podcast === 'Przeprogramowani ft. Gość').map(episode => (
              <a
                href={episode.link}
                target="_blank"
                rel="noopener noreferrer"
                class="group bg-white/5 hover:bg-white/10 rounded-xl p-6 border border-white/5 hover:border-white/10 transition-all duration-300"
              >
                <span class="text-gray-500 text-xs mb-2 block">{episode.date}</span>
                <h3 class="text-white font-semibold mb-2 line-clamp-2 group-hover:text-brand-accent-light transition-colors">
                  {episode.title}
                </h3>
                <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-4">
                  {episode.description}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-gray-500 text-sm flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {episode.duration}
                  </span>
                  <span class="text-brand-accent-light text-sm font-medium group-hover:underline">Słuchaj</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="text-center py-16 bg-gradient-to-br from-brand-accent/10 to-brand-purple/10 rounded-2xl">
        <h3 class="text-2xl font-bold text-white mb-4">Jesteśmy na twojej ulubionej platformie</h3>
        <div class="flex flex-wrap items-center justify-center gap-6 mt-8">
          <a href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1508387250" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors text-sm font-medium px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5">
            Apple Podcasts
          </a>
          <a href="https://open.spotify.com/show/4qHUZJpeBK8Ij9e2wTVm2o" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors text-sm font-medium px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5">
            Spotify
          </a>
          <a href="https://podcasts.google.com/feed/aHR0cHM6Ly9hbmNob3IuZm0vcy8yMjU0NGI3Yy9wb2RjYXN0L3Jzcw" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors text-sm font-medium px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5">
            Google Podcasts
          </a>
          <a href="https://anchor.fm/s/22544b7c/podcast/rss" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors text-sm font-medium px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/5">
            RSS
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>