---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="relative flex min-h-screen items-center overflow-hidden pt-20">
    <div class="absolute inset-0 bg-gradient-to-br from-gray-950 via-gray-900 to-blue-950"></div>
    <div class="absolute top-1/4 right-0 h-96 w-96 rounded-full bg-blue-500/10 blur-3xl"></div>
    <div class="absolute bottom-1/4 left-0 h-72 w-72 rounded-full bg-cyan-500/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="max-w-xl">
          <span class="inline-block rounded-full bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-400">
            Nowość - Maj 2026
          </span>
          <h1 class="mt-6 text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
            10xDevs
          </h1>
          <p class="mt-4 text-xl font-semibold text-blue-400 sm:text-2xl">
            Nowe oblicze programowania z wykorzystaniem Generatywnego AI
          </p>
          <p class="mt-4 text-lg leading-relaxed text-gray-300">
            Techniki i narzędzia pozwalające świadomie stosować AI w całym cyklu wytwarzania oprogramowania. 
            Od researchu i planowania, przez implementację, aż po utrzymanie produkcji.
          </p>
          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="https://10xdevs.pl"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-cyan-500 to-blue-500 px-6 py-3 text-base font-semibold text-white transition-all hover:from-cyan-400 hover:to-blue-400 hover:shadow-lg hover:shadow-blue-500/25"
            >
              Dołącz do 10xDevs
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="/kursy"
              class="inline-flex items-center gap-2 rounded-full border border-gray-600 px-6 py-3 text-base font-medium text-gray-300 transition-all hover:border-gray-400 hover:text-white"
            >
              Zobacz wszystkie kursy
            </a>
          </div>
          <div class="mt-10 flex items-center gap-6 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-cyan-500/10 text-cyan-400 font-bold">5+1</span>
              Tygodni
            </div>
            <div class="h-8 w-px bg-gray-700"></div>
            <div class="flex items-center gap-2">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-500/10 text-blue-400 font-bold">6.7k</span>
              Absolwentów
            </div>
          </div>
        </div>

        <div class="relative hidden lg:block">
          <div class="relative rounded-2xl border border-gray-800 bg-gray-900/50 p-1 backdrop-blur">
            <div class="rounded-xl bg-gradient-to-br from-cyan-900/50 to-blue-900/50 p-8">
              <div class="mb-4 flex items-center gap-2">
                <div class="h-3 w-3 rounded-full bg-red-500"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
                <div class="h-3 w-3 rounded-full bg-green-500"></div>
              </div>
              <div class="space-y-3 font-mono text-sm">
                <p class="text-green-400">$ ai agent init</p>
                <p class="text-gray-400">Preparing Agentic Environment...</p>
                <p class="text-blue-400">→ Configuring MCP servers</p>
                <p class="text-blue-400">→ Setting up Claude Code</p>
                <p class="text-blue-400">→ Installing Agent Skills</p>
                <p class="text-gray-400 mt-2">Agent ready. Starting workflow:</p>
                <p class="text-cyan-400">• Research & Analysis</p>
                <p class="text-cyan-400">• Architecture Planning</p>
                <p class="text-cyan-400">• Implementation</p>
                <p class="text-cyan-400">• Testing & QA</p>
                <p class="text-cyan-400">• Deployment</p>
                <p class="mt-2 animate-pulse text-green-400">▊ AI-Native workflow active</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Courses Section -->
  <section class="bg-gray-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Edukacja technologiczna w epoce AI</h2>
        <p class="mt-4 text-lg text-gray-400">Topowe programy edukacyjne dla ambitnych programistów</p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <a
          href="https://opanuj.ai"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-2xl border border-gray-800 bg-gray-950 p-6 transition-all hover:border-blue-500/50 hover:shadow-lg hover:shadow-blue-500/10"
        >
          <div class="mb-4 flex items-center gap-3">
            <span class="rounded-lg bg-purple-500/10 px-3 py-1 text-xs font-medium text-purple-400">AI</span>
          </div>
          <h3 class="mb-3 text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Opanuj AI</h3>
          <p class="text-sm leading-relaxed text-gray-400">
            Warsztaty, podcast, blog i darmowe ebooki o sztucznej inteligencji. Zdobądź praktyczną wiedzę o AI i wdróż ją w codziennej pracy.
          </p>
        </a>

        <a
          href="https://opanujfrontend.pl"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-2xl border border-gray-800 bg-gray-950 p-6 transition-all hover:border-blue-500/50 hover:shadow-lg hover:shadow-blue-500/10"
        >
          <div class="mb-4 flex items-center gap-3">
            <span class="rounded-lg bg-blue-500/10 px-3 py-1 text-xs font-medium text-blue-400">Kurs</span>
          </div>
          <h3 class="mb-3 text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Opanuj Frontend: AI Edition</h3>
          <p class="text-sm leading-relaxed text-gray-400">
            Zostań nowoczesnym frontend developerem — 5 modułów o frontendzie, testowaniu, CI/CD i architekturze. Cztery edycje i prawie 400 absolwentów!
          </p>
        </a>

        <a
          href="https://opanujtypescript.pl"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-2xl border border-gray-800 bg-gray-950 p-6 transition-all hover:border-blue-500/50 hover:shadow-lg hover:shadow-blue-500/10"
        >
          <div class="mb-4 flex items-center gap-3">
            <span class="rounded-lg bg-sky-500/10 px-3 py-1 text-xs font-medium text-sky-400">Kurs</span>
          </div>
          <h3 class="mb-3 text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Opanuj TypeScript</h3>
          <p class="text-sm leading-relaxed text-gray-400">
            Szkolenie podnoszące jakość projektów na produkcji. Pracujemy z najnowszymi wersjami TypeScript 5 i React 19!
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="bg-gray-950 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 text-center sm:grid-cols-3">
        <div>
          <div class="text-4xl font-extrabold text-blue-400">7 lat</div>
          <div class="mt-2 text-gray-400">na rynku edukacji technologicznej</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-blue-400">15k+</div>
          <div class="mt-2 text-gray-400">programistów w społeczności</div>
        </div>
        <div>
          <div class="text-4xl font-extrabold text-blue-400">900+</div>
          <div class="mt-2 text-gray-400">uczestników szkoleń</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="bg-gray-900 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-2xl border border-gray-800 bg-gray-950 p-8 md:p-12">
        <div class="absolute top-0 right-0 h-64 w-64 rounded-full bg-blue-500/5 blur-3xl"></div>
        <div class="relative">
          <h2 class="text-3xl font-bold text-white sm:text-4xl">Przeprogramowany Newsletter</h2>
          <p class="mt-4 max-w-xl text-gray-400">
            Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1: 3 rekomendacje techniczne, 
            2 rekomendacje rozwojowe i 1 bonus niespodzianka.
          </p>
          <a
            href="https://przeprogramowani.substack.com"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 rounded-full bg-blue-500 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-blue-400"
          >
            Zapisz się za darmo
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>