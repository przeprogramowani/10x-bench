---
import BaseLayout from "../layouts/BaseLayout.astro";
import { courses } from "../data/content";
---

<BaseLayout>
  <section class="pt-24 pb-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Nasze kursy</h1>
        <p class="mt-4 text-xl text-gray-400">Topowe programy edukacyjne dla ambitnych programistów</p>
      </div>

      <div class="space-y-12">
        {courses.map((course) => (
          <div class="group relative overflow-hidden rounded-2xl border border-gray-800 bg-gray-900">
            <div class="grid gap-0 lg:grid-cols-3">
              <div class={`flex items-center justify-center bg-gradient-to-br ${course.color} p-8 lg:p-12`}>
                <div class="text-center">
                  <h2 class="text-2xl font-extrabold text-white sm:text-3xl">{course.title}</h2>
                  <p class="mt-3 text-white/80">{course.tagline}</p>
                  {course.stats && (
                    <p class="mt-4 inline-block rounded-full bg-white/20 px-4 py-1.5 text-sm font-medium text-white backdrop-blur">
                      {course.stats}
                    </p>
                  )}
                </div>
              </div>

              <div class="col-span-2 p-8 lg:p-12">
                <p class="text-lg leading-relaxed text-gray-300">
                  {course.description}
                </p>

                <ul class="mt-6 grid gap-2 sm:grid-cols-2">
                  {course.features.map((feature) => (
                    <li class="flex items-start gap-2 text-sm text-gray-400">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="mt-0.5 shrink-0 text-blue-400">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>

                <div class="mt-6 flex flex-wrap gap-2">
                  {course.techStack.map((tech) => (
                    <span class="rounded-md bg-gray-800 px-2.5 py-1 text-xs font-medium text-gray-300">
                      {tech}
                    </span>
                  ))}
                </div>

                <a
                  href={course.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`mt-8 inline-flex items-center gap-2 rounded-full bg-gradient-to-r ${course.color} px-6 py-3 text-sm font-semibold text-white transition-all hover:shadow-lg`}
                >
                  Szczegóły
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>