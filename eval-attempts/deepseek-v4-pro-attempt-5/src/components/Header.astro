---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/o-nas", label: "O Nas" },
  { href: "/podcast", label: "Podcast" },
  { href: "/youtube", label: "YouTube" },
  { href: "/kursy", label: "Kursy" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-800 bg-gray-950/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-white hover:text-blue-400 transition-colors">
      <span class="text-blue-400">&lt;/&gt;</span>
      <span>Przeprogramowani</span>
    </a>

    <div class="hidden items-center gap-6 md:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors hover:text-blue-400 ${
            currentPath === link.href ? "text-blue-400" : "text-gray-300"
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://10xdevs.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-gradient-to-r from-cyan-500 to-blue-500 px-4 py-1.5 text-sm font-semibold text-white transition-all hover:from-cyan-400 hover:to-blue-400 hover:shadow-lg hover:shadow-blue-500/25"
      >
        10xDevs
      </a>
    </div>

    <button id="mobile-menu-btn" class="text-gray-300 hover:text-white md:hidden" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-gray-800 bg-gray-900/95 backdrop-blur-md md:hidden">
    <div class="flex flex-col gap-1 px-4 py-3">
      {links.map((link) => (
        <a
          href={link.href}
          class={`rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-gray-800 ${
            currentPath === link.href ? "text-blue-400" : "text-gray-300"
          }`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://10xdevs.pl"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 rounded-full bg-gradient-to-r from-cyan-500 to-blue-500 px-4 py-2 text-center text-sm font-semibold text-white"
      >
        10xDevs
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>