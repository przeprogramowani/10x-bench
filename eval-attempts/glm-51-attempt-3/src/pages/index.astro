---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Hero from '../components/Hero';
import Footer from '../components/Footer';
import PodcastCard from '../components/PodcastCard';
import YouTubeCard from '../components/YouTubeCard';
import SectionHeading from '../components/SectionHeading';
import { podcastEpisodes, podcastShows } from '../data/podcasts';
import { youtubeVideos } from '../data/videos';
---

<Layout title="Strona główna">
  <Navbar client:load />

  <main>
    <Hero />

    <section class="py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="Podcasty"
          subtitle="Słuchaj naszych podcastów o technologii, AI i programowaniu"
        />

        <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
          {podcastShows.map((show) => (
            <div class="flex items-center gap-3 rounded-xl border border-white/5 bg-white/[0.02] px-5 py-3">
              <img src={show.image} alt={show.name} class="h-10 w-10 rounded-lg object-cover" loading="lazy" />
              <div>
                <p class="text-sm font-semibold text-white">{show.name}</p>
                <p class="text-xs text-gray-500">{show.listeners} słuchaczy</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {podcastEpisodes.slice(0, 6).map((episode) => (
            <PodcastCard episode={episode} />
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/podcast"
            class="inline-flex items-center gap-2 rounded-xl border border-brand-500/20 bg-brand-500/10 px-6 py-3 text-sm font-medium text-brand-400 transition-colors hover:bg-brand-500/20"
          >
            Wszystkie odcinki
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="YouTube"
          subtitle="Rozwój nowoczesnego programisty — filmy i live'y"
        />

        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {youtubeVideos.slice(0, 3).map((video) => (
            <YouTubeCard video={video} />
          ))}
        </div>

        <div class="mt-8 text-center">
          <a
            href="/youtube"
            class="inline-flex items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/10 px-6 py-3 text-sm font-medium text-red-400 transition-colors hover:bg-red-500/20"
          >
            Wszystkie filmy
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="7 lat na rynku edukacji technologicznej"
          subtitle="Współpracujemy z najlepszymi"
        />

        <div class="mt-10 flex flex-wrap items-center justify-center gap-8 opacity-50 grayscale">
          {['Huuuge Games', 'SmartRecruiters', 'Callstack', 'edrone', 'Autodesk', 'Future Processing', 'Xfive', 'Euvic'].map(
            (brand) => (
              <div class="flex h-12 items-center px-4">
                <span class="text-sm font-medium text-gray-500">{brand}</span>
              </div>
            )
          )}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
