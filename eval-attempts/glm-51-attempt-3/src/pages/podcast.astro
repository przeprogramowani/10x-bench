---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import SectionHeading from '../components/SectionHeading';
import PodcastCard from '../components/PodcastCard';
import { podcastEpisodes, podcastShows } from '../data/podcasts';
---

<Layout title="Podcast" description="Słuchaj naszych podcastów o technologii, AI i programowaniu">
  <Navbar client:load />

  <main class="pt-24 sm:pt-32">
    <section class="pb-16 sm:pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="Podcasty"
          subtitle="Słuchaj naszych podcastów o technologii, AI i programowaniu"
        />

        <div class="mt-10 grid gap-8 sm:grid-cols-2">
          {podcastShows.map((show) => (
            <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-8">
              <div class="flex items-center gap-4">
                <img
                  src={show.image}
                  alt={show.name}
                  class="h-16 w-16 rounded-xl object-cover"
                  loading="lazy"
                />
                <div>
                  <h3 class="text-xl font-bold text-white">{show.name}</h3>
                  <p class="text-sm text-gray-400">{show.listeners} słuchaczy</p>
                </div>
              </div>
              <p class="mt-4 text-sm leading-relaxed text-gray-400">{show.description}</p>
              <div class="mt-4 flex flex-wrap gap-3">
                <a
                  href={show.spotifyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-lg bg-[#1DB954]/10 px-4 py-2 text-sm font-medium text-[#1DB954] transition-colors hover:bg-[#1DB954]/20"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/>
                  </svg>
                  Spotify
                </a>
                <a
                  href="https://podcasts.apple.com/pl/podcast/przeprogramowani/id1508387250"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-lg bg-white/5 px-4 py-2 text-sm font-medium text-gray-300 transition-colors hover:bg-white/10"
                >
                  Apple Podcasts ↗
                </a>
                <a
                  href="https://anchor.fm/s/22544b7c/podcast/rss"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-lg bg-orange-500/10 px-4 py-2 text-sm font-medium text-orange-400 transition-colors hover:bg-orange-500/20"
                >
                  RSS
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h3 class="text-2xl font-bold text-white">Opanuj.AI Podcast</h3>
        <p class="mt-1 text-sm text-gray-400">Najnowsze odcinki</p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {podcastEpisodes
            .filter((ep) => ep.showSlug === 'opanuj-ai')
            .map((episode) => (
              <PodcastCard episode={episode} />
            ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h3 class="text-2xl font-bold text-white">Przeprogramowani ft. Gość</h3>
        <p class="mt-1 text-sm text-gray-400">Rozmowy z ekspertami</p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {podcastEpisodes
            .filter((ep) => ep.showSlug === 'przeprogramowani-gosc')
            .map((episode) => (
              <PodcastCard episode={episode} />
            ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
