---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';
import SectionHeading from '../components/SectionHeading';
---

<Layout title="O nas" description="Łączymy świat programowania, biznesu i rozwoju">
  <Navbar client:load />

  <main class="pt-24 sm:pt-32">
    <section class="pb-16 sm:pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="O nas"
          subtitle="Łączymy świat programowania, biznesu i rozwoju"
        />

        <div class="mx-auto mt-12 max-w-3xl text-center">
          <p class="text-lg leading-relaxed text-gray-400">
            Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-gray-400">
            Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
          </p>
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="Twórcy"
          subtitle="Poznaj osoby stojące za Przeprogramowanymi"
        />

        <div class="mt-12 grid gap-8 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-8">
            <div class="flex items-start gap-5">
              <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-brand-400 to-brand-600 text-2xl font-bold text-white">
                PS
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">Przemek Smyrdek</h3>
                <p class="text-sm font-medium text-brand-400">Co-founder, Przeprogramowani</p>
              </div>
            </div>
            <p class="mt-4 text-sm leading-relaxed text-gray-400">
              Autor programów edukacyjnych, kursów i podcastów. Lead Engineer i Manager w DAZN i Cabify. Full-stack developer (.NET/C#, Java, Node.js, Angular, TypeScript). Prelegent na 4Developers, ReactiveConf i InfoShare. Kontrybutor Open Source (CursorLens, openapi-typescript).
            </p>
            <div class="mt-4 flex gap-4">
              <a
                href="https://www.linkedin.com/in/psmyrdek/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-500 transition-colors hover:text-brand-400"
              >
                LinkedIn ↗
              </a>
              <a
                href="https://twitter.com/psmyrdek"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-500 transition-colors hover:text-brand-400"
              >
                Twitter ↗
              </a>
            </div>
          </div>

          <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-8">
            <div class="flex items-start gap-5">
              <div class="flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600 text-2xl font-bold text-white">
                MC
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">Marcin Czarkowski</h3>
                <p class="text-sm font-medium text-emerald-400">Co-founder, Przeprogramowani</p>
              </div>
            </div>
            <p class="mt-4 text-sm leading-relaxed text-gray-400">
              Lead techniczny Platformy Frontendowej w SmartRecruiters z ponad 10-letnim doświadczeniem. Entuzjasta neurobiologii, tworzący materiały edukacyjne w oparciu o badania nad uczeniem się. Twórca "Opanuj AI Podcast" — najpopularniejszego technicznego podcastu o LLM w Polsce. Specjalista TypeScript, React, Node.js.
            </p>
            <div class="mt-4 flex gap-4">
              <a
                href="https://www.linkedin.com/in/mkczarkowski/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-500 transition-colors hover:text-emerald-400"
              >
                LinkedIn ↗
              </a>
              <a
                href="https://twitter.com/mkczarkowski"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-500 transition-colors hover:text-emerald-400"
              >
                Twitter ↗
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="Co nas wyróżnia?"
          subtitle="Dlaczego warto z nami pracować i uczyć się od nas"
        />

        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              icon: '🎯',
              title: 'Praktyczne podejście',
              desc: 'Łączymy dziesiątki zrealizowanych projektów komercyjnych z efektywnym przekazywaniem wiedzy.',
            },
            {
              icon: '🌍',
              title: 'Globalne doświadczenie',
              desc: 'Praca w globalnych firmach produktowych: DAZN, Cabify, SmartRecruiters — frontend w dużej skali.',
            },
            {
              icon: '🧠',
              title: 'Szersze spojrzenie',
              desc: 'Od technicznych deep-dive\'ów po rozmowy o karierze, biznesie i rozwoju osobistym.',
            },
            {
              icon: '📚',
              title: '7 lat edukacji',
              desc: 'Od 2019 roku tworzymy darmowe treści dla społeczności tysięcy programistów.',
            },
            {
              icon: '🎙️',
              title: 'Najpopularniejsze podcasty',
              desc: 'Opanuj AI Podcast — najpopularniejszy techniczny podcast o LLM w Polsce. Ponad 4000 słuchaczy.',
            },
            {
              icon: '🏆',
              title: '1500+ przeszkolonych devów',
              desc: 'Siedem edycji programów szkoleniowych z pozytywnymi ocenami od setek absolwentów.',
            },
          ].map((item) => (
            <div class="rounded-xl border border-white/5 bg-white/[0.02] p-6">
              <span class="text-2xl">{item.icon}</span>
              <h3 class="mt-3 text-base font-semibold text-white">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-gray-400">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-white/5 py-16 sm:py-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <SectionHeading
          title="7 lat na rynku edukacji technologicznej"
          subtitle="Współpracujemy z najlepszymi"
        />

        <div class="mt-10 flex flex-wrap items-center justify-center gap-8 opacity-50 grayscale">
          {['Huuuge Games', 'SmartRecruiters', 'Callstack', 'edrone', 'Autodesk', 'Future Processing', 'Xfive', 'Euvic', 'Nutridome', 'Strabag'].map(
            (brand) => (
              <div class="flex h-12 items-center px-4">
                <span class="text-sm font-medium text-gray-500">{brand}</span>
              </div>
            )
          )}
        </div>

        <div class="mt-10 text-center">
          <p class="text-gray-500">Chcesz nawiązać współpracę?</p>
          <a
            href="mailto:kontakt@przeprogramowani.pl"
            class="mt-2 inline-flex items-center gap-2 text-brand-400 transition-colors hover:text-brand-300"
          >
            kontakt@przeprogramowani.pl
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
