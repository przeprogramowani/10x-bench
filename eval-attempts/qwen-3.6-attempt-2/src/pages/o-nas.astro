---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout currentPage="/o-nas" title="O nas – Przeprogramowani.pl" description="Poznaj zespół Przeprogramowani. Edukacja technologiczna w epoce AI z Przemkiem Smyrkiem i Marcinem Czarkowskim.">

<!-- Hero -->
<section class="relative py-28 lg:py-36 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-hero"></div>
  <div class="glow-orb top-10 right-[-100px] bg-brand-blue opacity-10"></div>
  <div class="glow-orb bottom-10 left-[-100px] bg-brand-accent opacity-10"></div>
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(59,130,246,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <div class="container-fluid relative z-10 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-brand-border bg-brand-surface/50 px-4 py-2 backdrop-blur-sm mb-6">
      <span class="text-sm text-text-secondary">O naszym zespole</span>
    </div>
    <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
      <span class="text-text-primary">Łączymy świat</span>
      <br />
      <span class="gradient-text">programowania, biznesu i rozwoju</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary lg:text-xl">
      Przeprogramowani to społeczność i platforma edukacyjna, która od lat pomaga developerom rosnąć zawodowo. W erze AI uczymy, jak wykorzystywać nowe technologie, by pracować mądrzej, nie harder.
    </p>
  </div>
</section>

<!-- Mission -->
<section class="section">
  <div class="container-fluid">
    <div class="grid gap-12 lg:grid-cols-2 items-center">
      <div>
        <h2 class="text-3xl font-bold sm:text-4xl">
          Nasza <span class="gradient-text">misja</span>
        </h2>
        <p class="mt-4 text-lg text-text-secondary leading-relaxed">
          Edukacja technologiczna w epoce AI. Wierzymy, że każdy developer może osiągnąć więcej, jeśli zna narzędzia przyszłości. Nasze kursy, podcast i materiały pomagają Ci rozwijać się w kierunku, który naprawdę ma znaczenie.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="card">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-blue/10">
                <svg class="h-5 w-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </div>
              <h3 class="font-semibold text-text-primary">AI-first</h3>
            </div>
            <p class="text-sm text-text-secondary">Uczymy programowania z AI od pierwszego dnia. Claude Code, Cursor, Copilot — to Twoje nowe narzędzia.</p>
          </div>
          <div class="card">
            <div class="flex items-center gap-3 mb-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-accent/10">
                <svg class="h-5 w-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.858M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.858M7 20H2v-2a3 3 0 015.356-1.858M7 20v-2c0-.656.126-1.283.356-1.858m0 0v2a3 3 0 01-5.356-1.858M2 20h5v-2a3 3 0 00-5.356-1.858M7 20v-2c0-.656-.126-1.283-.356-1.858m0 0v2a3 3 0 01-5.356-1.858M12 16a4 4 0 110-8 4 4 0 010 8z"/></svg>
              </div>
              <h3 class="font-semibold text-text-primary">Społeczność</h3>
            </div>
            <p class="text-sm text-text-secondary">7800+ subskrybentów podcastu i rosnąca społeczna developerów w całej Polsce.</p>
          </div>
        </div>
      </div>
      <div class="relative">
        <div class="card p-8 text-center">
          <div class="inline-flex items-center justify-center w-32 h-32 rounded-full bg-gradient-to-br from-brand-blue to-brand-accent mb-6">
            <span class="text-5xl font-extrabold text-white">P</span>
          </div>
          <h3 class="text-xl font-bold text-text-primary">Przeprogramowani.pl</h3>
          <p class="text-brand-lightblue text-sm mt-1">Szerejsze spojrzenie na programowanie</p>
          <div class="mt-6 grid grid-cols-3 gap-4">
            <div>
              <div class="text-2xl font-bold text-text-primary">7+</div>
              <div class="text-xs text-text-muted">lat</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-text-primary">7800+</div>
              <div class="text-xs text-text-muted">sluchaczy</div>
            </div>
            <div>
              <div class="text-2xl font-bold text-text-primary">400+</div>
              <div class="text-xs text-text-muted">absolwentów</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Team -->
<section class="section border-t border-white/5 bg-brand-darker/30">
  <div class="container-fluid">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold sm:text-4xl">
        Poznaj <span class="gradient-text">zespół</span>
      </h2>
      <p class="mt-4 text-lg text-text-secondary">Ludzie za Przeprogramowani</p>
    </div>
    <div class="grid gap-8 md:grid-cols-2 max-w-3xl mx-auto">
      <!-- Przemek -->
      <div class="card card-glow text-center group">
        <div class="mx-auto mb-6 flex h-28 w-28 items-center justify-center rounded-full bg-gradient-to-br from-brand-blue to-brand-glow p-1">
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-brand-dark">
            <span class="text-3xl font-bold text-text-primary">PS</span>
          </div>
        </div>
        <h3 class="text-xl font-bold text-text-primary">Przemek Smyrdek</h3>
        <p class="text-brand-lightblue text-sm mt-1">Co-founder, Lead Engineer</p>
        <p class="mt-3 text-sm text-text-secondary">DAZN i Cababy. Full-stack developer i open-source contributor. Pasjonat nowych technologii i AI.</p>
        <div class="mt-4 flex justify-center gap-3">
          <a href="https://linkedin.com" class="text-text-muted hover:text-brand-lightblue transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
      <!-- Marcin -->
      <div class="card card-glow text-center group">
        <div class="mx-auto mb-6 flex h-28 w-28 items-center justify-center rounded-full bg-gradient-to-br from-brand-accent to-brand-blue p-1">
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-brand-dark">
            <span class="text-3xl font-bold text-text-primary">MC</span>
          </div>
        </div>
        <h3 class="text-xl font-bold text-text-primary">Marcin Czarkowski</h3>
        <p class="text-brand-lightblue text-sm mt-1">Co-founder, Tech Lead</p>
        <p class="mt-3 text-sm text-text-secondary">SmartRecruiters. Twórca Opanuj.AI Podcast. Łączy świat AI z praktyką programistyczną.</p>
        <div class="mt-4 flex justify-center gap-3">
          <a href="https://linkedin.com" class="text-text-muted hover:text-brand-lightblue transition-colors">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Partners -->
<section class="section border-t border-white/5">
  <div class="container-fluid">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold sm:text-4xl">
        Zaufali <span class="gradient-text">nam</span>
      </h2>
      <p class="mt-4 text-lg text-text-secondary">Firmy, które współpracują z Przeprogramowani</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-5 max-w-4xl mx-auto">
      {['Autodesk', 'SmartRecruiters', 'Callstack', 'Future Processing', 'edrone', 'Xfive', 'Euvic', 'Strabag', 'Huuuge Games', 'Nutridome'].map(name => (
        <div class="card flex items-center justify-center h-20">
          <span class="text-sm font-semibold text-text-muted">{name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Social Links -->
<section class="section border-t border-white/5 bg-brand-darker/30">
  <div class="container-fluid">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold sm:text-4xl">
        Śledź nas <span class="gradient-text">nasocialach</span>
      </h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 max-w-3xl mx-auto">
      {[
        { name: 'YouTube', href: 'https://youtube.com/@przeprogramowani', desc: 'Filmy technologiczne', color: 'from-red-500 to-red-700' },
        { name: 'Instagram', href: 'https://instagram.com/przeprogramowani', desc: 'Na bieżąco', color: 'from-pink-500 to-purple-600' },
        { name: 'LinkedIn', href: 'https://linkedin.com/company/przeprogramowani', desc: 'B2B i kariera', color: 'from-blue-600 to-blue-800' },
        { name: 'TikTok', href: 'https://tiktok.com/@przeprogramowani', desc: 'Krótka forma', color: 'from-gray-800 to-gray-900' },
      ].map(social => (
        <a href={social.href} target="_blank" rel="noopener noreferrer" class={`card card-glow group`}>
          <div class={`inline-flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br ${social.color} mb-3`}>
            <svg class="h-5 w-5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
          </div>
          <h3 class="font-semibold text-text-primary group-hover:text-brand-lightblue transition-colors">{social.name}</h3>
          <p class="text-xs text-text-muted">{social.desc}</p>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>
