---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEpisodes = (await getCollection('podcasts')).sort((a, b) => b.data.date.localeCompare(a.data.date));
const opanujAi = allEpisodes.filter(e => e.data.series === 'opanuj-ai');
const przeprogramowani = allEpisodes.filter(e => e.data.series === 'przeprogramowani');
---

<BaseLayout currentPage="/podcast" title="Podcast – Przeprogramowani.pl" description="Opanuj.AI Podcast i Przeprogramowani ft. Gość. Najnowsze trendy w AI, programowaniu i karierze developerskiej.">

<!-- Hero -->
<section class="relative py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-hero"></div>
  <div class="glow-orb top-10 right-[-100px] bg-brand-accent opacity-10"></div>
  <div class="glow-orb bottom-10 left-[-100px] bg-brand-blue opacity-10"></div>
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(59,130,246,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
  <div class="container-fluid relative z-10 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-brand-border bg-brand-surface/50 px-4 py-2 backdrop-blur-sm mb-6">
      <svg class="h-4 w-4 text-brand-blue" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
      <span class="text-sm text-text-secondary">Dwa podcasty, jedna pasja</span>
    </div>
    <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
      <span class="text-text-primary">Nasze</span>
      <br />
      <span class="gradient-text">podcasty</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary lg:text-xl">
      Opanuj.AI Podcast i Przeprogramowani ft. Gość — rozmowy o AI, programowaniu, karierze i świecie technologii z najlepszymi ekspertami.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="https://spotify.com" target="_blank" rel="noopener noreferrer" class="btn-primary">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.75 10.13c-.13-.09-.27-.17-.42-.22.35-.97.26-2.06-.27-2.94-.63-1.05-1.68-1.7-2.84-1.82-.38-.04-.76-.06-1.14-.06-2.57 0-4.8 1.55-5.66 3.87-.23.6-.35 1.24-.35 1.9 0 .37.03.74.09 1.1-.72.32-1.26.92-1.51 1.67-.2.58-.26 1.19-.19 1.8.15 1.3.88 2.44 1.98 3.13.07.04.14.08.22.11-.04.18-.07.36-.07.55 0 1.19.97 2.16 2.16 2.16.31 0 .61-.07.88-.2.78-.42 1.3-1.22 1.36-2.11 0-.04 0-.07 0-.11.85-.48 1.44-1.33 1.59-2.29.04-.24.05-.49.03-.73.38.12.79.18 1.21.18 2.48 0 4.49-2.01 4.49-4.49 0-.18-.01-.36-.03-.54.47-.2.88-.52 1.21-.94.03-.51-.03-1.03-.18-1.53-.15-.5-.4-.97-.73-1.38zM11.25 17c-.36 0-.65-.29-.65-.65s.29-.65.65-.65.65.29.65.65-.29.65-.65.65z"/></svg>
        Spotify
      </a>
      <a href="https://podcasts.apple.com" target="_blank" rel="noopener noreferrer" class="btn-secondary">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.75 10.13c-.13-.09-.27-.17-.42-.22.35-.97.26-2.06-.27-2.94-.63-1.05-1.68-1.7-2.84-1.82-.38-.04-.76-.06-1.14-.06-2.57 0-4.8 1.55-5.66 3.87-.23.6-.35 1.24-.35 1.9 0 .37.03.74.09 1.1-.72.32-1.26.92-1.51 1.67-.2.58-.26 1.19-.19 1.8.15 1.3.88 2.44 1.98 3.13.07.04.14.08.22.11-.04.18-.07.36-.07.55 0 1.19.97 2.16 2.16 2.16.31 0 .61-.07.88-.2.78-.42 1.3-1.22 1.36-2.11 0-.04 0-.07 0-.11.85-.48 1.44-1.33 1.59-2.29.04-.24.05-.49.03-.73.38.12.79.18 1.21.18 2.48 0 4.49-2.01 4.49-4.49 0-.18-.01-.36-.03-.54.47-.2.88-.52 1.21-.94.03-.51-.03-1.03-.18-1.53-.15-.5-.4-.97-.73-1.38zM11.25 17c-.36 0-.65-.29-.65-.65s.29-.65.65-.65.65.29.65.65-.29.65-.65.65z"/></svg>
        Apple Podcasts
      </a>
    </div>
  </div>
</section>

<!-- Podcast Tabs -->
<section class="section">
  <div class="container-fluid">
    <!-- Tabs -->
    <div class="flex justify-center mb-12">
      <div class="inline-flex rounded-xl bg-brand-surface p-1">
        <button id="tab-pan" class="tab-btn px-6 py-2.5 rounded-lg text-sm font-semibold transition-all bg-brand-blue text-white" onclick="switchTab('opanuj-ai')">Opanuj.AI Podcast</button>
        <button id="tab-pg" class="tab-btn px-6 py-2.5 rounded-lg text-sm font-semibold transition-all text-text-secondary hover:text-text-primary" onclick="switchTab('przeprogramowani')">Przeprogramowani ft. Gość</button>
      </div>
    </div>

    <!-- Opanuj.AI Episodes -->
    <div id="episodes-pan" class="episodes-grid space-y-4">
      {opanujAi.map(episode => (
        <div class="card card-glow group">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="shrink-0 flex h-16 w-16 items-center justify-center rounded-xl bg-gradient-to-br from-brand-blue to-brand-accent">
              <svg class="h-7 w-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <span class="rounded-full bg-brand-blue/10 px-2 py-0.5 text-[11px] font-medium text-brand-lightblue">Opanuj.AI</span>
                <span class="text-xs text-text-muted">{episode.data.date}</span>
              </div>
              <h3 class="text-lg font-bold text-text-primary group-hover:text-brand-lightblue transition-colors">{episode.data.title}</h3>
              <p class="text-sm text-text-secondary mt-1">{episode.data.description}</p>
            </div>
            <div class="shrink-0 flex items-center gap-3">
              <span class="rounded-full border border-white/10 px-3 py-1 text-sm text-text-secondary">{episode.data.duration}</span>
              <svg class="h-5 w-5 text-text-muted group-hover:text-brand-lightblue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Przeprogramowani Episodes -->
    <div id="episodes-pg" class="episodes-grid hidden space-y-4">
      {przeprogramowani.map(episode => (
        <div class="card card-glow group">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="shrink-0 flex h-16 w-16 items-center justify-center rounded-xl bg-gradient-to-br from-brand-accent to-brand-blue">
              <svg class="h-7 w-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8a4 4 0 018 0v3m-8-3a4 4 0 00-4 4v3m8-7a4 4 0 00-4-4h0a4 4 0 00-4 4v3m12-1v3m0 0v3m0-3h3m-3 0h-3"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <span class="rounded-full bg-brand-accent/10 px-2 py-0.5 text-[11px] font-medium text-brand-accent">Gość</span>
                <span class="text-xs text-text-muted">{episode.data.date}</span>
              </div>
              <h3 class="text-lg font-bold text-text-primary group-hover:text-brand-lightblue transition-colors">{episode.data.title}</h3>
              {episode.data.guest && <p class="text-sm text-brand-lightblue mt-1">Gość: {episode.data.guest}</p>}
              <p class="text-sm text-text-secondary mt-1">{episode.data.description}</p>
            </div>
            <div class="shrink-0 flex items-center gap-3">
              <span class="rounded-full border border-white/10 px-3 py-1 text-sm text-text-secondary">{episode.data.duration}</span>
              <svg class="h-5 w-5 text-text-muted group-hover:text-brand-lightblue transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  function switchTab(series: string) {
    document.querySelectorAll('.episodes-grid').forEach(el => el.classList.add('hidden'));
    document.querySelectorAll('.tab-btn').forEach(el => {
      el.classList.remove('bg-brand-blue', 'text-white');
      el.classList.add('text-text-secondary');
    });
    document.getElementById('episodes-' + series.replace('.', '-'))?.classList.remove('hidden');
    document.getElementById('tab-' + series.replace('.', '-'))?.classList.add('bg-brand-blue', 'text-white');
    document.getElementById('tab-' + series.replace('.', '-'))?.classList.remove('text-text-secondary');
  }
</script>

</BaseLayout>
