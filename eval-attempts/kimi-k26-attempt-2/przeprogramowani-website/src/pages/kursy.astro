---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation';
import Footer from '../components/Footer';

const courses = [
  {
    id: '10xdevs',
    name: '10xDevs',
    subtitle: 'AI-Native Software Engineering',
    description: '5-tygodniowy, intensywny program, który uczy developerów pracować z AI w całym cyklu tworzenia oprogramowania: od researchu i planowania, przez implementację, aż po utrzymanie produkcji.',
    features: [
      'Agentic Environment i Context Engineering',
      '10xDevs Workflow - Plan → Implement → Review',
      'AI Development Quality & Maintenance',
      'Large Scale & Legacy Projects',
      'AI-Native Teamwork',
      'Certyfikacja 10xBuilder, 10xArchitect, 10xChampion',
    ],
    stats: {
      duration: '5 tygodni',
      lessons: '40h materiałów',
      community: '3700+ absolwentów',
      live: 'Sesje Q&A na żywo',
    },
    price: 'Od 2990 zł',
    badge: 'Bestseller',
    badgeColor: 'bg-amber-500/20 text-amber-400 border-amber-500/30',
    gradient: 'from-cyan-500 to-blue-600',
    cta: 'Dołącz do 10xDevs',
    ctaLink: 'https://10xdevs.pl',
    image: '🚀',
  },
  {
    id: 'frontend',
    name: 'Opanuj Frontend',
    subtitle: 'AI Edition',
    description: 'Intensywne 10-tygodniowe szkolenie, które przygotuje Cię do tworzenia zaawansowanych aplikacji webowych z wykorzystaniem najnowszych technologii i najlepszych praktyk.',
    features: [
      'Wzorce i dobre praktyki frontendu',
      'Inżynieria jakości - testy i accessibility',
      'Wdrożenia i utrzymanie produkcji (CI/CD, AWS)',
      'Frontend zespołowo (Open Source, Inner Source)',
      'Architektura aplikacji frontendowych',
      'Lekcje AI Edition - praca z asystentem AI',
    ],
    stats: {
      duration: '10 tygodni',
      lessons: '25 lekcji',
      community: '383 absolwentów',
      live: '5 spotkań LIVE z ekspertami',
    },
    price: 'Sprawdź cenę',
    badge: 'IV Edycja',
    badgeColor: 'bg-violet-500/20 text-violet-400 border-violet-500/30',
    gradient: 'from-violet-500 to-purple-600',
    cta: 'Zobacz agendę',
    ctaLink: 'https://opanujfrontend.pl',
    image: '⚡',
  },
  {
    id: 'typescript',
    name: 'Opanuj TypeScript',
    subtitle: 'Frontend Pro',
    description: 'Praktyczny kurs, który pomoże Ci pewnie używać typów generycznych, podejmować lepsze decyzje o typowaniu i skutecznie rozwijać projekty na produkcji.',
    features: [
      'TypeScript 5.7+ - Core Pro',
      'React 19 - Tajniki i ekosystem',
      'Zod, tRPC, Astro 5',
      '40+ ćwiczeń praktycznych',
      'Lekcja bonusowa AI Edition',
      'Wsparcie społeczności i mentorów',
    ],
    stats: {
      duration: 'Własne tempo',
      lessons: '2 moduły',
      community: '121 programistów',
      live: 'Materiały wideo + tekst',
    },
    price: 'Kup teraz',
    badge: 'Dostępny',
    badgeColor: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
    gradient: 'from-emerald-500 to-teal-600',
    cta: 'Kup teraz',
    ctaLink: 'https://opanujtypescript.pl',
    image: '💎',
  },
];

const testimonials = [
  {
    quote: "To nie był 'kolejny kurs' – to przełom w podejściu do wytwarzania oprogramowania, w którym AI to nie tylko dodatek, ale integralny element każdego etapu developmentu.",
    author: "Mariusz Rudnik",
    role: "Absolwent 10xDevs",
    rating: 5,
  },
  {
    quote: "Kurs dał mi szersze spojrzenie na programowanie. Uświadamia, że warto najpierw przemyśleć co jak ma działać, poukładać to sobie w głowie i dopiero wtedy działać.",
    author: "Paulina K",
    role: "Absolwentka Opanuj Frontend",
    rating: 5,
  },
  {
    quote: "Mam 5 lat stażu jako full stack i to jest kolejny raz gdy Przeprogramowani zaskakują mnie rzeczami, których wcześniej nie znałem.",
    author: "Paweł",
    role: "Full-Stack Developer",
    rating: 5,
  },
];
---

<Layout title="Kursy - Przeprogramowani.pl">
  <Navigation client:load />
  
  <main class="pt-16">
    <!-- Hero -->
    <section class="relative py-24 overflow-hidden">
      <div class="absolute inset-0 bg-slate-950">
        <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-cyan-500/10 rounded-full blur-3xl"></div>
      </div>
      
      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-black mb-6">
          <span class="bg-gradient-to-r from-white via-slate-200 to-slate-400 bg-clip-text text-transparent">
            Programy{' '}
          </span>
          <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
            szkoleniowe
          </span>
        </h1>
        <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
          Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI
        </p>
      </div>
    </section>

    {/* Courses */}
    <section class="py-16 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="space-y-12">
          {courses.map((course) => (
            <div class="relative p-8 bg-slate-900/50 border border-slate-800/50 rounded-2xl hover:border-slate-700 transition-all duration-300">
              <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${course.gradient} rounded-t-2xl`}></div>
              
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                {/* Left - Info */}
                <div class="lg:col-span-2">
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-4xl">{course.image}</span>
                    <div>
                      <h2 class="text-2xl sm:text-3xl font-bold text-white">{course.name}</h2>
                      <p class={`text-lg font-medium bg-gradient-to-r ${course.gradient} bg-clip-text text-transparent`}>
                        {course.subtitle}
                      </p>
                    </div>
                  </div>
                  
                  <p class="text-slate-400 leading-relaxed mb-6">{course.description}</p>
                  
                  <div class="grid grid-cols-2 gap-3 mb-6">
                    {course.features.map((feature) => (
                      <div class="flex items-center gap-2 text-sm text-slate-300">
                        <svg class="w-4 h-4 text-cyan-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M5 13l4 4L19 7" />
                        </svg>
                        {feature}
                      </div>
                    ))}
                  </div>
                  
                  <div class="flex flex-wrap gap-4">
                    {Object.entries(course.stats).map(([key, value]) => (
                      <div class="px-4 py-2 bg-slate-800/50 rounded-lg">
                        <span class="text-sm text-slate-400">{value}</span>
                      </div>
                    ))}
                  </div>
                </div>
                
                {/* Right - CTA */}
                <div class="flex flex-col justify-center items-start lg:items-end gap-4">
                  <span class={`px-3 py-1 text-xs font-semibold rounded-full border ${course.badgeColor}`}>
                    {course.badge}
                  </span>
                  <a
                    href={course.ctaLink}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`w-full lg:w-auto px-8 py-4 bg-gradient-to-r ${course.gradient} text-white font-semibold rounded-xl hover:shadow-lg transition-all duration-200 text-center`}
                  >
                    {course.cta}
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Testimonials */}
    <section class="py-24 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center mb-12">
          <span class="bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
            Co mówią absolwenci
          </span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {testimonials.map((testimonial) => (
            <div class="p-6 bg-slate-900/50 border border-slate-800/50 rounded-2xl">
              <div class="flex gap-1 mb-4">
                {Array.from({ length: testimonial.rating }).map(() => (
                  <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                ))}
              </div>
              <p class="text-slate-300 leading-relaxed mb-4 text-sm">"{testimonial.quote}"</p>
              <div>
                <div class="font-semibold text-white text-sm">{testimonial.author}</div>
                <div class="text-slate-500 text-sm">{testimonial.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="py-24 bg-slate-950">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4">
          <span class="bg-gradient-to-r from-white to-slate-400 bg-clip-text text-transparent">
            Nie wiesz, który kurs wybrać?
          </span>
        </h2>
        <p class="text-slate-400 mb-8">
          Napisz do nas, a pomożemy dobrać program do Twoich potrzeb i doświadczenia
        </p>
        <a
          href="mailto:kontakt@przeprogramowani.pl"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-cyan-500/25"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Skontaktuj się z nami
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
