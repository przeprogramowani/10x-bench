---
import { courses } from "../data/site";
---

<section id="kursy" class="py-20">
  <div class="section-shell mb-10 flex flex-col justify-between gap-6 md:flex-row md:items-end">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-orange-600">Programy edukacyjne</p>
      <h2 class="max-w-3xl text-3xl font-black tracking-tight md:text-5xl">
        Kursy dla developerów, którzy pracują z realnymi projektami.
      </h2>
    </div>
    <p class="max-w-sm text-base leading-7 text-neutral-600">
      Od frontendu i TypeScripta po pełny system pracy z AI. Każdy program prowadzi do praktycznego, produkcyjnego warsztatu.
    </p>
  </div>
  <div class="section-shell grid gap-4 lg:grid-cols-3">
    {
      courses.map((course) => (
        <article class="group flex min-h-[390px] flex-col justify-between rounded-sm border border-neutral-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
          <div>
            <div class={`mb-7 h-1.5 w-24 rounded-full bg-gradient-to-r ${course.accent}`} />
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-neutral-500">{course.kicker}</p>
            <h3 class="mt-3 text-2xl font-black tracking-tight">{course.title}</h3>
            <p class="mt-5 text-sm leading-6 text-neutral-600">{course.description}</p>
            <ul class="mt-6 grid gap-2">
              {course.points.map((point) => (
                <li class="flex gap-2 text-sm text-neutral-700">
                  <span class="mt-2 size-1.5 shrink-0 rounded-full bg-orange-500" />
                  {point}
                </li>
              ))}
            </ul>
          </div>
          <a class="focus-ring mt-8 inline-flex rounded-sm bg-neutral-950 px-4 py-3 text-sm font-bold text-white transition group-hover:bg-orange-600" href={course.href}>
            Szczegóły programu
          </a>
        </article>
      ))
    }
  </div>
</section>
