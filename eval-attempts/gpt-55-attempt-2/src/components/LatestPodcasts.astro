---
import { podcasts } from "../data/site";
---

<div class="section-shell grid gap-4 md:grid-cols-2 lg:grid-cols-3">
  {
    podcasts.map((episode) => (
      <a class="focus-ring flex min-h-[260px] flex-col justify-between rounded-sm border border-neutral-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-xl" href={episode.href}>
        <div>
          <div class="mb-5 inline-flex rounded-sm bg-orange-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-orange-800">
            {episode.duration}
          </div>
          <p class="text-sm font-semibold text-neutral-500">{episode.show}</p>
          <h2 class="mt-3 text-lg font-black leading-tight">{episode.title}</h2>
          <p class="mt-4 text-sm leading-6 text-neutral-600">{episode.description}</p>
        </div>
        <span class="mt-6 text-sm font-bold text-neutral-950">Posłuchaj odcinka</span>
      </a>
    ))
  }
</div>
