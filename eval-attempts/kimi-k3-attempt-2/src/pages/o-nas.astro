---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TrustedBy from '../components/TrustedBy.astro';
import { founders } from '../data/brands';

const values = [
  {
    title: 'Szersze spojrzenie',
    description: 'Patrzymy dalej niż framework — na architekturę, biznes, ludzi i rozwój osobisty.',
    icon: 'M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7zm10 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6z',
  },
  {
    title: 'Pragmatyzm',
    description: 'Łączymy teorię z praktyką w najbardziej użyteczny dla programisty sposób.',
    icon: 'M14.7 6.3a4 4 0 0 0-5.4 5.4L3 18v3h3l6.3-6.3a4 4 0 0 0 5.4-5.4l-2.8 2.8-2-2 2.8-2.8z',
  },
  {
    title: 'Społeczność',
    description: 'Od 2019 roku tworzymy darmowe treści dla ponad 15 000 programistów.',
    icon: 'M16 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm-8 0a4 4 0 1 0-4-4 4 4 0 0 0 4 4zm0 2c-2.7 0-8 1.3-8 4v3h9v-3a5.2 5.2 0 0 1 2-4 12.8 12.8 0 0 0-3 0zm8 0a12.8 12.8 0 0 0-3 .1 6.5 6.5 0 0 1 2 4.9v3h9v-3c0-2.7-5.3-5-8-5z',
  },
  {
    title: 'Jakość oparta o badania',
    description: 'Materiały edukacyjne tworzymy z uwzględnieniem badań nad efektywnym przyswajaniem wiedzy.',
    icon: 'M12 2 4 6v6c0 5 3.4 8.4 8 10 4.6-1.6 8-5 8-10V6l-8-4zm-2 15-4-4 1.4-1.4L10 14.2l6.6-6.6L18 9l-8 8z',
  },
];
---

<Layout
  title="O nas — Przeprogramowani"
  description="Łączymy świat programowania, biznesu i rozwoju. Poznaj Przemka i Marcina — twórców Przeprogramowanych."
>
  <PageHero
    eyebrow="O nas"
    title="Łączymy świat programowania, biznesu i rozwoju"
    description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie."
  />

  <!-- Twórcy -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading eyebrow="Zespół" title="Poznaj twórców" />
      <div class="mt-14 grid gap-8 md:grid-cols-2">
        {
          founders.map((founder) => (
            <article class="card p-8">
              <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center">
                <img
                  src={founder.photo}
                  alt={`Zdjęcie — ${founder.name}`}
                  loading="lazy"
                  class="h-28 w-28 flex-none rounded-2xl border border-white/10 object-cover"
                />
                <div>
                  <h3 class="text-2xl font-bold text-white">{founder.name}</h3>
                  <p class="mt-1 font-medium text-orange-400">{founder.role}</p>
                  <a
                    href={founder.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-3 inline-flex items-center gap-2 rounded-lg border border-white/10 px-3 py-1.5 text-sm font-medium text-zinc-300 transition hover:border-sky-500/40 hover:text-sky-400"
                  >
                    <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                      <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z" />
                    </svg>
                    LinkedIn
                  </a>
                </div>
              </div>
              <p class="mt-6 leading-relaxed text-zinc-400">{founder.bio}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Misja -->
  <section class="border-t border-white/5 bg-night-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-mono text-sm uppercase tracking-widest text-orange-500">Witaj na Przeprogramowanych</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
          Zyskaj szersze spojrzenie na programowanie
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-zinc-400">
          Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach — od
          technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((value) => (
            <div class="card p-6">
              <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-orange-500/20 to-rose-500/20 text-orange-400">
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
                  <path d={value.icon} />
                </svg>
              </span>
              <h3 class="mt-5 font-bold text-white">{value.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-zinc-400">{value.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <TrustedBy />

  <!-- Kontakt -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-night-800 via-night-900 to-night-950 p-10 text-center sm:p-14">
        <div class="absolute -left-24 -top-24 h-72 w-72 rounded-full bg-orange-500/15 blur-[100px]" aria-hidden="true">
        </div>
        <div class="relative">
          <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">Chcesz nawiązać współpracę?</h2>
          <p class="mx-auto mt-4 max-w-xl leading-relaxed text-zinc-400">
            Warsztaty dla firm, współpraca przy treściach lub sponsorowane wydania newslettera — napisz do nas.
          </p>
          <a href="mailto:kontakt@przeprogramowani.pl" class="btn-primary mt-8">
            kontakt@przeprogramowani.pl
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
