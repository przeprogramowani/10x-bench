---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustedBy from '../components/TrustedBy.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CourseCard from '../components/CourseCard.astro';
import StatCounter from '../components/react/StatCounter';
import { courses } from '../data/courses';
import { videos, channelUrl } from '../data/videos';
import { shows } from '../data/podcasts';

const latestVideos = videos.slice(0, 3);
const latestEpisodes = shows[0].episodes.slice(0, 3);

const stats = [
  { value: 7, suffix: '', label: 'lat na rynku edukacji technologicznej' },
  { value: 6700, suffix: '+', label: 'absolwentów programu 10xDevs' },
  { value: 15000, suffix: '+', label: 'programistów w społeczności' },
  { value: 7800, suffix: '+', label: 'słuchaczy naszych podcastów' },
];
---

<Layout title="Przeprogramowani.pl — Szersze spojrzenie na programowanie">
  <Hero />
  <TrustedBy />

  <!-- Kursy -->
  <section id="kursy" class="scroll-mt-20 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Nasze programy"
        title="Edukacja technologiczna w epoce AI"
        description="Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generatywnego AI."
      />
      <div class="mt-14 grid gap-8 lg:grid-cols-3">
        {courses.map((course) => <CourseCard course={course} />)}
      </div>
    </div>
  </section>

  <!-- Filmy i podcasty -->
  <section class="border-t border-white/5 bg-night-900/30 py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <SectionHeading
        eyebrow="Darmowe treści"
        title="Filmy i podcasty"
        description="Rozwój nowoczesnego programisty — oglądaj i słuchaj, gdziekolwiek jesteś."
      />

      <div class="mt-14 grid gap-12 lg:grid-cols-2">
        <div>
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-xl font-bold text-white">Ostatnie filmy</h3>
            <a href="/youtube" class="text-sm font-semibold text-orange-400 transition hover:text-orange-300">
              Wszystkie filmy →
            </a>
          </div>
          <ul class="mt-6 space-y-4">
            {
              latestVideos.map((video) => (
                <li>
                  <a
                    href={`https://www.youtube.com/watch?v=${video.id}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="card group flex items-center gap-4 p-3"
                  >
                    <span class="relative w-36 flex-none overflow-hidden rounded-lg">
                      <img
                        src={`https://i3.ytimg.com/vi/${video.id}/mqdefault.jpg`}
                        alt=""
                        loading="lazy"
                        class="aspect-video w-full object-cover transition duration-300 group-hover:scale-105"
                      />
                      <span class="absolute inset-0 flex items-center justify-center bg-night-950/30 opacity-0 transition group-hover:opacity-100">
                        <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6 text-white" aria-hidden="true">
                          <path d="M8 5.5v13l11-6.5z" />
                        </svg>
                      </span>
                    </span>
                    <span class="text-sm font-semibold leading-snug text-zinc-200 transition group-hover:text-white">
                      {video.title}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href={channelUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-zinc-400 transition hover:text-white"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4 text-red-500" aria-hidden="true">
              <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12z" />
            </svg>
            youtube.com/c/przeprogramowani
          </a>
        </div>

        <div>
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-xl font-bold text-white">Ostatnie odcinki</h3>
            <a href="/podcast" class="text-sm font-semibold text-orange-400 transition hover:text-orange-300">
              Wszystkie odcinki →
            </a>
          </div>
          <ul class="mt-6 space-y-4">
            {
              latestEpisodes.map((episode) => (
                <li>
                  <a href={episode.url} target="_blank" rel="noopener noreferrer" class="card group flex items-center gap-4 p-3">
                    <span class="relative w-20 flex-none overflow-hidden rounded-lg">
                      <img src={episode.image} alt="" loading="lazy" class="aspect-square w-full object-cover" />
                    </span>
                    <span class="min-w-0">
                      <span class="block font-mono text-xs text-orange-400">{episode.duration}</span>
                      <span class="mt-1 line-clamp-2 block text-sm font-semibold leading-snug text-zinc-200 transition group-hover:text-white">
                        {episode.title}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
          <p class="mt-6 text-sm text-zinc-500">
            Opanuj.AI Podcast — comiesięczne podsumowanie najważniejszych wydarzeń ze świata AI.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-night-800 via-night-900 to-night-950 p-10 sm:p-14">
        <div
          class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-orange-500/15 blur-[100px]"
          aria-hidden="true"
        >
        </div>
        <div class="relative grid items-center gap-10 lg:grid-cols-2">
          <div>
            <p class="font-mono text-sm uppercase tracking-widest text-orange-500">Newsletter</p>
            <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
              Przeprogramowany Newsletter
            </h2>
            <p class="mt-4 leading-relaxed text-zinc-400">
              Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1. Nie przegapisz też nowości od
              Przeprogramowanych i ofert specjalnych.
            </p>
            <a
              href="https://przeprogramowani.substack.com"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary mt-8"
            >
              Zapisz się za darmo
              <span aria-hidden="true">→</span>
            </a>
          </div>
          <ul class="space-y-4">
            {
              [
                { n: '3', text: 'rekomendacje techniczne' },
                { n: '2', text: 'rekomendacje rozwojowe' },
                { n: '1', text: 'bonus niespodzianka' },
              ].map((item) => (
                <li class="flex items-center gap-5 rounded-2xl border border-white/10 bg-night-950/60 p-5">
                  <span class="flex h-12 w-12 flex-none items-center justify-center rounded-xl bg-gradient-to-br from-orange-500 to-rose-500 text-xl font-extrabold text-white">
                    {item.n}
                  </span>
                  <span class="font-medium text-zinc-200">{item.text}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Statystyki -->
  <section class="border-t border-white/5 bg-night-900/30 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <StatCounter client:visible stats={stats} />
    </div>
  </section>
</Layout>
