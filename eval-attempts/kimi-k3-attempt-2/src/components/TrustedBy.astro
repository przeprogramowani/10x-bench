---
import { brands } from '../data/brands';
---

<section class="border-y border-white/5 bg-night-900/40 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-center font-mono text-sm uppercase tracking-widest text-zinc-500">
      Zaufali nam — 7 lat na rynku edukacji technologicznej
    </p>
    <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      {
        brands.map((brand) => (
          <li class="text-lg font-semibold tracking-wide text-zinc-600 transition hover:text-zinc-300">{brand}</li>
        ))
      }
    </ul>
  </div>
</section>
