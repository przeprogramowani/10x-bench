---
const year = new Date().getFullYear();

const courseLinks = [
  { href: 'https://10xdevs.pl', label: '10xDevs' },
  { href: 'https://www.opanujfrontend.pl', label: 'Opanuj Frontend' },
  { href: 'https://www.opanujtypescript.pl', label: 'Opanuj TypeScript' },
  { href: 'https://opanuj.ai', label: 'Opanuj AI' },
];

const contentLinks = [
  { href: '/o-nas', label: 'O nas' },
  { href: '/podcast', label: 'Podcast' },
  { href: '/youtube', label: 'YouTube' },
  { href: 'https://przeprogramowani.substack.com', label: 'Newsletter', external: true },
  { href: 'https://przeprogramowani.pl/artykuly', label: 'Blog', external: true },
];

const socials = [
  {
    name: 'YouTube',
    href: 'https://youtube.com/c/przeprogramowani',
    icon: 'M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12z',
  },
  {
    name: 'Facebook',
    href: 'https://facebook.com/przeprogramowani',
    icon: 'M24 12a12 12 0 1 0-13.9 11.9v-8.4h-3V12h3V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9V12h3.4l-.5 3.5h-2.9v8.4A12 12 0 0 0 24 12z',
  },
  {
    name: 'Instagram',
    href: 'https://instagram.com/przeprogramowani',
    icon: 'M12 2.2c3.2 0 3.6 0 4.9.1 3.3.1 4.8 1.7 4.9 4.9.1 1.3.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 3.2-1.7 4.8-4.9 4.9-1.3.1-1.6.1-4.9.1-3.2 0-3.6 0-4.8-.1-3.3-.1-4.8-1.7-4.9-4.9-.1-1.3-.1-1.6-.1-4.8s0-3.6.1-4.8C2.4 4 4 2.4 7.2 2.3c1.2-.1 1.6-.1 4.8-.1zM12 0C8.7 0 8.3 0 7.1.1 2.7.3.3 2.7.1 7.1 0 8.3 0 8.7 0 12s0 3.7.1 4.9c.2 4.4 2.6 6.8 7 7 1.2.1 1.6.1 4.9.1s3.7 0 4.9-.1c4.4-.2 6.8-2.6 7-7 .1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.2-4.4-2.6-6.8-7-7C15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 1 0 0 12.4 6.2 6.2 0 0 0 0-12.4zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.8a1.4 1.4 0 1 0 0 2.9 1.4 1.4 0 0 0 0-2.9z',
  },
];
---

<footer class="border-t border-white/5 bg-night-900/50">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2.5 font-bold text-white">
          <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-orange-500/30 bg-orange-500/10 font-mono text-sm text-orange-400">
            &lt;/&gt;
          </span>
          <span class="text-lg tracking-tight">Przeprogramowani</span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-zinc-500">
          Szersze spojrzenie na programowanie. Kursy, podcasty i filmy dla ambitnych programistów — od 2019 roku.
        </p>
        <div class="mt-6 flex gap-3">
          {
            socials.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.name}
                class="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 text-zinc-400 transition hover:border-orange-500/40 hover:text-orange-400"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                  <path d={social.icon} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="font-mono text-sm uppercase tracking-widest text-zinc-500">Kursy</h3>
        <ul class="mt-5 space-y-3">
          {
            courseLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-zinc-400 transition hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-sm uppercase tracking-widest text-zinc-500">Treści</h3>
        <ul class="mt-5 space-y-3">
          {
            contentLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="text-sm text-zinc-400 transition hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-sm uppercase tracking-widest text-zinc-500">Kontakt</h3>
        <p class="mt-5 text-sm leading-relaxed text-zinc-400">
          Chcesz nawiązać współpracę?
        </p>
        <a
          href="mailto:kontakt@przeprogramowani.pl"
          class="mt-3 inline-block text-sm font-semibold text-orange-400 transition hover:text-orange-300"
        >
          kontakt@przeprogramowani.pl
        </a>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-white/5 pt-8 sm:flex-row">
      <p class="text-sm text-zinc-600">
        © {year} Przeprogramowani.pl — Szersze spojrzenie na programowanie
      </p>
      <p class="font-mono text-xs text-zinc-700">Astro + React + Tailwind • Cloudflare Pages</p>
    </div>
  </div>
</footer>
