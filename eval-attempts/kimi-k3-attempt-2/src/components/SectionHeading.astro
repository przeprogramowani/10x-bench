---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mx-auto max-w-3xl text-center">
  {eyebrow && <p class="font-mono text-sm uppercase tracking-widest text-orange-500">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-lg leading-relaxed text-zinc-400">{description}</p>}
</div>
