---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="relative overflow-hidden border-b border-white/5">
  <div class="absolute inset-0 bg-grid mask-fade-b" aria-hidden="true"></div>
  <div
    class="absolute -top-32 left-1/2 h-[320px] w-[640px] -translate-x-1/2 rounded-full bg-orange-500/10 blur-[110px]"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
    <p class="font-mono text-sm uppercase tracking-widest text-orange-500">{eyebrow}</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-extrabold tracking-tight text-white sm:text-5xl">{title}</h1>
    <p class="mt-5 max-w-2xl text-lg leading-relaxed text-zinc-400">{description}</p>
    <slot />
  </div>
</section>
