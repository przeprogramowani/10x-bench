---
import FounderCard from '../components/FounderCard.astro';
import Layout from '../layouts/Layout.astro';
import {
  courses,
  featuredVideo,
  founders,
  heroBullets,
  partners,
  podcastEpisodes,
  site,
  values,
  videoCards
} from '../data/site';

const latestEpisodes = podcastEpisodes.slice(0, 3);
const latestVideos = videoCards.slice(0, 3);
---

<Layout
  title="Przeprogramowani"
  description="Nowoczesna, responsywna strona projektu Przeprogramowani.pl z sekcjami O nas, Podcast, YouTube oraz kursami 10xDevs, Opanuj Frontend i Opanuj TypeScript."
  currentPath="/"
>
  <section class="mx-auto grid max-w-7xl gap-10 px-5 pb-14 pt-16 lg:grid-cols-[1.08fr_0.92fr] lg:pt-24">
    <div class="space-y-8">
      <div class="space-y-4">
        <p class="eyebrow">Edukacja technologiczna w epoce AI</p>
        <h1 class="max-w-3xl font-heading text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
          Nowoczesny dom dla kursów, podcastów i treści Przeprogramowani.pl.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-slate-300">
          Projekt zbiera w jednym miejscu to, co najmocniejsze w marce Przeprogramowani: 10xDevs w hero,
          kursy premium dla frontend developerów, najnowsze odcinki podcastu i świeże materiały z YouTube.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a class="button-primary" href={site.primaryCta} target="_blank" rel="noreferrer">
          Poznaj 10xDevs
        </a>
        <a class="button-secondary" href="/podcast">
          Zobacz podcast
        </a>
        <a class="button-secondary" href="/youtube">
          Otwórz YouTube
        </a>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        <div class="surface-card p-4">
          <p class="text-sm uppercase tracking-[0.22em] text-slate-500">Od</p>
          <p class="mt-3 font-heading text-3xl font-bold text-white">2017</p>
          <p class="mt-2 text-sm text-slate-400">oficjalnie budują platformę edukacyjną dla developerów</p>
        </div>
        <div class="surface-card p-4">
          <p class="text-sm uppercase tracking-[0.22em] text-slate-500">Oferta</p>
          <p class="mt-3 font-heading text-3xl font-bold text-white">3 filary</p>
          <p class="mt-2 text-sm text-slate-400">10xDevs, Opanuj Frontend i Opanuj TypeScript</p>
        </div>
        <div class="surface-card p-4">
          <p class="text-sm uppercase tracking-[0.22em] text-slate-500">Media</p>
          <p class="mt-3 font-heading text-3xl font-bold text-white">2 kanały</p>
          <p class="mt-2 text-sm text-slate-400">Podcast i YouTube z aktualnymi publikacjami</p>
        </div>
      </div>

      <div class="grid gap-3">
        {
          heroBullets.map((bullet, index) => (
            <div class="flex items-start gap-3 rounded-2xl border border-white/8 bg-white/[0.03] px-4 py-4">
              <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white">
                0{index + 1}
              </span>
              <p class="text-sm leading-7 text-slate-300">{bullet}</p>
            </div>
          ))
        }
      </div>
    </div>

    <div class="relative">
      <div class="surface-card relative overflow-hidden p-6 sm:p-8">
        <div class="absolute right-5 top-5 rounded-full border border-[#65d8c4]/30 bg-[#65d8c4]/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.22em] text-[#9ce7db]">
          Hero programu
        </div>
        <p class="eyebrow">10xDevs 3.0</p>
        <h2 class="mt-4 max-w-lg font-heading text-3xl font-bold text-white sm:text-4xl">
          AI-First MVP od pierwszej linijki kodu po produkcję.
        </h2>
        <p class="mt-4 max-w-xl text-sm leading-7 text-slate-300">
          Oficjalny landing opisuje program jako praktyczną ścieżkę przez dane, REST API, frontend,
          dokumentację, testy i deployment. To nie kurs o demach narzędzi, tylko o świadomym wykorzystaniu AI
          w całym cyklu wytwarzania oprogramowania.
        </p>

        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-white/10 bg-black/15 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Stack</p>
            <p class="mt-2 text-sm font-semibold text-white">Astro + React + TypeScript</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/15 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Delivery</p>
            <p class="mt-2 text-sm font-semibold text-white">Docker + Cloudflare</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/15 p-4">
            <p class="text-xs uppercase tracking-[0.2em] text-slate-500">Workflow</p>
            <p class="mt-2 text-sm font-semibold text-white">LLM, agenci, context engineering</p>
          </div>
        </div>

        <div class="mt-8 rounded-[1.75rem] border border-white/10 bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.02))] p-5">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.22em] text-slate-500">Na czasie</p>
              <p class="mt-2 text-lg font-semibold text-white">{featuredVideo.title}</p>
            </div>
            <a class="button-secondary whitespace-nowrap" href={featuredVideo.href} target="_blank" rel="noreferrer">
              Obejrzyj
            </a>
          </div>
          <img
            class="mt-5 aspect-video w-full rounded-[1.25rem] border border-white/10 object-cover"
            src={featuredVideo.thumbnail}
            alt={featuredVideo.title}
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-14">
    <div class="mb-8 flex items-end justify-between gap-4">
      <div>
        <p class="eyebrow">Oferta</p>
        <h2 class="section-title">Programy, które prowadzą od kodu do świadomej pracy productowej</h2>
      </div>
    </div>

    <div class="grid gap-5 lg:grid-cols-3">
      {
        courses.map((course, index) => (
          <article class:list={['surface-card flex h-full flex-col gap-6 p-6', index === 0 && 'lg:col-span-2 lg:grid lg:grid-cols-[1.1fr_0.9fr]']}>
            <div class="space-y-4">
              <div class="flex items-center justify-between gap-3">
                <p class="eyebrow">{course.label}</p>
                <a class="text-sm font-semibold text-[#ffd6c6] transition hover:text-white" href={course.url} target="_blank" rel="noreferrer">
                  Otwórz →
                </a>
              </div>
              <h3 class="font-heading text-3xl font-bold text-white">{course.name}</h3>
              <p class="text-base leading-8 text-slate-300">{course.summary}</p>
              <p class="rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-4 text-sm font-medium text-white">
                {course.highlight}
              </p>
            </div>

            <div class="grid gap-3">
              {
                course.details.map((detail) => (
                  <div class="rounded-2xl border border-white/8 bg-black/10 px-4 py-4 text-sm leading-7 text-slate-300">{detail}</div>
                ))
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-14">
    <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-5">
        <p class="eyebrow">O projekcie</p>
        <h2 class="section-title">Przeprogramowani łączą programowanie, biznes i rozwój specjalisty</h2>
        <p class="text-base leading-8 text-slate-300">
          Oficjalna strona opisuje markę jako miejsce, w którym ambitni programiści znajdą wiedzę o programowaniu,
          produktach i rozwoju. To ekosystem dla osób, które chcą rozumieć nie tylko narzędzia, ale też realny
          kontekst pracy w branży.
        </p>
        <p class="text-base leading-8 text-slate-300">
          W praktyce przekłada się to na miks kursów premium, podcastów, materiałów YouTube i treści, które uczą
          nowoczesnego frontendu oraz świadomego korzystania z Generative AI.
        </p>

        <div class="grid gap-3 sm:grid-cols-2">
          {
            values.slice(0, 2).map((value) => (
              <div class="rounded-2xl border border-white/8 bg-white/[0.03] p-4">
                <h3 class="font-heading text-lg font-bold text-white">{value.title}</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">{value.text}</p>
              </div>
            ))
          }
        </div>

        <a class="button-secondary" href="/o-nas">
          Przejdź do strony O nas
        </a>
      </div>

      <div class="grid gap-5 md:grid-cols-2">
        {founders.map((founder) => <FounderCard founder={founder} />)}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-14">
    <div class="grid gap-8 xl:grid-cols-2">
      <div class="surface-card p-6">
        <div class="mb-6 flex items-center justify-between gap-4">
          <div>
            <p class="eyebrow">Podcast</p>
            <h2 class="section-title !text-3xl">Ostatnie odcinki z ekosystemu Przeprogramowani</h2>
          </div>
          <a class="button-secondary" href="/podcast">
            Wszystkie
          </a>
        </div>

        <div class="grid gap-3">
          {
            latestEpisodes.map((episode) => (
              <a class="group rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-5 transition hover:border-white/15 hover:bg-white/[0.06]" href={episode.href} target="_blank" rel="noreferrer">
                <p class="text-xs uppercase tracking-[0.22em] text-slate-500">{episode.series}</p>
                <h3 class="mt-3 text-lg font-semibold text-white transition group-hover:text-[#ffd6c6]">{episode.title}</h3>
                <p class="mt-3 text-sm leading-7 text-slate-300">{episode.description}</p>
              </a>
            ))
          }
        </div>
      </div>

      <div class="surface-card p-6">
        <div class="mb-6 flex items-center justify-between gap-4">
          <div>
            <p class="eyebrow">YouTube</p>
            <h2 class="section-title !text-3xl">Najnowsze filmy i live'y</h2>
          </div>
          <a class="button-secondary" href="/youtube">
            Wszystkie
          </a>
        </div>

        <div class="grid gap-4">
          {
            latestVideos.map((video) => (
              <a class="group grid gap-4 rounded-[1.5rem] border border-white/8 bg-white/[0.03] p-4 transition hover:border-white/15 hover:bg-white/[0.06] sm:grid-cols-[190px_1fr]" href={video.href} target="_blank" rel="noreferrer">
                <img class="aspect-video w-full rounded-[1rem] border border-white/10 object-cover" src={video.thumbnail} alt={video.title} loading="lazy" />
                <div>
                  <p class="text-xs uppercase tracking-[0.22em] text-slate-500">YouTube</p>
                  <h3 class="mt-3 text-lg font-semibold text-white transition group-hover:text-[#ffd6c6]">{video.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-slate-300">{video.description}</p>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-14">
    <div class="surface-card overflow-hidden p-6 sm:p-8">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
        <div class="space-y-5">
          <p class="eyebrow">Zaufanie rynku</p>
          <h2 class="section-title">Przeprogramowani współpracują z mocnymi markami produktowymi i software house'ami</h2>
          <p class="text-base leading-8 text-slate-300">
            Na oficjalnej stronie pojawiają się między innymi Huuuge Games, SmartRecruiters, Callstack, Future Processing
            i Autodesk. To dobry sygnał dla strony, która ma komunikować wiarygodność i jakość edukacji technologicznej.
          </p>
          <a class="button-primary" href={`mailto:${site.contactEmail}`}>
            Nawiąż współpracę
          </a>
        </div>

        <div class="flex flex-wrap gap-3">
          {
            partners.map((partner) => (
              <span class="rounded-full border border-white/10 bg-white/[0.04] px-4 py-3 text-sm text-slate-200">{partner}</span>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</Layout>
