---
import { navigation, partners, site } from '../data/site';
---

<footer class="border-t border-white/8 bg-[rgba(5,10,16,0.86)]">
  <div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.4fr_1fr]">
    <div class="space-y-6">
      <div>
        <p class="eyebrow">Źródła i kontekst</p>
        <h2 class="font-heading text-2xl font-bold text-white">Projekt gotowy pod Cloudflare Workers</h2>
      </div>

      <p class="max-w-2xl text-sm leading-7 text-slate-300">
        Treści zostały zebrane z oficjalnych stron Przeprogramowani, 10xDevs, Opanuj Frontend i Opanuj TypeScript.
        Listingi podcastów i filmów bazują na aktualnych pozycjach dostępnych online w dniu budowy projektu.
      </p>

      <div class="flex flex-wrap gap-2 text-xs text-slate-400">
        {
          partners.slice(0, 6).map((partner) => (
            <span class="rounded-full border border-white/10 px-3 py-2">{partner}</span>
          ))
        }
      </div>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      <div class="space-y-4">
        <h3 class="font-heading text-sm font-bold uppercase tracking-[0.24em] text-slate-400">Nawigacja</h3>
        <div class="flex flex-col gap-3 text-sm text-slate-300">
          {
            navigation.map((item) => (
              <a class="transition hover:text-white" href={item.href}>
                {item.label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="font-heading text-sm font-bold uppercase tracking-[0.24em] text-slate-400">Kontakt</h3>
        <div class="flex flex-col gap-3 text-sm text-slate-300">
          <a class="transition hover:text-white" href={site.primaryCta} target="_blank" rel="noreferrer">
            10xDevs
          </a>
          <a class="transition hover:text-white" href="https://www.opanujfrontend.pl/" target="_blank" rel="noreferrer">
            Opanuj Frontend
          </a>
          <a class="transition hover:text-white" href="https://www.opanujtypescript.pl/" target="_blank" rel="noreferrer">
            Opanuj TypeScript
          </a>
          <a class="transition hover:text-white" href={`mailto:${site.contactEmail}`}>
            {site.contactEmail}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
