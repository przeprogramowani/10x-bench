---
import type { Founder } from '../data/site';

interface Props {
  founder: Founder;
}

const { founder } = Astro.props;
---

<article class="surface-card flex h-full flex-col gap-6 p-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="eyebrow">Co-founder</p>
      <h3 class="mt-3 font-heading text-2xl font-bold text-white">{founder.name}</h3>
      <p class="mt-2 text-sm font-medium text-[#ffd6c6]">{founder.role}</p>
      <p class="mt-1 text-sm text-slate-400">{founder.company}</p>
    </div>
    <span class="inline-flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-lg font-bold text-white">
      {founder.name.split(' ').map((part) => part[0]).join('')}
    </span>
  </div>

  <p class="text-sm leading-7 text-slate-300">{founder.bio}</p>

  <div class="flex flex-wrap gap-2">
    {
      founder.focus.map((item) => (
        <span class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-2 text-xs text-slate-300">{item}</span>
      ))
    }
  </div>
</article>
