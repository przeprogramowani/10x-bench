---
import Layout from '../layouts/Layout.astro';
import PodcastShows from '../components/PodcastShows';
import { shows, platformLinks } from '../data/podcast';

const platforms = [
  { name: 'Spotify', url: platformLinks.spotify },
  { name: 'Apple Podcasts', url: platformLinks.apple },
  { name: 'YouTube', url: platformLinks.youtube },
  { name: 'RSS', url: platformLinks.rss },
];
---

<Layout
  title="Podcast — Przeprogramowani"
  description="Słuchaj naszych podcastów o technologii, AI i programowaniu. Opanuj.AI Podcast — najpopularniejszy techniczny podcast o LLM-ach w Polsce — oraz Przeprogramowani ft. Gość."
>
  <section class="relative overflow-hidden pb-12 pt-32 sm:pt-40">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute -top-40 left-1/2 h-96 w-[50rem] -translate-x-1/2 rounded-full bg-accent-500/10 blur-3xl"></div>
    </div>
    <div class="container-page relative">
      <div class="mx-auto max-w-3xl text-center">
        <span class="section-kicker">Podcast</span>
        <h1 class="text-4xl font-black tracking-tight text-white sm:text-5xl">
          Słuchaj naszych podcastów o
          <span class="bg-gradient-to-r from-accent-400 to-brand-400 bg-clip-text text-transparent">
            technologii, AI i programowaniu
          </span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          Comiesięczne podsumowania świata AI i rozmowy z ekspertami o programowaniu,
          karierze i rozwoju. Zapraszają Marcin Czarkowski i Przemek Smyrdek.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          {
            platforms.map((platform) => (
              <a
                href={platform.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/60 px-5 py-2 text-sm font-semibold text-slate-200 transition hover:border-slate-500 hover:text-white"
              >
                {platform.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 pb-20 sm:pb-28">
    <div class="container-page">
      <PodcastShows client:load shows={shows} />
    </div>
  </section>
</Layout>
