---
import type { Course } from '../data/courses';

interface Props {
  course: Course;
}

const { course } = Astro.props;
---

<article class="card group relative flex h-full flex-col overflow-hidden p-8">
  <div class={`absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r ${course.gradient}`}></div>

  <div class="flex items-start justify-between gap-4">
    <div
      class={`flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br ${course.gradient} text-white shadow-lg`}
    >
      {course.icon === 'frontend' && (
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/>
        </svg>
      )}
      {course.icon === 'typescript' && (
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/>
        </svg>
      )}
      {course.icon === 'ai' && (
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"/>
        </svg>
      )}
    </div>
    {course.badge && (
      <span class="rounded-full border border-slate-700 bg-slate-800/80 px-3 py-1 text-xs font-semibold text-slate-300">
        {course.badge}
      </span>
    )}
  </div>

  <h3 class="mt-6 text-xl font-bold text-white">{course.name}</h3>
  <p class="mt-1 text-sm font-medium text-brand-300">{course.tagline}</p>
  <p class="mt-4 text-sm leading-relaxed text-slate-400">{course.description}</p>

  <ul class="mt-6 space-y-2.5">
    {course.features.map((feature) => (
      <li class="flex items-start gap-2.5 text-sm text-slate-300">
        <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
        </svg>
        {feature}
      </li>
    ))}
  </ul>

  <div class="mt-auto pt-8">
    <a
      href={course.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 text-sm font-semibold text-brand-400 transition group-hover:gap-3 hover:text-brand-300"
    >
      Poznaj kurs
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
      </svg>
    </a>
  </div>
</article>
