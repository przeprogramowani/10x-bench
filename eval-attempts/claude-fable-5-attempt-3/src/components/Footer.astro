---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="container-page py-12">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 text-lg font-extrabold text-white">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-400 to-brand-600 font-mono text-sm">
            {'</>'}
          </span>
          Przeprogramowani
        </a>
        <p class="mt-4 max-w-md text-sm leading-relaxed text-slate-400">
          Szersze spojrzenie na programowanie. Od 7 lat łączymy świat programowania, biznesu
          i rozwoju — kursy, podcasty i materiały dla programistów na każdym etapie kariery.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">Nawigacja</h3>
        <ul class="mt-4 space-y-2 text-sm text-slate-400">
          <li><a href="/o-nas" class="transition hover:text-white">O nas</a></li>
          <li><a href="/podcast" class="transition hover:text-white">Podcast</a></li>
          <li><a href="/youtube" class="transition hover:text-white">YouTube</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-300">Kursy</h3>
        <ul class="mt-4 space-y-2 text-sm text-slate-400">
          <li>
            <a href="https://przeprogramowani.pl/opanuj-frontend" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">
              Opanuj Frontend
            </a>
          </li>
          <li>
            <a href="https://przeprogramowani.pl/opanuj-typescript" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">
              Opanuj TypeScript
            </a>
          </li>
          <li>
            <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="transition hover:text-white">
              10xDevs
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-slate-800 pt-8 sm:flex-row">
      <p class="text-sm text-slate-500">© {year} Przeprogramowani. Wszelkie prawa zastrzeżone.</p>
      <div class="flex items-center gap-4">
        <a
          href="https://www.youtube.com/c/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="YouTube"
          class="text-slate-500 transition hover:text-white"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.6 15.6V8.4L15.8 12l-6.2 3.6z"/>
          </svg>
        </a>
        <a
          href="https://www.facebook.com/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="text-slate-500 transition hover:text-white"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.8-4.7 4.55-4.7 1.32 0 2.7.24 2.7.24v2.97h-1.52c-1.5 0-1.96.93-1.96 1.89v2.26h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/przeprogramowani"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="text-slate-500 transition hover:text-white"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.07 1.26.07 1.64.07 4.85s0 3.6-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.26.07-1.64.07-4.85.07s-3.6 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.6 2.2 15.21 2.2 12s0-3.6.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.4 2.2 8.79 2.2 12 2.2zM12 0C8.74 0 8.33 0 7.05.07 5.78.13 4.9.33 4.14.63a5.9 5.9 0 0 0-2.13 1.38A5.9 5.9 0 0 0 .63 4.14C.33 4.9.13 5.78.07 7.05 0 8.33 0 8.74 0 12s0 3.67.07 4.95c.06 1.27.26 2.15.56 2.91.3.79.72 1.46 1.38 2.13a5.9 5.9 0 0 0 2.13 1.38c.76.3 1.64.5 2.91.56C8.33 24 8.74 24 12 24s3.67 0 4.95-.07c1.27-.06 2.15-.26 2.91-.56a5.9 5.9 0 0 0 2.13-1.38 5.9 5.9 0 0 0 1.38-2.13c.3-.76.5-1.64.56-2.91.07-1.28.07-1.69.07-4.95s0-3.67-.07-4.95c-.06-1.27-.26-2.15-.56-2.91a5.9 5.9 0 0 0-1.38-2.13A5.9 5.9 0 0 0 19.86.63c-.76-.3-1.64-.5-2.91-.56C15.67 0 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm7.85-10.4a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0z"/>
          </svg>
        </a>
        <a
          href="mailto:kontakt@przeprogramowani.pl"
          aria-label="E-mail"
          class="text-slate-500 transition hover:text-white"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
