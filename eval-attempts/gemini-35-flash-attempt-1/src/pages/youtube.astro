---
import Layout from '../layouts/Layout.astro';
import YouTubeList from '../components/YouTubeList.tsx';
import { Mail } from 'lucide-react';
---

<Layout title="YouTube — Przeprogramowani | Przeprogramowani" description="Oglądaj nasze najnowsze nagrania wideo o programowaniu z AI, inżynierii systemowej, testach modelu Claude Code oraz rewolucji 10xDevs na YouTube.">
  <!-- HEADER -->
  <section class="relative pt-12 pb-16 overflow-hidden border-b border-slate-900/40">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-64 bg-red-600/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <nav class="flex text-xs text-slate-500 font-semibold space-x-2 mb-6 uppercase tracking-wider">
        <a href="/" class="hover:text-orange-500 transition-colors">Strona Główna</a>
        <span>/</span>
        <span class="text-slate-300">YouTube</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-8 space-y-4">
          <span class="text-red-500 text-xs font-bold uppercase tracking-widest block">Treści Wideo i Programowanie Na Żywo</span>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-white tracking-tight">
            Nasz kanał YouTube — Szersze spojrzenie w wersji wideo
          </h1>
          <p class="text-slate-400 text-sm sm:text-base leading-relaxed max-w-2xl">
            Tworzymy materiały wizualne, live coding, testy narzędzi AI i recenzje technologii. Nasz kanał to miejsce spotkań dla ponad 30 000 ambitnych inżynierów. Sprawdź, jak w praktyce wyglądają testy <strong class="text-white">Claude Code</strong>, <strong class="text-white">Cursor editor</strong> czy wdrażanie zaawansowanych architektur frontendowych.
          </p>
        </div>

        {/* Channel Info column */}
        <div class="lg:col-span-4 bg-slate-900 border border-slate-800 p-6 rounded-2xl space-y-4">
          <div class="flex items-center gap-3">
            <div class="p-3 bg-red-600/10 rounded-xl text-red-500 border border-red-600/20">
              <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" class="fill-current"></polygon>
              </svg>
            </div>
            <div>
              <span class="text-xs text-slate-500 uppercase tracking-widest font-extrabold">Oficjalny Kanał</span>
              <h2 class="text-white font-extrabold text-sm sm:text-base">Przeprogramowani YT</h2>
            </div>
          </div>
          <p class="text-slate-400 text-xs">Subskrybuj, aby otrzymać natychmiastowe powiadomienia o nowościach i comiesięcznych live-streamach.</p>
          <a
            href="https://youtube.com/c/przeprogramowani"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full inline-flex items-center justify-center gap-2 py-3 px-4 rounded-xl text-xs font-extrabold text-white bg-red-600 hover:bg-red-700 transition-all shadow-lg shadow-red-950/20"
          >
            Subskrybuj Kanał na YT →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- INTERACTIVE LIST SECTION -->
  <section class="py-16 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {/* List rendered dynamically via React */}
      <YouTubeList client:load />
    </div>
  </section>
</Layout>
