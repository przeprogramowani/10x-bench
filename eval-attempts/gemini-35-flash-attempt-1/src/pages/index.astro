---
import Layout from '../layouts/Layout.astro';
import CourseCard from '../components/CourseCard.tsx';
import EpisodeCard from '../components/EpisodeCard.tsx';
import VideoCard from '../components/VideoCard.tsx';
import RuleBuilderDemo from '../components/RuleBuilderDemo.tsx';
import { ArrowUpRight, ArrowRight, Sparkles, Mail, CheckCircle2, Trophy, Users, Star, BrainCircuit } from 'lucide-react';

const courses = [
  {
