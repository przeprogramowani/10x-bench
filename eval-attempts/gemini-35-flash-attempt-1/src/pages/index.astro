    description: "Zostań nowoczesnym frontend developerem. Kompleksowy program szkoleniowy z 5 obszernymi modułami o architekturze, testowaniu, nowoczesnym React (v19), optymalizacji, CI/CD i automatyzacji pracy za pomocą AI.",
    badge: "Bestseller",
    tags: ["React 19", "AI Workflow", "CI/CD", "Testing", "Architecture"],
    link: "/opanuj-frontend",
    linkText: "Sprawdź program",
    isFeatured: true,
    meta: { students: "400+ absolwentów", level: "Średniozaawansowany/Zaawansowany" }
  },
  {
    title: "Opanuj TypeScript",
    description: "Szkolenie, które podniesie jakość Twoich komercyjnych projektów i wyeliminuje błędy na produkcji. Pracujemy z najnowszymi funkcjami TypeScript 5 oraz ekosystemem React 19.",
    badge: "Kurs online",
    tags: ["TypeScript 5", "React 19", "Design Patterns", "Type-safety"],
    link: "/opanuj-typescript",
    linkText: "Zobacz szczegóły",
    isFeatured: false,
    meta: { students: "Ponad 1000 uczestników", level: "Dowolny" }
  },
  {
    title: "Opanuj AI",
    description: "Warsztaty, autorski podcast, blog oraz darmowe ebooki o sztucznej inteligencji. Zdobądź unikalne, techniczne umiejętności pracy z LLM i wdróż je w codziennej pracy programisty.",
    badge: "AI i Automatyzacja",
    tags: ["LLM", "Prompt Engineering", "Agents", "OpenAI / Claude"],
    link: "https://opanuj.ai",
    linkText: "Wypróbuj Opanuj AI",
    isFeatured: false,
    meta: { students: "Społeczność AI", level: "Wszyscy programiści" }
  }
];

