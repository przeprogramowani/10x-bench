---
import Base from '../layouts/Base.astro';
import Brands from '../components/Brands.tsx';
import Newsletter from '../components/Newsletter.tsx';
import Reveal from '../components/Reveal.tsx';
import VideoGrid, { YouTubeCTA } from '../components/VideoGrid.tsx';
import { site } from '../data/site';
---
<Base title="YouTube — Przeprogramowani" description="Najnowsze materiały o AI, programowaniu i karierze na kanale Przeprogramowani na YouTube.">
  <section class="container-x pt-28 pb-8 sm:pt-36">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">YouTube</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Filmy o <span class="gradient-text">AI, programowaniu i karierze</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
        Najnowsze materiały z naszego kanału — relacje z konferencji, porównania modeli AI, live demo i deep dive'y.
      </p>
      <div class="mt-8 flex justify-center">
        <a href={site.social.youtube} target="_blank" rel="noopener noreferrer" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z" /></svg>
          Subskrybuj kanał
        </a>
      </div>
    </div>
  </section>

  <Reveal client:visible>
    <section class="container-x py-12">
      <h2 class="section-title mb-8">Ostatnie filmy</h2>
      <VideoGrid client:visible />
      <div class="mt-10">
        <YouTubeCTA />
      </div>
    </section>
  </Reveal>

  <Newsletter client:visible />
  <Brands client:visible />
</Base>
