---
import Base from '../layouts/Base.astro';
import Brands from '../components/Brands.tsx';
import Newsletter from '../components/Newsletter.tsx';
import Reveal from '../components/Reveal.tsx';
import { team } from '../data/site';
---
<Base title="O nas — Przeprogramowani" description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Poznaj nasz zespół i misję.">
  <section class="container-x pt-28 pb-12 sm:pt-36">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">O nas</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
        Łączymy świat <span class="gradient-text">programowania</span>, biznesu i rozwoju
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
        Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
      </p>
    </div>
  </section>

  <Reveal client:visible>
    <section class="container-x py-12">
      <div class="grid gap-6 sm:grid-cols-2">
        {team.map((member) => (
          <article class="card card-hover p-8">
            <div class="flex items-center gap-4">
              <div class="grid h-16 w-16 shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-brand-500 to-accent-500 text-xl font-bold text-white">
                {member.initials}
              </div>
              <div>
                <h2 class="text-xl font-bold text-white">{member.name}</h2>
                <p class="text-sm text-brand-300">{member.role}</p>
              </div>
            </div>
            <p class="mt-5 text-sm leading-relaxed text-slate-400">{member.bio}</p>
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-white"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.44-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.55V9h3.57v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.52C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.74V1.74C24 .78 23.2 0 22.22 0Z" /></svg>
              LinkedIn
            </a>
          </article>
        ))}
      </div>
    </section>
  </Reveal>

  <Reveal client:visible>
    <section class="container-x py-12">
      <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-brand-600/15 via-ink-800 to-accent-600/10 p-8 sm:p-12">
        <p class="eyebrow">Witaj na Przeprogramowanych!</p>
        <h2 class="mt-3 text-2xl font-bold text-white sm:text-3xl">Zyskaj szersze spojrzenie na programowanie</h2>
        <p class="mt-4 max-w-2xl text-slate-300">
          Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od technicznych deep-dive'ów po rozmowy o karierze i rozwoju.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="https://10xdevs.pl" target="_blank" rel="noopener noreferrer" class="btn-primary text-xs">
            Poznaj 10xDevs
          </a>
          <a href="/podcast" class="btn-ghost text-xs">
            Słuchaj podcastu
          </a>
        </div>
      </div>
    </section>
  </Reveal>

  <Newsletter client:visible />
  <Brands client:visible />
</Base>
