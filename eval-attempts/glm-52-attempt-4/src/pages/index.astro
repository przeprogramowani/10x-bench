---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.tsx';
import Newsletter from '../components/Newsletter.tsx';
import Brands from '../components/Brands.tsx';
import Reveal from '../components/Reveal.tsx';
import VideoGrid, { VideoSectionHeader, YouTubeCTA } from '../components/VideoGrid.tsx';
import { PodcastShows } from '../components/PodcastList.tsx';
import { site } from '../data/site';
---
<Base title="Przeprogramowani — Szersze spojrzenie na programowanie" description={site.description}>
  <Hero client:load />

  <Reveal client:visible>
    <section class="container-x py-16">
      <VideoSectionHeader />
      <div class="mt-8">
        <VideoGrid limit={6} client:visible />
      </div>
      <YouTubeCTA />
    </section>
  </Reveal>

  <Reveal client:visible>
    <section class="container-x py-16">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="eyebrow">Słuchaj na każdej platformie</p>
          <h2 class="section-title mt-2">Podcasty</h2>
        </div>
        <a href="/podcast" class="inline-flex items-center gap-1 text-sm font-semibold text-brand-300 hover:text-brand-200">
          Wszystkie odcinki
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      </div>
      <div class="mt-8">
        <PodcastShows limit={3} client:visible />
      </div>
    </section>
  </Reveal>

  <Newsletter client:visible />
  <Brands client:visible />
</Base>
