---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.tsx';
import Footer from '../components/Footer.tsx';
import CourseCard from '../components/CourseCard.tsx';

const courses = [
  {
    title: '10xDevs 3.0',
    description: 'Nowe oblicze programowania z wykorzystaniem Generatywnego AI. Techniki i narzędzia pozwalające świadomie stosować AI w całym cyklu wytwarzania oprogramowania.',
    features: [
      '5 tygodni intensywnej nauki',
      'Praktyczne projekty z AI',
      'Mentoring od ekspertów',
      '3700+ absolwentów'
    ],
    url: 'https://10xdevs.pl',
    badge: 'Nowość',
    color: 'orange' as const,
  },
  {
    title: 'Opanuj Frontend',
    description: 'Zostań nowoczesnym frontend developerem. 5 obszernych modułów o frontendzie, testowaniu, CI/CD, open source i architekturze aplikacji webowych.',
    features: [
      '10 tygodni nauki',
      'React, Vue, Angular, Svelte',
      'Testowanie i CI/CD',
      '400+ absolwentów'
    ],
    url: 'https://opanujfrontend.pl',
    color: 'blue' as const,
  },
  {
    title: 'Opanuj TypeScript',
    description: 'Opanuj TypeScript 5 i React 19. Praktyczne kursy, które podniosą jakość twoich projektów działających na produkcji i ułatwią ich rozwój.',
    features: [
      'TypeScript 5.7+',
      'React 19',
      '40+ ćwiczeń praktycznych',
      '1500+ przeszkolonych'
    ],
    url: 'https://opanujtypescript.pl',
    color: 'purple' as const,
  },
];

const latestVideos = [
  {
    title: 'Skills vs AgentsMD: 53% vs 100%. Co poszło nie tak?',
    videoId: '_kQHwE6zAbM',
    thumbnail: 'https://i3.ytimg.com/vi/_kQHwE6zAbM/maxresdefault.jpg',
  },
  {
    title: 'Claude Code + GLM-4.7 - Programowanie z darmowym AI',
    videoId: 'KAJTsQbqBow',
    thumbnail: 'https://i3.ytimg.com/vi/KAJTsQbqBow/maxresdefault.jpg',
  },
  {
    title: '5 TECHNIK, KTÓRE NAPRAWIŁY MÓJ WORKFLOW PROGRAMOWANIA Z AI',
    videoId: 'uwi39C2O8NI',
    thumbnail: 'https://i3.ytimg.com/vi/uwi39C2O8NI/maxresdefault.jpg',
  },
];

const partners = [
  'Huuuge Games', 'SmartRecruiters', 'Callstack', 'Future Processing',
  'edrone', 'Xfive', 'Euvic', 'Autodesk'
];
---

<Layout title="Przeprogramowani - Szersze spojrzenie na programowanie">
  <Header currentPage="/" />

  <main>
    <section class="hero-gradient text-white py-20 lg:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <span class="inline-block px-4 py-2 bg-white/10 rounded-full text-sm font-medium mb-6 backdrop-blur-sm">
            7 lat na rynku edukacji technologicznej
          </span>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
            Edukacja technologiczna<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-orange-400">
              w epoce AI
            </span>
          </h1>
          <p class="text-lg md:text-xl text-slate-300 mb-10 max-w-2xl mx-auto leading-relaxed">
            Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a
              href="https://10xdevs.pl"
              target="_blank"
              rel="noopener noreferrer"
              class="px-8 py-4 bg-gradient-to-r from-orange-500 to-red-500 text-white font-semibold rounded-xl hover:from-orange-600 hover:to-red-600 transition-all shadow-lg hover:shadow-xl"
            >
              Dołącz do 10xDevs
            </a>
            <a
              href="/o-nas"
              class="px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-xl hover:bg-white/20 transition-all border border-white/20"
            >
              Poznaj nas
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            Nasze kursy
          </h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Praktyczne szkolenia prowadzone przez doświadczonych inżynierów
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {courses.map((course) => (
            <CourseCard {...course} />
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            Ostatnie na YouTube
          </h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Darmowe materiały o programowaniu i AI
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestVideos.map((video) => (
            <a
              href={`https://www.youtube.com/watch?v=${video.videoId}`}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-white rounded-xl overflow-hidden shadow-md card-hover border border-slate-100 group"
            >
              <div class="relative aspect-video">
                <img
                  src={video.thumbnail}
                  alt={video.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                  <div class="w-14 h-14 bg-red-600 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                    <svg class="w-6 h-6 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M8 5v14l11-7z" />
                    </svg>
                  </div>
                </div>
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-slate-900 group-hover:text-primary-600 transition-colors line-clamp-2 text-sm">
                  {video.title}
                </h3>
              </div>
            </a>
          ))}
        </div>

        <div class="text-center mt-8">
          <a
            href="/youtube"
            class="inline-flex items-center gap-2 px-6 py-3 border border-slate-300 text-slate-700 rounded-xl hover:bg-slate-100 transition-colors"
          >
            Zobacz więcej filmów
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            Współpracujemy z najlepszymi
          </h2>
          <p class="text-lg text-slate-600">
            Firmy, które nam zaufały
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-8 items-center">
          {partners.map((partner) => (
            <div class="px-6 py-3 bg-slate-100 rounded-lg text-slate-600 font-medium text-sm">
              {partner}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 bg-gradient-to-r from-primary-600 to-primary-800 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Dołącz do newslettera
        </h2>
        <p class="text-lg text-primary-100 mb-8 max-w-2xl mx-auto">
          Co tydzień w piątek otrzymaj porcję wartościowych treści w formacie 3-2-1: 3 rekomendacje techniczne, 2 rozwojowe i 1 bonus niespodzianka
        </p>
        <a
          href="https://przeprogramowani.substack.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-4 bg-white text-primary-700 font-semibold rounded-xl hover:bg-primary-50 transition-colors"
        >
          Zapisz się za darmo
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
