---
import MobileMenu from './MobileMenu';
import { navItems } from '../data/content';
const currentPath = Astro.url.pathname;
---

<header class="absolute inset-x-0 top-0 z-50 border-b border-white/12 text-white">
  <div class="container-page flex h-20 items-center justify-between">
    <a href="/" class="group flex items-center gap-3" aria-label="Przeprogramowani — strona główna">
      <span class="grid size-9 place-items-center rounded-full bg-coral font-mono text-sm font-black text-white transition-transform group-hover:-rotate-6">&lt;/&gt;</span>
      <span class="text-[15px] font-extrabold tracking-tight sm:text-base">Przeprogramowani</span>
    </a>

    <nav aria-label="Główna nawigacja" class="hidden items-center gap-1 lg:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-full px-4 py-2 text-sm font-semibold transition-colors hover:bg-white/10',
            currentPath === item.href ? 'bg-white/10 text-white' : 'text-white/70',
          ]}
        >{item.label}</a>
      ))}
      <a href="https://10xdevs.pl" class="ml-3 rounded-full bg-lime px-5 py-2.5 text-sm font-extrabold text-ink transition hover:bg-white">
        10xDevs <span aria-hidden="true">↗</span>
      </a>
    </nav>

    <MobileMenu items={navItems} client:load />
  </div>
</header>
