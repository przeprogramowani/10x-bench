---
import Layout from '../layouts/Layout.astro';
import YouTubeGallery from '../components/YouTubeGallery';
import { Youtube, Users, Video, Gift } from 'lucide-react';
---

<Layout 
  title="YouTube — Przeprogramowani.pl" 
  description="Filmy o programowaniu, sztucznej inteligencji, asystentach AI (Claude Code, Cursor, Copilot) oraz architekturze oprogramowania."
>
  <section class="relative py-16 md:py-24 bg-slate-950 overflow-hidden">
    {/* Decorative gradients */}
    <div class="absolute top-1/4 right-10 w-[450px] h-[450px] bg-red-600/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-20 left-20 w-[350px] h-[350px] bg-brand-purple/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      
      {/* Page Header */}
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-end gap-8 mb-16 border-b border-slate-800 pb-12">
        <div class="space-y-4 max-w-2xl">
          <div class="inline-flex items-center gap-2 rounded-full bg-red-600/10 border border-red-500/20 px-3.5 py-1.5 text-xs font-semibold text-red-500">
            <Youtube class="h-4 w-4" />
            <span>Materiały wideo na kanale</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-black text-white tracking-tight">
            Nasz Kanał <span class="bg-gradient-to-r from-red-600 to-amber-500 bg-clip-text text-transparent">YouTube</span>
          </h1>
          <p class="text-slate-400 text-sm sm:text-base leading-relaxed">
            Praktyczna i konkretna wiedza o AI, agentach programistycznych, testach porównawczych modeli LLM oraz inżynierii kontekstu. Subskrybuj i zostań świadomym programistą nowej ery.
          </p>
        </div>

        {/* Stats and buttons row */}
        <div class="flex flex-wrap gap-4">
          <div class="flex items-center gap-3 bg-brand-card/30 border border-slate-800/80 px-4.5 py-3 rounded-2xl">
            <Users class="text-red-500 h-5 w-5" />
            <div>
              <span class="text-xs text-slate-500 block">Subskrybenci</span>
              <span class="text-sm font-black text-white">40k+ ambitnych devów</span>
            </div>
          </div>
          <a 
            href="https://youtube.com/c/przeprogramowani" 
            target="_blank" 
            rel="noreferrer" 
            class="inline-flex items-center justify-center gap-2 rounded-2xl bg-red-600 hover:bg-red-500 text-white px-6 py-4 text-xs font-bold transition-all shadow-[0_0_20px_rgba(220,38,38,0.25)] hover:shadow-[0_0_25px_rgba(220,38,38,0.4)]"
          >
            Subskrybuj na YouTube
            <Youtube class="h-4 w-4" />
          </a>
        </div>
      </div>

      {/* YouTube List (React Component) */}
      <div class="pb-12">
        <YouTubeGallery client:load />
      </div>

      {/* Course CTA Banner */}
      <div class="mt-16 bg-gradient-to-r from-red-950/20 via-brand-card/30 to-brand-card/20 border border-slate-800 rounded-3xl p-8 md:p-12 relative overflow-hidden shadow-2xl">
        <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-red-600/10 rounded-full blur-[80px] pointer-events-none"></div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center relative z-10">
          <div class="md:col-span-8 space-y-4">
            <div class="inline-flex items-center gap-2 rounded-full bg-red-500/10 px-3 py-1 text-xs font-semibold text-red-500">
              <Gift class="h-3.5 w-3.5" />
              <span>Darmowe programy szkoleniowe</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-black text-white">
              Gotowy na skok jakościowy w programowaniu?
            </h3>
            <p class="text-slate-300 text-sm md:text-base leading-relaxed max-w-2xl">
              Dołącz do naszych flagowych kursów Opanuj Frontend, Opanuj TypeScript lub 10xDevs. Każde szkolenie zawiera dziesiątki godzin materiałów wideo wysokiej jakości, lekcji kodu, projektów i certyfikatów.
            </p>
          </div>
          <div class="md:col-span-4 flex justify-start md:justify-end">
            <a 
              href="/#courses" 
              class="inline-flex items-center justify-center gap-2 rounded-xl bg-white hover:bg-slate-200 text-brand-dark px-6 py-3.5 text-sm font-bold transition-colors w-full md:w-auto text-center"
            >
              Przejdź do oferty kursów
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>
