---
import Layout from '../layouts/Layout.astro';
import { FOUNDERS, PARTNERS, SITE, COURSES } from '../data/content';
---

<Layout title="O nas" description="Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi programiści to ci, którzy patrzą szerzej.">
  <section class="relative overflow-hidden border-b border-ink-800/60">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full bg-brand-600/15 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#21232d_1px,transparent_1px),linear-gradient(to_bottom,#21232d_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"></div>
    </div>

    <div class="container-page py-20 sm:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <span class="section-eyebrow">O nas</span>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
          Łączymy świat programowania, biznesu i <span class="gradient-text">rozwoju</span>
        </h1>
      </div>
    </div>
  </section>

  <section class="container-page py-20 lg:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Witaj na Przeprogramowanych!</h2>
      <p class="mt-6 text-lg leading-relaxed text-ink-300">
        Przeprogramowani to miejsce, w którym programowanie spotyka się z rozwojem osobistym. Wierzymy, że najlepsi
        programiści to ci, którzy patrzą szerzej — na architekturę, na biznes, na ludzi i na siebie.
      </p>
      <p class="mt-4 text-lg leading-relaxed text-ink-300">
        Tworzymy treści, kursy i narzędzia, które pomagają programistom rozwijać się na wielu płaszczyznach. Od
        technicznych deep-dive'ów po rozmowy o karierze i rozwoju. <span class="font-semibold text-white">Zyskaj szersze spojrzenie na programowanie.</span>
      </p>
    </div>
  </section>

  <section class="border-y border-ink-800/60 bg-ink-900/30">
    <div class="container-page py-20 lg:py-28">
      <div class="text-center">
        <span class="section-eyebrow">Założyciele</span>
        <h2 class="section-title">Poznaj <span class="gradient-text">co-founderów</span></h2>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl gap-8 md:grid-cols-2">
        {FOUNDERS.map((person) => (
          <article class="card group p-8">
            <div class="flex items-center gap-4">
              <div class="grid h-16 w-16 flex-shrink-0 place-items-center rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 text-xl font-extrabold text-white shadow-lg shadow-brand-700/30">
                {person.initials}
              </div>
              <div>
                <h3 class="text-xl font-bold text-white">{person.name}</h3>
                <p class="text-sm text-brand-300">{person.role}</p>
              </div>
            </div>
            <p class="mt-6 text-sm leading-relaxed text-ink-400">{person.bio}</p>
            <a
              href={person.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ink-300 transition hover:text-white"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.27c-.97 0-1.75-.79-1.75-1.76s.78-1.75 1.75-1.75 1.75.79 1.75 1.75-.78 1.76-1.75 1.76zm13.5 12.27h-3v-5.6c0-3.37-4-3.12-4 0v5.6h-3v-11h3v1.77c1.4-2.6 7-2.79 7 2.48v6.75z"/></svg>
              LinkedIn
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container-page py-20 lg:py-28">
    <div class="text-center">
      <span class="section-eyebrow">Co tworzymy</span>
      <h2 class="section-title">Nasze <span class="gradient-text">projekty</span></h2>
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {COURSES.map((course) => (
        <a href={course.href} target="_blank" rel="noopener noreferrer" class="card group p-6 hover:border-brand-500/40">
          <span class="inline-flex rounded-full bg-ink-800 px-3 py-1 text-xs font-semibold text-ink-300">{course.badge}</span>
          <h3 class="mt-4 text-xl font-bold text-white">{course.title}</h3>
          <p class="mt-1 text-sm font-mono text-brand-300">{course.tagline}</p>
          <p class="mt-3 text-sm leading-relaxed text-ink-400 line-clamp-3">{course.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="border-t border-ink-800/60 bg-ink-900/30">
    <div class="container-page py-16">
      <div class="text-center">
        <span class="section-eyebrow">7 lat na rynku edukacji technologicznej</span>
        <h2 class="mt-3 text-2xl font-bold text-white sm:text-3xl">Współpracujemy z najlepszymi</h2>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {PARTNERS.map((partner) => (
          <span class="text-sm font-semibold text-ink-400 transition hover:text-ink-200">{partner}</span>
        ))}
      </div>
      <div class="mt-10 text-center">
        <p class="text-sm text-ink-400">Chcesz nawiązać współpracę?</p>
        <a href={`mailto:${SITE.email}`} class="mt-2 inline-flex items-center gap-2 font-semibold text-brand-300 hover:text-brand-200">
          {SITE.email}
        </a>
      </div>
    </div>
  </section>
</Layout>
