---
import Layout from '../layouts/Layout.astro';
import { COURSES, VIDEOS, PODCASTS, PARTNERS, SITE } from '../data/content';
import VideoGrid from '../components/VideoGrid.tsx';
import PodcastList from '../components/PodcastList.tsx';

const featuredCourse = COURSES.find((c) => c.featured)!;
const otherCourses = COURSES.filter((c) => !c.featured);
const latestVideos = VIDEOS.slice(0, 3);
const latestPodcasts = PODCASTS.map((p) => ({
  ...p,
  episodes: p.episodes.slice(0, 3),
}));
---

<Layout>
  {/* HERO */}
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/4 top-0 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-brand-600/20 blur-[120px]"></div>
      <div class="absolute right-0 top-1/3 h-[400px] w-[400px] rounded-full bg-emerald-500/10 blur-[100px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#21232d_1px,transparent_1px),linear-gradient(to_bottom,#21232d_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"></div>
    </div>

    <div class="container-page py-20 sm:py-28 lg:py-36">
      <div class="mx-auto max-w-4xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-xs font-semibold text-brand-300">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
          </span>
          {featuredCourse.badge}
        </div>

        <h1 class="mt-8 text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl">
          Nowe oblicze<br />
          <span class="gradient-text">programowania</span><br />
          z Generatywnym AI
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-300 sm:text-xl">
          {SITE.description}
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href={featuredCourse.href} target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
            {featuredCourse.title} — {featuredCourse.cta}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/o-nas" class="btn-ghost text-base">
            Poznaj nas
          </a>
        </div>

        <div class="mt-16 grid grid-cols-3 gap-4 border-t border-ink-800 pt-8">
          <div>
            <div class="text-2xl font-extrabold text-white sm:text-3xl">7+</div>
            <div class="mt-1 text-xs text-ink-400 sm:text-sm">lat na rynku</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-white sm:text-3xl">400+</div>
            <div class="mt-1 text-xs text-ink-400 sm:text-sm">absolwentów</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-white sm:text-3xl">7800+</div>
            <div class="mt-1 text-xs text-ink-400 sm:text-sm">słuchaczy podcastów</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* COURSES */}
  <section id="kursy" class="border-t border-ink-800/60">
    <div class="container-page py-20 lg:py-28">
      <div class="mx-auto max-w-2xl text-center">
        <span class="section-eyebrow">Edukacja technologiczna</span>
        <h2 class="section-title">Wybierz swój <span class="gradient-text">program</span></h2>
        <p class="mt-4 text-lg text-ink-400">
          Topowe programy edukacyjne dla ambitnych programistów i świadome korzystanie z potencjału Generative AI.
        </p>
      </div>

      <div class="mt-16 grid gap-6 lg:grid-cols-3">
        {otherCourses.map((course) => (
          <a
            href={course.href}
            target="_blank"
            rel="noopener noreferrer"
            class="card group relative flex flex-col overflow-hidden p-8 hover:border-brand-500/40"
          >
            <div class={`absolute -right-12 -top-12 h-40 w-40 rounded-full bg-gradient-to-br ${course.accent} opacity-10 blur-2xl transition group-hover:opacity-20`}></div>
            <div class="relative">
              <span class="inline-flex rounded-full bg-ink-800 px-3 py-1 text-xs font-semibold text-ink-300">{course.badge}</span>
              <h3 class="mt-5 text-2xl font-extrabold text-white">{course.title}</h3>
              <p class="mt-1 text-sm font-mono text-brand-300">{course.tagline}</p>
              <p class="mt-4 text-sm leading-relaxed text-ink-400">{course.description}</p>
              <div class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-brand-300 transition group-hover:gap-2">
                {course.cta}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* YOUTUBE */}
  <section id="youtube" class="border-t border-ink-800/60 bg-ink-900/30">
    <div class="container-page py-20 lg:py-28">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
        <div class="max-w-2xl">
          <span class="section-eyebrow">Filmy i podcasty</span>
          <h2 class="section-title">Najnowsze <span class="gradient-text">na YouTube</span></h2>
          <p class="mt-4 text-lg text-ink-400">Rozwój nowoczesnego programisty w pigułce.</p>
        </div>
        <a href="/youtube" class="btn-ghost whitespace-nowrap">
          Wszystkie filmy
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="mt-12" data-reveal>
        <VideoGrid client:visible videos={latestVideos} />
      </div>
    </div>
  </section>

  {/* PODCAST */}
  <section id="podcast" class="border-t border-ink-800/60">
    <div class="container-page py-20 lg:py-28">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
        <div class="max-w-2xl">
          <span class="section-eyebrow">Podcasty</span>
          <h2 class="section-title">Słuchaj <span class="gradient-text">na Spotify</span></h2>
          <p class="mt-4 text-lg text-ink-400">Technologia, AI i programowanie w formie audio.</p>
        </div>
        <a href="/podcast" class="btn-ghost whitespace-nowrap">
          Wszystkie odcinki
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="mt-12" data-reveal>
        <PodcastList client:visible podcasts={latestPodcasts} limit={3} />
      </div>
    </div>
  </section>

  {/* PARTNERS */}
  <section class="border-t border-ink-800/60 bg-ink-900/30">
    <div class="container-page py-16">
      <div class="text-center">
        <span class="section-eyebrow">7 lat na rynku edukacji technologicznej</span>
        <h2 class="mt-3 text-2xl font-bold text-white sm:text-3xl">Współpracujemy z najlepszymi</h2>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {PARTNERS.map((partner) => (
          <span class="text-sm font-semibold text-ink-400 transition hover:text-ink-200">{partner}</span>
        ))}
      </div>
      <div class="mt-10 text-center">
        <p class="text-sm text-ink-400">Chcesz nawiązać współpracę?</p>
        <a href={`mailto:${SITE.email}`} class="mt-2 inline-flex items-center gap-2 font-semibold text-brand-300 hover:text-brand-200">
          {SITE.email}
        </a>
      </div>
    </div>
  </section>
</Layout>
