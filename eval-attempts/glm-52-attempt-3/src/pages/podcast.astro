---
import Layout from '../layouts/Layout.astro';
import { PODCASTS, PODCAST_PLATFORMS } from '../data/content';
import PodcastList from '../components/PodcastList.tsx';
---

<Layout title="Podcast" description="Słuchaj naszych podcastów o technologii, AI i programowaniu. Opanuj.AI Podcast i Przeprogramowani ft. Gość.">
  <section class="relative overflow-hidden border-b border-ink-800/60">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full bg-brand-600/15 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#21232d_1px,transparent_1px),linear-gradient(to_bottom,#21232d_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"></div>
    </div>

    <div class="container-page py-20 sm:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <span class="section-eyebrow">Podcasty</span>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
          Słuchaj naszych <span class="gradient-text">podcastów</span>
        </h1>
        <p class="mt-6 text-lg text-ink-300">
          O technologii, AI i programowaniu. Comiesięczne podsumowania i rozmowy z gośćmi.
        </p>
      </div>
    </div>
  </section>

  <section class="container-page py-20 lg:py-28">
    <PodcastList client:visible podcasts={PODCASTS} />
  </section>

  <section class="border-t border-ink-800/60 bg-ink-900/30">
    <div class="container-page py-20">
      <div class="text-center">
        <span class="section-eyebrow">Słuchaj wszędzie</span>
        <h2 class="mt-3 text-2xl font-bold text-white sm:text-3xl">Jesteśmy na twojej ulubionej platformie</h2>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        {PODCAST_PLATFORMS.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-ink-700 bg-ink-900 px-6 py-3 text-sm font-semibold text-ink-100 transition hover:border-brand-500/50 hover:text-white"
          >
            {platform.name}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
