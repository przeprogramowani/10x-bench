---
import Layout from '../layouts/Layout.astro';
import { VIDEOS, SITE } from '../data/content';
import VideoGrid from '../components/VideoGrid.tsx';
---

<Layout title="YouTube" description="Najnowsze filmy Przeprogramowani na YouTube. Rozwój nowoczesnego programisty, AI, frontend i kariera w IT.">
  <section class="relative overflow-hidden border-b border-ink-800/60">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[400px] w-[600px] -translate-x-1/2 rounded-full bg-red-600/15 blur-[120px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#21232d_1px,transparent_1px),linear-gradient(to_bottom,#21232d_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"></div>
    </div>

    <div class="container-page py-20 sm:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <span class="section-eyebrow">YouTube</span>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
          Filmy i <span class="gradient-text">podcasty</span>
        </h1>
        <p class="mt-6 text-lg text-ink-300">
          Rozwój nowoczesnego programisty w pigułce. Najnowsze materiały na naszej kanale.
        </p>
        <div class="mt-8">
          <a href={SITE.social.youtube} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23 12s0-3.5-.4-5.2c-.3-1-.9-1.6-1.9-1.9C18.9 4.5 12 4.5 12 4.5s-6.9 0-8.7.4c-1 .3-1.6.9-1.9 1.9C1 8.5 1 12 1 12s0 3.5.4 5.2c.3 1 .9 1.6 1.9 1.9 1.8.4 8.7.4 8.7.4s6.9 0 8.7-.4c1-.3 1.6-.9 1.9-1.9.4-1.7.4-5.2.4-5.2zM9.7 15.3V8.7l5.7 3.3-5.7 3.3z"/></svg>
            Subskrybuj kanał
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page py-20 lg:py-28">
    <div class="mb-10">
      <span class="section-eyebrow">Najnowsze materiały</span>
      <h2 class="mt-3 text-2xl font-bold text-white sm:text-3xl">Ostatnie filmy</h2>
    </div>
    <VideoGrid client:visible videos={VIDEOS} limit={6} />
  </section>
</Layout>
