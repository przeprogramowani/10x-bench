---
import type { Course } from '../data/site';

interface Props {
  course: Course;
}

const { course } = Astro.props;
---

<a
  href={course.href}
  target="_blank"
  rel="noreferrer noopener"
  class="group relative overflow-hidden rounded-3xl border border-white/15 bg-slate-900/70 p-6 transition hover:-translate-y-1 hover:border-cyan-300/60"
>
  <div class={`absolute -right-12 -top-12 h-40 w-40 rounded-full bg-gradient-to-br ${course.gradient} opacity-35 blur-3xl`}></div>
  <p class="relative text-xs font-semibold uppercase tracking-[0.24em] text-cyan-200">{course.badge}</p>
  <h3 class="relative mt-3 text-2xl font-bold text-white">{course.title}</h3>
  <p class="relative mt-2 text-sm font-semibold text-amber-200">{course.subtitle}</p>
  <p class="relative mt-4 text-sm leading-relaxed text-slate-300">{course.description}</p>
  <span class="relative mt-5 inline-flex items-center rounded-full bg-white/10 px-4 py-2 text-sm font-semibold text-white transition group-hover:bg-cyan-300 group-hover:text-slate-950">
    Sprawdź kurs
  </span>
</a>
