---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const alignmentClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<div class={`mb-10 flex flex-col gap-3 ${alignmentClass}`}>
  {eyebrow ? <p class="text-xs font-semibold uppercase tracking-[0.28em] text-cyan-300">{eyebrow}</p> : null}
  <h2 class="max-w-3xl text-3xl font-bold text-white sm:text-4xl">{title}</h2>
  {description ? <p class="max-w-3xl text-base text-slate-300 sm:text-lg">{description}</p> : null}
</div>
