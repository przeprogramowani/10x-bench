---
import type { PodcastEpisode } from '../data/site';
import { formatDate } from '../lib/format';

interface Props {
  episode: PodcastEpisode;
}

const { episode } = Astro.props;
---

<a
  href={episode.link}
  target="_blank"
  rel="noreferrer noopener"
  class="group rounded-2xl border border-white/12 bg-slate-900/70 p-5 transition hover:-translate-y-1 hover:border-cyan-300/60"
>
  <div class="flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.18em] text-slate-400">
    <span>{formatDate(episode.published)}</span>
    <span>•</span>
    <span>{episode.duration}</span>
  </div>
  <h3 class="mt-3 line-clamp-3 text-lg font-semibold text-white">{episode.title}</h3>
  <p class="mt-4 inline-flex rounded-full bg-white/10 px-3 py-1 text-sm font-semibold text-cyan-200 transition group-hover:bg-cyan-300 group-hover:text-slate-950">
    Słuchaj odcinka
  </p>
</a>
