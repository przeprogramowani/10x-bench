---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, description, align = 'left' } = Astro.props;
---

<div class={align === 'center' ? 'mx-auto max-w-2xl text-center' : 'max-w-2xl'}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="mt-4 text-3xl font-bold sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-relaxed text-slate-400 sm:text-lg">{description}</p>}
</div>
