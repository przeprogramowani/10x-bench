---
import Icon from './Icon';
import type { Episode } from '../data/podcast';

interface Props {
  episode: Episode;
}
const { episode } = Astro.props;
const formatted = new Date(episode.date).toLocaleDateString('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="card card-hover group flex flex-col p-6">
  <div class="flex items-center gap-3 text-xs text-slate-400">
    <time datetime={episode.date}>{formatted}</time>
    <span class="h-1 w-1 rounded-full bg-slate-600"></span>
    <span class="inline-flex items-center gap-1">
      <Icon name="clock" className="h-3.5 w-3.5" />
      {episode.duration}
    </span>
  </div>

  <h3 class="mt-3 text-lg font-semibold leading-snug text-white">
    {episode.title}
    {episode.guest && <span class="text-brand-200"> — {episode.guest}</span>}
  </h3>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">{episode.description}</p>

  <a
    href={episode.url}
    target="_blank"
    rel="noopener"
    class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-200 transition-colors hover:text-white"
  >
    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-500/20 text-brand-200 transition-colors group-hover:bg-brand-500 group-hover:text-white">
      <Icon name="play" className="h-4 w-4" />
    </span>
    Posłuchaj odcinka
  </a>
</article>
