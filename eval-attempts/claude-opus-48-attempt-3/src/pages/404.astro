---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon';
---

<Layout title="Nie znaleziono strony" description="Ta strona nie istnieje.">
  <section class="relative overflow-hidden">
    <div class="glow pointer-events-none absolute inset-x-0 top-0 h-[500px]"></div>
    <div class="container-x relative flex min-h-[70vh] flex-col items-center justify-center py-24 text-center">
      <p class="bg-gradient-to-r from-brand-300 to-fuchsia-300 bg-clip-text text-7xl font-black text-transparent sm:text-8xl">
        404
      </p>
      <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Nie znaleźliśmy tej strony</h1>
      <p class="mt-3 max-w-md text-slate-400">
        Wygląda na to, że ten adres nie istnieje albo został przeniesiony. Wróćmy na właściwe tory.
      </p>
      <a href="/" class="btn-primary mt-8">
        <Icon name="arrow" className="h-4 w-4 rotate-180" />
        Wróć na stronę główną
      </a>
    </div>
  </section>
</Layout>
