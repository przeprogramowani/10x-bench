---
import type { PodcastEpisode } from '../data/podcasts';

interface Props {
  episode: PodcastEpisode;
  compact?: boolean;
}

const { episode, compact = false } = Astro.props;

const showColor =
  episode.show === 'Opanuj.AI'
    ? 'bg-brand-500/15 text-brand-200 border-brand-400/30'
    : 'bg-accent-500/15 text-accent-200 border-accent-400/30';

const formattedDate = new Intl.DateTimeFormat('pl-PL', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(episode.date));
---

<article class:list={['group card flex h-full flex-col', compact ? 'p-5' : 'p-6']}>
  <div class="flex items-center justify-between gap-3">
    <span class:list={['inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium', showColor]}>
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 14a3 3 0 003-3V6a3 3 0 10-6 0v5a3 3 0 003 3zm-7-3a7 7 0 0014 0M12 18v3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {episode.show}
    </span>
    <span class="font-mono text-xs text-slate-500">#{episode.number}</span>
  </div>

  <h3 class:list={['mt-4 font-display font-semibold leading-snug text-white', compact ? 'text-base' : 'text-lg']}>
    {episode.title}
  </h3>

  {episode.guest && (
    <p class="mt-2 text-xs text-slate-400">
      <span class="text-slate-500">Gość:</span> {episode.guest}
    </p>
  )}

  {!compact && (
    <p class="mt-3 line-clamp-3 text-sm leading-relaxed text-slate-400">
      {episode.description}
    </p>
  )}

  <div class="mt-auto flex items-center justify-between gap-3 pt-5 text-xs text-slate-500">
    <div class="flex items-center gap-3">
      <span>{formattedDate}</span>
      <span class="h-1 w-1 rounded-full bg-slate-600"></span>
      <span class="font-mono">{episode.duration}</span>
    </div>
    {episode.spotify && (
      <a
        href={episode.spotify}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-semibold text-white transition-colors hover:border-white/25 hover:bg-white/10"
        aria-label={`Posłuchaj odcinek ${episode.title} na Spotify`}
      >
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm4.6 14.4a.6.6 0 01-.9.2c-2.4-1.5-5.5-1.8-9.1-1a.6.6 0 11-.3-1.2c4-.9 7.4-.5 10.1 1.1.3.2.4.6.2.9zm1.2-2.7a.8.8 0 01-1 .3c-2.7-1.7-6.9-2.2-10.2-1.2a.8.8 0 11-.4-1.5c3.7-1.1 8.3-.6 11.4 1.3.3.2.4.7.2 1.1zm.1-2.8c-3.3-1.9-8.6-2.1-11.7-1.2a.9.9 0 11-.5-1.8c3.6-1.1 9.4-.9 13.2 1.4a.9.9 0 11-1 1.6z"/>
        </svg>
        Posłuchaj
      </a>
    )}
  </div>
</article>
