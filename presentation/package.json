{
  "name": "presentation",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "description": "Presentation slides built with Slidev",
  "scripts": {
    "dev": "slidev --open",
    "build": "slidev build",
    "export": "slidev export",
    "export:pdf": "slidev export --format pdf",
    "export:pptx": "slidev export --format pptx",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@slidev/cli": "^0.50.0",
    "@slidev/theme-default": "^0.25.0",
    "@slidev/theme-seriph": "^0.25.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright-chromium": "^1.49.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
